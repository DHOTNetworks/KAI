fn printi(i: Int) {
    __kai_print_int(i)
}

fn printff(f: Float) {
    __kai_print_float(f)
}

fn prints(s: Str) {
    printf("%s\n", s)
}

fn printc(c: Char) {
    printf("%c\n", c)
}
