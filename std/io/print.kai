// Standard print module — utility functions
import KaiAllocator from std.core.allocator

extern fn printf(format: *Void) Str
extern fn __kai_print_int(i: Int) -> Void
extern fn __kai_print_float(f: Float) -> Void

fn print_separator () {
    printf("---\n")
}
