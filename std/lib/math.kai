fn __kai_std_math_checked_add_i32(left: Int, right: Int) -> ?Int {
    let max: Int = 2147483647
    let min: Int = 0 - 2147483647 - 1
    if right > 0 && left > max - right {
        return none
    }
    if right < 0 && left < min - right {
        return none
    }
    return left + right
}

fn __kai_std_math_checked_sub_i32(left: Int, right: Int) -> ?Int {
    let max: Int = 2147483647
    let min: Int = 0 - 2147483647 - 1
    if right > 0 && left < min + right {
        return none
    }
    if right < 0 && left > max + right {
        return none
    }
    return left - right
}

fn __kai_std_math_checked_mul_i32(left: Int, right: Int) -> ?Int {
    let max: Int = 2147483647
    let min: Int = 0 - 2147483647 - 1
    let wide: Int = (left as Int) * (right as Int)
    if wide > max || wide < min {
        return none
    }
    return wide as Int
}

fn __kai_std_math_saturating_add_i32(left: Int, right: Int) -> Int {
    let result: ?Int = __kai_std_math_checked_add_i32(left, right)
    if result != none {
        return (result catch 0)
    }
    if right > 0 {
        return 2147483647
    }
    return 0 - 2147483647 - 1
}

fn __kai_std_math_saturating_sub_i32(left: Int, right: Int) -> Int {
    let result: ?Int = __kai_std_math_checked_sub_i32(left, right)
    if result != none {
        return (result catch 0)
    }
    if right > 0 {
        return 0 - 2147483647 - 1
    }
    return 2147483647
}

fn __kai_std_math_saturating_mul_i32(left: Int, right: Int) -> Int {
    let result: ?Int = __kai_std_math_checked_mul_i32(left, right)
    if result != none {
        return (result catch 0)
    }
    if (left < 0 && right < 0) || (left > 0 && right > 0) {
        return 2147483647
    }
    return 0 - 2147483647 - 1
}

fn __kai_std_math_gcd_u32(a0: Int, b0: Int) -> Int {
    var a: Int = a0
    var b: Int = b0
    while b != 0 {
        let next: Int = a % b
        a = b
        b = next
    }
    return a
}

fn __kai_std_math_lcm_u32(left: Int, right: Int) -> Int {
    if left == 0 || right == 0 {
        return 0
    }
    return left / __kai_std_math_gcd_u32(left, right) * right
}

fn __kai_std_math_checked_lcm_u32(left: Int, right: Int) -> ?Int {
    if left == 0 || right == 0 {
        return 0
    }
    return __kai_std_math_checked_mul_u32(left / __kai_std_math_gcd_u32(left, right), right)
}

fn __kai_std_math_pow_u32(base: Int, exponent: Int) -> Int {
    var result: Int = 1
    var current: Int = base
    var exp: Int = exponent
    while exp > 0 {
        if exp % 2 == 1 {
            result = result * current
        }
        current = current * current
        exp = exp / 2
    }
    return result
}

fn __kai_std_math_checked_pow_u32(base: Int, exponent: Int) -> ?Int {
    var result: Int = 1
    var current: Int = base
    var exp: Int = exponent
    while exp > 0 {
        if exp % 2 == 1 {
            let next_result: ?Int = __kai_std_math_checked_mul_u32(result, current)
            if next_result == none {
                return none
            }
            result = (next_result catch 0)
        }
        exp = exp / 2
        if exp > 0 {
            let next_current: ?Int = __kai_std_math_checked_mul_u32(current, current)
            if next_current == none {
                return none
            }
            current = (next_current catch 0)
        }
    }
    return result
}

fn __kai_std_math_mod_pow_u32(base: Int, exponent: Int, modulus: Int) -> Int {
    if modulus == 0 {
        return 0
    }
    let wide_modulus: Int = modulus as Int
    var result: Int = 1 % wide_modulus
    var current: Int = (base as Int) % wide_modulus
    var exp: Int = exponent
    while exp > 0 {
        if exp % 2 == 1 {
            result = result * current % wide_modulus
        }
        current = current * current % wide_modulus
        exp = exp / 2
    }
    return result as Int
}

fn __kai_std_math_is_prime_u32(value: Int) -> Bool {
    if value < 2 {
        return false
    }
    if value == 2 {
        return true
    }
    if value % 2 == 0 {
        return false
    }
    var divisor: Int = 3
    while divisor <= value / divisor {
        if value % divisor == 0 {
            return false
        }
        divisor = divisor + 2
    }
    return true
}

fn __kai_std_math_is_even_u32(value: Int) -> Bool {
    return value % 2 == 0
}

fn __kai_std_math_is_odd_u32(value: Int) -> Bool {
    return value % 2 == 1
}

fn __kai_std_math_sqrt_floor_u32(value: Int) -> Int {
    var low: Int = 0
    var high: Int = 65536
    while low + 1 < high {
        let mid: Int = low + (high - low) / 2
        if mid <= value / mid {
            low = mid
        } else {
            high = mid
        }
    }
    return low
}

fn __kai_std_math_factorial_u32(value: Int) -> ?Int {
    var result: Int = 1
    var next: Int = 2
    while next <= value {
        let multiplied: ?Int = __kai_std_math_checked_mul_u32(result, next)
        if multiplied == none {
            return none
        }
        result = (multiplied catch 0)
        next = next + 1
    }
    return result
}

fn __kai_std_math_binomial_u32(n: Int, k0: Int) -> ?Int {
    if k0 > n {
        return none
    }
    var k: Int = k0
    if k > n - k {
        k = n - k
    }
    var result: Int = 1
    var i: Int = 1
    while i <= k {
        var numerator: Int = n - k + i
        var denominator: Int = i
        let numerator_gcd: Int = __kai_std_math_gcd_u32(numerator, denominator)
        numerator = numerator / numerator_gcd
        denominator = denominator / numerator_gcd
        let result_gcd: Int = __kai_std_math_gcd_u32(result, denominator)
        result = result / result_gcd
        denominator = denominator / result_gcd
        if denominator != 1 {
            return none
        }
        let multiplied: ?Int = __kai_std_math_checked_mul_u32(result, numerator)
        if multiplied == none {
            return none
        }
        result = (multiplied catch 0)
        i = i + 1
    }
    return result
}

fn __kai_std_math_divisor_count_u32(value: Int) -> Int {
    if value == 0 {
        return 0
    }
    var count: Int = 0
    var divisor: Int = 1
    while divisor <= value / divisor {
        if value % divisor == 0 {
            let paired: Int = value / divisor
            if paired == divisor {
                count = count + 1
            } else {
                count = count + 2
            }
        }
        divisor = divisor + 1
    }
    return count
}

fn __kai_std_math_proper_divisor_sum_u32(value: Int) -> Int {
    if value <= 1 {
        return 0
    }
    var sum: Int = 1
    var divisor: Int = 2
    while divisor <= value / divisor {
        if value % divisor == 0 {
            let paired: Int = value / divisor
            sum = sum + divisor
            if paired != divisor {
                sum = sum + paired
            }
        }
        divisor = divisor + 1
    }
    return sum
}
