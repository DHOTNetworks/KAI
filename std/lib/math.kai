fn __kai_std_math_abs_i32(value: Int) -> Int {
    let min_i32: Int = 0 - 2147483647 - 1
    if value == min_i32 {
        return 2147483648
    }
    if value < 0 {
        return (0 - value) as Int
    }
    return value as Int
}

fn __kai_std_math_abs_i64(value: Int) -> Int {
    let min_i64: Int = 0 - 9223372036854775807 - 1
    if value == min_i64 {
        return (0 - 9223372036854775807 - 1)
    }
    if value < 0 {
        return (0 - value) as Int
    }
    return value as Int
}

fn __kai_std_math_checked_add_u32(left: Int, right: Int) -> ?Int {
    if left > 4294967295 - right {
        return none
    }
    return left + right
}

fn __kai_std_math_checked_sub_u32(left: Int, right: Int) -> ?Int {
    if left < right {
        return none
    }
    return left - right
}

fn __kai_std_math_checked_mul_u32(left: Int, right: Int) -> ?Int {
    if left != 0 && right > 4294967295 / left {
        return none
    }
    return left * right
}

fn __kai_std_math_saturating_add_u32(left: Int, right: Int) -> Int {
    let result: ?Int = __kai_std_math_checked_add_u32(left, right)
    if result != none {
        return (result catch 0)
    }
    return 4294967295
}

