fn __kai_std_math_min_u32(left: Int, right: Int) -> Int {
    if left < right {
        return left
    }
    return right
}

fn __kai_std_math_max_u32(left: Int, right: Int) -> Int {
    if left > right {
        return left
    }
    return right
}

fn __kai_std_math_clamp_u32(value: Int, low: Int, high: Int) -> Int {
    let lower: Int = __kai_std_math_min_u32(low, high)
    let upper: Int = __kai_std_math_max_u32(low, high)
    if value < lower {
        return lower
    }
    if value > upper {
        return upper
    }
    return value
}

