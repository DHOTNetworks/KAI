}

fn __kai_std_io_read_until_delimiter(bytes: Str, start: Int, delimiter: Char) -> ?Str {
    if start >= strlen((bytes) as Str) {
        return none
    }
    var end: Int = start
    while end < strlen((bytes) as Str) && bytes[end] != delimiter {
        end = end + 1
    }
    return bytes[start..end]
}

fn __kai_std_io_read_until_delimiter_start(bytes: Str, start: Int, delimiter: Char) -> Int {
    if start >= strlen((bytes) as Str) {
        return strlen((bytes) as Str)
    }
    var end: Int = start
    while end < strlen((bytes) as Str) && bytes[end] != delimiter {
        end = end + 1
    }
    if end < strlen((bytes) as Str) {
        return end + 1
    }
    return strlen((bytes) as Str)
}

fn __kai_std_io_fixed_reader(bytes: Str, cursor: Int) -> FixedReader {
