fn __kai_std_io_fixed_reader_read_line(reader: mutref<FixedReader>) -> ?Str {
    let line: ?Str = __kai_std_io_next_line(reader.bytes, reader.cursor)
    if line != none {
        reader.cursor = __kai_std_io_next_line_start(reader.bytes, reader.cursor)
    }
