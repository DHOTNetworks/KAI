}

fn __kai_std_io_fixed_reader_read_until_delimiter(reader: mutref<FixedReader>, delimiter: Char) -> ?Str {
    let chunk: ?Str = __kai_std_io_read_until_delimiter(reader.bytes, reader.cursor, delimiter)
    if chunk != none {
        reader.cursor = __kai_std_io_read_until_delimiter_start(reader.bytes, reader.cursor, delimiter)
    }
