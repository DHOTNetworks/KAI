fn __kai_std_io_fixed_reader_limit(reader: ref<FixedReader>, count: Int) -> FixedReader {
    let bytes: Str = __kai_std_mem_cursor_chunk(reader.bytes, reader.cursor, count)
    return FixedReader { bytes: bytes, cursor: 0 }
