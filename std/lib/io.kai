fn __kai_std_io_copy_buffer(reader: mutref<FixedReader>, writer: mutref<FixedWriter>, scratch: *Char) -> Int {
    if strlen((scratch) as Str) == 0 {
        return 0
    }
    var total: Int = 0
    while true {
        let writable: Int = __kai_std_io_fixed_writer_remaining(writer)
        if writable == 0 {
            return total
        }
        var chunk_len: Int = strlen((scratch) as Str)
        if writable < chunk_len {
            chunk_len = writable
        }
        let chunk_buffer: *Char = scratch[..chunk_len]
        let before: Int = reader.cursor
        let count: Int = __kai_std_io_fixed_reader_read(reader, chunk_buffer)
        if count == 0 {
            return total
        }
        let chunk: Str = __kai_std_io_written(chunk_buffer, count)
        if !__kai_std_io_fixed_writer_write_all(writer, chunk) {
            reader.cursor = before
            return total
        }
        total = total + count
    }
    return total
}

fn __kai_std_io_copy_reader_n(reader: mutref<FixedReader>, writer: mutref<FixedWriter>, count: Int, scratch: *Char) -> ?Int {
    if count == 0 {
        return 0
    }
    if strlen((scratch) as Str) == 0 {
        return none
    }
    let reader_start: Int = reader.cursor
    let writer_start: Int = writer.cursor
    if count > __kai_std_io_fixed_reader_remaining(reader) {
        return none
    }
    if count > __kai_std_io_fixed_writer_remaining(writer) {
        return none
    }
    var copied: Int = 0
    while copied < count {
        var chunk_len: Int = count - copied
        if chunk_len > strlen((scratch) as Str) {
            chunk_len = strlen((scratch) as Str)
        }
        let chunk_buffer: *Char = scratch[..chunk_len]
        if !__kai_std_io_fixed_reader_read_exact(reader, chunk_buffer) {
            reader.cursor = reader_start
            writer.cursor = writer_start
            return none
        }
        let chunk: Str = __kai_std_io_written(chunk_buffer, chunk_len)
        if !__kai_std_io_fixed_writer_write_all(writer, chunk) {
            reader.cursor = reader_start
            writer.cursor = writer_start
            return none
        }
        copied = copied + chunk_len
    }
    return copied
}

fn __kai_std_io_discard(reader: mutref<FixedReader>, scratch: *Char) -> Int {
    if strlen((scratch) as Str) == 0 {
        return 0
    }
    var total: Int = 0
    while true {
        let count: Int = __kai_std_io_fixed_reader_read(reader, scratch)
        if count == 0 {
            return total
