fn __kai_std_io_fixed_reader_read(reader: mutref<FixedReader>, buffer: *Char) -> Int {
    let before: Int = reader.cursor
    let next: ?Int = __kai_std_io_read(reader.bytes, before, buffer)
    if next != none {
        reader.cursor = (next catch 0)
        return (next catch 0) - before
    }
    return 0
}

fn __kai_std_io_fixed_reader_read_exact(reader: mutref<FixedReader>, buffer: *Char) -> Bool {
    let next: ?Int = __kai_std_io_read_exact(reader.bytes, reader.cursor, buffer)
    if next != none {
        reader.cursor = (next catch 0)
