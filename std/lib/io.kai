}

fn __kai_std_io_multi_read(first: mutref<FixedReader>, second: mutref<FixedReader>, buffer: *Char) -> Int {
    let first_count: Int = __kai_std_io_fixed_reader_read(first, buffer)
    if first_count >= strlen((buffer) as Str) {
        return first_count
    }
    let second_count: Int = __kai_std_io_fixed_reader_read(second, buffer[first_count..])
    return first_count + second_count
}

fn __kai_std_io_error_none() -> Int {
    return 0
}

fn __kai_std_io_error_eof() -> Int {
    return 1
}

fn __kai_std_io_error_short_read() -> Int {
    return 2
}

fn __kai_std_io_error_short_write() -> Int {
    return 3
}

fn __kai_std_io_error_capacity() -> Int {
    return 4
}

fn __kai_std_io_error_permission() -> Int {
    return 5
}

fn __kai_std_io_error_timeout() -> Int {
    return 6
}

fn __kai_std_io_error_io() -> Int {
    return 7
}

fn __kai_std_io_error_name(code: Int) -> Str {
    if code == 0 {
        return "none"
    }
    if code == 1 {
        return "eof"
    }
    if code == 2 {
        return "short_read"
    }
    if code == 3 {
        return "short_write"
    }
    if code == 4 {
        return "capacity"
    }
    if code == 5 {
        return "permission"
    }
    if code == 6 {
        return "timeout"
    }
    if code == 7 {
        return "io"
    }
    return "unknown"
}

fn __kai_std_io_count_lines(bytes: Str) -> Int {
    var start: Int = 0
    var count: Int = 0
    while start < strlen((bytes) as Str) {
        count = count + 1
        start = __kai_std_io_next_line_start(bytes, start)
    }
    return count
}
