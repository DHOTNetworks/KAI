        total = total + count
    }
    return total
}

fn __kai_std_io_tee_read(reader: mutref<FixedReader>, writer: mutref<FixedWriter>, buffer: *Char) -> ?Int {
    let before: Int = reader.cursor
    let count: Int = __kai_std_io_fixed_reader_read(reader, buffer)
    if count == 0 {
        return 0
    }
    let chunk: Str = __kai_std_io_written(buffer, count)
    if __kai_std_io_fixed_writer_write_all(writer, chunk) {
        return count
