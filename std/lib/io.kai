}

fn __kai_std_io_fixed_reader_read_all(reader: mutref<FixedReader>, buffer: *Char) -> ?Str {
    let remaining: Int = __kai_std_io_fixed_reader_remaining(reader)
    if remaining > strlen((buffer) as Str) {
        return none
    }
    let copied: ?Int = __kai_std_io_copy_n(buffer, reader.bytes[reader.cursor..], remaining)
    if copied != none {
        reader.cursor = strlen((reader.bytes) as Str)
        return __kai_std_io_written(buffer, (copied catch 0))
    }
    return none
}

