fn __kai_std_io_write_byte(buffer: *Char, offset: Int, byte: Char) -> ?Int {
    if offset >= strlen((buffer) as Str) {
        return none
    }
    buffer[offset] = byte
    return offset + 1
}

fn __kai_std_io_write_span(buffer: *Char, offset: Int, bytes: Str) -> ?Int {
    if offset > strlen((buffer) as Str) {
        return none
    }
    if strlen((bytes) as Str) > strlen((buffer) as Str) - offset {
        return none
    }
    var index: Int = 0
    while index < strlen((bytes) as Str) {
        buffer[offset + index] = bytes[index]
        index = index + 1
    }
    return offset + strlen((bytes) as Str)
}

fn __kai_std_io_write_all(buffer: *Char, offset: Int, bytes: Str) -> ?Int {
    return __kai_std_io_write_span(buffer, offset, bytes)
}

fn __kai_std_io_write_at(buffer: *Char, offset: Int, bytes: Str) -> ?Int {
    return __kai_std_io_write_span(buffer, offset, bytes)
}

fn __kai_std_io_read(bytes: Str, offset: Int, buffer: *Char) -> ?Int {
    if offset > strlen((bytes) as Str) {
        return none
    }
    let available: Int = strlen((bytes) as Str) - offset
    var count: Int = strlen((buffer) as Str)
    if available < count {
        count = available
    }
    var index: Int = 0
    while index < count {
        buffer[index] = bytes[offset + index]
        index = index + 1
    }
    return offset + count
}

fn __kai_std_io_read_exact(bytes: Str, offset: Int, buffer: *Char) -> ?Int {
    if offset > strlen((bytes) as Str) {
        return none
    }
    if strlen((buffer) as Str) > strlen((bytes) as Str) - offset {
        return none
    }
    var index: Int = 0
    while index < strlen((buffer) as Str) {
        buffer[index] = bytes[offset + index]
        index = index + 1
    }
    return offset + strlen((buffer) as Str)
}

fn __kai_std_io_read_at(bytes: Str, offset: Int, buffer: *Char) -> ?Int {
    return __kai_std_io_read(bytes, offset, buffer)
}

fn __kai_std_io_read_all(bytes: Str, buffer: *Char) -> ?Str {
    let count: Int = strlen((bytes) as Str)
    let copied: ?Int = __kai_std_io_copy_n(buffer, bytes, count)
    if copied != none {
        return __kai_std_io_written(buffer, (copied catch 0))
    }
    return none
}

fn __kai_std_io_copy(buffer: *Char, bytes: Str) -> Int {
    var count: Int = strlen((bytes) as Str)
    if strlen((buffer) as Str) < count {
        count = strlen((buffer) as Str)
    }
    var index: Int = 0
    while index < count {
        buffer[index] = bytes[index]
        index = index + 1
    }
    return count
}

fn __kai_std_io_read_byte(bytes: Str, offset: Int) -> ?Char {
    if offset >= strlen((bytes) as Str) {
        return none
    }
    return bytes[offset]
}

fn __kai_std_io_copy_n(buffer: *Char, bytes: Str, count: Int) -> ?Int {
    if count > strlen((buffer) as Str) {
        return none
    }
    if count > strlen((bytes) as Str) {
        return none
    }
    var index: Int = 0
    while index < count {
        buffer[index] = bytes[index]
        index = index + 1
    }
    return count
}

fn __kai_std_io_written(buffer: Str, len: Int) -> Str {
    if len > strlen((buffer) as Str) {
        return buffer
    }
    return buffer[..len]
}

fn __kai_std_io_remaining(buffer: Str, offset: Int) -> Int {
    if offset >= strlen((buffer) as Str) {
        return 0
    }
    return strlen((buffer) as Str) - offset
}

fn __kai_std_io_next_line(bytes: Str, start: Int) -> ?Str {
    if start >= strlen((bytes) as Str) {
        return none
    }
    var end: Int = start
    while end < strlen((bytes) as Str) && bytes[end] != Char(10) {
        end = end + 1
    }
    if end > start && bytes[end - 1] == Char(13) {
        return bytes[start..end - 1]
    }
    return bytes[start..end]
}

fn __kai_std_io_read_line(bytes: Str, start: Int) -> ?Str {
    return __kai_std_io_next_line(bytes, start)
}

fn __kai_std_io_next_line_start(bytes: Str, start: Int) -> Int {
    if start >= strlen((bytes) as Str) {
        return strlen((bytes) as Str)
    }
    var end: Int = start
    while end < strlen((bytes) as Str) && bytes[end] != Char(10) {
        end = end + 1
    }
    if end < strlen((bytes) as Str) {
        return end + 1
    }
    return strlen((bytes) as Str)
}

fn __kai_std_io_read_line_start(bytes: Str, start: Int) -> Int {
