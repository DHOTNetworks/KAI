    if rem == 5 {
        let c4: ?Char = __kai_std_codec_base32_value(text[len - 1])
        if c4 == none || (c4 catch Char(0)) % Char(2) != Char(0) {
            return none
        }
        return full + 3
    }
    if rem == 7 {
        let c6: ?Char = __kai_std_codec_base32_value(text[len - 1])
        if c6 == none || (c6 catch Char(0)) % Char(8) != Char(0) {
            return none
        }
        return full + 4
    }
    return none
}

fn __kai_std_codec_base32_decode_impl(buffer: *Char, text: Str, padding: Bool) -> ?Str {
