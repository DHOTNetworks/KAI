        }
        if has4 {
            buffer[output] = __kai_std_codec_base32_char(b4 % Char(32))
            output = output + 1
        } else if has3 && padding {
            buffer[output] = Char(61)
            output = output + 1
        }
        input = input + 5
    }
    return substring(buffer, 0, output)
}

