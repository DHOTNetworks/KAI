        var b3: Char = Char(0)
        var b4: Char = Char(0)
        let has1: Bool = input + 1 < strlen((bytes) as Str)
        let has2: Bool = input + 2 < strlen((bytes) as Str)
        let has3: Bool = input + 3 < strlen((bytes) as Str)
        let has4: Bool = input + 4 < strlen((bytes) as Str)
        if has1 {
            b1 = bytes[input + 1]
        }
        if has2 {
            b2 = bytes[input + 2]
        }
