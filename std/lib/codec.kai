fn __kai_std_codec_base64_decoded_len(text: Str) -> ?Int {
    let len: Int = strlen((text) as Str)
    if len == 0 {
        return 0
    }
    if len % 4 != 0 {
        return none
    }
    var padding: Int = 0
    if text[len - 1] == Char(61) {
        padding = padding + 1
    }
    if text[len - 2] == Char(61) {
        padding = padding + 1
    }
    var index: Int = 0
    while index < len {
        let byte: Char = text[index]
        if byte == Char(61) {
            if index < len - padding {
                return none
            }
        } else {
            let value: ?Char = __kai_std_codec_base64_value(byte)
            if value == none {
                return none
            }
        }
        index = index + 1
    }
    if padding == 2 {
        let c1: ?Char = __kai_std_codec_base64_value(text[len - 3])
        if c1 == none || (c1 catch Char(0)) % Char(16) != Char(0) {
            return none
        }
    } else if padding == 1 {
        let c2: ?Char = __kai_std_codec_base64_value(text[len - 2])
        if c2 == none || (c2 catch Char(0)) % Char(4) != Char(0) {
            return none
        }
    }
    return (len / 4) * 3 - padding
}

fn __kai_std_codec_base64_decode(buffer: *Char, text: Str) -> ?Str {
    let decoded_len: ?Int = __kai_std_codec_base64_decoded_len(text)
    if decoded_len == none || (decoded_len catch 0) > 1000000 {
        return none
    }
    var input: Int = 0
    var output: Int = 0
    while input < strlen((text) as Str) {
        let c0: ?Char = __kai_std_codec_base64_value(text[input])
        let c1: ?Char = __kai_std_codec_base64_value(text[input + 1])
        if c0 == none || c1 == none {
            return none
        }
        let pad2: Bool = text[input + 2] == Char(61)
        let pad3: Bool = text[input + 3] == Char(61)
        var value2: Char = Char(0)
        var value3: Char = Char(0)
        if !pad2 {
            let c2: ?Char = __kai_std_codec_base64_value(text[input + 2])
            if c2 == none {
                return none
            }
            value2 = (c2 catch Char(0))
        }
        if !pad3 {
            let c3: ?Char = __kai_std_codec_base64_value(text[input + 3])
            if c3 == none {
                return none
            }
            value3 = (c3 catch Char(0))
        }
        if pad2 && !pad3 {
            return none
        }
        if output < (decoded_len catch 0) {
            buffer[output] = (c0 catch Char(0)) * Char(4) + (c1 catch Char(0)) / Char(16)
            output = output + 1
        }
        if output < (decoded_len catch 0) {
            buffer[output] = ((c1 catch Char(0)) % Char(16)) * Char(16) + value2 / Char(4)
            output = output + 1
        }
        if output < (decoded_len catch 0) {
            buffer[output] = (value2 % Char(4)) * Char(64) + value3
            output = output + 1
        }
        input = input + 4
    }
    return substring(buffer, 0, output)
}

fn __kai_std_codec_base64_any_char(value: Char, url: Bool) -> Char {
    if url && value == Char(62) {
        return Char(45)
    }
    if url && value == Char(63) {
        return Char(95)
    }
    return __kai_std_codec_base64_char(value)
}

fn __kai_std_codec_base64_any_value(byte: Char, url: Bool) -> ?Char {
    if url {
        if byte >= Char(65) && byte <= Char(90) {
            return byte - Char(65)
        }
        if byte >= Char(97) && byte <= Char(122) {
            return byte - Char(71)
        }
        if byte >= Char(48) && byte <= Char(57) {
            return byte + Char(4)
        }
        if byte == Char(45) {
            return Char(62)
        }
        if byte == Char(95) {
            return Char(63)
        }
        return none
    }
    return __kai_std_codec_base64_value(byte)
}

fn __kai_std_codec_base64_raw_encoded_len(len: Int) -> Int {
    let full: Int = (len / 3) * 4
    let rem: Int = len % 3
    if rem == 0 {
