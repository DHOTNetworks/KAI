            b4 = bytes[input + 4]
        }
        buffer[output] = __kai_std_codec_base32_char(b0 / Char(8))
        buffer[output + 1] = __kai_std_codec_base32_char((b0 % Char(8)) * Char(4) + b1 / Char(64))
        output = output + 2
        if has1 {
            buffer[output] = __kai_std_codec_base32_char((b1 / Char(2)) % Char(32))
            buffer[output + 1] = __kai_std_codec_base32_char((b1 % Char(2)) * Char(16) + b2 / Char(16))
            output = output + 2
        } else if padding {
            var pad: Int = 0
            while pad < 6 {
                buffer[output] = Char(61)
                output = output + 1
                pad = pad + 1
            }
        }
        if has2 {
            buffer[output] = __kai_std_codec_base32_char((b2 % Char(16)) * Char(2) + b3 / Char(128))
            output = output + 1
        } else if has1 && padding {
            var pad2: Int = 0
            while pad2 < 4 {
                buffer[output] = Char(61)
                output = output + 1
                pad2 = pad2 + 1
            }
        }
