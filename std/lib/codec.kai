            return none
        }
        index = index + 1
    }
    let rem: Int = len % 8
    let full: Int = (len / 8) * 5
    if rem == 0 {
        return full
    }
    if rem == 2 {
        let c1: ?Char = __kai_std_codec_base32_value(text[len - 1])
        if c1 == none || (c1 catch Char(0)) % Char(4) != Char(0) {
            return none
        }
        return full + 1
    }
    if rem == 4 {
        let c3: ?Char = __kai_std_codec_base32_value(text[len - 1])
        if c3 == none || (c3 catch Char(0)) % Char(16) != Char(0) {
            return none
