fn __kai_std_codec_crc32(s: Str) -> Int {
    var crc = 4294967295
    var i = 0
    let len = strlen(s)
    while i < len {
        var byte = s[i] as Int
        crc = crc ^ byte
        var j = 0
        while j < 8 {
            if (crc & 1) != 0 {
                crc = (crc >> 1) ^ 3988292384
            } else {
                crc = crc >> 1
            }
            j = j + 1
        }
        i = i + 1
    }
    return crc ^ 4294967295
}

fn __kai_std_codec_crc32_bytes(s: Str) -> Int {
    return __kai_std_codec_crc32(s)
}

fn __kai_std_codec_hex_char(value: Char) -> Char {
    if value < Char(10) {
        return Char(48) + value
    }
    return Char(97) + value - Char(10)
}

fn __kai_std_codec_hex_encode(buffer: *Char, bytes: Str) -> ?Str {
    let encoded_len: Int = strlen((bytes) as Str) * 2
    if encoded_len > 1000000 {
        return none
    }
    var input: Int = 0
    var output: Int = 0
    while input < strlen((bytes) as Str) {
        let byte: Char = bytes[input]
        buffer[output] = __kai_std_codec_hex_char(byte / Char(16))
        buffer[output + 1] = __kai_std_codec_hex_char(byte % Char(16))
        input = input + 1
        output = output + 2
    }
    return substring(buffer, 0, output)
}

fn __kai_std_codec_hex_decoded_len(text: Str) -> ?Int {
    if strlen((text) as Str) % 2 != 0 {
        return none
    }
    var index: Int = 0
    while index < strlen((text) as Str) {
        let high: ?Char = __kai_std_ascii_hex_value(text[index])
        let low: ?Char = __kai_std_ascii_hex_value(text[index + 1])
        if high == none || low == none {
            return none
        }
        index = index + 2
    }
    return strlen((text) as Str) / 2
}

fn __kai_std_codec_hex_decode(buffer: *Char, text: Str) -> ?Str {
    let decoded_len: ?Int = __kai_std_codec_hex_decoded_len(text)
    if decoded_len == none || (decoded_len catch 0) > 1000000 {
        return none
    }
    var input: Int = 0
    var output: Int = 0
    while input < strlen((text) as Str) {
        let high: ?Char = __kai_std_ascii_hex_value(text[input])
        let low: ?Char = __kai_std_ascii_hex_value(text[input + 1])
        if high == none || low == none {
            return none
        }
        buffer[output] = (high catch Char(0)) * Char(16) + (low catch Char(0))
        input = input + 2
        output = output + 1
    }
    return substring(buffer, 0, output)
}

fn __kai_std_codec_base64_value(byte: Char) -> ?Char {
    if byte >= Char(65) && byte <= Char(90) {
        return byte - Char(65)
    }
    if byte >= Char(97) && byte <= Char(122) {
        return byte - Char(71)
    }
    if byte >= Char(48) && byte <= Char(57) {
        return byte + Char(4)
    }
    if byte == Char(43) {
        return Char(62)
    }
    if byte == Char(47) {
        return Char(63)
    }
    return none
}

fn __kai_std_codec_base64_char(value: Char) -> Char {
    if value < Char(26) {
        return Char(65) + value
    }
    if value < Char(52) {
        return Char(97) + value - Char(26)
    }
    if value < Char(62) {
        return Char(48) + value - Char(52)
    }
    if value == Char(62) {
        return Char(43)
    }
    return Char(47)
}

fn __kai_std_codec_base64_encoded_len(len: Int) -> Int {
    if len == 0 {
        return 0
    }
    return ((len + 2) / 3) * 4
}

fn __kai_std_codec_base64_encode(buffer: *Char, bytes: Str) -> ?Str {
    let encoded_len: Int = __kai_std_codec_base64_encoded_len(strlen((bytes) as Str))
    if encoded_len > 1000000 {
        return none
    }
    var input: Int = 0
    var output: Int = 0
    while input < strlen((bytes) as Str) {
        let b0: Char = bytes[input]
        var b1: Char = Char(0)
        var b2: Char = Char(0)
        let has1: Bool = input + 1 < strlen((bytes) as Str)
        let has2: Bool = input + 2 < strlen((bytes) as Str)
        if has1 {
            b1 = bytes[input + 1]
        }
        if has2 {
            b2 = bytes[input + 2]
        }
        buffer[output] = __kai_std_codec_base64_char(b0 / Char(4))
        buffer[output + 1] = __kai_std_codec_base64_char((b0 % Char(4)) * Char(16) + (b1 / Char(16)))
        if has1 {
            buffer[output + 2] = __kai_std_codec_base64_char((b1 % Char(16)) * Char(4) + (b2 / Char(64)))
        } else {
            buffer[output + 2] = Char(61)
        }
        if has2 {
            buffer[output + 3] = __kai_std_codec_base64_char(b2 % Char(64))
        } else {
            buffer[output + 3] = Char(61)
        }
        input = input + 3
        output = output + 4
    }
