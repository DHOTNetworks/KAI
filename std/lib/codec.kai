fn __kai_std_codec_base32_decoded_len(text: Str) -> ?Int {
    let len: Int = strlen((text) as Str)
    if len == 0 {
        return 0
    }
    if len % 8 != 0 {
        return none
    }
    var padding: Int = 0
    while padding < len && text[len - 1 - padding] == Char(61) {
        padding = padding + 1
    }
    if padding != 0 && padding != 1 && padding != 3 && padding != 4 && padding != 6 {
        return none
    }
    var index: Int = 0
    while index < len {
        let byte: Char = text[index]
        if byte == Char(61) {
            if index < len - padding {
                return none
            }
        } else {
            let value: ?Char = __kai_std_codec_base32_value(byte)
            if value == none {
                return none
            }
        }
        index = index + 1
    }
    if padding == 6 {
        let c1: ?Char = __kai_std_codec_base32_value(text[len - 7])
        if c1 == none || (c1 catch Char(0)) % Char(4) != Char(0) {
            return none
        }
        return (len / 8) * 5 - 4
    }
    if padding == 4 {
        let c3: ?Char = __kai_std_codec_base32_value(text[len - 5])
        if c3 == none || (c3 catch Char(0)) % Char(16) != Char(0) {
            return none
        }
        return (len / 8) * 5 - 3
    }
    if padding == 3 {
        let c4: ?Char = __kai_std_codec_base32_value(text[len - 4])
        if c4 == none || (c4 catch Char(0)) % Char(2) != Char(0) {
            return none
        }
        return (len / 8) * 5 - 2
    }
    if padding == 1 {
        let c6: ?Char = __kai_std_codec_base32_value(text[len - 2])
        if c6 == none || (c6 catch Char(0)) % Char(8) != Char(0) {
            return none
        }
        return (len / 8) * 5 - 1
    }
    return (len / 8) * 5
}

fn __kai_std_codec_base32_raw_decoded_len(text: Str) -> ?Int {
    let len: Int = strlen((text) as Str)
    if len == 0 {
        return 0
    }
    var index: Int = 0
    while index < len {
        let value: ?Char = __kai_std_codec_base32_value(text[index])
