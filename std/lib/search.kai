}

fn __kai_std_search_partition_point_desc_i32(items: *Int, pivot: Int) -> Int {
    return __kai_std_search_lower_bound_desc_i32(items, pivot)
}

fn __kai_std_search_min_i32(items: *Int) -> ?Int {
    if __kai_std_mem_is_empty(items) {
        return none
    }
    var best: Int = items[0]
    var index: Int = 1
    while index < strlen((items) as Str) {
        if items[index] < best {
            best = items[index]
        }
        index = index + 1
    }
    return best
}

fn __kai_std_search_min_index_i32(items: *Int) -> Int {
    if __kai_std_mem_is_empty(items) {
        return strlen((items) as Str)
    }
    var best: Int = 0
    var index: Int = 1
    while index < strlen((items) as Str) {
        if items[index] < items[best] {
            best = index
        }
        index = index + 1
    }
    return best
}

