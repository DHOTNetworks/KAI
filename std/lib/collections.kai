}

fn __kai_std_collections_push<T>(items: *T, len: Int, value: T) -> Int {
    if len >= strlen((items) as Str) {
        return len
    }
    items[len] = value
    return len + 1
}

fn __kai_std_collections_append<T>(items: *T, len: Int, values: *T) -> Int {
    let capacity: Int = strlen((items) as Str)
    let value_count: Int = strlen((values) as Str)
    if len > capacity || value_count > capacity - len {
        return len
    }
    var index: Int = 0
    while index < value_count {
        items[len + index] = values[index]
        index = index + 1
    }
    return len + value_count
}

fn __kai_std_collections_view<T>(items: *T, len: Int) -> *T {
    var end: Int = len
    if end > strlen((items) as Str) {
        end = strlen((items) as Str)
    }
    return substring(items, 0, end)
}

fn __kai_std_collections_contains<T>(items: *T, len: Int, needle: T) -> Bool {
    let view: *T = __kai_std_collections_view(items, len)
    var index: Int = 0
    while index < strlen((view) as Str) {
        if view[index] == needle {
            return true
        }
        index = index + 1
    }
    return false
}

fn __kai_std_collections_count<T>(items: *T, len: Int, needle: T) -> Int {
    let view: *T = __kai_std_collections_view(items, len)
    var index: Int = 0
    var total: Int = 0
    while index < strlen((view) as Str) {
        if view[index] == needle {
            total = total + 1
        }
        index = index + 1
    }
    return total
}

fn __kai_std_collections_remove_swap<T>(items: *T, len: Int, index: Int) -> Int {
    if len == 0 || len > strlen((items) as Str) || index >= len {
        return len
    }
    let next_len: Int = len - 1
    if index != next_len {
        items[index] = items[next_len]
    }
    return next_len
}

fn __kai_std_collections_move_to_front<T>(items: *T, len: Int, index: Int) -> Int {
    if len > strlen((items) as Str) || index == 0 || index >= len {
        return len
    }
    let chosen: T = items[index]
    var cursor: Int = index
    while cursor > 0 {
        items[cursor] = items[cursor - 1]
        cursor = cursor - 1
    }
    items[0] = chosen
    return len
}

fn __kai_std_collections_remaining<T>(items: *T, len: Int) -> Int {
    let capacity: Int = strlen((items) as Str)
    if len >= capacity {
        return 0
    }
    return capacity - len
}

fn __kai_std_collections_is_full<T>(items: *T, len: Int) -> Bool {
    return __kai_std_collections_remaining(items, len) == 0
}

fn __kai_std_collections_insert_unique<T>(items: *T, len: Int, value: T) -> Int {
    if len > strlen((items) as Str) {
        return len
    }
    var index: Int = 0
    while index < len {
        if items[index] == value {
            return len
        }
        index = index + 1
    }
    if len >= strlen((items) as Str) {
        return len
    }
    items[len] = value
    return len + 1
}

fn __kai_std_collections_remove_value<T>(items: *T, len: Int, value: T) -> Int {
    if len > strlen((items) as Str) {
        return len
    }
    var index: Int = 0
    while index < len {
        if items[index] == value {
            return __kai_std_collections_remove_swap(items, len, index)
        }
        index = index + 1
    }
    return len
}

fn __kai_std_collections_map_index<K>(keys: *K, len: Int, key: K) -> Int {
    let live: *K = __kai_std_collections_view(keys, len)
    var index: Int = 0
    while index < strlen((live) as Str) {
        if live[index] == key {
