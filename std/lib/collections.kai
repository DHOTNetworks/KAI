        index = index + 1
    }
    return true
}

fn __kai_std_collections_reverse<T>(items: *T, len: Int) -> Bool {
    if len > strlen((items) as Str) {
        return false
    }
    var left: Int = 0
    var right: Int = len
    while left < right {
        right = right - 1
        if left < right {
            let temporary: T = items[left]
            items[left] = items[right]
            items[right] = temporary
            left = left + 1
        }
    }
    return true
}

fn __kai_std_collections_rotate_left<T>(items: *T, len: Int, count: Int) -> Bool {
    if len > strlen((items) as Str) {
        return false
    }
    if len == 0 || len == 1 {
        return true
    }
    var steps: Int = count
    while steps >= len {
        steps = steps - len
    }
    while steps > 0 {
        let first: T = items[0]
        let last_index: Int = len - 1
        var index: Int = 0
        while index < last_index {
            items[index] = items[index + 1]
            index = index + 1
        }
        items[last_index] = first
        steps = steps - 1
    }
    return true
}

fn __kai_std_collections_rotate_right<T>(items: *T, len: Int, count: Int) -> Bool {
    if len > strlen((items) as Str) {
        return false
    }
    if len == 0 || len == 1 {
        return true
    }
    var steps: Int = count
    while steps >= len {
        steps = steps - len
    }
    while steps > 0 {
        let last_index: Int = len - 1
        let last: T = items[last_index]
        var index: Int = last_index
        while index > 0 {
            items[index] = items[index - 1]
            index = index - 1
        }
        items[0] = last
        steps = steps - 1
    }
    return true
}
