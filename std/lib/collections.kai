fn __kai_std_collections_fixed_set_remove<T>(fixed_set: mutref<FixedSet<T>>, value: T) -> Bool {
    let items: *T = fixed_set.items
    let next_len: Int = __kai_std_collections_set_remove(items, fixed_set.len, value)
