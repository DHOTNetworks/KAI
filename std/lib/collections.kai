fn __kai_std_collections_swap_at<T>(items: *T, len: Int, left: Int, right: Int) -> Bool {
    if len > strlen((items) as Str) || left >= len || right >= len {
        return false
    }
    if left != right {
        let temporary: T = items[left]
        items[left] = items[right]
        items[right] = temporary
    }
    return true
}

fn __kai_std_collections_fill<T>(items: *T, len: Int, value: T) -> Bool {
    if len > strlen((items) as Str) {
