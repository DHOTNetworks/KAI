fn __kai_std_collections_fixed_map_put<K: Type, V>(fixed_map: mutref<FixedMap<K, V>>, key: K, value: V) -> Bool {
    let keys: *K = fixed_map.keys
    let values: *V = fixed_map.values
    if fixed_map.len > strlen((keys) as Str) || fixed_map.len > strlen((values) as Str) {
        return false
    }
    var index: Int = 0
    while index < fixed_map.len {
        if keys[index] == key {
            values[index] = value
            return true
        }
        index = index + 1
    }
    if fixed_map.len >= strlen((keys) as Str) || fixed_map.len >= strlen((values) as Str) {
        return false
    }
    keys[fixed_map.len] = key
    values[fixed_map.len] = value
    fixed_map.len = fixed_map.len + 1
    return true
}

fn __kai_std_collections_fixed_map_remove<K: Type, V>(fixed_map: mutref<FixedMap<K, V>>, key: K) -> Bool {
    let keys: *K = fixed_map.keys
    let values: *V = fixed_map.values
    if fixed_map.len == 0 || fixed_map.len > strlen((keys) as Str) || fixed_map.len > strlen((values) as Str) {
        return false
    }
    var index: Int = 0
    while index < fixed_map.len {
        if keys[index] == key {
            break
        }
        index = index + 1
    }
    if index >= fixed_map.len {
        return false
    }
    let next_len: Int = fixed_map.len - 1
    if index != next_len {
        keys[index] = keys[next_len]
        values[index] = values[next_len]
    }
    fixed_map.len = next_len
    return true
}

fn __kai_std_collections_fixed_map_clear<K: Type, V>(fixed_map: mutref<FixedMap<K, V>>) -> Int {
