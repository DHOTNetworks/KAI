        }
        index = index + 1
    }
    return strlen((live) as Str)
}

fn __kai_std_collections_map_get<K: Type, V>(keys: *K, values: *V, len: Int, key: K) -> ?V {
    var live_len: Int = len
    if live_len > strlen((keys) as Str) {
        live_len = strlen((keys) as Str)
    }
    if live_len > strlen((values) as Str) {
        live_len = strlen((values) as Str)
    }
    let index: Int = __kai_std_collections_map_index(keys, live_len, key)
    if index < live_len {
        return values[index]
    }
    return none
}

fn __kai_std_collections_map_remove<K: Type, V>(keys: *K, values: *V, len: Int, key: K) -> Int {
    if len == 0 || len > strlen((keys) as Str) || len > strlen((values) as Str) {
        return len
    }
    var index: Int = 0
    while index < len {
        if keys[index] == key {
            break
        }
        index = index + 1
    }
    if index >= len {
        return len
    }
    let next_len: Int = len - 1
    if index != next_len {
        keys[index] = keys[next_len]
        values[index] = values[next_len]
    }
    return next_len
}

fn __kai_std_collections_map_put<K: Type, V>(keys: *K, values: *V, len: Int, key: K, value: V) -> Int {
    if len > strlen((keys) as Str) || len > strlen((values) as Str) {
        return len
    }
    var index: Int = 0
    while index < len {
        if keys[index] == key {
            break
        }
        index = index + 1
    }
    if index < len {
        values[index] = value
        return len
    }
