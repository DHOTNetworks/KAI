    }
    return capacity - ring.len
}

fn __kai_std_collections_fixed_ring_buffer_is_full<T>(ring: ref<FixedRingBuffer<T>>) -> Bool {
    return __kai_std_collections_fixed_ring_buffer_remaining(ring) == 0
}

fn __kai_std_collections_fixed_ring_buffer_index<T>(ring: ref<FixedRingBuffer<T>>, offset: Int) -> Int {
    let capacity: Int = strlen((ring.items) as Str)
    if capacity == 0 {
        return 0
    }
    return (ring.head + offset) % capacity
}

fn __kai_std_collections_fixed_ring_buffer_get<T>(ring: ref<FixedRingBuffer<T>>, index: Int) -> ?T {
    if index >= ring.len || ring.len > strlen((ring.items) as Str) {
        return none
    }
    let storage_index: Int = __kai_std_collections_fixed_ring_buffer_index(ring, index)
    return ring.items[storage_index]
}

fn __kai_std_collections_fixed_ring_buffer_front<T>(ring: ref<FixedRingBuffer<T>>) -> ?T {
    return __kai_std_collections_fixed_ring_buffer_get(ring, 0)
}

fn __kai_std_collections_fixed_ring_buffer_back<T>(ring: ref<FixedRingBuffer<T>>) -> ?T {
    if ring.len == 0 {
        return none
    }
    return __kai_std_collections_fixed_ring_buffer_get(ring, ring.len - 1)
}

fn __kai_std_collections_fixed_ring_buffer_push_back<T>(ring: mutref<FixedRingBuffer<T>>, value: T) -> Bool {
    let items: *T = ring.items
    let capacity: Int = strlen((items) as Str)
    if capacity == 0 || ring.len >= capacity {
        return false
    }
    ring.head = ring.head % capacity
    let storage_index: Int = (ring.head + ring.len) % capacity
    items[storage_index] = value
    ring.len = ring.len + 1
    return true
}

fn __kai_std_collections_fixed_ring_buffer_push_front<T>(ring: mutref<FixedRingBuffer<T>>, value: T) -> Bool {
    let items: *T = ring.items
    let capacity: Int = strlen((items) as Str)
    if capacity == 0 || ring.len >= capacity {
        return false
    }
    ring.head = ring.head % capacity
    if ring.head == 0 {
        ring.head = capacity - 1
    } else {
        ring.head = ring.head - 1
    }
    items[ring.head] = value
    ring.len = ring.len + 1
    return true
}

fn __kai_std_collections_fixed_ring_buffer_pop_back<T>(ring: mutref<FixedRingBuffer<T>>) -> ?T {
    let capacity: Int = strlen((ring.items) as Str)
    if capacity == 0 || ring.len == 0 || ring.len > capacity {
        return none
    }
    ring.head = ring.head % capacity
    let storage_index: Int = (ring.head + ring.len - 1) % capacity
    let result: T = ring.items[storage_index]
    ring.len = ring.len - 1
    if ring.len == 0 {
        ring.head = 0
    }
    return result
}

fn __kai_std_collections_fixed_ring_buffer_pop_front<T>(ring: mutref<FixedRingBuffer<T>>) -> ?T {
    let capacity: Int = strlen((ring.items) as Str)
    if capacity == 0 || ring.len == 0 || ring.len > capacity {
        return none
    }
    ring.head = ring.head % capacity
    let result: T = ring.items[ring.head]
    ring.len = ring.len - 1
    if ring.len == 0 {
        ring.head = 0
    } else {
        ring.head = (ring.head + 1) % capacity
    }
    return result
}

fn __kai_std_collections_fixed_ring_buffer_clear<T>(ring: mutref<FixedRingBuffer<T>>) -> Int {
    ring.head = 0
    ring.len = 0
    return ring.len
}

fn __kai_std_collections_fixed_ring_buffer_truncate<T>(ring: mutref<FixedRingBuffer<T>>, new_len: Int) -> Int {
    let capacity: Int = strlen((ring.items) as Str)
    if capacity == 0 {
        ring.head = 0
    } else {
        ring.head = ring.head % capacity
    }
    var live_len: Int = ring.len
    if live_len > capacity {
        live_len = capacity
    }
    if new_len < live_len {
        live_len = new_len
    }
    ring.len = live_len
    if ring.len == 0 {
        ring.head = 0
    }
    return ring.len
}

fn __kai_std_collections_fixed_map<K: Type, V>(keys: *K, values: *V, len: Int) -> FixedMap<K, V> {
