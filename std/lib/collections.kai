fn __kai_std_collections_insert_at<T>(items: *T, len: Int, index: Int, value: T) -> Int {
    let capacity: Int = strlen((items) as Str)
    if len >= capacity || index > len {
        return len
    }
    var cursor: Int = len
    while cursor > index {
        items[cursor] = items[cursor - 1]
        cursor = cursor - 1
    }
    items[index] = value
    return len + 1
}

fn __kai_std_collections_remove_at<T>(items: *T, len: Int, index: Int) -> Int {
    if len == 0 || len > strlen((items) as Str) || index >= len {
        return len
    }
    let next_len: Int = len - 1
    var cursor: Int = index
    while cursor < next_len {
        items[cursor] = items[cursor + 1]
        cursor = cursor + 1
    }
    return next_len
}

