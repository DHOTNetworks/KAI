fn __kai_std_collections_fixed_ring_buffer<T>(items: *T, head: Int, len: Int) -> FixedRingBuffer<T> {
    let capacity: Int = strlen((items) as Str)
    var live_head: Int = 0
    if capacity != 0 {
        live_head = head % capacity
    }
    var live_len: Int = len
    if live_len > capacity {
        live_len = capacity
    }
    if live_len == 0 {
        live_head = 0
    }
    return FixedRingBuffer { items: items, head: live_head, len: live_len }
}

fn __kai_std_collections_fixed_ring_buffer_len<T>(ring: ref<FixedRingBuffer<T>>) -> Int {
    return ring.len
}

fn __kai_std_collections_fixed_ring_buffer_capacity<T>(ring: ref<FixedRingBuffer<T>>) -> Int {
