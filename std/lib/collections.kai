fn __kai_std_collections_fixed_set_clear<T>(fixed_set: mutref<FixedSet<T>>) -> Int {
    fixed_set.len = 0
    return fixed_set.len
}

fn __kai_std_collections_fixed_set_truncate<T>(fixed_set: mutref<FixedSet<T>>, new_len: Int) -> Int {
    var live_len: Int = fixed_set.len
    if live_len > strlen((fixed_set.items) as Str) {
        live_len = strlen((fixed_set.items) as Str)
    }
    if new_len < live_len {
        live_len = new_len
