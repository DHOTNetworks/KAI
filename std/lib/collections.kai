}

fn __kai_std_collections_fixed_set_view<T>(fixed_set: ref<FixedSet<T>>) -> *T {
    var end: Int = fixed_set.len
    if end > strlen((fixed_set.items) as Str) {
        end = strlen((fixed_set.items) as Str)
    }
    return substring(fixed_set.items, 0, end)
}

fn __kai_std_collections_fixed_set_contains<T>(fixed_set: ref<FixedSet<T>>, value: T) -> Bool {
    let live: *T = __kai_std_collections_fixed_set_view(fixed_set)
    var index: Int = 0
    while index < strlen((live) as Str) {
        if live[index] == value {
            return true
