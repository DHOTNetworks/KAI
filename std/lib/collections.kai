fn __kai_std_collections_fixed_set<T>(items: *T, len: Int) -> FixedSet<T> {
    var live_len: Int = len
    if live_len > strlen((items) as Str) {
        live_len = strlen((items) as Str)
    }
    return FixedSet { items: items, len: live_len }
}

