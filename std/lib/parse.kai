        index = index + 1
    }
    return index
}

fn __kai_std_parse_identifier_byte(byte: Char) -> Bool {
    return (byte >= Char(65) && byte <= Char(90)) || (byte >= Char(97) && byte <= Char(122)) || (byte >= Char(48) && byte <= Char(57)) || byte == Char(95)
}

fn __kai_std_parse_scan_identifier(value: Str) -> Int {
    if !__kai_std_parse_is_identifier_start(value) {
        return 0
    }
    var index: Int = 1
    while index < strlen((value) as Str) && __kai_std_parse_identifier_byte(value[index]) {
        index = index + 1
    }
    return index
}

fn __kai_std_parse_scan_until_byte(value: Str, byte: Char) -> Int {
    var index: Int = 0
    while index < strlen((value) as Str) {
        if value[index] == byte {
            return index
        }
        index = index + 1
    }
    return strlen((value) as Str)
}

fn __kai_std_parse_token_ascii(value: Str) -> Str {
    let start: Int = __kai_std_parse_scan_whitespace(value)
    var end: Int = start
    while end < strlen((value) as Str) && !(value[end] == Char(32) || value[end] == Char(9) || value[end] == Char(10) || value[end] == Char(13)) {
        end = end + 1
    }
    return substring(value, start, end)
}

fn __kai_std_parse_parse_u32_max(value: Str, max: Int) -> ?Int {
    if strlen((value) as Str) == 0 {
        return none
    }
    var index: Int = 0
    var total: Int = 0
    while index < strlen((value) as Str) {
        let byte: Char = value[index]
        if byte < Char(48) || byte > Char(57) {
            return none
        }
        let digit: Int = (byte - Char(48)) as Int
        if total > (max - digit) / 10 {
            return none
        }
        total = total * 10 + digit
        index = index + 1
    }
    return total
}

fn __kai_std_parse_digit_value(byte: Char) -> ?Int {
    if byte >= Char(48) && byte <= Char(57) {
        return (byte - Char(48)) as Int
    }
    if byte >= Char(65) && byte <= Char(90) {
        return ((byte - Char(65)) as Int) + 10
    }
    if byte >= Char(97) && byte <= Char(122) {
        return ((byte - Char(97)) as Int) + 10
    }
    return none
}

fn __kai_std_parse_parse_u32_base_max(value: Str, base: Int, max: Int) -> ?Int {
    if strlen((value) as Str) == 0 || base < 2 || base > 36 {
