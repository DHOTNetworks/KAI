fn __kai_std_parse_is_ascii_digit(value: Str) -> Bool {
    return strlen((value) as Str) > 0 && value[0] >= Char(48) && value[0] <= Char(57)
}

fn __kai_std_parse_is_ascii_alpha(value: Str) -> Bool {
    if strlen((value) as Str) == 0 {
        return false
    }
    let byte: Char = value[0]
    return (byte >= Char(65) && byte <= Char(90)) || (byte >= Char(97) && byte <= Char(122))
}

fn __kai_std_parse_is_identifier_start(value: Str) -> Bool {
    if strlen((value) as Str) == 0 {
        return false
    }
    let byte: Char = value[0]
    return __kai_std_parse_is_ascii_alpha(value) || byte == Char(95)
}

fn __kai_std_parse_is_whitespace(value: Str) -> Bool {
    if strlen((value) as Str) == 0 {
        return false
    }
    let byte: Char = value[0]
    return byte == Char(32) || byte == Char(9) || byte == Char(10) || byte == Char(13)
}

fn __kai_std_parse_scan_digits(value: Str) -> Int {
    var index: Int = 0
    while index < strlen((value) as Str) && value[index] >= Char(48) && value[index] <= Char(57) {
        index = index + 1
    }
