}

fn __kai_std_parse_byte_size_multiplier(unit: Str) -> ?Int {
    if strlen((unit) as Str) == 0 || strcmp(unit, "B") == 0 {
        return 1
    }
    if strcmp(unit, "KB") == 0 {
        return 1000
    }
    if strcmp(unit, "MB") == 0 {
        return 1000000
    }
    if strcmp(unit, "GB") == 0 {
        return 1000000000
    }
    if strcmp(unit, "KiB") == 0 {
        return 1024
    }
    if strcmp(unit, "MiB") == 0 {
        return 1048576
    }
    if strcmp(unit, "GiB") == 0 {
        return 1073741824
    }
    return none
}

fn __kai_std_parse_parse_byte_size(value: Str) -> ?Int {
