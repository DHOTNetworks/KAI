fn __kai_std_toml_validate(bytes: Str) -> Bool {
    var index: Int = 0
    while index < strlen((bytes) as Str) {
        let line_end: Int = __kai_std_toml_line_end(bytes, index)
        let content_end: Int = __kai_std_toml_comment_end(bytes, index, line_end)
        let start: Int = __kai_std_toml_skip_ws(bytes, index, content_end)
        if start < content_end {
            if bytes[start] == Char(91) {
                let table_end: ?Int = __kai_std_toml_table_end(bytes, start, content_end)
                if table_end == none {
                    return false
                }
            } else {
                let equals: ?Int = __kai_std_toml_find_equals(bytes, start, content_end)
                if equals == none {
                    return false
                }
                let key_end: Int = __kai_std_toml_trim_end(bytes, start, (equals catch 0))
                let value_start: Int = __kai_std_toml_skip_ws(bytes, (equals catch 0) + 1, content_end)
                let value_end: Int = __kai_std_toml_trim_end(bytes, value_start, content_end)
                if key_end == start || value_start == value_end || !__kai_std_toml_value_valid(bytes[value_start..value_end]) {
                    return false
                }
            }
        }
        index = line_end
        if index < strlen((bytes) as Str) && bytes[index] == Char(10) {
            index = index + 1
        }
    }
    return true
}

fn __kai_std_toml_validate_bytes(bytes: Str) -> Bool {
    return __kai_std_toml_validate(bytes)
}

fn __kai_std_toml_field(bytes: Str, key: Str) -> ?Str {
    var table_start: Int = 0
    var table_end: Int = 0
    var has_table: Bool = false
    var index: Int = 0
    while index < strlen((bytes) as Str) {
        let line_end: Int = __kai_std_toml_line_end(bytes, index)
        let content_end: Int = __kai_std_toml_comment_end(bytes, index, line_end)
        let start: Int = __kai_std_toml_skip_ws(bytes, index, content_end)
        if start < content_end {
            if bytes[start] == Char(91) {
                let next_table_end: ?Int = __kai_std_toml_table_end(bytes, start, content_end)
                if next_table_end == none {
                    return none
                }
                table_start = start + 1
                table_end = (next_table_end catch 0)
                has_table = true
            } else {
                let equals: ?Int = __kai_std_toml_find_equals(bytes, start, content_end)
                if equals == none {
                    return none
                }
                let field_key_end: Int = __kai_std_toml_trim_end(bytes, start, (equals catch 0))
                let value_start: Int = __kai_std_toml_skip_ws(bytes, (equals catch 0) + 1, content_end)
                let value_end: Int = __kai_std_toml_trim_end(bytes, value_start, content_end)
                var table: Str = bytes[0..0]
                if has_table {
                    table = bytes[table_start..table_end]
                }
                if __kai_std_toml_key_matches(table, bytes[start..field_key_end], key) {
                    return bytes[value_start..value_end]
                }
            }
        }
        index = line_end
        if index < strlen((bytes) as Str) && bytes[index] == Char(10) {
            index = index + 1
        }
    }
    return none
}

fn __kai_std_toml_string_decode(buffer: *Char, value: Str) -> ?Str {
    if strlen((value) as Str) < 2 || value[0] != Char(34) || value[strlen((value) as Str) - 1] != Char(34) {
        return none
    }
    var input: Int = 1
    var output: Int = 0
    while input + 1 < strlen((value) as Str) {
        var byte: Char = value[input]
        if byte == Char(92) {
            input = input + 1
            if input + 1 >= strlen((value) as Str) {
                return none
            }
            let escaped: Char = value[input]
            if escaped == Char(34) {
                byte = Char(34)
            } else if escaped == Char(92) {
                byte = Char(92)
            } else if escaped == Char(110) {
                byte = Char(10)
            } else if escaped == Char(114) {
                byte = Char(13)
            } else if escaped == Char(116) {
                byte = Char(9)
            } else {
                return none
            }
        }
        if output >= strlen((buffer) as Str) {
            return none
        }
        buffer[output] = byte
        output = output + 1
        input = input + 1
    }
    return buffer[..output]
}

fn __kai_std_toml_string(buffer: *Char, bytes: Str, key: Str) -> ?Str {
    let raw: ?Str = __kai_std_toml_field(bytes, key)
    if raw == none {
        return none
    }
    return __kai_std_toml_string_decode(buffer, (raw catch ""))
}

