fn __kai_std_toml_array_count(value: Str) -> ?Int {
    if !__kai_std_toml_array_valid(value) {
        return none
    }
    var count: Int = 0
    var index: Int = 1
    let end: Int = strlen((value) as Str) - 1
    while index < end {
        index = __kai_std_toml_skip_ws(value, index, end)
        if index == end {
            return count
        }
        let item_end: ?Int = __kai_std_toml_array_item_end(value, index, end)
        if item_end == none {
            return none
        }
        count = count + 1
        index = (item_end catch 0)
        index = __kai_std_toml_skip_ws(value, index, end)
        if index < end {
            index = index + 1
        }
    }
