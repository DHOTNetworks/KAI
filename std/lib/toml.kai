fn __kai_std_toml_key_byte_valid(byte: Char) -> Bool {
    return (byte >= Char(65) && byte <= Char(90)) || (byte >= Char(97) && byte <= Char(122)) || (byte >= Char(48) && byte <= Char(57)) || byte == Char(45) || byte == Char(95)
}

fn __kai_std_toml_dotted_key_valid(key: Str) -> Bool {
    if strlen((key) as Str) == 0 {
        return false
    }
    var index: Int = 0
    var segment_has_byte: Bool = false
    while index < strlen((key) as Str) {
        let byte: Char = key[index]
        if byte == Char(46) {
            if !segment_has_byte {
                return false
            }
            segment_has_byte = false
        } else if __kai_std_toml_key_byte_valid(byte) {
            segment_has_byte = true
        } else {
            return false
        }
        index = index + 1
    }
    return segment_has_byte
}

fn __kai_std_toml_write_key_value_string(buffer: *Char, key: Str, value: Str) -> ?Str {
    if !__kai_std_toml_dotted_key_valid(key) {
