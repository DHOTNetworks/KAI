    return buffer[..(close_end catch 0)]
}

fn __kai_std_toml_line_end(bytes: Str, start: Int) -> Int {
    var index: Int = start
    while index < strlen((bytes) as Str) && bytes[index] != Char(10) {
        index = index + 1
    }
    return index
}

fn __kai_std_toml_skip_ws(bytes: Str, start: Int, end: Int) -> Int {
    var index: Int = start
    while index < end && (bytes[index] == Char(32) || bytes[index] == Char(9) || bytes[index] == Char(13)) {
        index = index + 1
    }
    return index
}

fn __kai_std_toml_trim_end(bytes: Str, start: Int, end: Int) -> Int {
    var index: Int = end
    while index > start && (bytes[index - 1] == Char(32) || bytes[index - 1] == Char(9) || bytes[index - 1] == Char(13)) {
        index = index - 1
    }
    return index
}

fn __kai_std_toml_comment_end(bytes: Str, start: Int, end: Int) -> Int {
    var index: Int = start
    var in_string: Bool = false
    var escaped: Bool = false
    while index < end {
        let byte: Char = bytes[index]
        if escaped {
            escaped = false
        } else if in_string && byte == Char(92) {
            escaped = true
        } else if byte == Char(34) {
            in_string = !in_string
        } else if !in_string && byte == Char(35) {
            return __kai_std_toml_trim_end(bytes, start, index)
        }
        index = index + 1
    }
    return end
}

fn __kai_std_toml_find_equals(bytes: Str, start: Int, end: Int) -> ?Int {
    var index: Int = start
    var in_string: Bool = false
    var escaped: Bool = false
    while index < end {
        let byte: Char = bytes[index]
        if escaped {
            escaped = false
        } else if in_string && byte == Char(92) {
            escaped = true
        } else if byte == Char(34) {
            in_string = !in_string
        } else if !in_string && byte == Char(61) {
            return index
        }
        index = index + 1
    }
    return none
}

fn __kai_std_toml_table_end(bytes: Str, start: Int, end: Int) -> ?Int {
    if start >= end || bytes[start] != Char(91) {
        return none
    }
    var index: Int = start + 1
    while index < end {
        if bytes[index] == Char(93) {
            let trailing: Int = __kai_std_toml_skip_ws(bytes, index + 1, end)
            if trailing == end && index > start + 1 {
                return index
            }
            return none
        }
        index = index + 1
    }
    return none
}

fn __kai_std_toml_string_value_end(value: Str) -> ?Int {
    if strlen((value) as Str) == 0 || value[0] != Char(34) {
        return none
    }
    var index: Int = 1
    var escaped: Bool = false
    while index < strlen((value) as Str) {
        let byte: Char = value[index]
        if escaped {
            if !(byte == Char(34) || byte == Char(92) || byte == Char(110) || byte == Char(114) || byte == Char(116)) {
                return none
            }
            escaped = false
        } else if byte == Char(92) {
            escaped = true
        } else if byte == Char(34) {
            return index + 1
        }
        index = index + 1
    }
    return none
}

fn __kai_std_toml_array_valid(value: Str) -> Bool {
    if strlen((value) as Str) < 2 || value[0] != Char(91) || value[strlen((value) as Str) - 1] != Char(93) {
        return false
    }
    var index: Int = 1
    let end: Int = strlen((value) as Str) - 1
    while index < end {
        index = __kai_std_toml_skip_ws(value, index, end)
        if index == end {
            return true
        }
        let item_end: ?Int = __kai_std_toml_array_item_end(value, index, end)
        if item_end == none {
            return false
        }
        index = (item_end catch 0)
        index = __kai_std_toml_skip_ws(value, index, end)
        if index < end {
            if value[index] != Char(44) {
                return false
            }
            index = index + 1
        }
    }
    return true
}

fn __kai_std_toml_array_item_end(value: Str, start: Int, end: Int) -> ?Int {
    if start >= end {
        return none
    }
    if value[start] == Char(34) {
        let item_end: ?Int = __kai_std_toml_string_value_end(value[start..end])
        if item_end == none {
            return none
        }
        return start + (item_end catch 0)
    }
    var index: Int = start
    while index < end && value[index] != Char(44) {
        index = index + 1
    }
    let trimmed: Int = __kai_std_toml_trim_end(value, start, index)
    if trimmed == start {
        return none
    }
    if __kai_std_toml_value_valid(value[start..trimmed]) {
        return trimmed
    }
    return none
}

fn __kai_std_toml_value_valid(value: Str) -> Bool {
    if strlen((value) as Str) == 0 {
        return false
    }
    if value[0] == Char(34) {
        let end: ?Int = __kai_std_toml_string_value_end(value)
        return end != none && (end catch 0) == strlen((value) as Str)
    }
    if value[0] == Char(91) {
        return __kai_std_toml_array_valid(value)
    }
    if strcmp(value, "true") == 0 || strcmp(value, "false") == 0 {
        return true
    }
    let signed: ?Int = __kai_std_parse_parse_i32(value)
    if signed != none {
        return true
    }
    let unsigned: ?Int = atoll(value)
    return unsigned != none
}

fn __kai_std_toml_write_span(buffer: *Char, cursor: Int, bytes: Str) -> ?Int {
    if cursor + strlen((bytes) as Str) > strlen((buffer) as Str) {
        return none
    }
    var index: Int = 0
    while index < strlen((bytes) as Str) {
        buffer[cursor + index] = bytes[index]
        index = index + 1
    }
    return cursor + strlen((bytes) as Str)
}

fn __kai_std_toml_write_escaped_string(buffer: *Char, cursor: Int, value: Str) -> ?Int {
    var output: Int = cursor
    let open_end: ?Int = __kai_std_toml_write_span(buffer, output, "\"")
    if open_end == none {
        return none
    }
    output = (open_end catch 0)
    var index: Int = 0
    while index < strlen((value) as Str) {
        let byte: Char = value[index]
        if byte == Char(34) {
            let next: ?Int = __kai_std_toml_write_span(buffer, output, "\\\"")
            if next == none {
                return none
            }
            output = (next catch 0)
        } else if byte == Char(92) {
            let next: ?Int = __kai_std_toml_write_span(buffer, output, "\\\\")
            if next == none {
                return none
            }
            output = (next catch 0)
        } else if byte == Char(10) {
            let next: ?Int = __kai_std_toml_write_span(buffer, output, "\\n")
            if next == none {
                return none
            }
            output = (next catch 0)
        } else if byte == Char(13) {
            let next: ?Int = __kai_std_toml_write_span(buffer, output, "\\r")
            if next == none {
                return none
            }
            output = (next catch 0)
        } else if byte == Char(9) {
            let next: ?Int = __kai_std_toml_write_span(buffer, output, "\\t")
            if next == none {
                return none
            }
            output = (next catch 0)
        } else {
            if byte < Char(32) || output >= strlen((buffer) as Str) {
                return none
            }
            buffer[output] = byte
            output = output + 1
        }
        index = index + 1
    }
    return __kai_std_toml_write_span(buffer, output, "\"")
}

fn __kai_std_toml_span_eq(left: Str, right: Str) -> Bool {
    if strlen((left) as Str) != strlen((right) as Str) {
        return false
    }
    var index: Int = 0
    while index < strlen((right) as Str) {
        if left[index] != right[index] {
            return false
        }
        index = index + 1
    }
    return true
}

fn __kai_std_toml_key_matches(table: Str, field: Str, query: Str) -> Bool {
    if __kai_std_toml_span_eq(field, query) {
        return true
    }
    if strlen((table) as Str) == 0 {
        return false
    }
    let table_len: Int = strlen((table) as Str)
    let field_len: Int = strlen((field) as Str)
    if strlen((query) as Str) != table_len + 1 + field_len {
        return false
    }
    var index: Int = 0
    while index < table_len {
        if query[index] != table[index] {
            return false
        }
        index = index + 1
    }
    if query[table_len] != Char(46) {
        return false
    }
    var field_index: Int = 0
    while field_index < field_len {
        if query[table_len + 1 + field_index] != field[field_index] {
            return false
        }
        field_index = field_index + 1
    }
    return true
}
