        }
        if best != index {
            let value: Int = items[index]
            items[index] = items[best]
            items[best] = value
        }
        index = index + 1
    }
    return true
}

fn __kai_std_sort_merge_sorted_usize(dst: *Int, left: *Int, right: *Int) -> Int {
    var written: Int = 0
    var left_index: Int = 0
    var right_index: Int = 0
    let capacity: Int = strlen((dst) as Str)
    while written < capacity && left_index < strlen((left) as Str) && right_index < strlen((right) as Str) {
        if left[left_index] <= right[right_index] {
            dst[written] = left[left_index]
            left_index = left_index + 1
        } else {
            dst[written] = right[right_index]
            right_index = right_index + 1
        }
        written = written + 1
    }
    while written < capacity && left_index < strlen((left) as Str) {
        dst[written] = left[left_index]
        left_index = left_index + 1
        written = written + 1
    }
    while written < capacity && right_index < strlen((right) as Str) {
        dst[written] = right[right_index]
        right_index = right_index + 1
        written = written + 1
    }
    return written
}

fn __kai_std_sort_merge_sorted_desc_usize(dst: *Int, left: *Int, right: *Int) -> Int {
    var written: Int = 0
    var left_index: Int = 0
    var right_index: Int = 0
    let capacity: Int = strlen((dst) as Str)
    while written < capacity && left_index < strlen((left) as Str) && right_index < strlen((right) as Str) {
        if left[left_index] >= right[right_index] {
            dst[written] = left[left_index]
            left_index = left_index + 1
        } else {
