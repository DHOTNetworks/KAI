        while cursor > 0 && items[cursor - 1] < value {
            items[cursor] = items[cursor - 1]
            cursor = cursor - 1
        }
        items[cursor] = value
        index = index + 1
    }
}

fn __kai_std_sort_stable_desc_i32(items: *Int) -> Void {
