fn __kai_std_sort_dedupe_sorted_i32(items: *Int) -> Int {
    if strlen((items) as Str) == 0 {
        return 0
    }
    var write: Int = 1
    var index: Int = 1
    while index < strlen((items) as Str) {
        if items[index] != items[write - 1] {
            items[write] = items[index]
            write = write + 1
        }
        index = index + 1
    }
    return write
}

fn __kai_std_sort_select_nth_i32(items: *Int, nth: Int) -> Bool {
    let len: Int = strlen((items) as Str)
    if nth >= len {
        return false
    }
    var index: Int = 0
    while index <= nth {
        var best: Int = index
