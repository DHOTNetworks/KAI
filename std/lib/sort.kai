cimport "stdio.h"
cimport "stdlib.h"
cimport "string.h"
extern fn printf(format: Str, value: Str) -> Int
extern fn strcmp(s1: Str, s2: Str) -> Int
extern fn atoll(s: Str) -> Int
extern fn strlen(s: Str) -> Int

fn __kai_std_sort_insertion_i32(items: *Int) -> Void {
    var index: Int = 1
    while index < strlen((items) as Str) {
        let value: Int = items[index]
        var cursor: Int = index
        while cursor > 0 && items[cursor - 1] > value {
            items[cursor] = items[cursor - 1]
            cursor = cursor - 1
        }
        items[cursor] = value
        index = index + 1
    }
}

fn __kai_std_sort_stable_i32(items: *Int) -> Void {
    __kai_std_sort_insertion_i32(items)
}

fn __kai_std_sort_unstable_i32(items: *Int) -> Void {
    var index: Int = 0
    while index < strlen((items) as Str) {
        var best: Int = index
        var scan: Int = index + 1
        while scan < strlen((items) as Str) {
            if items[scan] < items[best] {
                best = scan
            }
            scan = scan + 1
        }
        if best != index {
            let value: Int = items[index]
            items[index] = items[best]
            items[best] = value
        }
        index = index + 1
    }
}

fn __kai_std_sort_reverse_i32(items: *Int) -> Void {
    var left: Int = 0
    var right: Int = strlen((items) as Str)
    while left < right {
        right = right - 1
        if left < right {
            let value: Int = items[left]
            items[left] = items[right]
            items[right] = value
            left = left + 1
        }
    }
}

fn __kai_std_sort_swap_i32(items: *Int, left: Int, right: Int) -> Bool {
    if left >= strlen((items) as Str) || right >= strlen((items) as Str) {
        return false
    }
    let value: Int = items[left]
    items[left] = items[right]
    items[right] = value
    return true
}

fn __kai_std_sort_rotate_left_i32(items: *Int, amount: Int) -> Void {
    let len: Int = strlen((items) as Str)
    if len == 0 {
        return
    }
    let shift: Int = amount % len
    var step: Int = 0
    while step < shift {
        let first: Int = items[0]
        var index: Int = 1
        while index < len {
            items[index - 1] = items[index]
            index = index + 1
        }
        items[len - 1] = first
        step = step + 1
    }
}

fn __kai_std_sort_rotate_right_i32(items: *Int, amount: Int) -> Void {
    let len: Int = strlen((items) as Str)
    if len == 0 {
        return
    }
    let shift: Int = amount % len
    if shift > 0 {
        __kai_std_sort_rotate_left_i32(items, len - shift)
    }
}

fn __kai_std_sort_is_sorted_i32(items: *Int) -> Bool {
    var index: Int = 1
    while index < strlen((items) as Str) {
        if items[index] < items[index - 1] {
            return false
        }
        index = index + 1
    }
    return true
}

fn __kai_std_sort_insertion_desc_i32(items: *Int) -> Void {
    var index: Int = 1
    while index < strlen((items) as Str) {
        let value: Int = items[index]
