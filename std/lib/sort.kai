fn __kai_std_sort_partition_desc_usize(items: *Int, pivot: Int) -> Int {
    var write: Int = 0
    var index: Int = 0
    while index < strlen((items) as Str) {
        if items[index] > pivot {
            let value: Int = items[index]
            items[index] = items[write]
            items[write] = value
            write = write + 1
        }
        index = index + 1
    }
    return write
}

fn __kai_std_sort_is_partitioned_desc_usize(items: *Int, pivot: Int) -> Bool {
    var seen_tail: Bool = false
    var index: Int = 0
    while index < strlen((items) as Str) {
        if items[index] > pivot {
            if seen_tail {
                return false
            }
        } else {
            seen_tail = true
        }
        index = index + 1
    }
    return true
}

fn __kai_std_sort_dedupe_sorted_usize(items: *Int) -> Int {
    if strlen((items) as Str) == 0 {
        return 0
    }
    var write: Int = 1
    var index: Int = 1
    while index < strlen((items) as Str) {
        if items[index] != items[write - 1] {
            items[write] = items[index]
            write = write + 1
        }
        index = index + 1
    }
    return write
}

fn __kai_std_sort_select_nth_usize(items: *Int, nth: Int) -> Bool {
    let len: Int = strlen((items) as Str)
    if nth >= len {
        return false
    }
    var index: Int = 0
    while index <= nth {
        var best: Int = index
        var scan: Int = index + 1
        while scan < len {
            if items[scan] < items[best] {
                best = scan
            }
            scan = scan + 1
        }
        if best != index {
            let value: Int = items[index]
            items[index] = items[best]
            items[best] = value
        }
        index = index + 1
    }
    return true
}

fn __kai_std_sort_select_nth_desc_usize(items: *Int, nth: Int) -> Bool {
