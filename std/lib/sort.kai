fn __kai_std_sort_partition_i32(items: *Int, pivot: Int) -> Int {
    var write: Int = 0
    var index: Int = 0
    while index < strlen((items) as Str) {
        if items[index] < pivot {
            let value: Int = items[index]
            items[index] = items[write]
            items[write] = value
            write = write + 1
        }
        index = index + 1
    }
    return write
}

fn __kai_std_sort_is_partitioned_i32(items: *Int, pivot: Int) -> Bool {
    var seen_tail: Bool = false
    var index: Int = 0
    while index < strlen((items) as Str) {
        if items[index] < pivot {
            if seen_tail {
                return false
            }
        } else {
            seen_tail = true
        }
        index = index + 1
    }
    return true
}

fn __kai_std_sort_partition_desc_i32(items: *Int, pivot: Int) -> Int {
    var write: Int = 0
