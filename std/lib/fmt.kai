fn __kai_std_fmt_write_bytes(buffer: *Char, text: Str) -> ?Str {
    if strlen((text) as Str) > strlen((buffer) as Str) {
        return none
    }
    var index: Int = 0
    while index < strlen((text) as Str) {
        buffer[index] = text[index]
        index = index + 1
    }
    return buffer[..strlen((text) as Str)]
}

fn __kai_std_fmt_bool(buffer: *Char, value: Bool) -> ?Str {
    if value {
        return __kai_std_fmt_write_bytes(buffer, "true")
    }
    return __kai_std_fmt_write_bytes(buffer, "false")
}

fn __kai_std_fmt_u32(buffer: *Char, value: Int) -> ?Str {
    let written: ?Int = __kai_std_fmt_write_u32_at(buffer, 0, value)
    if written != none {
        return buffer[..(written catch 0)]
    }
    return none
}

