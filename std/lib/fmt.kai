fn __kai_std_fmt_pad_left(buffer: *Char, text: Str, width: Int, pad: Char) -> ?Str {
    let len: Int = strlen((text) as Str)
    if len >= width {
        return __kai_std_fmt_write_bytes(buffer, text)
    }
    if width > strlen((buffer) as Str) {
        return none
    }
    let fill: Int = width - len
    var index: Int = 0
    while index < fill {
        buffer[index] = pad
        index = index + 1
    }
    var text_index: Int = 0
    while text_index < len {
        buffer[fill + text_index] = text[text_index]
        text_index = text_index + 1
    }
    return buffer[..width]
}

fn __kai_std_fmt_pad_right(buffer: *Char, text: Str, width: Int, pad: Char) -> ?Str {
    let len: Int = strlen((text) as Str)
    if len >= width {
        return __kai_std_fmt_write_bytes(buffer, text)
    }
    if width > strlen((buffer) as Str) {
        return none
    }
    var text_index: Int = 0
    while text_index < len {
        buffer[text_index] = text[text_index]
        text_index = text_index + 1
    }
    var index: Int = len
    while index < width {
        buffer[index] = pad
        index = index + 1
    }
    return buffer[..width]
}

fn __kai_std_fmt_write_span(writer: mutref<FixedWriter>, text: Str) -> Bool {
    return __kai_std_io_fixed_writer_write(writer, text)
}

fn __kai_std_fmt_write_bool(writer: mutref<FixedWriter>, value: Bool) -> Bool {
    var storage: [5]Char = [Char(0); 5]
    let text: ?Str = __kai_std_fmt_bool(storage, value)
    if text != none {
        return __kai_std_fmt_write_span(writer, (text catch ""))
    }
    return false
}

