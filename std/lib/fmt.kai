fn __kai_std_fmt_hex_lower_u32(buffer: *Char, value: Int) -> ?Str {
    var digits: Int = 1
    var scan: Int = value
    while scan >= 16 {
        digits = digits + 1
        scan = scan / 16
    }
    if digits > strlen((buffer) as Str) {
        return none
    }
    var cursor: Int = digits
    var current: Int = value
    while cursor > 0 {
        cursor = cursor - 1
        let digit: Char = (current % 16) as Char
        if digit < Char(10) {
            buffer[cursor] = Char(48) + digit
        } else {
            buffer[cursor] = Char(87) + digit
        }
        current = current / 16
    }
    return buffer[..digits]
}
