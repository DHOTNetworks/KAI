fn __kai_std_fmt_digit_lower(value: Int) -> Char {
    if value < 10 {
        return Char(48) + (value as Char)
    }
    return Char(87) + (value as Char)
}

fn __kai_std_fmt_write_u32_base_at(buffer: *Char, offset: Int, value: Int, base: Int) -> ?Int {
    if offset > strlen((buffer) as Str) || (base < 2 || base > 36) {
        return none
    }
    var digits: Int = 1
    var scan: Int = value
    while scan >= base {
        digits = digits + 1
        scan = scan / base
    }
    if offset + digits > strlen((buffer) as Str) {
        return none
    }
    var cursor: Int = offset + digits
    var current: Int = value
    while cursor > offset {
        cursor = cursor - 1
        let digit: Int = current % base
        buffer[cursor] = __kai_std_fmt_digit_lower(digit)
        current = current / base
    }
    return offset + digits
}

