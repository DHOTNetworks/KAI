fn __kai_std_fmt_i32(buffer: *Char, value: Int) -> ?Str {
    if value >= 0 {
        return __kai_std_fmt_u32(buffer, value as Int)
    }
    if strlen((buffer) as Str) == 0 {
        return none
    }
    buffer[0] = Char(45)
    let min_i32: Int = 0 - 2147483647 - 1
    if value == min_i32 {
        let written_min: ?Str = __kai_std_fmt_write_bytes(buffer[1..], "2147483648")
        if written_min != none {
            return buffer[..11]
        }
        return none
    }
    let magnitude: Int = (0 - value) as Int
    let written: ?Int = __kai_std_fmt_write_u32_at(buffer, 1, magnitude)
    if written != none {
        return buffer[..(written catch 0)]
    }
    return none
}

