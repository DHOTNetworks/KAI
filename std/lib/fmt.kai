fn __kai_std_fmt_write_u32_at(buffer: *Char, offset: Int, value: Int) -> ?Int {
    if offset > strlen((buffer) as Str) {
        return none
    }
    var digits: Int = 1
    var scan: Int = value
    while scan >= 10 {
        digits = digits + 1
        scan = scan / 10
    }
    if offset + digits > strlen((buffer) as Str) {
        return none
    }
    var cursor: Int = offset + digits
    var current: Int = value
    while cursor > offset {
        cursor = cursor - 1
        let digit: Char = (current % 10) as Char
        buffer[cursor] = Char(48) + digit
        current = current / 10
    }
    return offset + digits
}

