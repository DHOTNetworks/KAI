        buffer[output] = Char(240) + (codepoint / 262144) as Char
        buffer[output + 1] = Char(128) + (codepoint / 4096 % 64) as Char
        buffer[output + 2] = Char(128) + (codepoint / 64 % 64) as Char
        buffer[output + 3] = Char(128) + (codepoint % 64) as Char
