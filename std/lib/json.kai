    }
    if codepoint <= 2047 {
        if output + 2 > 1000000 {
            return none
        }
        buffer[output] = Char(192) + (codepoint / 64) as Char
        buffer[output + 1] = Char(128) + (codepoint % 64) as Char
        return output + 2
    }
    if codepoint <= 65535 {
        if codepoint >= 55296 && codepoint <= 57343 {
            return none
