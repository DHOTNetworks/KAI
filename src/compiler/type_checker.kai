import ArrayList from std.core.array
import Allocator from std.core.allocator
import KaiAllocator from std.core.allocator
import KaiAllocator from std.core.allocator
import StmtNode from compiler.ast_nodes
import ExprNode from compiler.ast_nodes
import PatternNode from compiler.ast_nodes
import StmtKind from compiler.ast_nodes
import ExprKind from compiler.ast_nodes
import PatternKind from compiler.ast_nodes
import Param from compiler.ast_nodes
import StructField from compiler.ast_nodes
import DropVarEntry from compiler.ast_nodes
import empty_str_array from compiler.ast_nodes
import SymbolTable from compiler.symbol_table
import Symbol from compiler.symbol_table
import length from std.core.string
import substring from std.core.string
import char_to_str from std.core.string
import int_to_str from std.core.string
import str_array_join from compiler.parser
import std.io.print
import get_source_line from utils
import ImportResolver from compiler.imports
import StringPool from compiler.string_pool
import TypeArena from compiler.types
import TypeKind from compiler.types
import Type from compiler.types

extern fn strlen(s: Str) -> Int

struct PtrRefResult {
    is_ptr: Bool
    is_mut: Bool
    inner: Str
}

struct StructInfo {
    name: Str
    has_drop: Bool
}

struct FuncEffect {
    func_name: Str
    free_param_indices: ArrayList<Int>
}

struct SymTrackState {
    name: Str
    table_idx: Int
    entry_idx: Int
    moved: Bool
    freed: Bool
}

struct TypeChecker {
    allocator: *KaiAllocator
    stmt_pool: *ArrayList<StmtNode>
    expr_pool: *ArrayList<ExprNode>
    pattern_pool: *ArrayList<PatternNode>
    
    symbol_tables: ArrayList<SymbolTable>
    current_table_idx: Int
    
    struct_info: ArrayList<StructInfo>
    has_error: Bool
    current_func_ret_type: Str
    source_file: Str
    source: Str
    import_resolver: *ImportResolver
    pool: *StringPool
    type_arena: TypeArena
    imported_names: ArrayList<Str>
    import_used: ArrayList<Bool>
    import_lines: ArrayList<Int>
    import_cols: ArrayList<Int>
    loop_depth: Int
    // Deferred tracking-state from defer/errdefer statements.
    // Stored flat to avoid nested ArrayList<T> types that break the -CC codegen.
    // scope_deferred_flat: all SymTrackState entries from all snapshots concatenated
    // scope_deferred_sizes[i]: entry count of the i-th snapshot
    // scope_deferred_counts[s]: how many snapshots belong to scope level s
    scope_deferred_flat: ArrayList<SymTrackState>
    scope_deferred_sizes: ArrayList<Int>
    scope_deferred_counts: ArrayList<Int>
    // Per-function effect inference: which parameters are freed/moved
    func_effects: ArrayList<FuncEffect>
}

impl TypeChecker {
    fn init(self, allocator: *KaiAllocator, stmt_pool: *ArrayList<StmtNode>, expr_pool: *ArrayList<ExprNode>, pattern_pool: *ArrayList<PatternNode>, source_file: Str, source: Str, import_resolver: *ImportResolver, pool: *StringPool) {
        self.allocator = allocator
        self.stmt_pool = stmt_pool
        self.expr_pool = expr_pool
        self.pattern_pool = pattern_pool
        self.symbol_tables = ArrayList<SymbolTable>(allocator)
        self.current_table_idx = -1
        self.struct_info = ArrayList<StructInfo>(allocator)
        self.has_error = false
        self.current_func_ret_type = ""
        self.source_file = source_file
        self.source = source
        self.import_resolver = import_resolver
        self.pool = pool
        self.type_arena.init(allocator)
        self.imported_names = ArrayList<Str>(allocator)
        self.import_used = ArrayList<Bool>(allocator)
        self.import_lines = ArrayList<Int>(allocator)
        self.import_cols = ArrayList<Int>(allocator)
        self.loop_depth = 0
        self.scope_deferred_flat = ArrayList<SymTrackState>(allocator)
        self.scope_deferred_sizes = ArrayList<Int>(allocator)
        self.scope_deferred_counts = ArrayList<Int>(allocator)
        self.func_effects = ArrayList<FuncEffect>(allocator)
    }

    fn err(self, code: Str, msg: Str, line: Int, col: Int) {
        printf("%s:%ld:%ld: error[%s]: %s\n", self.source_file, line, col, code, msg)
        if line >= 0 {
            // AST line numbers are 1-indexed; get_source_line expects 0-indexed
            let line_text = get_source_line(self.source, line - 1)
            if length(line_text) > 0 {
                printf("    %s\n", line_text)
                var caret = "    "
                var ci = 0
                while ci < col && ci < length(line_text) {
                    if line_text[ci] == Char(9) {
                        caret = caret + "\t"
                    } else {
                        caret = caret + " "
                    }
                    ci = ci + 1
                }
                caret = caret + "^"
                printf("%s\n", caret)
            }
        }
        self.has_error = true
    }

    fn enter_scope(self) {
        var new_table = SymbolTable(entries: ArrayList<Symbol>(self.allocator), parent_idx: self.current_table_idx, allocator: self.allocator)
        new_table.init(self.allocator, self.current_table_idx)
        self.symbol_tables.push(new_table)
        self.current_table_idx = self.symbol_tables.length() - 1
        self.scope_deferred_counts.push(0)
    }

    fn exit_scope(self) {
        // Apply deferred tracking effects from defer/errdefer before exiting
        if self.scope_deferred_counts.length() > 0 {
            let snap_count = self.scope_deferred_counts.get(self.scope_deferred_counts.length() - 1)
            if snap_count > 0 {
                // Reconstruct snapshots from the flat list
                let total_sizes_idx = self.scope_deferred_sizes.length() - snap_count
                let flat_idx = self.scope_deferred_flat.length()
                // Walk backward through sizes to find where reconstructed snapshots begin
                var walk = snap_count
                var begin = flat_idx
                while walk > 0 {
                    let sz = self.scope_deferred_sizes.get(total_sizes_idx + walk - 1)
                    begin = begin - sz
                    walk = walk - 1
                }
                // Build state list from reconstructed snapshots
                let states = ArrayList<ArrayList<SymTrackState>>(self.allocator)
                var si = 0
                var fi = begin
                while si < snap_count {
                    let sz = self.scope_deferred_sizes.get(total_sizes_idx + si)
                    var snapshot = ArrayList<SymTrackState>(self.allocator)
                    var ei = 0
                    while ei < sz {
                        snapshot.push(self.scope_deferred_flat.get(fi))
                        fi = fi + 1
                        ei = ei + 1
                    }
                    states.push(snapshot)
                    si = si + 1
                }
                self.merge_and_apply_tracking_state(states)
                var dsi = 0
                while dsi < states.length() { let s = states.get(dsi); s.deinit(); dsi = dsi + 1 }
                states.deinit()
                // Pop the processed snapshot metadata
                var pi = 0
                while pi < snap_count {
                    self.scope_deferred_sizes.pop()
                    pi = pi + 1
                }
                // Pop the flat entries
                var pop_count = self.scope_deferred_flat.length() - begin
                while pop_count > 0 {
                    self.scope_deferred_flat.pop()
                    pop_count = pop_count - 1
                }
            }
            self.scope_deferred_counts.pop()
        }
        if self.current_table_idx >= 0 {
            let table = self.symbol_tables.get(self.current_table_idx)
            self.current_table_idx = table.parent_idx
        }
    }

    fn define_symbol(self, name: Str, type_name: Str, is_mutable: Bool, kind: Str, decl_stmt_idx: Int) {
        if self.current_table_idx >= 0 {
            var table = self.symbol_tables.get(self.current_table_idx)
            table.define(name, type_name, is_mutable, kind, "", decl_stmt_idx)
            self.symbol_tables.set(self.current_table_idx, table)
        }
    }

    fn check_program(self, top_stmt_idx: Int) -> Bool {
        // Pre-pass: register struct drop info and detect imports
        self.register_struct_info(top_stmt_idx)
        self.detect_imports(top_stmt_idx)
        self.import_resolver.resolve_all(top_stmt_idx, self.stmt_pool, self.expr_pool, self.pattern_pool)

        if self.import_resolver.has_error {
            let err_idx = self.import_resolver.error_stmt_idx
            var err_line = 0
            var err_col = 0
            if err_idx >= 0 {
                let stmt = self.stmt_pool.get(err_idx)
                err_line = stmt.line
                err_col = stmt.col
            }
            self.err("E0034", self.import_resolver.error_message, err_line, err_col)
            return false
        }

        // Start checking
        self.enter_scope()
        self.check_stmt(top_stmt_idx)
        self.exit_scope()
        
        // Check for unused imports
        var ui = 0
        while ui < self.imported_names.length() {
            if !self.import_used.get(ui) {
                let line = self.import_lines.get(ui)
                let col = self.import_cols.get(ui)
                self.err("E0033", "unused import: '" + self.imported_names.get(ui) + "'", line, col)
            }
            ui = ui + 1
        }
        
        return !self.has_error
    }

    fn detect_imports(self, top_stmt_idx: Int) {
        let stmt = self.stmt_pool.get(top_stmt_idx)
        if stmt.kind == StmtKind.sk_block {
            var i = 0
            while i < stmt.block_stmts.length() {
                let s_idx = stmt.block_stmts.get(i)
                let s = self.stmt_pool.get(s_idx)
                if s.kind == StmtKind.sk_import {
                    // check for "import X from Y" — alias is set for named imports
                    if length(s.import_alias) > 0 {
                        self.imported_names.push(s.import_alias)
                        self.import_used.push(false)
                        self.import_lines.push(s.line)
                        self.import_cols.push(s.col)
                    }
                }
                i = i + 1
            }
        }
    }

    fn register_struct_info(self, top_stmt_idx: Int) {
        let stmt = self.stmt_pool.get(top_stmt_idx)
        if stmt.kind == StmtKind.sk_block {
            var i = 0
            while i < stmt.block_stmts.length() {
                let s_idx = stmt.block_stmts.get(i)
                let s = self.stmt_pool.get(s_idx)
                if s.kind == StmtKind.sk_impl_block {
                    var has_drop = false
                    var j = 0
                    while j < s.impl_methods.length() {
                        let m_idx = s.impl_methods.get(j)
                        let m = self.stmt_pool.get(m_idx)
                        if m.func_name == "drop" {
                            has_drop = true
                        }
                        j = j + 1
                    }
                    self.struct_info.push(StructInfo(name: s.impl_struct_name, has_drop: has_drop))
                }
                i = i + 1
            }
        }
    }

    fn has_drop_method(self, type_name: Str) -> Bool {
        var clean_type = type_name
        if length(type_name) > 4 && substring(type_name, 0, 4) == "own " {
            clean_type = substring(type_name, 4, length(type_name))
        }
        if length(clean_type) > 0 && (clean_type[0] == Char(38) || clean_type[0] == Char(42) || clean_type[0] == Char(63)) {
            return false
        }
        var i = 0
        while i < self.struct_info.length() {
            let info = self.struct_info.get(i)
            if info.name == clean_type {
                return info.has_drop
            }
            i = i + 1
        }
        return false
    }

    fn collect_block_drops(self, stmt_idx: Int) {
        if self.current_table_idx < 0 { return }
        let table = self.symbol_tables.get(self.current_table_idx)
        var drop_vars = ArrayList<DropVarEntry>(self.allocator)
        
        var i = table.entries.length() - 1
        while i >= 0 {
            let sym = table.entries.get(i)
            if (sym.kind == "var" || sym.kind == "param") && !sym.moved && !sym.freed {
                let base_type = sym.type_name
                if self.has_drop_method(base_type) {
                    drop_vars.push(DropVarEntry(name: sym.name, base_type: base_type))
                }
            }
            i = i - 1
        }
        
        var block_stmt = self.stmt_pool.get(stmt_idx)
        block_stmt.block_drop_vars = drop_vars
        self.stmt_pool.set(stmt_idx, block_stmt)
    }

    fn is_integer_type(self, type_name: Str) -> Bool {
        if type_name == "Int"    { return true }
        if type_name == "i8"     { return true }
        if type_name == "i16"    { return true }
        if type_name == "i32"    { return true }
        if type_name == "i64"    { return true }
        if type_name == "u8"     { return true }
        if type_name == "u16"    { return true }
        if type_name == "u32"    { return true }
        if type_name == "u64"    { return true }
        if type_name == "usize"  { return true }
        if type_name == "isize"  { return true }
        return false
    }

    fn is_numeric_type(self, type_name: Str) -> Bool {
        if self.is_integer_type(type_name) { return true }
        if type_name == "Float" { return true }
        return false
    }

    fn is_builtin_type(self, name: Str) -> Bool {
        return name == "Int" || name == "Float" || name == "Bool" || name == "Char" || name == "Str" || name == "Void" || name == "NoneType" || name == "usize"
    }

    fn is_struct_type(self, name: Str) -> Bool {
        if name == "ArrayList" || name == "HashMap" || name == "StringBuilder" { return true }
        var i = 0
        while i < self.stmt_pool.length() {
            let s = self.stmt_pool.get(i)
            if s.kind == StmtKind.sk_struct_decl && s.struct_name == name { return true }
            i = i + 1
        }
        return false
    }

    fn is_standard_c_func(self, name: Str) -> Bool {
        if name == "malloc" || name == "realloc" || name == "calloc" { return true }
        if name == "printf" || name == "fprintf" || name == "sprintf" || name == "snprintf" { return true }
        if name == "fopen" || name == "fread" || name == "fwrite" || name == "fclose" || name == "fseek" || name == "ftell" || name == "rewind" { return true }
        if name == "strlen" || name == "strcmp" { return true }
        if name == "exit" || name == "system" { return true }
        if name == "isdigit" || name == "isalpha" || name == "isalnum" || name == "isspace" { return true }
        if name == "toupper" || name == "tolower" { return true }
        if name == "atoll" { return true }
        if name == "sqrt" { return true }
        if name == "memset" || name == "memcpy" || name == "memmove" { return true }
        if name == "abort" { return true }
        return false
    }

    fn fits_in_type(self, val: Int, type_name: Str) -> Bool {
        if type_name == "i8"    { return val >= -128 && val <= 127 }
        if type_name == "i16"   { return val >= -32768 && val <= 32767 }
        if type_name == "i32"   { return val >= -2147483648 && val <= 2147483647 }
        if type_name == "u8"    { return val >= 0 && val <= 255 }
        if type_name == "u16"   { return val >= 0 && val <= 65535 }
        if type_name == "u32"   { return val >= 0 && val <= 4294967295 }
        if type_name == "u64"   { return val >= 0 }
        if type_name == "Int" || type_name == "i64" || type_name == "isize" { return true }
        if type_name == "usize" { return val >= 0 }
        return true
    }

    fn is_integer_literal(self, expr_idx: Int) -> Bool {
        if expr_idx < 0 { return false }
        let expr = self.expr_pool.get(expr_idx)
        return expr.kind == ExprKind.ek_literal && expr.lit_vkind == "INT"
    }

    fn int_literal_value(self, expr: ExprNode) -> Int {
        match expr.lit_value {
            case .tv_int(v) => { return v }
            case .tv_str(v) => {
                // ponytail: legacy tv_str fallback, kept for bootstrap transition safety
                let sval = self.pool.get(v)
                let len = length(sval)
                var res = 0
                var pos = 0
                while pos < len {
                    let digit = substring(sval, pos, pos + 1)
                    if digit == "1" { res = res * 10 + 1 }
                    else if digit == "2" { res = res * 10 + 2 }
                    else if digit == "3" { res = res * 10 + 3 }
                    else if digit == "4" { res = res * 10 + 4 }
                    else if digit == "5" { res = res * 10 + 5 }
                    else if digit == "6" { res = res * 10 + 6 }
                    else if digit == "7" { res = res * 10 + 7 }
                    else if digit == "8" { res = res * 10 + 8 }
                    else if digit == "9" { res = res * 10 + 9 }
                    else { res = res * 10 }
                    pos = pos + 1
                }
                return res
            }
            case else => { return 0 }
        }
    }

    fn is_copy_type(self, type_name: Str) -> Bool {
        if self.is_integer_type(type_name) { return true }
        if type_name == "Float" { return true }
        if type_name == "Bool" { return true }
        if type_name == "Char" { return true }
        if type_name == "Str" { return true }
        if type_name == "Void" { return true }
        if type_name == "NoneType" { return true }
        if length(type_name) > 0 && (type_name[0] == Char(42) || type_name[0] == Char(38)) {
            return true
        }
        return false
    }

    fn parse_ptr_ref(self, type_str: Str) -> PtrRefResult {
        var is_ptr = false
        var is_mut = false
        var inner = type_str
        if length(inner) > 0 && inner[0] == Char(63) {
            inner = substring(inner, 1, length(inner))
        }
        if length(inner) > 5 && substring(inner, 0, 5) == "*mut " {
            is_ptr = true
            is_mut = true
            inner = substring(inner, 5, length(inner))
        } else if length(inner) > 1 && inner[0] == Char(42) {
            is_ptr = true
            inner = substring(inner, 1, length(inner))
        } else if length(inner) > 5 && substring(inner, 0, 5) == "&mut " {
            is_ptr = true
            is_mut = true
            inner = substring(inner, 5, length(inner))
        } else if length(inner) > 1 && inner[0] == Char(38) {
            is_ptr = true
            inner = substring(inner, 1, length(inner))
        }
        return PtrRefResult(is_ptr: is_ptr, is_mut: is_mut, inner: inner)
    }

    fn types_compatible(self, target: Str, source: Str) -> Bool {
        var t = target
        var s = source
        if length(t) > 4 && substring(t, 0, 4) == "own " {
            t = substring(t, 4, length(t))
        }
        if length(s) > 4 && substring(s, 0, 4) == "own " {
            s = substring(s, 4, length(s))
        }
        if t == "Void" || s == "Void" {
            return true
        }
        if t == s {
            return true
        }
        if length(t) > 0 && t[0] == Char(40) && length(s) > 0 && s[0] == Char(40) {
            // Extract comma-separated types from both tuples
            let t_inner = t[1..length(t) - 1]
            var t_list = ArrayList<Str>(self.allocator)
            var start = 0
            var i = 0
            while i < length(t_inner) {
                if t_inner[i] == Char(44) {
                    var ts_start = start
                    while ts_start < i && t_inner[ts_start] == Char(32) { ts_start = ts_start + 1 }
                    var ts_end = i
                    while ts_end > ts_start && t_inner[ts_end - 1] == Char(32) { ts_end = ts_end - 1 }
                    t_list.push(t_inner[ts_start..ts_end])
                    start = i + 1
                }
                i = i + 1
            }
            var ts_start = start
            while ts_start < length(t_inner) && t_inner[ts_start] == Char(32) { ts_start = ts_start + 1 }
            var ts_end = length(t_inner)
            while ts_end > ts_start && t_inner[ts_end - 1] == Char(32) { ts_end = ts_end - 1 }
            t_list.push(t_inner[ts_start..ts_end])

            let s_inner = s[1..length(s) - 1]
            var s_list = ArrayList<Str>(self.allocator)
            start = 0
            i = 0
            while i < length(s_inner) {
                if s_inner[i] == Char(44) {
                    var ts_start = start
                    while ts_start < i && s_inner[ts_start] == Char(32) { ts_start = ts_start + 1 }
                    var ts_end = i
                    while ts_end > ts_start && s_inner[ts_end - 1] == Char(32) { ts_end = ts_end - 1 }
                    s_list.push(s_inner[ts_start..ts_end])
                    start = i + 1
                }
                i = i + 1
            }
            ts_start = start
            while ts_start < length(s_inner) && s_inner[ts_start] == Char(32) { ts_start = ts_start + 1 }
            ts_end = length(s_inner)
            while ts_end > ts_start && s_inner[ts_end - 1] == Char(32) { ts_end = ts_end - 1 }
            s_list.push(s_inner[ts_start..ts_end])

            if t_list.length() != s_list.length() {
                return false
            }
            var ti = 0
            while ti < t_list.length() {
                if !self.types_compatible(t_list.get(ti), s_list.get(ti)) {
                    return false
                }
                ti = ti + 1
            }
            return true
        }
        // Integer types are fully explicit — no implicit cross-type coercion
        if self.is_integer_type(t) && self.is_integer_type(s) {
            return false
        }
        if (t == "Str" && (s == "*Char" || s == "*Void")) || ((t == "*Char" || t == "*Void") && s == "Str") {
            return true
        }
        if length(t) > 0 && t[0] == Char(63) {
            if s == "NoneType" {
                return true
            }
            let t_inner = substring(t, 1, length(t))
            var s_inner = s
            if length(s) > 0 && s[0] == Char(63) {
                s_inner = substring(s, 1, length(s))
            }
            return self.types_compatible(t_inner, s_inner)
        }
        var excl_t = -1
        var i = 0
        while i < length(t) {
            if t[i] == Char(33) {
                excl_t = i
            }
            i = i + 1
        }
        if excl_t >= 0 {
            let target_val = substring(t, 0, excl_t)
            let target_err = substring(t, excl_t + 1, length(t))
            var excl_s = -1
            i = 0
            while i < length(s) {
                if s[i] == Char(33) {
                    excl_s = i
                }
                i = i + 1
            }
            if excl_s >= 0 {
                let source_val = substring(s, 0, excl_s)
                let source_err = substring(s, excl_s + 1, length(s))
                return self.types_compatible(target_val, source_val) && self.types_compatible(target_err, source_err)
            }
            if self.types_compatible(target_val, s) {
                return true
            }
            if s == target_err {
                return true
            }
        }
        // []T and *T are compatible — both are thin pointers (T*) in C
        let t_is_slice = length(t) >= 2 && t[0..2] == "[]"
        let s_is_slice = length(s) >= 2 && s[0..2] == "[]"
        if t_is_slice || s_is_slice {
            var t_inner = t
            if t_is_slice {
                t_inner = t[2..length(t)]
            } else if length(t) > 0 && t[0] == Char(42) {
                t_inner = t[1..length(t)]
            }
            var s_inner = s
            if s_is_slice {
                s_inner = s[2..length(s)]
            } else if length(s) > 0 && s[0] == Char(42) {
                s_inner = s[1..length(s)]
            }
            return self.types_compatible(t_inner, s_inner)
        }
        let t_ptr = self.parse_ptr_ref(t)
        let s_ptr = self.parse_ptr_ref(s)
        if t_ptr.is_ptr != s_ptr.is_ptr {
            return false
        }
        if t_ptr.is_ptr {
            if !s_ptr.is_mut && t_ptr.is_mut {
                return false
            }
            return self.types_compatible(t_ptr.inner, s_ptr.inner)
        }
        return false
    }

    fn find_func_decl(self, name: Str) -> Int {
        var idx = 0
        while idx < self.stmt_pool.length() {
            let stmt = self.stmt_pool.get(idx)
            if stmt.kind == StmtKind.sk_func_decl && stmt.func_name == name {
                if stmt.func_params.length() > 0 && stmt.func_params.get(0).ptype == "self" {
                    idx = idx + 1
                    continue
                }
                return idx
            }
            if stmt.kind == StmtKind.sk_extern && stmt.extern_name == name {
                return idx
            }
            idx = idx + 1
        }
        return -1
    }

    fn find_method_decl(self, struct_name: Str, meth_name: Str) -> Int {
        var clean_struct = struct_name
        var i = 0
        var clean = ""
        while i < length(clean_struct) {
            let c = clean_struct[i]
            if c != Char(42) && c != Char(38) {
                clean = clean + char_to_str(c)
            }
            i = i + 1
        }
        clean_struct = clean
        if length(clean_struct) > 4 && substring(clean_struct, 0, 4) == "mut " {
            clean_struct = substring(clean_struct, 4, length(clean_struct))
        }
        var lt_pos = -1
        i = 0
        while i < length(clean_struct) {
            if clean_struct[i] == Char(60) {
                lt_pos = i
            }
            i = i + 1
        }
        if lt_pos >= 0 {
            clean_struct = substring(clean_struct, 0, lt_pos)
        }
        var idx = 0
        while idx < self.stmt_pool.length() {
            let stmt = self.stmt_pool.get(idx)
            if stmt.kind == StmtKind.sk_impl_block {
                var impl_name = stmt.impl_struct_name
                var impl_lt = -1
                var j = 0
                while j < length(impl_name) {
                    if impl_name[j] == Char(60) {
                        impl_lt = j
                    }
                    j = j + 1
                }
                if impl_lt >= 0 {
                    impl_name = substring(impl_name, 0, impl_lt)
                }
                if impl_name == clean_struct {
                    var mi = 0
                    while mi < stmt.impl_methods.length() {
                        let m_idx = stmt.impl_methods.get(mi)
                        let m = self.stmt_pool.get(m_idx)
                        if m.func_name == meth_name {
                            return m_idx
                        }
                        mi = mi + 1
                    }
                }
            }
            idx = idx + 1
        }
        return -1
    }

    fn find_struct_decl(self, name: Str) -> Int {
        var idx = 0
        while idx < self.stmt_pool.length() {
            let stmt = self.stmt_pool.get(idx)
            if stmt.kind == StmtKind.sk_struct_decl && stmt.struct_name == name {
                return idx
            }
            idx = idx + 1
        }
        return -1
    }

    fn find_enum_decl(self, name: Str) -> Int {
        var idx = 0
        while idx < self.stmt_pool.length() {
            let stmt = self.stmt_pool.get(idx)
            if stmt.kind == StmtKind.sk_enum_decl && stmt.enum_name == name {
                return idx
            }
            idx = idx + 1
        }
        return -1
    }

    fn get_block_yield_type(self, stmt_idx: Int) -> Str {
        if stmt_idx < 0 { return "Void" }
        let stmt = self.stmt_pool.get(stmt_idx)
        if stmt.kind == StmtKind.sk_block {
            if stmt.block_stmts.length() == 0 {
                return "Void"
            }
            let last_idx = stmt.block_stmts.get(stmt.block_stmts.length() - 1)
            let last_stmt = self.stmt_pool.get(last_idx)
            if last_stmt.kind == StmtKind.sk_expr {
                return self.get_expr_type(last_stmt.expr_stmt)
            }
            if last_stmt.kind == StmtKind.sk_return {
                return "Void"
            }
        }
        if stmt.kind == StmtKind.sk_expr {
            return self.get_expr_type(stmt.expr_stmt)
        }
        return "Void"
    }

    fn mark_expr_moved(self, expr_idx: Int) {
        if expr_idx < 0 { return }
        // Walk through as casts and field-access wrappers to find the underlying identifier.
        // Borrow (&) is NOT peeled — borrowing creates a reference without transferring ownership.
        var inner = expr_idx
        var done = false
        while !done {
            let e = self.expr_pool.get(inner)
            if e.kind == ExprKind.ek_func_call && e.func_name == "as" && e.func_args.length() >= 1 {
                inner = e.func_args.get(0)
            } else if e.kind == ExprKind.ek_field_access {
                inner = e.field_expr
            } else {
                done = true
            }
        }
        let expr = self.expr_pool.get(inner)
        if expr.kind == ExprKind.ek_identifier {
            let t = self.get_expr_type(inner)
            if !self.is_copy_type(t) {
                var table = self.symbol_tables.get(self.current_table_idx)
                table.mark_moved(expr.ident_name, &self.symbol_tables)
                self.symbol_tables.set(self.current_table_idx, table)
            }
        }
    }

    fn mark_expr_freed(self, expr_idx: Int) {
        if expr_idx < 0 { return }
        // Walk through cast and field-access wrappers to find the root identifier
        var inner = expr_idx
        var done = false
        while !done {
            let e = self.expr_pool.get(inner)
            if e.kind == ExprKind.ek_func_call && e.func_name == "as" && e.func_args.length() >= 1 {
                inner = e.func_args.get(0)
            } else if e.kind == ExprKind.ek_field_access {
                inner = e.field_expr
            } else {
                done = true
            }
        }
        let expr = self.expr_pool.get(inner)
        if expr.kind == ExprKind.ek_identifier {
            var table = self.symbol_tables.get(self.current_table_idx)
            let sym = table.lookup_symbol(expr.ident_name, &self.symbol_tables)
            if length(sym.name) > 0 {
                if sym.freed {
                    self.err("E0032", "double-free: '" + expr.ident_name + "' is already freed", expr.line, expr.col)
                    return
                }
                if sym.moved {
                    self.err("E0009", "use of moved value: '" + expr.ident_name + "'", expr.line, expr.col)
                    return
                }
                table.mark_freed(expr.ident_name, &self.symbol_tables)
                self.symbol_tables.set(self.current_table_idx, table)
            }
        }
    }

    // ── Tracking state snapshot/restore/merge for branch & loop handling ──
    // These functions let us isolate tracking state between if/else branches,
    // match arms, and loop iterations, then merge results conservatively (OR).

    fn capture_tracking_state(self) -> ArrayList<SymTrackState> {
        let result = ArrayList<SymTrackState>(self.allocator)
        var tidx = self.current_table_idx
        while tidx >= 0 {
            let table = self.symbol_tables.get(tidx)
            var i = 0
            while i < table.entries.length() {
                let sym = table.entries.get(i)
                result.push(SymTrackState(
                    name: sym.name,
                    table_idx: tidx,
                    entry_idx: i,
                    moved: sym.moved,
                    freed: sym.freed
                ))
                i = i + 1
            }
            tidx = table.parent_idx
        }
        return result
    }

    fn restore_tracking_state(self, state: ArrayList<SymTrackState>) {
        var i = 0
        while i < state.length() {
            let s = state.get(i)
            if s.table_idx >= 0 && s.table_idx < self.symbol_tables.length() {
                var table = self.symbol_tables.get(s.table_idx)
                if s.entry_idx >= 0 && s.entry_idx < table.entries.length() {
                    var sym = table.entries.get(s.entry_idx)
                    sym.moved = s.moved
                    sym.freed = s.freed
                    table.entries.set(s.entry_idx, sym)
                    self.symbol_tables.set(s.table_idx, table)
                }
            }
            i = i + 1
        }
    }

    fn merge_and_apply_tracking_state(self, states: ArrayList<ArrayList<SymTrackState>>) {
        // For each unique (table_idx, entry_idx), OR the moved/freed flags across all states.
        let merged = ArrayList<SymTrackState>(self.allocator)
        var si = 0
        while si < states.length() {
            let state = states.get(si)
            var ei = 0
            while ei < state.length() {
                let s = state.get(ei)
                // Check if we already have an entry for this (table_idx, entry_idx)
                var found = false
                var mi = 0
                while mi < merged.length() {
                    let m = merged.get(mi)
                    if m.table_idx == s.table_idx && m.entry_idx == s.entry_idx {
                        // OR the flags
                        var updated = m
                        if s.moved { updated.moved = true }
                        if s.freed { updated.freed = true }
                        merged.set(mi, updated)
                        found = true
                        break
                    }
                    mi = mi + 1
                }
                if !found {
                    merged.push(s)
                }
                ei = ei + 1
            }
            si = si + 1
        }
        // Apply merged state directly
        var i = 0
        while i < merged.length() {
            let s = merged.get(i)
            if s.table_idx >= 0 && s.table_idx < self.symbol_tables.length() {
                var table = self.symbol_tables.get(s.table_idx)
                if s.entry_idx >= 0 && s.entry_idx < table.entries.length() {
                    var sym = table.entries.get(s.entry_idx)
                    sym.moved = s.moved
                    sym.freed = s.freed
                    table.entries.set(s.entry_idx, sym)
                    self.symbol_tables.set(s.table_idx, table)
                }
            }
            i = i + 1
        }
    }

    fn get_expr_type(self, expr_idx: Int) -> Str {
        if expr_idx < 0 { return "Void" }
        let expr = self.expr_pool.get(expr_idx)
        if expr.kind == ExprKind.ek_literal {
            let vkind = expr.lit_vkind
            if vkind == "INT" { return "Int" }
            if vkind == "FLOAT" { return "Float" }
            if vkind == "STRING" { return "Str" }
            if vkind == "BOOL" { return "Bool" }
            if vkind == "CHAR" { return "Char" }
            return "Void"
        }
        if expr.kind == ExprKind.ek_identifier {
            let name = expr.ident_name
            let table = self.symbol_tables.get(self.current_table_idx)
            let sym = table.lookup_symbol(name, &self.symbol_tables)
            if length(sym.name) > 0 {
                return sym.type_name
            }
            return "Void"
        }
        if expr.kind == ExprKind.ek_binary_op {
            let op = expr.binop_op
            if op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" || op == "&&" || op == "||" {
                return "Bool"
            }
            return self.get_expr_type(expr.binop_left)
        }
        if expr.kind == ExprKind.ek_unary_op {
            let op = expr.unop_op
            if op == "!" {
                return "Bool"
            }
            return self.get_expr_type(expr.unop_operand)
        }
        if expr.kind == ExprKind.ek_func_call {
            let name = expr.func_name
            if name == "cast" || name == "as" {
                return expr.func_type_args.get(0)
            }
            if name == "size_of" {
                return "usize"
            }
            if name == "Char" || name == "Int" || name == "Float" || name == "Bool" {
                return name
            }
            var is_struct = false
            var s_idx = 0
            while s_idx < self.stmt_pool.length() {
                let stmt = self.stmt_pool.get(s_idx)
                if stmt.kind == StmtKind.sk_struct_decl && stmt.struct_name == name {
                    is_struct = true
                }
                s_idx = s_idx + 1
            }
            if name == "ArrayList" || name == "HashMap" || name == "StringBuilder" {
                is_struct = true
            }
            if is_struct {
                if expr.func_type_args.length() > 0 {
                    return "*" + name + "<" + str_array_join(expr.func_type_args, ", ") + ">"
                }
                return "*" + name
            }
            let func_idx = self.find_func_decl(name)
            if func_idx >= 0 {
                let decl = self.stmt_pool.get(func_idx)
                if decl.kind == StmtKind.sk_func_decl {
                    return decl.func_return_type
                }
                if decl.kind == StmtKind.sk_extern {
                    return decl.extern_return
                }
            }
            let table = self.symbol_tables.get(self.current_table_idx)
            let sym = table.lookup_symbol(name, &self.symbol_tables)
            if length(sym.name) > 0 {
                return sym.type_name
            }
            return "Void"
        }
        if expr.kind == ExprKind.ek_field_access {
            let base_node = self.expr_pool.get(expr.field_expr)
            if base_node.kind == ExprKind.ek_identifier {
                var is_static = false
                var s_idx = 0
                while s_idx < self.stmt_pool.length() {
                    let stmt = self.stmt_pool.get(s_idx)
                    if (stmt.kind == StmtKind.sk_enum_decl && stmt.enum_name == base_node.ident_name) || (stmt.kind == StmtKind.sk_error_decl && stmt.error_name == base_node.ident_name) {
                        is_static = true
                    }
                    s_idx = s_idx + 1
                }
                if is_static {
                    return base_node.ident_name
                }
            }
            let base_type = self.get_expr_type(expr.field_expr)
            if length(base_type) > 0 && base_type[0] == Char(40) { // starts with '(' (tuple type)
                let field_name = expr.field_name
                if length(field_name) > 1 && field_name[0] == Char(102) { // starts with 'f'
                    // Parse index
                    var idx_val = 0
                    var fi = 1
                    var valid = true
                    while fi < length(field_name) {
                        let c = field_name[fi]
                        if c >= Char(48) && c <= Char(57) {
                            idx_val = idx_val * 10 + (Int(c) - 48)
                        } else {
                            valid = false
                        }
                        fi = fi + 1
                    }
                    if valid {
                        // Extract comma-separated types from tuple
                        let inner_types = base_type[1..length(base_type) - 1]
                        var types_list = ArrayList<Str>(self.allocator)
                        var start = 0
                        var i = 0
                        while i < length(inner_types) {
                            if inner_types[i] == Char(44) {
                                // Trim spaces
                                var ts_start = start
                                while ts_start < i && inner_types[ts_start] == Char(32) { ts_start = ts_start + 1 }
                                var ts_end = i
                                while ts_end > ts_start && inner_types[ts_end - 1] == Char(32) { ts_end = ts_end - 1 }
                                types_list.push(inner_types[ts_start..ts_end])
                                start = i + 1
                            }
                            i = i + 1
                        }
                        var ts_start = start
                        while ts_start < length(inner_types) && inner_types[ts_start] == Char(32) { ts_start = ts_start + 1 }
                        var ts_end = length(inner_types)
                        while ts_end > ts_start && inner_types[ts_end - 1] == Char(32) { ts_end = ts_end - 1 }
                        types_list.push(inner_types[ts_start..ts_end])

                        if idx_val < types_list.length() {
                            return types_list.get(idx_val)
                        }
                    }
                }
            }
            var clean_type = ""
            var i = 0
            while i < length(base_type) {
                let c = base_type[i]
                if c != Char(42) && c != Char(38) {
                    clean_type = clean_type + char_to_str(c)
                }
                i = i + 1
            }
            if length(clean_type) > 4 && substring(clean_type, 0, 4) == "mut " {
                clean_type = substring(clean_type, 4, length(clean_type))
            }
            var s_idx = 0
            while s_idx < self.stmt_pool.length() {
                let stmt = self.stmt_pool.get(s_idx)
                if stmt.kind == StmtKind.sk_struct_decl {
                    if stmt.struct_name == clean_type {
                        var f_idx = 0
                        while f_idx < stmt.struct_fields.length() {
                            let f = stmt.struct_fields.get(f_idx)
                            if f.name == expr.field_name {
                                return f.ftype
                            }
                            f_idx = f_idx + 1
                        }
                    }
                }
                s_idx = s_idx + 1
            }
            return "Void"
        }
        if expr.kind == ExprKind.ek_index {
            let base_type = self.get_expr_type(expr.idx_expr)
            if base_type == "Str" {
                return "Char"
            }
            if length(base_type) > 0 && base_type[0] == Char(42) {
                return substring(base_type, 1, length(base_type))
            }
            return "Void"
        }
        if expr.kind == ExprKind.ek_slice {
            return self.get_expr_type(expr.slice_expr)
        }
        if expr.kind == ExprKind.ek_range {
            return "Range"
        }
        if expr.kind == ExprKind.ek_borrow {
            let base_type = self.get_expr_type(expr.borrow_expr)
            if self.expr_is_mutable(expr.borrow_expr) {
                return "*mut " + base_type
            }
            return "*" + base_type
        }
        if expr.kind == ExprKind.ek_deref {
            let base_type = self.get_expr_type(expr.deref_expr)
            if length(base_type) > 5 && substring(base_type, 0, 5) == "*mut " {
                return substring(base_type, 5, length(base_type))
            }
            if length(base_type) > 5 && substring(base_type, 0, 5) == "&mut " {
                return substring(base_type, 5, length(base_type))
            }
            if length(base_type) > 0 && (base_type[0] == Char(42) || base_type[0] == Char(38)) {
                return substring(base_type, 1, length(base_type))
            }
            return "Void"
        }
        if expr.kind == ExprKind.ek_struct_init {
            let sname = expr.struct_name
            var dot_pos = -1
            var j = 0
            while j < length(sname) {
                if sname[j] == Char(46) {
                    dot_pos = j
                    break
                }
                j = j + 1
            }
            if dot_pos >= 0 {
                return substring(sname, 0, dot_pos)
            }
            return sname
        }
        if expr.kind == ExprKind.ek_method_call {
            let recv_type = self.get_expr_type(expr.meth_expr)
            var clean = ""
            var i = 0
            while i < length(recv_type) {
                let c = recv_type[i]
                if c != Char(42) && c != Char(38) {
                    clean = clean + char_to_str(c)
                }
                i = i + 1
            }
            if length(clean) > 4 && substring(clean, 0, 4) == "mut " {
                clean = substring(clean, 4, length(clean))
            }
            var lt_pos = -1
            i = 0
            while i < length(clean) {
                if clean[i] == Char(60) { lt_pos = i }
                i = i + 1
            }
            if lt_pos >= 0 {
                clean = substring(clean, 0, lt_pos)
            }
            let m_idx = self.find_method_decl(recv_type, expr.meth_name)
            if m_idx >= 0 {
                let decl = self.stmt_pool.get(m_idx)
                let ret_type = decl.func_return_type
                // Resolve generic type params: if return type is a single uppercase letter (e.g. "T"),
                // extract the first concrete type arg from the receiver (e.g. "ArrayList<Stmt>" -> "Stmt")
                if length(ret_type) == 1 && ret_type[0] >= Char(65) && ret_type[0] <= Char(90) {
                    var gt_pos = -1
                    var gi = 0
                    while gi < length(recv_type) {
                        if recv_type[gi] == Char(60) { gt_pos = gi }
                        gi = gi + 1
                    }
                    if gt_pos >= 0 {
                        var end_pos = length(recv_type)
                        gi = gt_pos + 1
                        while gi < length(recv_type) {
                            if recv_type[gi] == Char(62) { end_pos = gi; gi = length(recv_type) }
                            gi = gi + 1
                        }
                        if end_pos > gt_pos + 1 {
                            let first_param = substring(recv_type, gt_pos + 1, end_pos)
                            return first_param
                        }
                    }
                    return "Void"
                }
                return ret_type
            }
            if self.is_imported_name(expr.meth_name) {
                self.mark_import_used(expr.meth_name)
            }
            return "Void"
        }
        if expr.kind == ExprKind.ek_try {
            let inner_ty = self.get_expr_type(expr.try_expr)
            var excl_pos = -1
            var i = 0
            while i < length(inner_ty) {
                if inner_ty[i] == Char(33) {
                    excl_pos = i
                }
                i = i + 1
            }
            if excl_pos >= 0 {
                return substring(inner_ty, 0, excl_pos)
            }
            return "Void"
        }
        if expr.kind == ExprKind.ek_catch {
            let inner_ty = self.get_expr_type(expr.catch_expr)
            if length(inner_ty) > 0 && inner_ty[0] == Char(63) {
                return substring(inner_ty, 1, length(inner_ty))
            }
            var excl_pos = -1
            var i = 0
            while i < length(inner_ty) {
                if inner_ty[i] == Char(33) {
                    excl_pos = i
                }
                i = i + 1
            }
            if excl_pos >= 0 {
                return substring(inner_ty, 0, excl_pos)
            }
            return "Void"
        }
        if expr.kind == ExprKind.ek_tuple {
            var types = ArrayList<Str>(self.allocator)
            var i = 0
            while i < expr.tup_elements.length() {
                types.push(self.get_expr_type(expr.tup_elements.get(i)))
                i = i + 1
            }
            return "(" + str_array_join(types, ", ") + ")"
        }
        return "Void"
    }

    fn expr_is_mutable(self, expr_idx: Int) -> Bool {
        if expr_idx < 0 { return false }
        let expr = self.expr_pool.get(expr_idx)
        if expr.kind == ExprKind.ek_identifier {
            let table = self.symbol_tables.get(self.current_table_idx)
            let sym = table.lookup_symbol(expr.ident_name, &self.symbol_tables)
            if length(sym.name) > 0 {
                return sym.is_mutable
            }
        }
        if expr.kind == ExprKind.ek_field_access {
            return self.expr_is_mutable(expr.field_expr)
        }
        if expr.kind == ExprKind.ek_deref {
            return true
        }
        return false
    }

    fn is_enum_or_error_type(self, name: Str) -> Bool {
        var idx = 0
        while idx < self.stmt_pool.length() {
            let stmt = self.stmt_pool.get(idx)
            if stmt.kind == StmtKind.sk_enum_decl && stmt.enum_name == name {
                return true
            }
            if stmt.kind == StmtKind.sk_error_decl && stmt.error_name == name {
                return true
            }
            idx = idx + 1
        }
        return false
    }

    fn is_imported_name(self, name: Str) -> Bool {
        var i = 0
        while i < self.imported_names.length() {
            if self.imported_names.get(i) == name {
                return true
            }
            i = i + 1
        }
        return false
    }

    fn mark_import_used(self, name: Str) {
        var i = 0
        while i < self.imported_names.length() {
            if self.imported_names.get(i) == name {
                self.import_used.set(i, true)
                return
            }
            i = i + 1
        }
    }

    fn check_identifier(self, expr_idx: Int) {
        var expr = self.expr_pool.get(expr_idx)
        let name = expr.ident_name
        let table = self.symbol_tables.get(self.current_table_idx)
        let sym = table.lookup_symbol(name, &self.symbol_tables)
        if length(sym.name) > 0 {
            if sym.freed {
                self.err("E0031", "use of freed value: '" + name + "'", expr.line, expr.col)
            } else if sym.moved {
                self.err("E0009", "use of moved value: '" + name + "'", expr.line, expr.col)
            }
            expr.resolved_symbol_idx = sym.decl_stmt_idx
            self.expr_pool.set(expr_idx, expr)
        } else if !self.is_enum_or_error_type(name) && !self.is_builtin_type(name) && !self.is_imported_name(name) {
            self.err("E0019", "undefined identifier: '" + name + "'", expr.line, expr.col)
        }
        if self.is_imported_name(name) {
            self.mark_import_used(name)
        }
    }

    fn check_field_access(self, expr_idx: Int) {
        let expr = self.expr_pool.get(expr_idx)
        let recv_type = self.get_expr_type(expr.field_expr)
        if length(recv_type) > 0 && recv_type[0] == Char(63) { // '?' is 63
            self.err("E0011", "cannot access field '" + expr.field_name + "' on optional type '" + recv_type + "'. unwrap it first", expr.line, expr.col)
        }
    }

    fn check_method_call(self, expr_idx: Int) {
        let expr = self.expr_pool.get(expr_idx)
        let recv_type = self.get_expr_type(expr.meth_expr)
        if length(recv_type) > 0 && recv_type[0] == Char(63) {
            self.err("E0012", "cannot call method '" + expr.meth_name + "' on optional type '" + recv_type + "'. unwrap it first", expr.line, expr.col)
        }
    }

    fn check_return_stmt(self, stmt_idx: Int) -> Void {
        let stmt = self.stmt_pool.get(stmt_idx)
        var val_type = "Void"
        if stmt.return_value >= 0 {
            let expr = self.expr_pool.get(stmt.return_value)
            if expr.kind == ExprKind.ek_borrow {
                let borrowed = self.expr_pool.get(expr.borrow_expr)
                if borrowed.kind == ExprKind.ek_identifier {
                    let name = borrowed.ident_name
                    let table = self.symbol_tables.get(self.current_table_idx)
                    let sym = table.lookup_symbol(name, &self.symbol_tables)
                    if sym.kind == "var" || sym.kind == "param" {
                        self.err("E0010", "cannot return reference to local variable '" + name + "'", stmt.line, stmt.col)
                    }
                }
            }
            self.check_expr(stmt.return_value)
            self.mark_expr_moved(stmt.return_value)
            val_type = self.get_expr_type(stmt.return_value)
        }
        let expected_ret = self.current_func_ret_type
        if length(expected_ret) > 0 && expected_ret != "<infer>" {
            if !self.types_compatible(expected_ret, val_type) {
                self.err("E0007", "return type mismatch: expected '" + expected_ret + "', got '" + val_type + "'", stmt.line, stmt.col)
            }
        }
    }

    fn check_stmt(self, stmt_idx: Int) -> Void {
        if stmt_idx < 0 { return }
        let stmt = self.stmt_pool.get(stmt_idx)
        
        if stmt.kind == StmtKind.sk_block {
            self.enter_scope()
            var i = 0
            while i < stmt.block_stmts.length() {
                self.check_stmt(stmt.block_stmts.get(i))
                i = i + 1
            }
            // Temporarily apply deferred effects (from defer/errdefer) so that
            // collect_block_drops skips variables that will be freed by deferred code.
            var have_deferred = false
            var pre_drop_snapshot = ArrayList<SymTrackState>(self.allocator)
            if self.scope_deferred_counts.length() > 0 {
                let snap_cnt = self.scope_deferred_counts.get(self.scope_deferred_counts.length() - 1)
                if snap_cnt > 0 {
                    pre_drop_snapshot = self.capture_tracking_state()
                    // Reconstruct snapshots from flat structure
                    let total_sizes_idx = self.scope_deferred_sizes.length() - snap_cnt
                    var b = self.scope_deferred_flat.length()
                    var w = snap_cnt
                    while w > 0 {
                        let sz = self.scope_deferred_sizes.get(total_sizes_idx + w - 1)
                        b = b - sz
                        w = w - 1
                    }
                    let states = ArrayList<ArrayList<SymTrackState>>(self.allocator)
                    var si = 0
                    var fi = b
                    while si < snap_cnt {
                        let sz = self.scope_deferred_sizes.get(total_sizes_idx + si)
                        var snapshot = ArrayList<SymTrackState>(self.allocator)
                        var ei = 0
                        while ei < sz {
                            snapshot.push(self.scope_deferred_flat.get(fi))
                            fi = fi + 1
                            ei = ei + 1
                        }
                        states.push(snapshot)
                        si = si + 1
                    }
                    self.merge_and_apply_tracking_state(states)
                    have_deferred = true
                }
            }
            self.collect_block_drops(stmt_idx)
            if have_deferred {
                self.restore_tracking_state(pre_drop_snapshot)
            }
            self.exit_scope()
            return
        }
        
        if stmt.kind == StmtKind.sk_var_decl {
            self.check_expr(stmt.vardecl_value)
            let val_type = self.get_expr_type(stmt.vardecl_value)
            var var_type = stmt.vardecl_type
            if length(var_type) == 0 {
                var_type = val_type
            } else {
                if self.is_integer_type(var_type) && self.is_integer_literal(stmt.vardecl_value) {
                    let val_expr = self.expr_pool.get(stmt.vardecl_value)
                    let v = self.int_literal_value(val_expr)
                    if !self.fits_in_type(v, var_type) {
                        self.err("E0030", "integer literal " + int_to_str(v) + " does not fit in type '" + var_type + "'", stmt.line, stmt.col)
                    }
                } else if !self.types_compatible(var_type, val_type) {
                    self.err("E0001", "type mismatch in declaration of '" + stmt.vardecl_name + "': expected '" + var_type + "', got '" + val_type + "'", stmt.line, stmt.col)
                }
            }
            self.define_symbol(stmt.vardecl_name, var_type, stmt.vardecl_mut, "var", stmt_idx)
            // Conservative alias propagation: if the initializer is a non-copy-type
            // identifier (or as-cast thereof), copy its current moved/freed status
            // to the new variable.
            if stmt.vardecl_value >= 0 && !self.is_copy_type(var_type) {
                var src_expr = self.expr_pool.get(stmt.vardecl_value)
                var src_ident = stmt.vardecl_value
                var done = false
                while !done {
                    if src_expr.kind == ExprKind.ek_func_call && src_expr.func_name == "as" && src_expr.func_args.length() >= 1 {
                        src_ident = src_expr.func_args.get(0)
                        src_expr = self.expr_pool.get(src_ident)
                    } else {
                        done = true
                    }
                }
                if src_expr.kind == ExprKind.ek_identifier {
                    var table = self.symbol_tables.get(self.current_table_idx)
                    let src_sym = table.lookup_symbol(src_expr.ident_name, &self.symbol_tables)
                    if length(src_sym.name) > 0 {
                        if src_sym.freed {
                            table.mark_freed(stmt.vardecl_name, &self.symbol_tables)
                        } else if src_sym.moved {
                            table.mark_moved(stmt.vardecl_name, &self.symbol_tables)
                        }
                        self.symbol_tables.set(self.current_table_idx, table)
                    }
                }
            }
            self.mark_expr_moved(stmt.vardecl_value)
            return
        }
        
        if stmt.kind == StmtKind.sk_assignment {
            // Find root identifier of the assignment target and clear moved/freed flags,
            // because reassigning resurrects the variable (even if it was moved or freed)
            if stmt.assign_target >= 0 {
                var root = stmt.assign_target
                var done = false
                while !done {
                    let e = self.expr_pool.get(root)
                    if e.kind == ExprKind.ek_field_access {
                        root = e.field_expr
                    } else if e.kind == ExprKind.ek_deref {
                        root = e.deref_expr
                    } else {
                        done = true
                    }
                }
                let re = self.expr_pool.get(root)
                if re.kind == ExprKind.ek_identifier {
                    let tbl = self.symbol_tables.get(self.current_table_idx)
                    let rsym = tbl.lookup_symbol(re.ident_name, &self.symbol_tables)
                    if length(rsym.name) > 0 {
                        if rsym.moved {
                            tbl.clear_moved(re.ident_name, &self.symbol_tables)
                        }
                        if rsym.freed {
                            tbl.clear_freed(re.ident_name, &self.symbol_tables)
                        }
                        self.symbol_tables.set(self.current_table_idx, tbl)
                    }
                }
            }
            self.check_expr(stmt.assign_target)
            self.check_expr(stmt.assign_value)
            var target_type = "Void"
            if stmt.assign_target >= 0 {
                target_type = self.get_expr_type(stmt.assign_target)
                let target_expr = self.expr_pool.get(stmt.assign_target)
                if target_expr.kind == ExprKind.ek_identifier {
                    let table = self.symbol_tables.get(self.current_table_idx)
                    let sym = table.lookup_symbol(target_expr.ident_name, &self.symbol_tables)
                    if length(sym.name) > 0 {
                        if sym.freed {
                            self.err("E0031", "cannot assign to freed variable '" + target_expr.ident_name + "'", target_expr.line, target_expr.col)
                        } else if !sym.is_mutable {
                            self.err("E0008", "cannot assign to immutable variable '" + target_expr.ident_name + "'", target_expr.line, target_expr.col)
                        }
                    }
                }
            }
            let val_type = self.get_expr_type(stmt.assign_value)
            if self.is_integer_type(target_type) && self.is_integer_literal(stmt.assign_value) {
                let val_expr = self.expr_pool.get(stmt.assign_value)
                let v = self.int_literal_value(val_expr)
                if !self.fits_in_type(v, target_type) {
                    self.err("E0030", "integer literal " + int_to_str(v) + " does not fit in type '" + target_type + "'", stmt.line, stmt.col)
                }
            } else if !self.types_compatible(target_type, val_type) {
                var target_name = "<non-ident>"
                if stmt.assign_target >= 0 {
                    let target_expr = self.expr_pool.get(stmt.assign_target)
                    if target_expr.kind == ExprKind.ek_identifier {
                        target_name = target_expr.ident_name
                    }
                }
                self.err("E0002", "type mismatch in assignment to '" + target_name + "': expected '" + target_type + "', got '" + val_type + "'", stmt.line, stmt.col)
            }
            self.mark_expr_moved(stmt.assign_value)
            return
        }
        
        if stmt.kind == StmtKind.sk_func_decl {
            let old_ret = self.current_func_ret_type
            self.current_func_ret_type = stmt.func_return_type
            self.define_symbol(stmt.func_name, stmt.func_return_type, false, "func", stmt_idx)
            if stmt.func_type_params.length() > 0 {
                return
            }
            self.enter_scope()
            var i = 0
            while i < stmt.func_params.length() {
                let p = stmt.func_params.get(i)
                self.define_symbol(p.name, p.ptype, false, "param", stmt_idx)
                i = i + 1
            }
            self.check_stmt(stmt.func_body)
            // Infer effect annotations: detect which parameters were freed inside the body
            if stmt.func_type_params.length() == 0 && stmt.func_params.length() > 0 {
                var free_indices = ArrayList<Int>(self.allocator)
                var pi = 0
                while pi < stmt.func_params.length() {
                    let p = stmt.func_params.get(pi)
                    let table = self.symbol_tables.get(self.current_table_idx)
                    let sym = table.lookup_symbol(p.name, &self.symbol_tables)
                    if length(sym.name) > 0 && sym.freed {
                        free_indices.push(pi)
                    }
                    pi = pi + 1
                }
                if free_indices.length() > 0 {
                    var effect = FuncEffect(func_name: stmt.func_name, free_param_indices: free_indices)
                    self.func_effects.push(effect)
                }
            }
            self.exit_scope()
            self.current_func_ret_type = old_ret
            return
        }
        if stmt.kind == StmtKind.sk_trait_decl {
            return
        }
        
        if stmt.kind == StmtKind.sk_if {
            self.check_expr(stmt.if_cond)
            let cond_type = self.get_expr_type(stmt.if_cond)
            if cond_type != "Bool" && cond_type != "Void" {
                self.err("E0024", "if condition must be Bool, got '" + cond_type + "'", stmt.line, stmt.col)
            }
            // Snapshot tracking state, process then/else independently, merge (OR)
            let snapshot = self.capture_tracking_state()
            self.check_stmt(stmt.if_then)
            let then_state = self.capture_tracking_state()
            self.restore_tracking_state(snapshot)
            self.check_stmt(stmt.if_else)
            let else_state = self.capture_tracking_state()
            self.restore_tracking_state(snapshot)
            let states = ArrayList<ArrayList<SymTrackState>>(self.allocator)
            states.push(then_state)
            states.push(else_state)
            self.merge_and_apply_tracking_state(states)
            // ponytail: manual deinit — Kai has no destructors, so
            // tracking-state ArrayLists must be freed explicitly.
            // Note: after states.push(), the struct is copied (sharing the
            // data pointer), so deinit only through states, not originals.
            snapshot.deinit()
            var si2 = 0
            while si2 < states.length() { let s = states.get(si2); s.deinit(); si2 = si2 + 1 }
            states.deinit()
            return
        }
        
        if stmt.kind == StmtKind.sk_if_let {
            self.check_expr(stmt.iflet_expr)
            let opt_type = self.get_expr_type(stmt.iflet_expr)
            var unwrapped_type = opt_type
            if length(opt_type) > 0 && opt_type[0] == Char(63) {
                unwrapped_type = substring(opt_type, 1, length(opt_type))
            }
            // Snapshot tracking state before the if-let (the let-binding adds a new
            // scope for then-branch only; else-branch doesn't see it)
            let snapshot = self.capture_tracking_state()
            self.enter_scope()
            self.define_symbol(stmt.iflet_var, unwrapped_type, false, "var", stmt_idx)
            self.check_stmt(stmt.iflet_then)
            self.exit_scope()
            let then_state = self.capture_tracking_state()
            self.restore_tracking_state(snapshot)
            self.check_stmt(stmt.iflet_else)
            let else_state = self.capture_tracking_state()
            self.restore_tracking_state(snapshot)
            let states = ArrayList<ArrayList<SymTrackState>>(self.allocator)
            states.push(then_state)
            states.push(else_state)
            self.merge_and_apply_tracking_state(states)
            snapshot.deinit()
            var si2 = 0
            while si2 < states.length() { let s = states.get(si2); s.deinit(); si2 = si2 + 1 }
            states.deinit()
            return
        }
        
        if stmt.kind == StmtKind.sk_while {
            self.check_expr(stmt.while_cond)
            let cond_type = self.get_expr_type(stmt.while_cond)
            if cond_type != "Bool" && cond_type != "Void" {
                self.err("E0024", "while condition must be Bool, got '" + cond_type + "'", stmt.line, stmt.col)
            }
            self.loop_depth = self.loop_depth + 1
            self.check_stmt(stmt.while_body)
            self.loop_depth = self.loop_depth - 1
            return
        }
        if stmt.kind == StmtKind.sk_for {
            self.check_expr(stmt.for_start)
            self.check_expr(stmt.for_end)
            self.loop_depth = self.loop_depth + 1
            self.enter_scope()
            // Infer loop variable type from range start expression
            var iter_type = self.get_expr_type(stmt.for_start)
            if length(iter_type) == 0 || iter_type == "Void" {
                iter_type = "Int"
            }
            self.define_symbol(stmt.for_var, iter_type, false, "var", stmt_idx)
            self.check_stmt(stmt.for_body)
            self.exit_scope()
            self.loop_depth = self.loop_depth - 1
            return
        }
        
        if stmt.kind == StmtKind.sk_return {
            self.check_return_stmt(stmt_idx)
            return
        }
        
        if stmt.kind == StmtKind.sk_expr {
            self.check_expr(stmt.expr_stmt)
            return
        }
        
        if stmt.kind == StmtKind.sk_unsafe {
            self.check_stmt(stmt.unsafe_body)
            return
        }
        
        if stmt.kind == StmtKind.sk_match {
            self.check_expr(stmt.match_expr)
            // Snapshot tracking state before match, process each arm independently, merge (OR)
            let snapshot = self.capture_tracking_state()
            let arm_states = ArrayList<ArrayList<SymTrackState>>(self.allocator)
            var i = 0
            while i < stmt.match_cases.length() {
                self.restore_tracking_state(snapshot)
                let mc = stmt.match_cases.get(i)
                self.enter_scope()
                let pat = self.pattern_pool.get(mc.pattern)
                if pat.kind == PatternKind.pk_variant {
                    let expr_type = self.get_expr_type(stmt.match_expr)
                    let enum_idx = self.find_enum_decl(expr_type)
                    var found_variant = false
                    var matched_var = Variant(vname: "", params: empty_param_array())
                    if enum_idx != -1 {
                        let enum_stmt = self.stmt_pool.get(enum_idx)
                        var vi = 0
                        while vi < enum_stmt.enum_variants.length() {
                            let v = enum_stmt.enum_variants.get(vi)
                            var is_match = false
                            if v.vname == pat.variant_name {
                                is_match = true
                            } else {
                                let expected_suffix = "." + v.vname
                                let suffix_len = length(expected_suffix)
                                let pat_len = length(pat.variant_name)
                                if pat_len > suffix_len {
                                    let actual_suffix = substring(pat.variant_name, pat_len - suffix_len, pat_len)
                                    if actual_suffix == expected_suffix {
                                        is_match = true
                                    }
                                }
                            }
                            if is_match {
                                matched_var = v
                                found_variant = true
                                break
                            }
                            vi = vi + 1
                        }
                    }
                    var bi = 0
                    while bi < pat.bindings.length() {
                        var ptype = "Void"
                        if found_variant && bi < matched_var.params.length() {
                            ptype = matched_var.params.get(bi).ptype
                        }
                        self.define_symbol(pat.bindings.get(bi), ptype, false, "var", stmt_idx)
                        bi = bi + 1
                    }
                }
                self.check_stmt(mc.body)
                self.exit_scope()
                arm_states.push(self.capture_tracking_state())
                i = i + 1
            }
            self.restore_tracking_state(snapshot)
            if arm_states.length() > 0 {
                self.merge_and_apply_tracking_state(arm_states)
            }
            snapshot.deinit()
            var ai = 0
            while ai < arm_states.length() { let s = arm_states.get(ai); s.deinit(); ai = ai + 1 }
            arm_states.deinit()
            return
        }
        
        if stmt.kind == StmtKind.sk_impl_block {
            var i = 0
            while i < stmt.impl_methods.length() {
                let m_idx = stmt.impl_methods.get(i)
                let m = self.stmt_pool.get(m_idx)
                let mangled_name = stmt.impl_struct_name + "_" + m.func_name
                self.define_symbol(mangled_name, m.func_return_type, false, "func", m_idx)
                
                let old_ret = self.current_func_ret_type
                self.current_func_ret_type = m.func_return_type
                
                self.enter_scope()
                self.define_symbol("self", stmt.impl_struct_name, true, "param", m_idx)
                var pi = 1
                while pi < m.func_params.length() {
                    let p = m.func_params.get(pi)
                    self.define_symbol(p.name, p.ptype, false, "param", m_idx)
                    pi = pi + 1
                }
                self.check_stmt(m.func_body)
                self.exit_scope()
                self.current_func_ret_type = old_ret
                i = i + 1
            }
            return
        }
        if stmt.kind == StmtKind.sk_struct_decl {
            return
        }
        if stmt.kind == StmtKind.sk_enum_decl {
            return
        }
        if stmt.kind == StmtKind.sk_extern {
            self.define_symbol(stmt.extern_name, stmt.extern_return, false, "func", stmt_idx)
            return
        }
        if stmt.kind == StmtKind.sk_import {
            return
        }
        if stmt.kind == StmtKind.sk_cimport {
            // cimport creates a module namespace from the C header.
            // We skip symbol definition here because the imported C names
            // are not visible to the Kai type checker — they resolve at link time.
            return
        }
        if stmt.kind == StmtKind.sk_error_decl {
            return
        }
        if stmt.kind == StmtKind.sk_break {
            if self.loop_depth <= 0 {
                self.err("E0029", "'break' outside of loop", stmt.line, stmt.col)
            }
            return
        }
        if stmt.kind == StmtKind.sk_continue {
            if self.loop_depth <= 0 {
                self.err("E0029", "'continue' outside of loop", stmt.line, stmt.col)
            }
            return
        }
        if stmt.kind == StmtKind.sk_defer {
            // Snapshot, process defer body, capture its tracking effects, restore.
            // The captured effects are applied at scope exit (in exit_scope).
            let snapshot = self.capture_tracking_state()
            self.check_stmt(stmt.defer_body)
            if self.scope_deferred_counts.length() > 0 {
                let idx = self.scope_deferred_counts.length() - 1
                let post_state = self.capture_tracking_state()
                var ei = 0
                while ei < post_state.length() {
                    self.scope_deferred_flat.push(post_state.get(ei))
                    ei = ei + 1
                }
                self.scope_deferred_sizes.push(post_state.length())
                var count = self.scope_deferred_counts.get(idx)
                count = count + 1
                self.scope_deferred_counts.set(idx, count)
                post_state.deinit()
            }
            self.restore_tracking_state(snapshot)
            snapshot.deinit()
            return
        }
        if stmt.kind == StmtKind.sk_errdefer {
            let snapshot = self.capture_tracking_state()
            self.check_stmt(stmt.errdefer_body)
            if self.scope_deferred_counts.length() > 0 {
                let idx = self.scope_deferred_counts.length() - 1
                let post_state = self.capture_tracking_state()
                var ei = 0
                while ei < post_state.length() {
                    self.scope_deferred_flat.push(post_state.get(ei))
                    ei = ei + 1
                }
                self.scope_deferred_sizes.push(post_state.length())
                var count = self.scope_deferred_counts.get(idx)
                count = count + 1
                self.scope_deferred_counts.set(idx, count)
                post_state.deinit()
            }
            self.restore_tracking_state(snapshot)
            snapshot.deinit()
            return
        }
    }

    fn check_expr(self, expr_idx: Int) -> Void {
        if expr_idx < 0 { return }
        self.check_expr_inner(expr_idx)
        var expr = self.expr_pool.get(expr_idx)
        let ty_name = self.get_expr_type(expr_idx)
        expr.type_id = self.map_type_to_id(ty_name)
        self.expr_pool.set(expr_idx, expr)
    }

    fn check_expr_inner(self, expr_idx: Int) -> Void {
        if expr_idx < 0 { return }
        let expr = self.expr_pool.get(expr_idx)
        
        if expr.kind == ExprKind.ek_identifier {
            self.check_identifier(expr_idx)
                        return
        }
        if expr.kind == ExprKind.ek_binary_op {
            self.check_expr(expr.binop_left)
            self.check_expr(expr.binop_right)
            let left_type = self.get_expr_type(expr.binop_left)
            let right_type = self.get_expr_type(expr.binop_right)
            let op = expr.binop_op
            if op == "+" {
                if !self.is_numeric_type(left_type) && left_type != "Str" && left_type != "Void" {
                    self.err("E0025", "left operand of '+' must be numeric or Str, got '" + left_type + "'", expr.line, expr.col)
                }
                if !self.is_numeric_type(right_type) && right_type != "Str" && right_type != "Void" {
                    self.err("E0025", "right operand of '+' must be numeric or Str, got '" + right_type + "'", expr.line, expr.col)
                }
            } else if op == "-" || op == "*" || op == "/" || op == "%" {
                if !self.is_numeric_type(left_type) && left_type != "Void" {
                    self.err("E0025", "left operand of '" + op + "' must be numeric, got '" + left_type + "'", expr.line, expr.col)
                }
                if !self.is_numeric_type(right_type) && right_type != "Void" {
                    self.err("E0025", "right operand of '" + op + "' must be numeric, got '" + right_type + "'", expr.line, expr.col)
                }
            } else if op == "&&" || op == "||" {
                if left_type != "Bool" && left_type != "Void" {
                    self.err("E0025", "left operand of '" + op + "' must be Bool, got '" + left_type + "'", expr.line, expr.col)
                }
                if right_type != "Bool" && right_type != "Void" {
                    self.err("E0025", "right operand of '" + op + "' must be Bool, got '" + right_type + "'", expr.line, expr.col)
                }
            } else if op == "|" || op == "^" || op == "&" || op == "<<" || op == ">>" {
                if !self.is_integer_type(left_type) && left_type != "Void" {
                    self.err("E0025", "left operand of '" + op + "' must be an integer type, got '" + left_type + "'", expr.line, expr.col)
                }
                if !self.is_integer_type(right_type) && right_type != "Void" {
                    self.err("E0025", "right operand of '" + op + "' must be an integer type, got '" + right_type + "'", expr.line, expr.col)
                }
            } else if op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" {
                if left_type != "Void" && right_type != "Void" && !self.types_compatible(left_type, right_type) {
                    self.err("E0025", "type mismatch in comparison: '" + left_type + "' and '" + right_type + "' are not compatible", expr.line, expr.col)
                }
            }
                        return
        }
        if expr.kind == ExprKind.ek_unary_op {
            self.check_expr(expr.unop_operand)
            let operand_type = self.get_expr_type(expr.unop_operand)
            let binop = expr.unop_op
            if binop == "!" {
                if operand_type != "Bool" && operand_type != "Void" {
                    self.err("E0026", "operand of '!' must be Bool, got '" + operand_type + "'", expr.line, expr.col)
                }
            } else if binop == "-" {
                if !self.is_numeric_type(operand_type) && operand_type != "Void" {
                    self.err("E0026", "operand of negation must be numeric, got '" + operand_type + "'", expr.line, expr.col)
                }
            } else if binop == "~" {
                if !self.is_integer_type(operand_type) && operand_type != "Void" {
                    self.err("E0026", "operand of '~' must be an integer type, got '" + operand_type + "'", expr.line, expr.col)
                }
            }
                        return
        }
        if expr.kind == ExprKind.ek_func_call {
            let name = expr.func_name
            if name == "free" {
                var i = 0
                while i < expr.func_args.length() {
                    let arg = expr.func_args.get(i)
                    self.check_expr(arg)
                    i = i + 1
                }
                if expr.func_args.length() >= 1 {
                    self.mark_expr_freed(expr.func_args.get(0))
                }
                if self.is_imported_name(name) {
                    self.mark_import_used(name)
                }
            } else if name == "as" {
                var i = 0
                while i < expr.func_args.length() {
                    let arg = expr.func_args.get(i)
                    self.check_expr(arg)
                    i = i + 1
                }
            } else {
                // Pass 1: type-check all arguments
                var i = 0
                while i < expr.func_args.length() {
                    self.check_expr(expr.func_args.get(i))
                    i = i + 1
                }
                // Pass 2: apply tracking — check if the callee frees any arguments
                var free_set = ArrayList<Int>(self.allocator)
                var ei = 0
                while ei < self.func_effects.length() {
                    let eff = self.func_effects.get(ei)
                    if eff.func_name == name {
                        var fi = 0
                        while fi < eff.free_param_indices.length() {
                            free_set.push(eff.free_param_indices.get(fi))
                            fi = fi + 1
                        }
                    }
                    ei = ei + 1
                }
                i = 0
                while i < expr.func_args.length() {
                    var is_freed = false
                    var fi = 0
                    while fi < free_set.length() {
                        if free_set.get(fi) == i {
                            is_freed = true
                            break
                        }
                        fi = fi + 1
                    }
                    if is_freed {
                        self.mark_expr_freed(expr.func_args.get(i))
                    } else {
                        self.mark_expr_moved(expr.func_args.get(i))
                    }
                    i = i + 1
                }
            }
            if name == "cast" || name == "as" || name == "size_of" || name == "free" || name == "Char" || name == "Int" || name == "Float" || name == "Bool" || name == "printf" || name == "fprintf" || name == "sprintf" || name == "snprintf" {
                                return
            }
            let func_idx = self.find_func_decl(name)
            if func_idx >= 0 {
                let decl = self.stmt_pool.get(func_idx)
                var is_extern = decl.kind == StmtKind.sk_extern
                var params = decl.func_params
                var type_params = decl.func_type_params
                if is_extern {
                    params = decl.extern_params
                    type_params = empty_str_array()
                }
                if params.length() != expr.func_args.length() {
                    self.err("E0005", "argument count mismatch for function '" + name + "': expected " + int_to_str(params.length()) + ", got " + int_to_str(expr.func_args.length()), expr.line, expr.col)
                } else {
                    if type_params.length() > 0 {
                                                return
                    }
                    var arg_i = 0
                    while arg_i < expr.func_args.length() {
                        let arg = expr.func_args.get(arg_i)
                        let param = params.get(arg_i)
                        let arg_type = self.get_expr_type(arg)
                        let ptype = param.ptype
                        let is_generic_param = length(ptype) == 1 && ptype[0] >= Char(65) && ptype[0] <= Char(90)
                        if !is_generic_param && !self.types_compatible(ptype, arg_type) {
                            if self.is_integer_type(ptype) && self.is_integer_literal(arg) {
                                let v = self.int_literal_value(self.expr_pool.get(arg))
                                if !self.fits_in_type(v, ptype) {
                                    self.err("E0030", "integer literal " + int_to_str(v) + " does not fit in type '" + ptype + "'", expr.line, expr.col)
                                }
                            } else {
                                self.err("E0003", "argument type mismatch for function '" + name + "', parameter '" + param.name + "': expected '" + ptype + "', got '" + arg_type + "'", expr.line, expr.col)
                            }
                        }
                        arg_i = arg_i + 1
                    }
                }
            } else if !self.is_imported_name(name) && !self.is_standard_c_func(name) {
                if self.is_builtin_type(name) || self.is_struct_type(name) {
                    // Allowed as function call (e.g. Int(x), ArrayList_init(x))
                } else {
                    self.err("E0020", "undefined function: '" + name + "'", expr.line, expr.col)
                }
            }
            // Mark imported names as used when called as functions
            if self.is_imported_name(name) {
                self.mark_import_used(name)
            } else {
                // Check if any imported name is a prefix of this function (e.g. "KaiAllocator" for "KaiAllocator_new")
                var ui = 0
                while ui < self.imported_names.length() {
                    let iname = self.imported_names.get(ui)
                    if length(name) > length(iname) && name[0..length(iname)] == iname && name[length(iname)] == Char(95) {
                        self.mark_import_used(iname)
                    }
                    ui = ui + 1
                }
            }
                        return
        }
        if expr.kind == ExprKind.ek_field_access {
            self.check_expr(expr.field_expr)
            self.check_field_access(expr_idx)
                        return
        }
        if expr.kind == ExprKind.ek_method_call {
            self.check_expr(expr.meth_expr)
            self.check_method_call(expr_idx)
            var i = 0
            while i < expr.meth_args.length() {
                let arg = expr.meth_args.get(i)
                self.check_expr(arg)
                if expr.meth_name == "free" && i == 0 {
                    self.mark_expr_freed(arg)
                } else {
                    self.mark_expr_moved(arg)
                }
                i = i + 1
            }
            let recv_type = self.get_expr_type(expr.meth_expr)
            let meth_name = expr.meth_name
            let meth_idx = self.find_method_decl(recv_type, meth_name)
            if meth_idx >= 0 {
                let decl = self.stmt_pool.get(meth_idx)
                if decl.func_params.length() != expr.meth_args.length() + 1 {
                    self.err("E0006", "argument count mismatch for method '" + meth_name + "': expected " + int_to_str(decl.func_params.length() - 1) + ", got " + int_to_str(expr.meth_args.length()), expr.line, expr.col)
                } else {
                    var arg_i = 0
                    while arg_i < expr.meth_args.length() {
                        let arg = expr.meth_args.get(arg_i)
                        let param = decl.func_params.get(arg_i + 1)
                        let arg_type = self.get_expr_type(arg)
                        if !self.types_compatible(param.ptype, arg_type) {
                            if self.is_integer_type(param.ptype) && self.is_integer_literal(arg) {
                                let v = self.int_literal_value(self.expr_pool.get(arg))
                                if !self.fits_in_type(v, param.ptype) {
                                    self.err("E0030", "integer literal " + int_to_str(v) + " does not fit in type '" + param.ptype + "'", expr.line, expr.col)
                                }
                            } else {
                                self.err("E0003", "argument type mismatch for method '" + meth_name + "', parameter '" + param.name + "': expected '" + param.ptype + "', got '" + arg_type + "'", expr.line, expr.col)
                            }
                        }
                        arg_i = arg_i + 1
                    }
                }
            } else if recv_type != "Void" && !self.is_imported_name(meth_name) {
                self.err("E0022", "undefined method: '" + meth_name + "' for type '" + recv_type + "'", expr.line, expr.col)
            }
            if self.is_imported_name(meth_name) {
                self.mark_import_used(meth_name)
            }
                        return
        }
        if expr.kind == ExprKind.ek_index {
            self.check_expr(expr.idx_expr)
            self.check_expr(expr.idx_index)
            let index_type = self.get_expr_type(expr.idx_index)
            if index_type != "Int" && index_type != "Void" {
                self.err("E0027", "index must be Int, got '" + index_type + "'", expr.line, expr.col)
            }
            let base_type = self.get_expr_type(expr.idx_expr)
            if base_type != "Str" && base_type != "Void" {
                if length(base_type) == 0 || (base_type[0] != Char(42) && base_type[0] != Char(38)) {
                    if !(length(base_type) >= 2 && base_type[0..2] == "[]") {
                        self.err("E0028", "type '" + base_type + "' is not indexable", expr.line, expr.col)
                    }
                }
            }
                        return
        }
        if expr.kind == ExprKind.ek_slice {
            self.check_expr(expr.slice_expr)
            if expr.slice_lower >= 0 {
                self.check_expr(expr.slice_lower)
            }
            if expr.slice_upper >= 0 {
                self.check_expr(expr.slice_upper)
            }
                        return
        }
        if expr.kind == ExprKind.ek_range {
            self.check_expr(expr.range_start)
            self.check_expr(expr.range_end)
                        return
        }
        if expr.kind == ExprKind.ek_borrow {
            self.check_expr(expr.borrow_expr)
                        return
        }
        if expr.kind == ExprKind.ek_deref {
            self.check_expr(expr.deref_expr)
                        return
        }
        if expr.kind == ExprKind.ek_struct_init {
            var i = 0
            while i < expr.struct_fields.length() {
                let f = expr.struct_fields.get(i)
                self.check_expr(f.value)
                self.mark_expr_moved(f.value)
                i = i + 1
            }
            let struct_name = expr.struct_name
            var dot_pos = -1
            var j = 0
            while j < length(struct_name) {
                if struct_name[j] == Char(46) {
                    dot_pos = j
                    break
                }
                j = j + 1
            }
            if dot_pos >= 0 {
                let enum_name = substring(struct_name, 0, dot_pos)
                let enum_idx = self.find_enum_decl(enum_name)
                if enum_idx < 0 {
                    if !self.is_imported_name(enum_name) {
                        self.err("E0021", "undefined enum: '" + enum_name + "'", expr.line, expr.col)
                    }
                                        return
                }
                let decl = self.stmt_pool.get(enum_idx)
                let var_name = substring(struct_name, dot_pos + 1, length(struct_name))
                var found_var = false
                var matched_var = Variant(vname: "", params: empty_param_array())
                var vi = 0
                while vi < decl.enum_variants.length() {
                    let v = decl.enum_variants.get(vi)
                    if v.vname == var_name {
                        found_var = true
                        matched_var = v
                        break
                    }
                    vi = vi + 1
                }
                if !found_var {
                    self.err("E0021", "enum '" + enum_name + "' has no variant '" + var_name + "'", expr.line, expr.col)
                                        return
                }
                var fi = 0
                while fi < expr.struct_fields.length() {
                    let f = expr.struct_fields.get(fi)
                    var found = false
                    var pfi = 0
                    while pfi < matched_var.params.length() {
                        let param = matched_var.params.get(pfi)
                        if param.name == f.name {
                            found = true
                            let val_type = self.get_expr_type(f.value)
                            if !self.types_compatible(param.ptype, val_type) {
                                self.err("E0003", "type mismatch for enum variant field '" + f.name + "': expected '" + param.ptype + "', got '" + val_type + "'", expr.line, expr.col)
                            }
                            break
                        }
                        pfi = pfi + 1
                    }
                    if !found {
                        self.err("E0022", "enum variant '" + var_name + "' has no field '" + f.name + "'", expr.line, expr.col)
                    }
                    fi = fi + 1
                }
                                return
            }
            let struct_idx = self.find_struct_decl(struct_name)
            if struct_idx < 0 {
                if !self.is_imported_name(struct_name) {
                    self.err("E0021", "undefined struct: '" + struct_name + "'", expr.line, expr.col)
                }
                                return
            }
            if self.is_imported_name(struct_name) {
                self.mark_import_used(struct_name)
            }
            let decl = self.stmt_pool.get(struct_idx)
            var fi = 0
            while fi < expr.struct_fields.length() {
                    let f = expr.struct_fields.get(fi)
                    var found = false
                    var dfi = 0
                    while dfi < decl.struct_fields.length() {
                        let df = decl.struct_fields.get(dfi)
                        if df.name == f.name {
                            found = true
                            let val_type = self.get_expr_type(f.value)
                            if !self.types_compatible(df.ftype, val_type) {
                                self.err("E0004", "type mismatch in initializer for field '" + f.name + "' of struct '" + struct_name + "': expected '" + df.ftype + "', got '" + val_type + "'", expr.line, expr.col)
                            }
                        }
                        dfi = dfi + 1
                    }
                    if !found {
                        self.err("E0013", "field '" + f.name + "' does not exist in struct '" + struct_name + "'", expr.line, expr.col)
                    }
                    fi = fi + 1
                }
                        return
        }
        if expr.kind == ExprKind.ek_try {
            self.check_expr(expr.try_expr)
            let inner_ty = self.get_expr_type(expr.try_expr)
            // "Void" means the type couldn't be resolved (e.g. a function imported
            // from another module whose signature isn't visible to this pass) —
            // skip validation rather than raising a spurious error.
            if inner_ty == "Void" {
                return
            }
            var excl_pos = -1
            var i = 0
            while i < length(inner_ty) {
                if inner_ty[i] == Char(33) {
                    excl_pos = i
                }
                i = i + 1
            }
            if excl_pos < 0 {
                self.err("E0014", "cannot use 'try' on non-error-union type '" + inner_ty + "'", expr.line, expr.col)
            } else {
                let error_set = substring(inner_ty, excl_pos + 1, length(inner_ty))
                let expected_ret = self.current_func_ret_type
                var func_excl = -1
                i = 0
                while i < length(expected_ret) {
                    if expected_ret[i] == Char(33) {
                        func_excl = i
                    }
                    i = i + 1
                }
                if func_excl < 0 {
                    self.err("E0015", "cannot use 'try' in a function that returns non-error-union type '" + expected_ret + "'", expr.line, expr.col)
                } else {
                    let func_err = substring(expected_ret, func_excl + 1, length(expected_ret))
                    if !self.types_compatible(func_err, error_set) {
                        self.err("E0016", "error set '" + error_set + "' of try expression is not compatible with function error set '" + func_err + "'", expr.line, expr.col)
                    }
                }
            }
                        return
        }
        if expr.kind == ExprKind.ek_catch {
            self.check_expr(expr.catch_expr)
            let inner_ty = self.get_expr_type(expr.catch_expr)
            // "Void" means the type couldn't be resolved (e.g. a function imported
            // from another module whose signature isn't visible to this pass) —
            // skip validation rather than raising a spurious error.
            if inner_ty == "Void" {
                self.enter_scope()
                if length(expr.catch_var) > 0 {
                    self.define_symbol(expr.catch_var, "Void", false, "var", -1)
                }
                self.check_stmt(expr.catch_fallback)
                self.exit_scope()
                                return
            }
            if length(inner_ty) > 0 && inner_ty[0] == Char(63) {
                let val_type = substring(inner_ty, 1, length(inner_ty))
                self.enter_scope()
                if length(expr.catch_var) > 0 {
                    self.define_symbol(expr.catch_var, "Void", false, "var", -1)
                }
                self.check_stmt(expr.catch_fallback)
                self.exit_scope()
                let fallback_yields = self.get_block_yield_type(expr.catch_fallback)
                if !self.types_compatible(val_type, fallback_yields) {
                    self.err("E0018", "catch fallback type '" + fallback_yields + "' is not compatible with expected type '" + val_type + "'", expr.line, expr.col)
                }
                                return
            }
            var excl_pos = -1
            var i = 0
            while i < length(inner_ty) {
                if inner_ty[i] == Char(33) {
                    excl_pos = i
                }
                i = i + 1
            }
            if excl_pos < 0 {
                self.err("E0017", "cannot use 'catch' on non-error-union type '" + inner_ty + "'", expr.line, expr.col)
            } else {
                let val_type = substring(inner_ty, 0, excl_pos)
                let error_set = substring(inner_ty, excl_pos + 1, length(inner_ty))
                
                self.enter_scope()
                if length(expr.catch_var) > 0 {
                    self.define_symbol(expr.catch_var, error_set, false, "var", -1)
                }
                self.check_stmt(expr.catch_fallback)
                self.exit_scope()
                
                let fallback_yields = self.get_block_yield_type(expr.catch_fallback)
                if !self.types_compatible(val_type, fallback_yields) {
                    self.err("E0018", "catch fallback type '" + fallback_yields + "' is not compatible with expected type '" + val_type + "'", expr.line, expr.col)
                }
            }
            return
        }
    }

    fn map_type_to_id(self, type_name: Str) -> Int {
        if type_name == "Void" || length(type_name) == 0 { return 0 }
        if type_name == "Int" { return 1 }
        if type_name == "Float" { return 2 }
        if type_name == "Bool" { return 3 }
        if type_name == "Char" { return 4 }
        if type_name == "Str" { return 5 }
        
        if length(type_name) > 0 && type_name[0] == Char(42) { // '*'
            let element = type_name[1..length(type_name)]
            let element_id = self.map_type_to_id(element)
            return self.type_arena.intern_pointer(element_id)
        }
        return self.type_arena.intern_struct(type_name, -1)
    }

    fn get_expr_type_id(self, expr_idx: Int) -> Int {
        if expr_idx < 0 { return 0 }
        let expr = self.expr_pool.get(expr_idx)
        if expr.type_id >= 0 {
            return expr.type_id
        }
        let ty_name = self.get_expr_type(expr_idx)
        return self.map_type_to_id(ty_name)
    }
}
