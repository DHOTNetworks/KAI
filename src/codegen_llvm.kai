// ============================================================================
// LLVMCodegen Struct Definition
// ============================================================================

struct LLVMCodegen {
    allocator: *Allocator
    stmt_pool: *ArrayList<StmtNode>
    expr_pool: *ArrayList<ExprNode>
    pattern_pool: *ArrayList<PatternNode>

    // FFI handles
    ctx: *Void
    module: *Void
    builder: *Void
    cur_func: *Void
    last_was_term: Bool

    // Symbol Tables (mangled or plain name -> stringified pointers)
    sym_table: ArrayList<StrMapEntry>   // var name -> alloca LLVMValueRef as string
    type_table: ArrayList<StrMapEntry>  // var name -> Kai type
    func_types: ArrayList<StrMapEntry>  // mangled func name -> return Kai type
    func_param_types: ArrayList<StrMapEntry> // "func_param_N" -> parameter Kai type
    func_is_sret: ArrayList<StrMapEntry> // mangled func name -> "1" if it uses the sret calling convention

    // Module / Decl State
    struct_types: ArrayList<StrMapEntry> // struct name -> LLVMTypeRef as string
    enum_types: ArrayList<StrMapEntry>   // enum name -> LLVMTypeRef as string
    enum_decls: ArrayList<StrMapEntry>   // metadata mapping for tags & payload checks
    struct_field_types: ArrayList<StrMapEntry>   // "Struct.field" -> Kai type
    struct_field_indices: ArrayList<StrMapEntry> // "Struct.field" -> field index
    loaded_modules: ArrayList<Str>

    // Control Flow stacks for loops
    loop_cond_stack: ArrayList<Str>
    loop_step_stack: ArrayList<Str>
    loop_end_stack: ArrayList<Str>

    // Current function metadata
    cur_func_ret_type: Str
    cur_func_sret_ptr: *Void
}

impl LLVMCodegen {

fn init(self, allocator: *Allocator, stmt_pool: *ArrayList<StmtNode>, expr_pool: *ArrayList<ExprNode>, pattern_pool: *ArrayList<PatternNode>) {
    self.allocator = allocator
    self.stmt_pool = stmt_pool
    self.expr_pool = expr_pool
    self.pattern_pool = pattern_pool

    self.ctx = LLVMContextCreate()
    self.module = 0 as *Void
    self.builder = 0 as *Void
    self.cur_func = 0 as *Void
    self.last_was_term = false

    self.sym_table = ArrayList<StrMapEntry>(allocator)
    self.type_table = ArrayList<StrMapEntry>(allocator)
    self.func_types = ArrayList<StrMapEntry>(allocator)
    self.func_param_types = ArrayList<StrMapEntry>(allocator)
    self.func_is_sret = ArrayList<StrMapEntry>(allocator)

    self.struct_types = ArrayList<StrMapEntry>(allocator)
    self.enum_types = ArrayList<StrMapEntry>(allocator)
    self.enum_decls = ArrayList<StrMapEntry>(allocator)
    self.struct_field_types = ArrayList<StrMapEntry>(allocator)
    self.struct_field_indices = ArrayList<StrMapEntry>(allocator)
    self.loaded_modules = ArrayList<Str>(allocator)

    self.loop_cond_stack = ArrayList<Str>(allocator)
    self.loop_step_stack = ArrayList<Str>(allocator)
    self.loop_end_stack = ArrayList<Str>(allocator)
    self.cur_func_ret_type = ""
    self.cur_func_sret_ptr = 0 as *Void
}

// ============================================================================
// Symbol/Helper Methods
// ============================================================================

fn sym_reset(self) {
    self.sym_table.len = 0
    self.type_table.len = 0
}

fn sym_store(self, name: Str, val: *Void, ktype: Str) {
    let val_str = int_to_str(val as Int)
    type_map_put(&self.sym_table, name, val_str)
    type_map_put(&self.type_table, name, ktype)
}

fn sym_lookup(self, name: Str) -> *Void {
    let val_str = type_map_get(&self.sym_table, name)
    if length(val_str) == 0 { return 0 as *Void }
    return self.str_to_int(val_str) as *Void
}

fn sym_type(self, name: Str) -> Str {
    return type_map_get(&self.type_table, name)
}

fn str_to_int(self, s: Str) -> Int {
    var res = 0
    var sign = 1
    var i = 0
    if length(s) > 0 && s[0] == Char(45) { // '-' is 45
        sign = -1
        i = 1
    }
    while i < length(s) {
        let c = s[i] as Int
        if c >= 48 && c <= 57 {
            res = res * 10 + (c - 48)
        }
        i = i + 1
    }
    return res * sign
}

fn str_find(self, s: Str, c: Char) -> Int {
    var i = 0
    while i < length(s) {
        if s[i] == c { return i }
        i = i + 1
    }
    return -1
}

fn str_contains(self, s: Str, c: Char) -> Bool {
    return self.str_find(s, c) >= 0
}

fn str_list_find(self, val: Str) -> Int {
    var i = 0
    while i < self.loaded_modules.length() {
        if self.loaded_modules.get(i) == val { return i }
        i = i + 1
    }
    return -1
}

fn strip_pointers(self, ktype: Str) -> Str {
    var res = ktype
    while length(res) > 0 && (res[0] == Char(42) || res[0] == Char(38)) {
        res = substring(res, 1, length(res))
    }
    return res
}

// ============================================================================
fn is_pointer_type(self, t: Str) -> Bool {
    if length(t) == 0 { return false }
    if t[0] == Char(42) || t[0] == Char(38) { return true }
    if t == "Str" { return true }
    if length(t) >= 2 && substring(t, 0, 2) == "[]" { return true }
    return false
}

fn clean_type_for_mangling(self, s: Str) -> Str {
    var res = ""
    var i = 0
    while i < length(s) {
        let c = s[i]
        if c == Char(42) {
            res = res + "ptr"
        } else if c == Char(38) {
            res = res + "ref"
        } else if c == Char(32) {
            res = res + "_"
        } else if c == Char(63) {
            res = res + "opt_"
        } else if c == Char(60) || c == Char(62) || c == Char(44) || c == Char(33) {
            res = res + "_"
        } else {
            res = res + char_to_str(c)
        }
        i = i + 1
    }
    return res
}

fn map_type(self, ktype: Str) -> *Void {
    if length(ktype) == 0 {
        return LLVMInt64TypeInContext(self.ctx)
    }

    // Optional Type (?Type)
    if ktype[0] == Char(63) {
        let val_type = substring(ktype, 1, length(ktype))
        if self.is_pointer_type(val_type) {
            // ?Ptr -> just use the pointer (null == none)
            return self.map_type(val_type)
        }
        let clean_val = self.clean_type_for_mangling(val_type)
        let concrete_name = "Optional_" + clean_val
        let existing = type_map_get(&self.struct_types, concrete_name)
        if length(existing) > 0 {
            return self.str_to_int(existing) as *Void
        }
        let opt_ty = LLVMStructCreateNamed(self.ctx, concrete_name)
        type_map_put(&self.struct_types, concrete_name, int_to_str(opt_ty as Int))
        let types = self.allocator.alloc(16, 8) as **Void
        types[0] = LLVMInt8TypeInContext(self.ctx)
        types[1] = self.map_type(val_type)
        LLVMStructSetBody(opt_ty, types as *Void, 2, false)
        self.allocator.free(types as *Void)
        return opt_ty
    }

    // Error Union Type (Val!Err)
    if self.str_contains(ktype, Char(33)) {
        let excl_pos = self.str_find(ktype, Char(33))
        let val_type = substring(ktype, 0, excl_pos)
        let err_type = substring(ktype, excl_pos + 1, length(ktype))
        let clean_val = self.clean_type_for_mangling(val_type)
        let clean_err = self.clean_type_for_mangling(err_type)
        let concrete_name = "Result_" + clean_val + "_" + clean_err
        let existing = type_map_get(&self.struct_types, concrete_name)
        if length(existing) > 0 {
            return self.str_to_int(existing) as *Void
        }
        let res_ty = LLVMStructCreateNamed(self.ctx, concrete_name)
        type_map_put(&self.struct_types, concrete_name, int_to_str(res_ty as Int))
        let types = self.allocator.alloc(16, 8) as **Void
        types[0] = LLVMInt64TypeInContext(self.ctx)
        if val_type == "Void" {
            LLVMStructSetBody(res_ty, types as *Void, 1, false)
        } else {
            types[1] = self.map_type(val_type)
            LLVMStructSetBody(res_ty, types as *Void, 2, false)
        }
        self.allocator.free(types as *Void)
        return res_ty
    }

    // Primitive types
    if ktype == "Int" || ktype == "Int64"  { return LLVMInt64TypeInContext(self.ctx) }
    if ktype == "Float"                    { return LLVMDoubleTypeInContext(self.ctx) }
    if ktype == "Bool"                     { return LLVMInt64TypeInContext(self.ctx) }
    if ktype == "Char" || ktype == "Int8"  { return LLVMInt8TypeInContext(self.ctx) }
    if ktype == "Int32"                    { return LLVMInt32TypeInContext(self.ctx) }
    if ktype == "Str"                      { return LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0) }
    if ktype == "Void"                     { return LLVMVoidTypeInContext(self.ctx) }

    // Pointer type *T
    if ktype[0] == Char(42) {
        let inner = substring(ktype, 1, length(ktype))
        if length(inner) == 0 || inner == "Void" {
            return LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
        }
        if inner == "Char" || inner == "Int8" {
            return LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
        }
        return LLVMPointerType(self.map_type(inner), 0)
    }
    // Reference type &T
    if ktype[0] == Char(38) {
        let inner = substring(ktype, 1, length(ktype))
        if length(inner) == 0 || inner == "Void" {
            return LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
        }
        return LLVMPointerType(self.map_type(inner), 0)
    }
    // Array slice []T
    if length(ktype) >= 2 && substring(ktype, 0, 2) == "[]" {
        let inner = substring(ktype, 2, length(ktype))
        if length(inner) == 0 { return LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0) }
        return LLVMPointerType(self.map_type(inner), 0)
    }

    // Strip generic params (ArrayList<Int> -> look up ArrayList)
    // Special case: Optional<T> -> treat as ?T. Note: Kai has no Rust-style
    // Result<T, E> — error handling uses only the Zig-like `T!E` error-union syntax.
    var clean_base = ktype
    let lt_pos = self.str_find(ktype, Char(60))
    if lt_pos >= 0 {
        clean_base = substring(ktype, 0, lt_pos)
        // Optional<T> → ?T
        if clean_base == "Optional" {
            let inner = substring(ktype, lt_pos + 1, length(ktype) - 1)
            return self.map_type("?" + inner)
        }
        // ArrayList<T> → use the base ArrayList struct type (same layout for all T)
        // Register the concrete name pointing to the base type so emit_monomorphized_arraylists
        // can discover and generate method bodies for each ArrayList<T> instantiation.
        if clean_base == "ArrayList" {
            let existing = type_map_get(&self.struct_types, ktype)
            if length(existing) > 0 {
                return self.str_to_int(existing) as *Void
            }
            // Fall through to base struct lookup — registers "ArrayList<T>" → base %ArrayList
        }
    }

    // Struct lookup
    let s_ty_str = type_map_get(&self.struct_types, clean_base)
    if length(s_ty_str) > 0 {
        return self.str_to_int(s_ty_str) as *Void
    }

    // Enum lookup
    let e_ty_str = type_map_get(&self.enum_types, clean_base)
    if length(e_ty_str) > 0 {
        let e_ty = self.str_to_int(e_ty_str) as *Void
        if self.enum_has_payload(clean_base) {
            // Return the enum struct type directly (value type, not pointer)
            return e_ty
        }
        return LLVMInt64TypeInContext(self.ctx)
    }

    return LLVMInt64TypeInContext(self.ctx)
}

fn is_integer_type(self, ktype: Str) -> Bool {
    if ktype == "Int" { return true }
    if ktype == "Char" { return true }
    if ktype == "Bool" { return true }
    if ktype == "Int8" { return true }
    if ktype == "Int32" { return true }
    
    let clean_t = self.strip_pointers(ktype)
    let enum_val = type_map_get(&self.enum_decls, clean_t)
    if length(enum_val) > 0 {
        if !self.enum_has_payload(clean_t) { return true }
    }
    return false
}

fn is_builtin_llvm_func(self, name: Str) -> Bool {
    if name == "printf" { return true }
    if name == "sprintf" { return true }
    if name == "snprintf" { return true }
    if name == "exit" { return true }
    if name == "malloc" { return true }
    if name == "free" { return true }
    if name == "realloc" { return true }
    if name == "memset" { return true }
    if name == "memcpy" { return true }
    if name == "strlen" { return true }
    if name == "strcmp" { return true }
    if name == "strcpy" { return true }
    if name == "strcat" { return true }
    return false
}

// ============================================================================
// Standard Library Helpers Declarer
// ============================================================================

fn get_or_declare_func(self, fname: Str, ret_ktype: Str, p1: Str, p2: Str, p3: Str, param_count: Int) -> *Void {
    let existing = LLVMGetNamedFunction(self.module, fname)
    if existing != 0 as *Void { return existing }
    
    let param_types = self.allocator.alloc(param_count * 8, 8) as **Void
    if param_count > 0 { param_types[0] = self.map_type(p1) }
    if param_count > 1 { param_types[1] = self.map_type(p2) }
    if param_count > 2 { param_types[2] = self.map_type(p3) }
    
    let ret_ll = self.map_type(ret_ktype)
    let fn_ty = LLVMFunctionType(ret_ll, param_types as *Void, param_count, false)
    let func = LLVMAddFunction(self.module, fname, fn_ty)
    
    type_map_put(&self.func_types, fname, ret_ktype)
    self.allocator.free(param_types as *Void)
    return func
}

fn get_malloc(self) -> *Void {
    return self.get_or_declare_func("malloc", "*Void", "Int", "", "", 1)
}

fn get_memset(self) -> *Void {
    return self.get_or_declare_func("memset", "*Void", "*Void", "Int", "Int", 3)
}

fn get_memcpy(self) -> *Void {
    return self.get_or_declare_func("memcpy", "*Void", "*Void", "*Void", "Int", 3)
}

fn get_strlen(self) -> *Void {
    return self.get_or_declare_func("strlen", "Int", "Str", "", "", 1)
}

fn get_strcpy(self) -> *Void {
    return self.get_or_declare_func("strcpy", "Str", "Str", "Str", "", 2)
}

fn get_strcat(self) -> *Void {
    return self.get_or_declare_func("strcat", "Str", "Str", "Str", "", 2)
}

fn get_strcmp(self) -> *Void {
    return self.get_or_declare_func("strcmp", "Int", "Str", "Str", "", 2)
}

fn get_or_declare_printf(self) -> *Void {
    let fname = "printf"
    let printf_func = LLVMGetNamedFunction(self.module, fname)
    if printf_func != 0 as *Void { return printf_func }
    
    let ret_type = LLVMInt32TypeInContext(self.ctx)
    let params = self.allocator.alloc(8, 8) as **Void
    params[0] = LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
    
    let fn_ty = LLVMFunctionType(ret_type, params as *Void, 1, true)
    let func = LLVMAddFunction(self.module, fname, fn_ty)
    self.allocator.free(params as *Void)
    return func
}

fn get_printf_type(self) -> *Void {
    let ret_type = LLVMInt32TypeInContext(self.ctx)
    let params = self.allocator.alloc(8, 8) as **Void
    params[0] = LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
    let fn_ty = LLVMFunctionType(ret_type, params as *Void, 1, true)
    self.allocator.free(params as *Void)
    return fn_ty
}

// ============================================================================
// String Concatenation Runtime Helper
// ============================================================================

fn emit_str_concat_helper(self) {
    let fname = "_kai_str_concat"
    let ret_type = self.map_type("Str")
    
    let params = self.allocator.alloc(16, 8) as **Void
    params[0] = ret_type
    params[1] = ret_type
    
    let fn_ty = LLVMFunctionType(ret_type, params as *Void, 2, false)
    let func = LLVMAddFunction(self.module, fname, fn_ty)
    // params is kept alive — it is reused for strcpy/strcat fn types below
    
    let entry_bb = LLVMAppendBasicBlockInContext(self.ctx, func, "entry")
    let helper_builder = LLVMCreateBuilderInContext(self.ctx)
    LLVMPositionBuilderAtEnd(helper_builder, entry_bb)
    
    let a = LLVMGetParam(func, 0)
    let b = LLVMGetParam(func, 1)
    
    let strlen_func = self.get_strlen()
    // strlen takes 1 Str param, returns i64 — build fn type from proper heap arrays
    let strlen_param_types = self.allocator.alloc(8, 8) as **Void
    strlen_param_types[0] = ret_type
    let strlen_ty = LLVMFunctionType(LLVMInt64TypeInContext(self.ctx), strlen_param_types as *Void, 1, false)

    let la_params = self.allocator.alloc(8, 8) as **Void
    la_params[0] = a
    let la = LLVMBuildCall2(helper_builder, strlen_ty, strlen_func, la_params as *Void, 1, "la")
    self.allocator.free(la_params as *Void)

    let lb_params = self.allocator.alloc(8, 8) as **Void
    lb_params[0] = b
    let lb = LLVMBuildCall2(helper_builder, strlen_ty, strlen_func, lb_params as *Void, 1, "lb")
    self.allocator.free(lb_params as *Void)
    self.allocator.free(strlen_param_types as *Void)
    
    let total = LLVMBuildAdd(helper_builder, la, lb, "total")
    let sz = LLVMBuildAdd(helper_builder, total, LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 1, false), "sz")
    
    let malloc_func = self.get_malloc()
    let malloc_param_types = self.allocator.alloc(8, 8) as **Void
    malloc_param_types[0] = LLVMInt64TypeInContext(self.ctx)
    let malloc_args = self.allocator.alloc(8, 8) as **Void
    malloc_args[0] = sz
    let buf = LLVMBuildCall2(helper_builder, LLVMFunctionType(ret_type, malloc_param_types as *Void, 1, false), malloc_func, malloc_args as *Void, 1, "buf")
    self.allocator.free(malloc_param_types as *Void)
    self.allocator.free(malloc_args as *Void)
    
    let strcpy_func = self.get_strcpy()
    let cpy_params = self.allocator.alloc(16, 8) as **Void
    cpy_params[0] = buf
    cpy_params[1] = a
    let strcpy_ty = LLVMFunctionType(ret_type, params as *Void, 2, false)
    let _ = LLVMBuildCall2(helper_builder, strcpy_ty, strcpy_func, cpy_params as *Void, 2, "")
    
    let strcat_func = self.get_strcat()
    cpy_params[1] = b
    let _ = LLVMBuildCall2(helper_builder, strcpy_ty, strcat_func, cpy_params as *Void, 2, "")
    
    let _ = LLVMBuildRet(helper_builder, buf)
    
    LLVMDisposeBuilder(helper_builder)
    self.allocator.free(cpy_params as *Void)
    self.allocator.free(params as *Void)
    
    type_map_put(&self.func_types, fname, "Str")
}

// ============================================================================
// AST Declarations Scanner Pass
// ============================================================================

fn register_all_decls(self) {
    // Pass 1: Declare Named Structs & Enums
    var idx = 0
    while idx < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(idx)
        if stmt.kind == StmtKind.sk_struct_decl {
            let existing = type_map_get(&self.struct_types, stmt.struct_name)
            if length(existing) == 0 {
                let s_ty = LLVMStructCreateNamed(self.ctx, stmt.struct_name)
                type_map_put(&self.struct_types, stmt.struct_name, int_to_str(s_ty as Int))
                
                // Register metadata fields
                var f_idx = 0
                while f_idx < stmt.struct_fields.length() {
                    let f = stmt.struct_fields.get(f_idx)
                    let key = stmt.struct_name + "." + f.name
                    type_map_put(&self.struct_field_types, key, f.ftype)
                    type_map_put(&self.struct_field_indices, key, int_to_str(f_idx))
                    f_idx = f_idx + 1
                }
            }
        }
        if stmt.kind == StmtKind.sk_enum_decl {
            let existing = type_map_get(&self.enum_types, stmt.enum_name)
            if length(existing) == 0 {
                let e_ty = LLVMStructCreateNamed(self.ctx, stmt.enum_name)
                type_map_put(&self.enum_types, stmt.enum_name, int_to_str(e_ty as Int))
                type_map_put(&self.enum_decls, stmt.enum_name, int_to_str(idx))
                
                // Register variants tags
                var v_idx = 0
                while v_idx < stmt.enum_variants.length() {
                    let v = stmt.enum_variants.get(v_idx)
                    let tag_key = stmt.enum_name + "_" + v.vname + "_TAG"
                    let tag_key2 = stmt.enum_name + "." + v.vname
                    type_map_put(&self.enum_decls, tag_key, int_to_str(v_idx))
                    type_map_put(&self.enum_decls, tag_key2, int_to_str(v_idx))
                    v_idx = v_idx + 1
                }
            }
        }
        if stmt.kind == StmtKind.sk_error_decl {
            let existing = type_map_get(&self.enum_types, stmt.error_name)
            if length(existing) == 0 {
                let e_ty = LLVMStructCreateNamed(self.ctx, stmt.error_name)
                type_map_put(&self.enum_types, stmt.error_name, int_to_str(e_ty as Int))
                type_map_put(&self.enum_decls, stmt.error_name, int_to_str(idx))
                
                // Register variants tags
                var v_idx = 0
                while v_idx < stmt.error_variants.length() {
                    let v_name = stmt.error_variants.get(v_idx)
                    let tag_key = stmt.error_name + "_" + v_name + "_TAG"
                    let tag_key2 = stmt.error_name + "." + v_name
                    type_map_put(&self.enum_decls, tag_key, int_to_str(v_idx))
                    type_map_put(&self.enum_decls, tag_key2, int_to_str(v_idx))
                    v_idx = v_idx + 1
                }
            }
        }
        idx = idx + 1
    }

    // Pass 2: Set Body for Structs & Enums
    idx = 0
    while idx < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(idx)
        if stmt.kind == StmtKind.sk_struct_decl {
            let s_ty_str = type_map_get(&self.struct_types, stmt.struct_name)
            let s_ty = self.str_to_int(s_ty_str) as *Void
            
            // Set struct body elements
            let count = stmt.struct_fields.length()
            let types = self.allocator.alloc(count * 8, 8) as **Void
            var f_idx = 0
            while f_idx < count {
                let f = stmt.struct_fields.get(f_idx)
                types[f_idx] = self.map_type(f.ftype)
                f_idx = f_idx + 1
            }
            LLVMStructSetBody(s_ty, types as *Void, count, false)
            self.allocator.free(types as *Void)
        }
        if stmt.kind == StmtKind.sk_enum_decl {
            let e_ty_str = type_map_get(&self.enum_types, stmt.enum_name)
            let e_ty = self.str_to_int(e_ty_str) as *Void
            
            let types = self.allocator.alloc(16, 8) as **Void
            types[0] = LLVMInt8TypeInContext(self.ctx)
            types[1] = LLVMInt64TypeInContext(self.ctx)
            LLVMStructSetBody(e_ty, types as *Void, 2, false)
            self.allocator.free(types as *Void)
        }
        if stmt.kind == StmtKind.sk_error_decl {
            let e_ty_str = type_map_get(&self.enum_types, stmt.error_name)
            let e_ty = self.str_to_int(e_ty_str) as *Void
            
            let types = self.allocator.alloc(16, 8) as **Void
            types[0] = LLVMInt8TypeInContext(self.ctx)
            types[1] = LLVMInt64TypeInContext(self.ctx)
            LLVMStructSetBody(e_ty, types as *Void, 2, false)
            self.allocator.free(types as *Void)
        }
        idx = idx + 1
    }

    // Pass 3: Register Extern and Functions Declarations
    idx = 0
    while idx < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(idx)
        if stmt.kind == StmtKind.sk_func_decl {
            // Skip trait/impl method stubs: they will be generated via impl_block iteration
            var is_method_stub = false
            var ti = 0
            while ti < self.stmt_pool.length() {
                let ts = self.stmt_pool.get(ti)
                if ts.kind == StmtKind.sk_trait_decl {
                    var mi = 0
                    while mi < ts.trait_methods.length() {
                        if ts.trait_methods.get(mi) == idx {
                            is_method_stub = true
                        }
                        mi = mi + 1
                    }
                }
                if ts.kind == StmtKind.sk_impl_block {
                    var mi = 0
                    while mi < ts.impl_methods.length() {
                        if ts.impl_methods.get(mi) == idx {
                            is_method_stub = true
                        }
                        mi = mi + 1
                    }
                }
                ti = ti + 1
            }
            // Register the function declaration even if it's a stub so the type signature is known
            let _ = self.register_func_decl(idx, "", false)
            
            if !is_method_stub && stmt.func_body >= 0 {
                // The body will be processed later in gen_func_body
            }
        }
        if stmt.kind == StmtKind.sk_impl_block {
            let struct_name = stmt.impl_struct_name
            var j = 0
            while j < stmt.impl_methods.length() {
                let m_idx = stmt.impl_methods.get(j)
                let _ = self.register_func_decl(m_idx, struct_name, false)
                j = j + 1
            }
        }
        if stmt.kind == StmtKind.sk_trait_decl {
            let struct_name = stmt.trait_name
            var j = 0
            while j < stmt.trait_methods.length() {
                let m_idx = stmt.trait_methods.get(j)
                let _ = self.register_func_decl(m_idx, struct_name, false)
                j = j + 1
            }
        }
        if stmt.kind == StmtKind.sk_extern {
            self.register_extern_decl(idx)
        }
        idx = idx + 1
    }
}

// Returns true when `ret_ktype` names a registered struct type (i.e. a
// bare struct name, not a pointer/reference to one, and not Void/a
// primitive/an enum) and therefore must be returned via the sret calling
// convention rather than as a first-class LLVM value.
fn is_struct_by_value_return(self, ret_ktype: Str) -> Bool {
    if length(ret_ktype) == 0 { return false }
    if ret_ktype == "Void" { return false }

    // Pointer (*T) and reference (&T) returns are never sret.
    if ret_ktype[0] == Char(42) || ret_ktype[0] == Char(38) { return false }

    // Primitive/scalar return types are never sret.
    if ret_ktype == "Int" || ret_ktype == "Int64"  { return false }
    if ret_ktype == "Float"                        { return false }
    if ret_ktype == "Bool"                          { return false }
    if ret_ktype == "Char" || ret_ktype == "Int8"   { return false }
    if ret_ktype == "Int32"                         { return false }
    if ret_ktype == "Str"                           { return false }

    // Strip generic params (e.g. ArrayList<Int> -> ArrayList) before lookup.
    var clean_base = ret_ktype
    let lt_pos = self.str_find(ret_ktype, Char(60))
    if lt_pos >= 0 {
        clean_base = substring(ret_ktype, 0, lt_pos)
    }

    // Enums are value types constructed via alloca+load, not sret.
    let e_ty_str = type_map_get(&self.enum_types, clean_base)
    if length(e_ty_str) > 0 { return false }

    // Must name a registered struct type to qualify.
    let s_ty_str = type_map_get(&self.struct_types, clean_base)
    if length(s_ty_str) > 0 { return true }

    return false
}

fn register_func_decl(self, stmt_idx: Int, struct_name: Str, is_init: Bool) -> *Void {
    let stmt = self.stmt_pool.get(stmt_idx)
    let method_name = stmt.func_name
    
    var fname = method_name
    var ret_ktype = stmt.func_return_type
    var has_self = false
    
    if length(struct_name) > 0 {
        fname = struct_name + "_" + method_name
        has_self = (method_name != "init")
        if method_name == "init" || ret_ktype == struct_name || ret_ktype == "*" + struct_name {
            ret_ktype = "*" + struct_name
        }
    }
    
    let existing = LLVMGetNamedFunction(self.module, fname)
    if existing != 0 as *Void {
        // Re-registration check: if the function was previously declared when its
        // return type wasn't registered yet (fell back to i64), and NOW the type
        // is registered as an enum/struct, delete and re-declare with the correct type.
        // This handles the import-ordering problem (e.g. make_keyword_value returning
        // TokenValue, which is an enum that may not have been in enum_types when
        // the first register_func_decl ran).
        let prev_recorded_ret = type_map_get(&self.func_types, fname)
        // Only re-register if:
        //   1. The recorded Kai return type matches the current ret_ktype (same function, same type string)
        //   2. The type was NOT previously an enum/struct (i.e. previously resolved to i64 fallback)
        //   3. It NOW resolves to an enum or struct (i.e. NOT i64 fallback anymore)
        let now_ll = self.map_type(ret_ktype)
        let i64_ll = LLVMInt64TypeInContext(self.ctx)
        if prev_recorded_ret == ret_ktype && now_ll != i64_ll {
            // Check whether it actually changed: if it's not a pointer type and not Void,
            // the previous registration likely used i64. Delete and re-declare.
            let is_ptr = length(ret_ktype) > 0 && (ret_ktype[0] == Char(42) || ret_ktype[0] == Char(38))
            let is_prim = ret_ktype == "Int" || ret_ktype == "Int64" || ret_ktype == "Float" || ret_ktype == "Bool" || ret_ktype == "Char" || ret_ktype == "Int8" || ret_ktype == "Int32" || ret_ktype == "Str" || ret_ktype == "Void"
            if !is_ptr && !is_prim {
                LLVMDeleteFunction(existing)
                // fall through to re-declare below
            } else {
                return existing
            }
        } else {
            return existing
        }
    }
    
    let param_count = stmt.func_params.length()
    let param_types = self.allocator.alloc(param_count * 8, 8) as **Void
    
    var p_idx = 0
    var i = 0
    while i < stmt.func_params.length() {
        let p = stmt.func_params.get(i)
        if p.name == "self" {
            param_types[p_idx] = LLVMPointerType(self.map_type(struct_name), 0)
            let p_key = fname + "_param_" + int_to_str(i)
            type_map_put(&self.func_param_types, p_key, "*" + struct_name)
        } else {
            param_types[p_idx] = self.map_type(p.ptype)
            let p_key = fname + "_param_" + int_to_str(i)
            type_map_put(&self.func_param_types, p_key, p.ptype)
        }
        p_idx = p_idx + 1
        i = i + 1
    }
    
    var ret_ll: *Void = 0 as *Void
    if ret_ktype == "Void" || length(ret_ktype) == 0 {
        ret_ll = LLVMVoidTypeInContext(self.ctx)
    } else {
        ret_ll = self.map_type(ret_ktype)
    }

    if self.is_struct_by_value_return(ret_ktype) {
        // sret calling convention: hidden first ptr param, void return
        let sret_params = self.allocator.alloc((param_count + 1) * 8, 8) as **Void
        var j = 0
        while j < param_count {
            sret_params[j + 1] = param_types[j]
            j = j + 1
        }
        let sret_ll = self.map_type(ret_ktype)
        sret_params[0] = LLVMPointerType(sret_ll, 0)
        self.allocator.free(param_types as *Void)
        let sret_ret_ll = LLVMVoidTypeInContext(self.ctx)
        let fn_ty = LLVMFunctionType(sret_ret_ll, sret_params as *Void, param_count + 1, false)
        let func = LLVMAddFunction(self.module, fname, fn_ty)
        type_map_put(&self.func_types, fname, ret_ktype)
        type_map_put(&self.func_is_sret, fname, "1")
        self.allocator.free(sret_params as *Void)
        return func
    }

    let fn_ty = LLVMFunctionType(ret_ll, param_types as *Void, param_count, false)
    let func = LLVMAddFunction(self.module, fname, fn_ty)
    
    type_map_put(&self.func_types, fname, ret_ktype)
    self.allocator.free(param_types as *Void)
    return func
}

fn register_extern_decl(self, stmt_idx: Int) {
    let stmt = self.stmt_pool.get(stmt_idx)
    let name = stmt.extern_name
    
    if self.is_builtin_llvm_func(name) {
        type_map_put(&self.func_types, name, stmt.extern_return)
        return
    }
    
    let existing = LLVMGetNamedFunction(self.module, name)
    if existing != 0 as *Void { return }
    
    let param_count = stmt.extern_params.length()
    let param_types = self.allocator.alloc(param_count * 8, 8) as **Void
    
    var i = 0
    while i < param_count {
        let p = stmt.extern_params.get(i)
        param_types[i] = self.map_type(p.ptype)
        let p_key = name + "_param_" + int_to_str(i)
        type_map_put(&self.func_param_types, p_key, p.ptype)
        i = i + 1
    }
    
    var ret_ll: *Void = 0 as *Void
    if stmt.extern_return == "Void" || length(stmt.extern_return) == 0 {
        ret_ll = LLVMVoidTypeInContext(self.ctx)
    } else {
        ret_ll = self.map_type(stmt.extern_return)
    }
    let fn_ty = LLVMFunctionType(ret_ll, param_types as *Void, param_count, false)
    let _ = LLVMAddFunction(self.module, name, fn_ty)
    
    type_map_put(&self.func_types, name, stmt.extern_return)
    self.allocator.free(param_types as *Void)
}

// ============================================================================
// Code Generation: Statements
// ============================================================================

fn gen_func_body(self, stmt_idx: Int, struct_name: Str) {
    let stmt = self.stmt_pool.get(stmt_idx)
    let method_name = stmt.func_name
    
    var fname = method_name
    if length(struct_name) > 0 {
        fname = struct_name + "_" + method_name
    }
    
    let func_val = LLVMGetNamedFunction(self.module, fname)
    self.cur_func = func_val
    self.last_was_term = false
    self.sym_reset()
    // Track current function return type for correct return wrapping
    self.cur_func_ret_type = type_map_get(&self.func_types, fname)
    self.cur_func_sret_ptr = 0 as *Void
    
    let entry_bb = LLVMAppendBasicBlockInContext(self.ctx, func_val, "entry")
    LLVMPositionBuilderAtEnd(self.builder, entry_bb)
    
    let is_sret = (type_map_get(&self.func_is_sret, fname) == "1")
    if is_sret {
        let sret_ptr = LLVMGetParam(func_val, 0)
        self.cur_func_sret_ptr = sret_ptr
    }

    var p_idx = 0
    var i = 0
    while i < stmt.func_params.length() {
        let p = stmt.func_params.get(i)
        var param_val: *Void = 0 as *Void
        if is_sret {
            param_val = LLVMGetParam(func_val, p_idx + 1)
        } else {
            param_val = LLVMGetParam(func_val, p_idx)
        }
        if p.name == "self" {
            let self_ll = LLVMPointerType(self.map_type(struct_name), 0)
            let addr = LLVMBuildAlloca(self.builder, self_ll, "self.addr")
            LLVMBuildStore(self.builder, param_val, addr)
            self.sym_store("self", addr, "*" + struct_name)
        } else {
            var param_lltype = self.map_type(p.ptype)
            // Guard: never alloca void type
            if param_lltype == LLVMVoidTypeInContext(self.ctx) {
                param_lltype = LLVMInt64TypeInContext(self.ctx)
            }
            let addr = LLVMBuildAlloca(self.builder, param_lltype, p.name + ".addr")
            LLVMBuildStore(self.builder, param_val, addr)
            self.sym_store(p.name, addr, p.ptype)
        }
        p_idx = p_idx + 1
        i = i + 1
    }
    
    if stmt.func_body >= 0 {
        self.gen_stmt(stmt.func_body)
    }
    
    // Emit default return (only if not already terminated)
    if !self.last_was_term {
        let ret_ktype = type_map_get(&self.func_types, fname)
        if is_sret {
            LLVMBuildRetVoid(self.builder)
        } else if ret_ktype == "Void" || length(ret_ktype) == 0 {
            LLVMBuildRetVoid(self.builder)
        } else if ret_ktype == "Str" {
            // Return empty string literal as default
            let empty = LLVMBuildGlobalStringPtr(self.builder, "", "default_str")
            LLVMBuildRet(self.builder, empty)
        } else {
            let ret_ll = self.map_type(ret_ktype)
            // For pointer/reference types, return null pointer
            if length(ret_ktype) > 0 && (ret_ktype[0] == Char(42) || ret_ktype[0] == Char(38)) {
                let null_val = LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
                let null_ptr = LLVMBuildIntToPtr(self.builder, null_val, ret_ll, "null_ptr")
                LLVMBuildRet(self.builder, null_ptr)
            } else if ret_ll == LLVMVoidTypeInContext(self.ctx) {
                LLVMBuildRetVoid(self.builder)
            } else {
                LLVMBuildRet(self.builder, LLVMConstInt(ret_ll, 0, false))
            }
        }
        self.last_was_term = true
    }
    self.cur_func_sret_ptr = 0 as *Void
}

fn gen_stmt(self, stmt_idx: Int) {
    if stmt_idx < 0 { return }
    let stmt = self.stmt_pool.get(stmt_idx)
    if self.last_was_term { return }

    if stmt.kind == StmtKind.sk_block {
        var i = 0
        while i < stmt.block_stmts.length() {
            self.gen_stmt(stmt.block_stmts.get(i))
            i = i + 1
        }
        return
    }
    if stmt.kind == StmtKind.sk_var_decl {
        let name = stmt.vardecl_name
        var vtype = stmt.vardecl_type
        if length(vtype) == 0 {
            vtype = self.get_expr_type(stmt.vardecl_value)
        }
        // Never alloca void type - use i64 as safe fallback
        var lltype = self.map_type(vtype)
        if lltype == LLVMVoidTypeInContext(self.ctx) {
            lltype = LLVMInt64TypeInContext(self.ctx)
            vtype = "Int"
        }
        
        var addr: *Void = 0 as *Void
        if self.cur_func == 0 as *Void {
            // Global variable
            addr = LLVMAddGlobal(self.module, lltype, name)
            if stmt.vardecl_value >= 0 {
                let init_val = self.gen_expr(stmt.vardecl_value)
                LLVMSetInitializer(addr, init_val)
            } else {
                LLVMSetInitializer(addr, LLVMConstNull(lltype))
            }
        } else {
            // Local variable
            if stmt.vardecl_value >= 0 {
                let val_node = self.expr_pool.get(stmt.vardecl_value)
                if val_node.kind == ExprKind.ek_struct_init {
                    // Struct init returns an alloca pointer - use it directly as variable address
                    addr = self.gen_expr(stmt.vardecl_value)
                } else if (val_node.kind == ExprKind.ek_func_call || val_node.kind == ExprKind.ek_method_call) {
                    // Check if the callee uses sret convention — if so, gen_expr already allocates
                    // the sret slot and returns it as the pointer; use that directly as the var addr.
                    var callee_is_sret = false
                    if val_node.kind == ExprKind.ek_func_call {
                        let cfname = val_node.func_name
                        // Plain free-function call
                        let sret_flag = type_map_get(&self.func_is_sret, cfname)
                        if sret_flag == "1" { callee_is_sret = true }
                        // Uppercase constructor sugar (e.g. KaiAllocator(...) -> KaiAllocator_init)
                        if !callee_is_sret && length(cfname) > 0 {
                            let fc = cfname[0]
                            if fc >= Char(65) && fc <= Char(90) {
                                let init_name = cfname + "_init"
                                let sret_flag2 = type_map_get(&self.func_is_sret, init_name)
                                if sret_flag2 == "1" { callee_is_sret = true }
                            }
                        }
                    } else {
                        // Method call: func_name = base_type + "_" + meth_name resolved by gen_expr
                        let mrec_type = self.get_expr_type(val_node.meth_expr)
                        let mbase = self.strip_pointers(mrec_type)
                        let mfname = mbase + "_" + val_node.meth_name
                        let sret_flag = type_map_get(&self.func_is_sret, mfname)
                        if sret_flag == "1" { callee_is_sret = true }
                    }
                    if callee_is_sret {
                        // gen_expr returns the sret alloca slot — use it directly (Defect C fix)
                        addr = self.gen_expr(stmt.vardecl_value)
                    } else {
                        addr = LLVMBuildAlloca(self.builder, lltype, name + ".addr")
                        var val = self.gen_expr(stmt.vardecl_value)
                        let val_type = self.get_expr_type(stmt.vardecl_value)
                        if lltype == LLVMInt64TypeInContext(self.ctx) && self.is_integer_type(val_type) {
                            val = self.cast_to_i64(val, val_type)
                        }
                        LLVMBuildStore(self.builder, val, addr)
                    }
                } else {
                    addr = LLVMBuildAlloca(self.builder, lltype, name + ".addr")
                    var val = self.gen_expr(stmt.vardecl_value)
                    let val_type = self.get_expr_type(stmt.vardecl_value)
                    if lltype == LLVMInt64TypeInContext(self.ctx) && self.is_integer_type(val_type) {
                        val = self.cast_to_i64(val, val_type)
                    }
                    LLVMBuildStore(self.builder, val, addr)
                }
            } else {
                addr = LLVMBuildAlloca(self.builder, lltype, name + ".addr")
            }
        }
        
        self.sym_store(name, addr, vtype)
        return
    }

    if stmt.kind == StmtKind.sk_expr {
        let _ = self.gen_expr(stmt.expr_stmt)
        return
    }

    if stmt.kind == StmtKind.sk_assignment {
        let lhs_node = self.expr_pool.get(stmt.assign_target)
        let rhs_val = self.gen_expr(stmt.assign_value)
        let op = stmt.assign_op
        
        if lhs_node.kind == ExprKind.ek_identifier {
            let addr = self.sym_lookup(lhs_node.ident_name)
            if addr != 0 as *Void {
                if length(op) > 0 && op != "=" {
                    // Compound assignment: load, operate, store
                    let ktype = self.sym_type(lhs_node.ident_name)
                    let lltype = self.map_type(ktype)
                    let cur_val = LLVMBuildLoad2(self.builder, lltype, addr, "cur_val")
                    var new_val: *Void = 0 as *Void
                    if op == "+=" { new_val = LLVMBuildAdd(self.builder, cur_val, rhs_val, "add_assign") }
                    else if op == "-=" { new_val = LLVMBuildSub(self.builder, cur_val, rhs_val, "sub_assign") }
                    else if op == "*=" { new_val = LLVMBuildMul(self.builder, cur_val, rhs_val, "mul_assign") }
                    else if op == "/=" { new_val = LLVMBuildSDiv(self.builder, cur_val, rhs_val, "div_assign") }
                    else if op == "%=" { new_val = LLVMBuildSRem(self.builder, cur_val, rhs_val, "rem_assign") }
                    else if op == "&=" { new_val = LLVMBuildAnd(self.builder, cur_val, rhs_val, "and_assign") }
                    else if op == "|=" { new_val = LLVMBuildOr(self.builder, cur_val, rhs_val, "or_assign") }
                    else if op == "^=" { new_val = LLVMBuildXor(self.builder, cur_val, rhs_val, "xor_assign") }
                    else if op == "<<=" { new_val = LLVMBuildShl(self.builder, cur_val, rhs_val, "shl_assign") }
                    else if op == ">>=" { new_val = LLVMBuildAShr(self.builder, cur_val, rhs_val, "shr_assign") }
                    else { new_val = rhs_val }
                    LLVMBuildStore(self.builder, new_val, addr)
                } else {
                    LLVMBuildStore(self.builder, rhs_val, addr)
                }
                return
            }
        }
        if lhs_node.kind == ExprKind.ek_deref {
            let addr = self.gen_expr(lhs_node.deref_expr)
            LLVMBuildStore(self.builder, rhs_val, addr)
            return
        }
        if lhs_node.kind == ExprKind.ek_field_access {
            let struct_node = self.expr_pool.get(lhs_node.field_expr)
            let rec_type = self.get_expr_type(lhs_node.field_expr)
            let base_type = self.strip_pointers(rec_type)
            
            let key = base_type + "." + lhs_node.field_name
            let idx_str = type_map_get(&self.struct_field_indices, key)
            let idx = self.str_to_int(idx_str)
            
            // For struct-typed identifier LHS, use the alloca address directly
            // (gen_expr on an identifier loads the value, making GEP invalid on struct values)
            var rec_ptr: *Void = 0 as *Void
            if struct_node.kind == ExprKind.ek_identifier && !self.is_pointer_type(rec_type) {
                let addr = self.sym_lookup(struct_node.ident_name)
                if addr != 0 as *Void {
                    rec_ptr = addr
                } else {
                    rec_ptr = self.gen_expr(lhs_node.field_expr)
                }
            } else {
                rec_ptr = self.gen_expr(lhs_node.field_expr)
            }
            let struct_lltype = self.map_type(base_type)
            // For non-pointer, non-identifier receiver (e.g. method call returning struct),
            // spill to alloca so GEP has a valid pointer base.
            if !self.is_pointer_type(rec_type) && struct_node.kind != ExprKind.ek_identifier {
                let tmp_addr = LLVMBuildAlloca(self.builder, struct_lltype, "field_tmp")
                LLVMBuildStore(self.builder, rec_ptr, tmp_addr)
                rec_ptr = tmp_addr
            }
            let gep = LLVMBuildStructGEP2(self.builder, struct_lltype, rec_ptr, idx, "field_gep")
            LLVMBuildStore(self.builder, rhs_val, gep)
            return
        }
        if lhs_node.kind == ExprKind.ek_index {
            let arr_ptr = self.gen_expr(lhs_node.idx_expr)
            let idx_val = self.gen_expr(lhs_node.idx_index)
            let arr_type = self.get_expr_type(lhs_node.idx_expr)
            var elem_ktype = "Int"
            if length(arr_type) > 2 && substring(arr_type, 0, 2) == "[]" {
                elem_ktype = substring(arr_type, 2, length(arr_type))
            }
            let elem_lltype = self.map_type(elem_ktype)
            let gep = LLVMBuildGEP2(self.builder, elem_lltype, arr_ptr, &idx_val as *Void, 1, "idx_gep")
            LLVMBuildStore(self.builder, rhs_val, gep)
            return
        }
        return
    }

    if stmt.kind == StmtKind.sk_return {
        if stmt.return_value >= 0 {
            let val = self.gen_expr(stmt.return_value)
            let ret_type = self.cur_func_ret_type
            let val_type = self.get_expr_type(stmt.return_value)

            // sret path: store into the hidden sret pointer and return void
            if self.cur_func_sret_ptr != 0 as *Void {
                let sret_ll = self.map_type(ret_type)
                let ret_expr_node = self.expr_pool.get(stmt.return_value)
                if ret_expr_node.kind == ExprKind.ek_struct_init {
                    // gen_expr for ek_struct_init returns an alloca ptr, load through it
                    let loaded = LLVMBuildLoad2(self.builder, sret_ll, val, "sret_val")
                    LLVMBuildStore(self.builder, loaded, self.cur_func_sret_ptr)
                } else {
                    LLVMBuildStore(self.builder, val, self.cur_func_sret_ptr)
                }
                LLVMBuildRetVoid(self.builder)
                self.last_was_term = true
                return
            }

            // Wrap value in Result struct for error union return types
            if self.str_contains(ret_type, Char(33)) && !self.str_contains(val_type, Char(33)) {
                let res_lltype = self.map_type(ret_type)
                let ret_addr = LLVMBuildAlloca(self.builder, res_lltype, "ret_result")

                // Check if returning an error (enum type) or a value (primitive)
                let excl_pos = self.str_find(ret_type, Char(33))
                let result_val_type = substring(ret_type, 0, excl_pos)
                let result_err_type = substring(ret_type, excl_pos + 1, length(ret_type))

                let is_error_val = (length(type_map_get(&self.enum_types, val_type)) > 0)
                let tag_gep = LLVMBuildStructGEP2(self.builder, res_lltype, ret_addr, 0, "tag_gep")
                if is_error_val {
                    // Returning an error: tag = 1 (or the error code), value = 0
                    LLVMBuildStore(self.builder, LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 1, false), tag_gep)
                } else {
                    // Returning a value: tag = 0 (ok)
                    LLVMBuildStore(self.builder, LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false), tag_gep)
                    let val_gep = LLVMBuildStructGEP2(self.builder, res_lltype, ret_addr, 1, "val_gep")
                    LLVMBuildStore(self.builder, val, val_gep)
                }
                let wrapped = LLVMBuildLoad2(self.builder, res_lltype, ret_addr, "wrapped_result")
                LLVMBuildRet(self.builder, wrapped)
            } else if length(ret_type) > 0 && ret_type[0] == Char(63) && !(length(val_type) > 0 && val_type[0] == Char(63)) {
                // Wrap value in Optional struct — but check for `return none` (identifier "none")
                let opt_lltype = self.map_type(ret_type)
                let ret_addr = LLVMBuildAlloca(self.builder, opt_lltype, "ret_opt")

                // Detect `return none`: check if return expr is `none` (literal NONE or identifier "none")
                let ret_expr_node = self.expr_pool.get(stmt.return_value)
                var is_none = false
                if ret_expr_node.kind == ExprKind.ek_literal && ret_expr_node.lit_vkind == "NONE" {
                    is_none = true
                }
                if ret_expr_node.kind == ExprKind.ek_identifier && ret_expr_node.ident_name == "none" {
                    is_none = true
                }

                let has_gep = LLVMBuildStructGEP2(self.builder, opt_lltype, ret_addr, 0, "has_gep")
                if is_none {
                    // Return none: has_value = 0
                    LLVMBuildStore(self.builder, LLVMConstInt(LLVMInt8TypeInContext(self.ctx), 0, false), has_gep)
                } else {
                    LLVMBuildStore(self.builder, LLVMConstInt(LLVMInt8TypeInContext(self.ctx), 1, false), has_gep)
                    let val_gep = LLVMBuildStructGEP2(self.builder, opt_lltype, ret_addr, 1, "val_gep")
                    LLVMBuildStore(self.builder, val, val_gep)
                }

                let wrapped = LLVMBuildLoad2(self.builder, opt_lltype, ret_addr, "wrapped_opt")
                LLVMBuildRet(self.builder, wrapped)
            } else {
                // Check if we need to cast the return value to match the declared type
                let ret_ll = self.map_type(ret_type)
                let ret_is_ptr = length(ret_type) > 0 && ret_type[0] == Char(42)
                let ret_is_str = ret_type == "Str"
                let val_is_int = val_type == "Int" || val_type == "Bool" || val_type == "Char" || val_type == "Int8" || val_type == "Int32"
                let val_is_ptr = length(val_type) > 0 && val_type[0] == Char(42)

                if (ret_is_ptr || ret_is_str) && val_is_int {
                    // int -> ptr: inttoptr
                    let cast_val = LLVMBuildIntToPtr(self.builder, val, ret_ll, "cast_ret")
                    LLVMBuildRet(self.builder, cast_val)
                } else if !ret_is_ptr && !ret_is_str && val_is_ptr {
                    // ptr -> int: ptrtoint
                    let cast_val = LLVMBuildPtrToInt(self.builder, val, ret_ll, "cast_ret")
                    LLVMBuildRet(self.builder, cast_val)
                } else {
                    LLVMBuildRet(self.builder, val)
                }
            }
        } else {
            // Check if the function returns Optional/Result for 'return none'
            let ret_type = self.cur_func_ret_type
            // sret path with no value: just return void
            if self.cur_func_sret_ptr != 0 as *Void {
                LLVMBuildRetVoid(self.builder)
                self.last_was_term = true
                return
            }
            if length(ret_type) > 0 && ret_type[0] == Char(63) {
                // Return none: Optional with has_value=0
                let opt_lltype = self.map_type(ret_type)
                let ret_addr = LLVMBuildAlloca(self.builder, opt_lltype, "none_opt")
                // Zero-initialize
                let has_gep = LLVMBuildStructGEP2(self.builder, opt_lltype, ret_addr, 0, "has_gep")
                LLVMBuildStore(self.builder, LLVMConstInt(LLVMInt8TypeInContext(self.ctx), 0, false), has_gep)
                let wrapped = LLVMBuildLoad2(self.builder, opt_lltype, ret_addr, "none_result")
                LLVMBuildRet(self.builder, wrapped)
            } else {
                LLVMBuildRetVoid(self.builder)
            }
        }
        self.last_was_term = true
        return
    }

    if stmt.kind == StmtKind.sk_if {
        let cond_val = self.gen_expr(stmt.if_cond)
        let cond_i1 = LLVMBuildICmp(self.builder, 33, cond_val, LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false), "cond_i1")
        
        let then_bb = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "then")
        let else_bb = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "else")
        let merge_bb = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "merge")
        
        LLVMBuildCondBr(self.builder, cond_i1, then_bb, else_bb)
        
        // Then block
        LLVMPositionBuilderAtEnd(self.builder, then_bb)
        self.last_was_term = false
        self.gen_stmt(stmt.if_then)
        if !self.last_was_term {
            LLVMBuildBr(self.builder, merge_bb)
        }
        
        // Else block
        LLVMPositionBuilderAtEnd(self.builder, else_bb)
        self.last_was_term = false
        if stmt.if_else >= 0 {
            self.gen_stmt(stmt.if_else)
        }
        if !self.last_was_term {
            LLVMBuildBr(self.builder, merge_bb)
        }
        
        // Merge block
        LLVMPositionBuilderAtEnd(self.builder, merge_bb)
        self.last_was_term = false
        return
    }

    if stmt.kind == StmtKind.sk_while {
        let cond_bb = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "loop_cond")
        let body_bb = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "loop_body")
        let end_bb = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "loop_end")
        
        LLVMBuildBr(self.builder, cond_bb)
        
        // Cond block
        LLVMPositionBuilderAtEnd(self.builder, cond_bb)
        self.last_was_term = false
        let cond_val = self.gen_expr(stmt.while_cond)
        let cond_i1 = LLVMBuildICmp(self.builder, 33, cond_val, LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false), "cond_i1")
        LLVMBuildCondBr(self.builder, cond_i1, body_bb, end_bb)
        
        // Push stacks
        self.loop_cond_stack.push(int_to_str(cond_bb as Int))
        self.loop_step_stack.push(int_to_str(cond_bb as Int))
        self.loop_end_stack.push(int_to_str(end_bb as Int))
        
        // Body block
        LLVMPositionBuilderAtEnd(self.builder, body_bb)
        self.last_was_term = false
        self.gen_stmt(stmt.while_body)
        if !self.last_was_term {
            LLVMBuildBr(self.builder, cond_bb)
        }
        
        // Pop stacks
        let _ = self.loop_cond_stack.pop()
        let _ = self.loop_step_stack.pop()
        let _ = self.loop_end_stack.pop()
        
        // End block
        LLVMPositionBuilderAtEnd(self.builder, end_bb)
        self.last_was_term = false
        return
    }

    if stmt.kind == StmtKind.sk_for {
        let loop_var = stmt.for_var
        let start_val = self.gen_expr(stmt.for_start)
        let end_val = self.gen_expr(stmt.for_end)
        
        let i_ll = LLVMInt64TypeInContext(self.ctx)
        let var_addr = LLVMBuildAlloca(self.builder, i_ll, loop_var)
        LLVMBuildStore(self.builder, start_val, var_addr)
        self.sym_store(loop_var, var_addr, "Int")
        
        let cond_bb = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "for_cond")
        let body_bb = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "for_body")
        let step_bb = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "for_step")
        let end_bb = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "for_end")
        
        LLVMBuildBr(self.builder, cond_bb)
        
        // Cond block
        LLVMPositionBuilderAtEnd(self.builder, cond_bb)
        self.last_was_term = false
        let current_i = LLVMBuildLoad2(self.builder, i_ll, var_addr, "curr_i")
        let cmp = LLVMBuildICmp(self.builder, 40, current_i, end_val, "cmp")
        LLVMBuildCondBr(self.builder, cmp, body_bb, end_bb)
        
        // Push stacks
        self.loop_cond_stack.push(int_to_str(cond_bb as Int))
        self.loop_step_stack.push(int_to_str(step_bb as Int))
        self.loop_end_stack.push(int_to_str(end_bb as Int))
        
        // Body block
        LLVMPositionBuilderAtEnd(self.builder, body_bb)
        self.last_was_term = false
        self.gen_stmt(stmt.for_body)
        if !self.last_was_term {
            LLVMBuildBr(self.builder, step_bb)
        }
        
        // Step block
        LLVMPositionBuilderAtEnd(self.builder, step_bb)
        self.last_was_term = false
        let val_step = LLVMBuildLoad2(self.builder, i_ll, var_addr, "val_step")
        let next_val = LLVMBuildAdd(self.builder, val_step, LLVMConstInt(i_ll, 1, false), "next_val")
        LLVMBuildStore(self.builder, next_val, var_addr)
        LLVMBuildBr(self.builder, cond_bb)
        
        // Pop stacks
        let _ = self.loop_cond_stack.pop()
        let _ = self.loop_step_stack.pop()
        let _ = self.loop_end_stack.pop()
        
        // End block
        LLVMPositionBuilderAtEnd(self.builder, end_bb)
        self.last_was_term = false
        return
    }

    if stmt.kind == StmtKind.sk_break {
        let end_bb_str = self.loop_end_stack.get(self.loop_end_stack.length() - 1)
        let end_bb = self.str_to_int(end_bb_str) as *Void
        LLVMBuildBr(self.builder, end_bb)
        self.last_was_term = true
        return
    }

    if stmt.kind == StmtKind.sk_continue {
        let step_bb_str = self.loop_step_stack.get(self.loop_step_stack.length() - 1)
        let step_bb = self.str_to_int(step_bb_str) as *Void
        LLVMBuildBr(self.builder, step_bb)
        self.last_was_term = true
        return
    }

    if stmt.kind == StmtKind.sk_match {
        self.gen_match(stmt_idx)
        return
    }

    if stmt.kind == StmtKind.sk_import {
        self.handle_import(stmt_idx)
        return
    }

    if stmt.kind == StmtKind.sk_unsafe {
        // unsafe block - just emit the body
        if stmt.unsafe_body >= 0 {
            self.gen_stmt(stmt.unsafe_body)
        }
        return
    }

    if stmt.kind == StmtKind.sk_defer {
        // TODO: Full defer semantics requires a per-scope defer stack.
        // For now, skip defer body at declaration point.
        // The C codegen handles defers correctly; this LLVM backend
        // will need a proper defer stack implementation in a future pass.
        return
    }

    if stmt.kind == StmtKind.sk_print {
        if stmt.print_value >= 0 {
            let ptype = self.get_expr_type(stmt.print_value)
            let pval  = self.gen_expr(stmt.print_value)
            self.emit_print_call(ptype, pval)
        }
        return
    }

    if stmt.kind == StmtKind.sk_if_let {
        // if let val = optional_expr { ... }
        let opt_val = self.gen_expr(stmt.iflet_expr)
        let opt_type = self.get_expr_type(stmt.iflet_expr)

        // Determine inner type (strip leading ?)
        var inner_type = opt_type
        if length(opt_type) > 0 && opt_type[0] == Char(63) {
            inner_type = substring(opt_type, 1, length(opt_type))
        }

        let then_bb  = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "iflet_then")
        let else_bb  = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "iflet_else")
        let merge_bb = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "iflet_merge")

        var cond_i1: *Void = 0 as *Void
        if self.is_pointer_type(inner_type) {
            // ?Ptr — null == none
            let null_ptr = LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
            cond_i1 = LLVMBuildICmp(self.builder, 33, opt_val, null_ptr, "iflet_cond")
        } else {
            // Optional struct { has_value: i8, value: T }
            // Store opt_val to alloca first to get a pointer for GEP
            let opt_lltype = self.map_type(opt_type)
            let opt_tmp = LLVMBuildAlloca(self.builder, opt_lltype, "opt_iflet_tmp")
            LLVMBuildStore(self.builder, opt_val, opt_tmp)
            let tag_gep = LLVMBuildStructGEP2(self.builder, opt_lltype, opt_tmp, 0, "has_val_gep")
            let has_val = LLVMBuildLoad2(self.builder, LLVMInt8TypeInContext(self.ctx), tag_gep, "has_val")
            cond_i1 = LLVMBuildICmp(self.builder, 33, has_val, LLVMConstInt(LLVMInt8TypeInContext(self.ctx), 0, false), "iflet_cond")
        }
        LLVMBuildCondBr(self.builder, cond_i1, then_bb, else_bb)

        // Then block: bind the variable
        LLVMPositionBuilderAtEnd(self.builder, then_bb)
        self.last_was_term = false
        var inner_lltype = self.map_type(inner_type)
        if inner_lltype == LLVMVoidTypeInContext(self.ctx) {
            inner_lltype = LLVMInt64TypeInContext(self.ctx)
        }
        let bind_addr = LLVMBuildAlloca(self.builder, inner_lltype, stmt.iflet_var + ".addr")
        if self.is_pointer_type(inner_type) {
            LLVMBuildStore(self.builder, opt_val, bind_addr)
        } else {
            let opt_lltype2 = self.map_type(opt_type)
            let opt_tmp2 = LLVMBuildAlloca(self.builder, opt_lltype2, "opt_iflet_tmp2")
            LLVMBuildStore(self.builder, opt_val, opt_tmp2)
            let val_gep = LLVMBuildStructGEP2(self.builder, opt_lltype2, opt_tmp2, 1, "val_gep")
            let unwrapped = LLVMBuildLoad2(self.builder, inner_lltype, val_gep, "unwrapped")
            LLVMBuildStore(self.builder, unwrapped, bind_addr)
        }
        self.sym_store(stmt.iflet_var, bind_addr, inner_type)
        self.gen_stmt(stmt.iflet_then)
        if !self.last_was_term {
            LLVMBuildBr(self.builder, merge_bb)
        }

        // Else block
        LLVMPositionBuilderAtEnd(self.builder, else_bb)
        self.last_was_term = false
        if stmt.iflet_else >= 0 {
            self.gen_stmt(stmt.iflet_else)
        }
        if !self.last_was_term {
            LLVMBuildBr(self.builder, merge_bb)
        }

        LLVMPositionBuilderAtEnd(self.builder, merge_bb)
        self.last_was_term = false
        return
    }
}

// ============================================================================
// Code Generation: Expressions
// ============================================================================

fn gen_expr(self, idx: Int) -> *Void {
    if idx < 0 { return 0 as *Void }
    let expr = self.expr_pool.get(idx)

    // ---- Literals ----
    if expr.kind == ExprKind.ek_literal {
        let vk = expr.lit_vkind
        if vk == "INT" {
            var val_int = 0
            match expr.lit_value {
                case .tv_int(v) => { val_int = v }
                case .tv_str(v) => { val_int = self.str_to_int(v) }
                case else => {}
            }
            return LLVMConstInt(LLVMInt64TypeInContext(self.ctx), val_int, true)
        }
        if vk == "FLOAT" {
            return LLVMConstReal(LLVMDoubleTypeInContext(self.ctx), 0.0)
        }
        if vk == "STRING" {
            var s_val = ""
            match expr.lit_value {
                case .tv_str(v) => { s_val = v }
                case else => {}
            }
            return LLVMBuildGlobalStringPtr(self.builder, s_val, "str_lit")
        }
        if vk == "BOOL" {
            var b_val = 0
            match expr.lit_value {
                case .tv_bool(v) => { if v { b_val = 1 } }
                case .tv_str(v) => {
                    let is_true = strcmp(v, "true")
                    if is_true == 0 { b_val = 1 }
                }
                case .tv_int(v) => { b_val = v }
                case else => {}
            }
            return LLVMConstInt(LLVMInt64TypeInContext(self.ctx), b_val, false)
        }
        if vk == "CHAR" {
            var c_val = 0
            match expr.lit_value {
                case .tv_int(v) => { c_val = v }
                case .tv_str(v) => { if length(v) > 0 { c_val = v[0] as Int } }
                case else => {}
            }
            return LLVMConstInt(LLVMInt8TypeInContext(self.ctx), c_val, false)
        }
        return LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
    }

    // ---- Identifier ----
    if expr.kind == ExprKind.ek_identifier {
        let name = expr.ident_name
        // Handle 'none' - returns zero for optional types
        if name == "none" {
            return LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
        }
        let addr = self.sym_lookup(name)
        if addr != 0 as *Void {
            let ktype = self.sym_type(name)
            var lltype = self.map_type(ktype)
            if lltype == LLVMVoidTypeInContext(self.ctx) {
                lltype = LLVMInt64TypeInContext(self.ctx)
            }
            return LLVMBuildLoad2(self.builder, lltype, addr, name)
        }
        let func = LLVMGetNamedFunction(self.module, name)
        if func != 0 as *Void { return func }
        // Unknown identifier - return zero
        return LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
    }



    // ---- Binary Operation ----
    if expr.kind == ExprKind.ek_binary_op {
        let ltype = self.get_expr_type(expr.binop_left)
        let op = expr.binop_op

        // String operations
        if ltype == "Str" && op == "+" {
            let lv = self.gen_expr(expr.binop_left)
            let rv = self.gen_expr(expr.binop_right)
            
            let concat_func = LLVMGetNamedFunction(self.module, "_kai_str_concat")
            let params = self.allocator.alloc(16, 8) as **Void
            params[0] = lv
            params[1] = rv
            
            let str_ptr = LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
            let fn_ty = LLVMFunctionType(str_ptr, params as *Void, 2, false)
            let res = LLVMBuildCall2(self.builder, fn_ty, concat_func, params as *Void, 2, "concat_res")
            self.allocator.free(params as *Void)
            return res
        }
        if ltype == "Str" && (op == "==" || op == "!=") {
            let lv = self.gen_expr(expr.binop_left)
            let rv = self.gen_expr(expr.binop_right)
            let strcmp_func = self.get_strcmp()
            
            let params = self.allocator.alloc(16, 8) as **Void
            params[0] = lv
            params[1] = rv
            
            let str_ptr = LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
            let fn_ty = LLVMFunctionType(LLVMInt64TypeInContext(self.ctx), params as *Void, 2, false)
            let cmp = LLVMBuildCall2(self.builder, fn_ty, strcmp_func, params as *Void, 2, "cmp_res")
            
            var res: *Void = 0 as *Void
            if op == "==" {
                res = LLVMBuildICmp(self.builder, 32, cmp, LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false), "eq_res")
            } else {
                res = LLVMBuildICmp(self.builder, 33, cmp, LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false), "ne_res")
            }
            let res_i64 = LLVMBuildZExt(self.builder, res, LLVMInt64TypeInContext(self.ctx), "zext")
            self.allocator.free(params as *Void)
            return res_i64
        }

        var lv = self.gen_expr(expr.binop_left)
        var rv = self.gen_expr(expr.binop_right)
        let rtype = self.get_expr_type(expr.binop_right)
        
        // Float operations
        if ltype == "Float" {
            if op == "+" { return LLVMBuildFAdd(self.builder, lv, rv, "fadd") }
            if op == "-" { return LLVMBuildFSub(self.builder, lv, rv, "fsub") }
            if op == "*" { return LLVMBuildFMul(self.builder, lv, rv, "fmul") }
            if op == "/" { return LLVMBuildFDiv(self.builder, lv, rv, "fdiv") }
            return LLVMConstReal(LLVMDoubleTypeInContext(self.ctx), 0.0)
        }

        // Integer operations: Promote both to i64
        if self.is_integer_type(ltype) { lv = self.cast_to_i64(lv, ltype) }
        if self.is_integer_type(rtype) { rv = self.cast_to_i64(rv, rtype) }

        if op == "+" { return LLVMBuildAdd(self.builder, lv, rv, "add") }
        if op == "-" { return LLVMBuildSub(self.builder, lv, rv, "sub") }
        if op == "*" { return LLVMBuildMul(self.builder, lv, rv, "mul") }
        if op == "/" { return LLVMBuildSDiv(self.builder, lv, rv, "div") }
        if op == "%" { return LLVMBuildSRem(self.builder, lv, rv, "rem") }
        if op == "&" { return LLVMBuildAnd(self.builder, lv, rv, "and") }
        if op == "|" { return LLVMBuildOr(self.builder, lv, rv, "or") }
        if op == "^" { return LLVMBuildXor(self.builder, lv, rv, "xor") }
        if op == "<<" { return LLVMBuildShl(self.builder, lv, rv, "shl") }
        if op == ">>" { return LLVMBuildAShr(self.builder, lv, rv, "ashr") }

        var cmp_val: *Void = 0 as *Void
        // Normalize pointer-to-integer comparisons before icmp
        // If one side is a pointer type and the other is integer 0 (null check), convert
        // the integer to a null pointer so both sides have matching ptr type for icmp.
        if op == "==" || op == "!=" || op == "<" || op == "<=" || op == ">" || op == ">=" {
            let ltype_is_ptr = self.is_pointer_type(ltype)
            let rtype_is_ptr = self.is_pointer_type(rtype)
            if ltype_is_ptr && !rtype_is_ptr {
                // lv is ptr, rv is int — convert rv to null ptr
                let ptr_ll = self.map_type(ltype)
                rv = LLVMBuildIntToPtr(self.builder, rv, ptr_ll, "null_ptr")
            } else if !ltype_is_ptr && rtype_is_ptr {
                // lv is int, rv is ptr — convert lv to ptr
                let ptr_ll = self.map_type(rtype)
                lv = LLVMBuildIntToPtr(self.builder, lv, ptr_ll, "null_ptr")
            }
        }
        if op == "==" { cmp_val = LLVMBuildICmp(self.builder, 32, lv, rv, "eq") }
        else if op == "!=" { cmp_val = LLVMBuildICmp(self.builder, 33, lv, rv, "ne") }
        else if op == "<" { cmp_val = LLVMBuildICmp(self.builder, 40, lv, rv, "lt") }
        else if op == "<=" { cmp_val = LLVMBuildICmp(self.builder, 41, lv, rv, "le") }
        else if op == ">" { cmp_val = LLVMBuildICmp(self.builder, 38, lv, rv, "gt") }
        else if op == ">=" { cmp_val = LLVMBuildICmp(self.builder, 39, lv, rv, "ge") }
        else if op == "&&" { cmp_val = LLVMBuildAnd(self.builder, lv, rv, "logical_and") }
        else if op == "||" { cmp_val = LLVMBuildOr(self.builder, lv, rv, "logical_or") }

        if cmp_val != 0 as *Void {
            return LLVMBuildZExt(self.builder, cmp_val, LLVMInt64TypeInContext(self.ctx), "zext")
        }
        return lv
    }

    // ---- Unary Operation ----
    if expr.kind == ExprKind.ek_unary_op {
        let val = self.gen_expr(expr.unop_operand)
        let op = expr.unop_op
        if op == "-" {
            let zero = LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
            return LLVMBuildSub(self.builder, zero, val, "neg")
        }
        if op == "!" {
            let one = LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 1, false)
            let val_i64 = self.cast_to_i64(val, self.get_expr_type(expr.unop_operand))
            let xor_res = LLVMBuildXor(self.builder, val_i64, one, "negate")
            return xor_res
        }
        return val
    }

    // ---- Function Call ----
    if expr.kind == ExprKind.ek_func_call {
        let fname = expr.func_name
        
        if fname == "print" {
            if expr.func_args.length() > 0 {
                let arg_idx = expr.func_args.get(0)
                let ktype = self.get_expr_type(arg_idx)
                let val = self.gen_expr(arg_idx)
                self.emit_print_call(ktype, val)
            }
            return LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
        }
        if fname == "cast" || fname == "as" {
            if expr.func_type_args.length() > 0 && expr.func_args.length() > 0 {
                return self.gen_cast(expr.func_args.get(0), expr.func_type_args.get(0))
            }
            return self.gen_expr(expr.func_args.get(0))
        }
        if fname == "Char" || fname == "Int8" {
            let av = self.gen_expr(expr.func_args.get(0))
            let src_type = self.get_expr_type(expr.func_args.get(0))
            if src_type == "Int" {
                return LLVMBuildTrunc(self.builder, av, LLVMInt8TypeInContext(self.ctx), "trunc")
            }
            return av
        }
        if fname == "Int" {
            let av = self.gen_expr(expr.func_args.get(0))
            let src_type = self.get_expr_type(expr.func_args.get(0))
            if src_type == "Float" {
                return LLVMBuildFPToSI(self.builder, av, LLVMInt64TypeInContext(self.ctx), "fptosi")
            }
            if src_type == "Char" || src_type == "Int8" {
                return LLVMBuildSExt(self.builder, av, LLVMInt64TypeInContext(self.ctx), "sext")
            }
            return av
        }
        if fname == "Float" {
            let av = self.gen_expr(expr.func_args.get(0))
            let src_type = self.get_expr_type(expr.func_args.get(0))
            let double_type = LLVMDoubleTypeInContext(self.ctx)
            if src_type == "Int" {
                return LLVMBuildSIToFP(self.builder, av, double_type, "sitofp")
            }
            if src_type == "Char" {
                let ext = LLVMBuildSExt(self.builder, av, LLVMInt64TypeInContext(self.ctx), "sext")
                return LLVMBuildSIToFP(self.builder, ext, double_type, "sitofp")
            }
            return av
        }
        if fname == "size_of" {
            return LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 8, false)
        }

        let first_char = fname[0]
        let is_upper = first_char >= Char(65) && first_char <= Char(90)
        // Only treat as constructor if the name is a registered struct type,
        // not arbitrary uppercase functions like LLVMContextCreate, StringBuilder, etc.
        // Check both struct_types and that an _init function actually exists.
        let potential_struct = length(type_map_get(&self.struct_types, fname)) > 0
        if is_upper && potential_struct {
            let init_name = fname + "_init"
            let func = LLVMGetNamedFunction(self.module, init_name)
            
            let arg_count = expr.func_args.length()
            // Constructor call: init method always takes self as first param.
            // Allocate a new instance and pass its address as self (args[0]).
            let struct_ll = self.map_type(fname)
            let self_slot = LLVMBuildAlloca(self.builder, struct_ll, fname + ".new")
            // Total args = 1 (self) + user-supplied args
            let total_args = arg_count + 1
            let args = self.allocator.alloc(total_args * 8, 8) as **Void
            args[0] = self_slot
            var i = 0
            while i < arg_count {
                args[i + 1] = self.gen_expr(expr.func_args.get(i))
                i = i + 1
            }
            
            // Build param types from registered func_param_types
            // param_0 = *StructName (self), param_1..N = user args
            let param_types = self.allocator.alloc(total_args * 8, 8) as **Void
            i = 0
            while i < total_args {
                let p_key = init_name + "_param_" + int_to_str(i)
                let p_ktype = type_map_get(&self.func_param_types, p_key)
                var pt = self.map_type(p_ktype)
                if pt == LLVMVoidTypeInContext(self.ctx) { pt = LLVMInt64TypeInContext(self.ctx) }
                param_types[i] = pt
                i = i + 1
            }

            // init methods return *StructName (the self pointer back)
            let ret_ktype = "*" + fname
            let ret_ll = self.map_type(ret_ktype)

            // Check if this init function uses sret calling convention
            if type_map_get(&self.func_is_sret, init_name) == "1" {
                // sret: prepend another sret slot before self
                let sret_ll = self.map_type(fname)
                let sret_slot = LLVMBuildAlloca(self.builder, sret_ll, "sret_slot")
                let sret_args = self.allocator.alloc((total_args + 1) * 8, 8) as **Void
                sret_args[0] = sret_slot
                var j = 0
                while j < total_args {
                    sret_args[j + 1] = args[j]
                    j = j + 1
                }
                let sret_param_types = self.allocator.alloc((total_args + 1) * 8, 8) as **Void
                sret_param_types[0] = LLVMPointerType(sret_ll, 0)
                j = 0
                while j < total_args {
                    sret_param_types[j + 1] = param_types[j]
                    j = j + 1
                }
                let sret_fn_ty = LLVMFunctionType(LLVMVoidTypeInContext(self.ctx), sret_param_types as *Void, total_args + 1, false)
                let _ = LLVMBuildCall2(self.builder, sret_fn_ty, func, sret_args as *Void, total_args + 1, "")
                self.allocator.free(args as *Void)
                self.allocator.free(param_types as *Void)
                self.allocator.free(sret_args as *Void)
                self.allocator.free(sret_param_types as *Void)
                return sret_slot
            }

            let fn_ty = LLVMFunctionType(ret_ll, param_types as *Void, total_args, false)
            let _ = LLVMBuildCall2(self.builder, fn_ty, func, args as *Void, total_args, "init_call")
            
            self.allocator.free(args as *Void)
            self.allocator.free(param_types as *Void)
            // Return the allocated self pointer as the "constructed" value
            return self_slot
        }

        if fname == "print_int" {
            if expr.func_args.length() > 0 {
                let av = self.gen_expr(expr.func_args.get(0))
                let src_type = self.get_expr_type(expr.func_args.get(0))
                self.emit_print_call(src_type, av)
            }
            return LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
        }
        if fname == "print_float" {
            if expr.func_args.length() > 0 {
                let av = self.gen_expr(expr.func_args.get(0))
                self.emit_print_call("Float", av)
            }
            return LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
        }
        if fname == "print_bool" {
            if expr.func_args.length() > 0 {
                let av = self.gen_expr(expr.func_args.get(0))
                self.emit_print_call("Bool", av)
            }
            return LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
        }

        var func = LLVMGetNamedFunction(self.module, fname)
        let arg_count = expr.func_args.length()
        let args = self.allocator.alloc((arg_count + 1) * 8, 8) as **Void
        var i = 0
        while i < arg_count {
            args[i] = self.gen_expr(expr.func_args.get(i))
            i = i + 1
        }
        
        let ret_ktype = type_map_get(&self.func_types, fname)
        var ret_ll = self.map_type(ret_ktype)
        if ret_ll == LLVMVoidTypeInContext(self.ctx) {
            ret_ll = LLVMInt64TypeInContext(self.ctx)
        }
        let param_types = self.allocator.alloc((arg_count + 1) * 8, 8) as **Void
        i = 0
        while i < arg_count {
            let p_key = fname + "_param_" + int_to_str(i)
            let p_ktype = type_map_get(&self.func_param_types, p_key)
            var pt = self.map_type(p_ktype)
            if pt == LLVMVoidTypeInContext(self.ctx) {
                pt = LLVMInt64TypeInContext(self.ctx)
            }
            param_types[i] = pt
            i = i + 1
        }
        let fn_ty = LLVMFunctionType(ret_ll, param_types as *Void, arg_count, false)

        // If function not found in module, auto-declare it
        if func == 0 as *Void {
            func = LLVMAddFunction(self.module, fname, fn_ty)
        }

        // Use empty name for void-returning calls
        var call_name = "call"
        if ret_ll == LLVMVoidTypeInContext(self.ctx) {
            call_name = ""
        }

        // Check if function uses sret calling convention
        if type_map_get(&self.func_is_sret, fname) == "1" {
            let sret_ll = self.map_type(ret_ktype)
            let sret_slot = LLVMBuildAlloca(self.builder, sret_ll, "sret_slot")
            let sret_args = self.allocator.alloc((arg_count + 1) * 8, 8) as **Void
            sret_args[0] = sret_slot
            var j = 0
            while j < arg_count {
                sret_args[j + 1] = args[j]
                j = j + 1
            }
            let sret_ptypes = self.allocator.alloc((arg_count + 1) * 8, 8) as **Void
            sret_ptypes[0] = LLVMPointerType(sret_ll, 0)
            j = 0
            while j < arg_count {
                sret_ptypes[j + 1] = param_types[j]
                j = j + 1
            }
            let sret_fn_ty = LLVMFunctionType(LLVMVoidTypeInContext(self.ctx), sret_ptypes as *Void, arg_count + 1, false)
            let _ = LLVMBuildCall2(self.builder, sret_fn_ty, func, sret_args as *Void, arg_count + 1, "")
            self.allocator.free(args as *Void)
            self.allocator.free(param_types as *Void)
            self.allocator.free(sret_args as *Void)
            self.allocator.free(sret_ptypes as *Void)
            return sret_slot
        }

        let res = LLVMBuildCall2(self.builder, fn_ty, func, args as *Void, arg_count, call_name)
        
        self.allocator.free(args as *Void)
        self.allocator.free(param_types as *Void)
        return res
    }

    // ---- Method Call ----
    if expr.kind == ExprKind.ek_method_call {
        let rec_type = self.get_expr_type(expr.meth_expr)
        let base_type = self.strip_pointers(rec_type)
        let mname = expr.meth_name

        let is_enum_type = (length(base_type) > 0) && (length(type_map_get(&self.enum_types, base_type)) > 0)
        // Only use enum construction path if the method name is an actual enum variant
        // (has a TAG entry), not a regular method on an enum type like is_ok/is_err/unwrap
        let tag_key_check = base_type + "_" + mname + "_TAG"
        let is_enum_variant_call = is_enum_type && length(type_map_get(&self.enum_decls, tag_key_check)) > 0
        let is_enum = is_enum_variant_call
        if is_enum {
            let struct_lltype = self.map_type(base_type)
            // Stack-allocate the enum struct
            let alloca_val = LLVMBuildAlloca(self.builder, struct_lltype, "enum_meth_init")
            
            // Set tag
            let tag_key = base_type + "_" + mname + "_TAG"
            let tag_val_str = type_map_get(&self.enum_decls, tag_key)
            var tag_num = 0
            if length(tag_val_str) > 0 { tag_num = self.str_to_int(tag_val_str) }
            
            let tag_gep = LLVMBuildStructGEP2(self.builder, struct_lltype, alloca_val, 0, "tag_gep")
            LLVMBuildStore(self.builder, LLVMConstInt(LLVMInt8TypeInContext(self.ctx), tag_num, false), tag_gep)
            
            // Set payload
            if expr.meth_args.length() > 0 {
                let arg_idx = expr.meth_args.get(0)
                let val = self.gen_expr(arg_idx)
                let gep = LLVMBuildStructGEP2(self.builder, struct_lltype, alloca_val, 1, "payload_gep")
                let f_type = self.get_expr_type(arg_idx)
                let val_cast = self.cast_to_i64(val, f_type)
                LLVMBuildStore(self.builder, val_cast, gep)
            }
            // Load and return as value type
            return LLVMBuildLoad2(self.builder, struct_lltype, alloca_val, "enum_val")
        }

        let func_name = base_type + "_" + mname
        let func = LLVMGetNamedFunction(self.module, func_name)
        
        // Check if the receiver is a type name (static method call like Parser.init_with_pools)
        // rather than an instance. If the receiver identifier has no sym_table entry,
        // treat as a free function call with no self arg.
        let rec_node_check = self.expr_pool.get(expr.meth_expr)
        let is_static_call = (rec_node_check.kind == ExprKind.ek_identifier && self.sym_lookup(rec_node_check.ident_name) == 0 as *Void)

        let arg_count = expr.meth_args.length() + 1
        let args = self.allocator.alloc(arg_count * 8, 8) as **Void
        
        let rec_val = self.gen_expr(expr.meth_expr)
        if is_static_call {
            // Static method call: no self arg, shift user args to [0..N-1]
            var i2 = 0
            while i2 < expr.meth_args.length() {
                args[i2] = self.gen_expr(expr.meth_args.get(i2))
                i2 = i2 + 1
            }
        } else if rec_type[0] == Char(42) || rec_type[0] == Char(38) {
            args[0] = rec_val
        } else {
            let rec_node = self.expr_pool.get(expr.meth_expr)
            if rec_node.kind == ExprKind.ek_identifier {
                args[0] = self.sym_lookup(rec_node.ident_name)
            } else {
                let lltype = self.map_type(rec_type)
                let addr = LLVMBuildAlloca(self.builder, lltype, "rec_temp")
                LLVMBuildStore(self.builder, rec_val, addr)
                args[0] = addr
            }
        }
        
        var i = 0
        if !is_static_call {
            while i < expr.meth_args.length() {
                args[i + 1] = self.gen_expr(expr.meth_args.get(i))
                i = i + 1
            }
        }
        
        // For static calls, effective arg count is just the user args (no self)
        var effective_arg_count = arg_count
        if is_static_call { effective_arg_count = expr.meth_args.length() }
        
        let ret_ktype_raw = type_map_get(&self.func_types, func_name)
        // For generic container methods (e.g. ArrayList<T>_get), the return type
        // registered may be the generic "T" which falls back to i64. Infer the
        // concrete element type from the receiver's generic parameter instead.
        var ret_ktype = ret_ktype_raw
        if (ret_ktype == "" || ret_ktype == "T") && mname == "get" {
            // Extract element type from base_type: ArrayList<Token> -> Token
            let lt_pos2 = self.str_find(base_type, Char(60))
            if lt_pos2 >= 0 {
                let elem_t = substring(base_type, lt_pos2 + 1, length(base_type) - 1)
                if length(elem_t) > 0 { ret_ktype = elem_t }
            }
        }
        var ret_ll = self.map_type(ret_ktype)
        if ret_ll == LLVMVoidTypeInContext(self.ctx) {
            ret_ll = LLVMInt64TypeInContext(self.ctx)
        }
        let param_types = self.allocator.alloc(effective_arg_count * 8, 8) as **Void
        if is_static_call {
            // Static: no self param — use user param types starting at index 0
            i = 0
            while i < expr.meth_args.length() {
                let p_key = func_name + "_param_" + int_to_str(i)
                let p_ktype = type_map_get(&self.func_param_types, p_key)
                var pt = self.map_type(p_ktype)
                if pt == LLVMVoidTypeInContext(self.ctx) { pt = LLVMInt64TypeInContext(self.ctx) }
                param_types[i] = pt
                i = i + 1
            }
        } else {
            param_types[0] = LLVMPointerType(self.map_type(base_type), 0)
            i = 0
            while i < expr.meth_args.length() {
                let p_key = func_name + "_param_" + int_to_str(i)
                let p_ktype = type_map_get(&self.func_param_types, p_key)
                var pt = self.map_type(p_ktype)
                if pt == LLVMVoidTypeInContext(self.ctx) {
                    pt = LLVMInt64TypeInContext(self.ctx)
                }
                param_types[i + 1] = pt
                i = i + 1
            }
        }
        
        let fn_ty = LLVMFunctionType(ret_ll, param_types as *Void, effective_arg_count, false)

        // Auto-declare if not found
        if func == 0 as *Void {
            func = LLVMAddFunction(self.module, func_name, fn_ty)
        }

        var meth_call_name = "meth_call"
        if ret_ll == LLVMVoidTypeInContext(self.ctx) {
            meth_call_name = ""
        }

        // Check if method uses sret calling convention
        if type_map_get(&self.func_is_sret, func_name) == "1" {
            let sret_ll = self.map_type(ret_ktype)
            let sret_slot = LLVMBuildAlloca(self.builder, sret_ll, "sret_slot")
            let tot = effective_arg_count + 1
            let sret_args = self.allocator.alloc(tot * 8, 8) as **Void
            sret_args[0] = sret_slot
            var j = 0
            while j < effective_arg_count {
                sret_args[j + 1] = args[j]
                j = j + 1
            }
            let sret_ptypes = self.allocator.alloc(tot * 8, 8) as **Void
            sret_ptypes[0] = LLVMPointerType(sret_ll, 0)
            j = 0
            while j < effective_arg_count {
                sret_ptypes[j + 1] = param_types[j]
                j = j + 1
            }
            let sret_fn_ty = LLVMFunctionType(LLVMVoidTypeInContext(self.ctx), sret_ptypes as *Void, tot, false)
            let _ = LLVMBuildCall2(self.builder, sret_fn_ty, func, sret_args as *Void, tot, "")
            self.allocator.free(args as *Void)
            self.allocator.free(param_types as *Void)
            self.allocator.free(sret_args as *Void)
            self.allocator.free(sret_ptypes as *Void)
            return sret_slot
        }

        let res = LLVMBuildCall2(self.builder, fn_ty, func, args as *Void, effective_arg_count, meth_call_name)
        
        self.allocator.free(args as *Void)
        self.allocator.free(param_types as *Void)
        return res
    }

    // ---- Struct Initialization ----
    if expr.kind == ExprKind.ek_struct_init {
        let sname = expr.struct_name
        let is_enum = (length(sname) > 0) && (self.str_contains(sname, Char(46)))
        if is_enum {
            let dot_pos = self.str_find(sname, Char(46))
            let enum_part = substring(sname, 0, dot_pos)
            let variant_name = substring(sname, dot_pos + 1, length(sname))
            
            let struct_lltype = self.map_type(enum_part)
            // Stack-allocate the enum struct
            let alloca_val = LLVMBuildAlloca(self.builder, struct_lltype, "enum_init")
            
            // Set tag
            let tag_key = enum_part + "_" + variant_name + "_TAG"
            let tag_val_str = type_map_get(&self.enum_decls, tag_key)
            var tag_num = 0
            if length(tag_val_str) > 0 { tag_num = self.str_to_int(tag_val_str) }
            
            let tag_gep = LLVMBuildStructGEP2(self.builder, struct_lltype, alloca_val, 0, "tag_gep")
            LLVMBuildStore(self.builder, LLVMConstInt(LLVMInt8TypeInContext(self.ctx), tag_num, false), tag_gep)
            
            // Set payload fields
            if expr.struct_fields.length() > 0 {
                let f = expr.struct_fields.get(0)
                let val = self.gen_expr(f.value)
                let gep = LLVMBuildStructGEP2(self.builder, struct_lltype, alloca_val, 1, "payload_gep")
                let f_type = self.get_expr_type(f.value)
                let val_cast = self.cast_to_i64(val, f_type)
                LLVMBuildStore(self.builder, val_cast, gep)
            }
            // Load and return as value type
            return LLVMBuildLoad2(self.builder, struct_lltype, alloca_val, "enum_val")
        }
        
        let struct_lltype = self.map_type(sname)
        // Stack-allocate the struct
        let alloca_val = LLVMBuildAlloca(self.builder, struct_lltype, "struct_init")
        
        // Initialize each field via GEP + store
        var i = 0
        while i < expr.struct_fields.length() {
            let f = expr.struct_fields.get(i)
            let field_ktype = self.get_field_type(sname, f.name)
            let field_lltype = self.map_type(field_ktype)
            let field_idx = self.get_field_index(sname, f.name)
            let val = self.gen_expr(f.value)
            let gep = LLVMBuildStructGEP2(self.builder, struct_lltype, alloca_val, field_idx, "field_gep")
            LLVMBuildStore(self.builder, val, gep)
            i = i + 1
        }
        // Return pointer to the struct (functions expect *StructType for self)
        return alloca_val
    }

    // ---- Borrow & Deref ----
    if expr.kind == ExprKind.ek_borrow {
        let inner = self.expr_pool.get(expr.borrow_expr)
        if inner.kind == ExprKind.ek_identifier {
            return self.sym_lookup(inner.ident_name)
        }
        if inner.kind == ExprKind.ek_field_access {
            let rec_type = self.get_expr_type(inner.field_expr)
            let base_type = self.strip_pointers(rec_type)
            let key = base_type + "." + inner.field_name
            let idx_str = type_map_get(&self.struct_field_indices, key)
            let idx = self.str_to_int(idx_str)
            
            // For struct-typed identifier, use sym_lookup (alloca ptr) not gen_expr (loads value)
            let inner_base_node = self.expr_pool.get(inner.field_expr)
            var rec_ptr: *Void = 0 as *Void
            if inner_base_node.kind == ExprKind.ek_identifier && !self.is_pointer_type(rec_type) {
                let addr = self.sym_lookup(inner_base_node.ident_name)
                if addr != 0 as *Void {
                    rec_ptr = addr
                } else {
                    rec_ptr = self.gen_expr(inner.field_expr)
                }
            } else {
                rec_ptr = self.gen_expr(inner.field_expr)
            }
            let struct_lltype = self.map_type(base_type)
            // For non-pointer, non-identifier receivers, spill to alloca
            if !self.is_pointer_type(rec_type) && inner_base_node.kind != ExprKind.ek_identifier {
                let tmp_addr = LLVMBuildAlloca(self.builder, struct_lltype, "borrow_tmp")
                LLVMBuildStore(self.builder, rec_ptr, tmp_addr)
                rec_ptr = tmp_addr
            }
            return LLVMBuildStructGEP2(self.builder, struct_lltype, rec_ptr, idx, "field_gep")
        }
        if inner.kind == ExprKind.ek_index {
            let arr_ptr = self.gen_expr(inner.idx_expr)
            let idx_val = self.gen_expr(inner.idx_index)
            let arr_type = self.get_expr_type(inner.idx_expr)
            var elem_ktype = "Int"
            if length(arr_type) > 2 && substring(arr_type, 0, 2) == "[]" {
                elem_ktype = substring(arr_type, 2, length(arr_type))
            }
            let elem_lltype = self.map_type(elem_ktype)
            return LLVMBuildGEP2(self.builder, elem_lltype, arr_ptr, &idx_val as *Void, 1, "idx_gep")
        }
        return self.gen_expr(expr.borrow_expr)
    }
    if expr.kind == ExprKind.ek_deref {
        let ptr_val = self.gen_expr(expr.deref_expr)
        let ptr_ktype = self.get_expr_type(expr.deref_expr)
        let elem_ktype = self.strip_pointers(ptr_ktype)
        let elem_lltype = self.map_type(elem_ktype)
        return LLVMBuildLoad2(self.builder, elem_lltype, ptr_val, "derefed")
    }

    // ---- Array Literal ----
    if expr.kind == ExprKind.ek_array {
        let count = expr.arr_elements.length()
        var elem_ktype = "Int"
        if count > 0 {
            elem_ktype = self.get_expr_type(expr.arr_elements.get(0))
        }
        let elem_lltype = self.map_type(elem_ktype)
        let arr_lltype = LLVMArrayType(elem_lltype, count)
        let addr = LLVMBuildAlloca(self.builder, arr_lltype, "arr_lit")
        
        var i = 0
        while i < count {
            let val = self.gen_expr(expr.arr_elements.get(i))
            let idx_const = LLVMConstInt(LLVMInt64TypeInContext(self.ctx), i, false)
            let indices = self.allocator.alloc(16, 8) as **Void
            indices[0] = LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
            indices[1] = idx_const
            
            let gep = LLVMBuildGEP2(self.builder, arr_lltype, addr, indices as *Void, 2, "arr_elem_gep")
            LLVMBuildStore(self.builder, val, gep)
            
            self.allocator.free(indices as *Void)
            i = i + 1
        }
        
        let indices2 = self.allocator.alloc(16, 8) as **Void
        indices2[0] = LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
        indices2[1] = LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
        let start_gep = LLVMBuildGEP2(self.builder, arr_lltype, addr, indices2 as *Void, 2, "arr_start")
        self.allocator.free(indices2 as *Void)
        return start_gep
    }

    // ---- Field Access ----
    if expr.kind == ExprKind.ek_field_access {
        let base_node = self.expr_pool.get(expr.field_expr)
        if base_node.kind == ExprKind.ek_identifier {
            let is_enum_val = (length(type_map_get(&self.enum_decls, base_node.ident_name)) > 0)
            if is_enum_val {
                let tag_key = base_node.ident_name + "_" + expr.field_name + "_TAG"
                let tag_val_str = type_map_get(&self.enum_decls, tag_key)
                var tag_num = 0
                if length(tag_val_str) > 0 { tag_num = self.str_to_int(tag_val_str) }
                return LLVMConstInt(LLVMInt64TypeInContext(self.ctx), tag_num, false)
            }
        }
        
        let rec_type = self.get_expr_type(expr.field_expr)
        let base_type = self.strip_pointers(rec_type)
        let key = base_type + "." + expr.field_name
        let idx_str = type_map_get(&self.struct_field_indices, key)
        let idx = self.str_to_int(idx_str)
        
        // For field access on a struct-typed local variable, use the alloca address
        // directly (not the loaded value) — gen_expr for an identifier loads the value,
        // which gives us the struct value instead of a pointer, making GEP invalid.
        var rec_ptr: *Void = 0 as *Void
        if base_node.kind == ExprKind.ek_identifier && !self.is_pointer_type(rec_type) {
            // struct-typed identifier: use sym_lookup to get the alloca pointer
            let addr = self.sym_lookup(base_node.ident_name)
            if addr != 0 as *Void {
                rec_ptr = addr
            } else {
                rec_ptr = self.gen_expr(expr.field_expr)
            }
        } else {
            rec_ptr = self.gen_expr(expr.field_expr)
        }
        let struct_lltype = self.map_type(base_type)
        
        // If rec_ptr is a struct value (not a pointer), store it to a temp alloca for GEP
        // This happens when the receiver is a method call returning a struct by value.
        // We can detect this: if rec_type is not a pointer and not empty, the value
        // might be a struct value rather than a pointer. The LLVM type of rec_ptr
        // should be a pointer to the struct for GEP to work. If it's an aggregate,
        // we need to spill to alloca first.
        // Heuristic: if rec_type doesn't start with * or & and maps to a struct type,
        // and the receiver is not an identifier (which we already handle above),
        // spill to alloca.
        if !self.is_pointer_type(rec_type) && base_node.kind != ExprKind.ek_identifier {
            let tmp_addr = LLVMBuildAlloca(self.builder, struct_lltype, "field_tmp")
            LLVMBuildStore(self.builder, rec_ptr, tmp_addr)
            rec_ptr = tmp_addr
        }
        
        let gep = LLVMBuildStructGEP2(self.builder, struct_lltype, rec_ptr, idx, "field_gep")
        let ftype = self.get_field_type(base_type, expr.field_name)
        let f_lltype = self.map_type(ftype)
        return LLVMBuildLoad2(self.builder, f_lltype, gep, expr.field_name)
    }

    // ---- Index Access ----
    if expr.kind == ExprKind.ek_index {
        let arr_ptr = self.gen_expr(expr.idx_expr)
        let idx_val = self.gen_expr(expr.idx_index)
        let arr_type = self.get_expr_type(expr.idx_expr)
        var elem_ktype = "Int"
        if length(arr_type) > 2 && substring(arr_type, 0, 2) == "[]" {
            elem_ktype = substring(arr_type, 2, length(arr_type))
        } else if arr_type == "Str" {
            elem_ktype = "Char"
        } else if length(arr_type) > 0 && arr_type[0] == Char(42) {
            // *T indexed -> element type is T (the thing being pointed to)
            elem_ktype = substring(arr_type, 1, length(arr_type))
        }
        var elem_lltype = self.map_type(elem_ktype)
        // For pointer element types, use ptr type for the load
        if length(elem_ktype) > 0 && elem_ktype[0] == Char(42) {
            elem_lltype = LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
        }
        if elem_lltype == LLVMVoidTypeInContext(self.ctx) {
            elem_lltype = LLVMInt64TypeInContext(self.ctx)
        }
        let gep = LLVMBuildGEP2(self.builder, elem_lltype, arr_ptr, &idx_val as *Void, 1, "idx_gep")
        return LLVMBuildLoad2(self.builder, elem_lltype, gep, "idx_val")
    }

    // ---- String Interpolation ----
    if expr.kind == ExprKind.ek_str_interp {
        if expr.interp_parts.length() == 0 {
            return LLVMBuildGlobalStringPtr(self.builder, "", "empty_str")
        }
        var result: *Void = 0 as *Void
        var i = 0
        while i < expr.interp_parts.length() {
            let part = expr.interp_parts.get(i)
            var part_val: *Void = 0 as *Void
            if part.kind == 0 {
                // Literal string
                part_val = LLVMBuildGlobalStringPtr(self.builder, part.str_val, "str_part")
            } else {
                // Expression part - format to string
                let pval = self.gen_expr(part.expr_idx)
                let ptype = self.get_expr_type(part.expr_idx)
                if ptype == "Str" {
                    part_val = pval
                } else {
                    // Use int_to_str if Int, else treat as opaque
                    let int_to_str_func = LLVMGetNamedFunction(self.module, "int_to_str")
                    if int_to_str_func != 0 as *Void && (ptype == "Int" || ptype == "Bool") {
                        let i64t = LLVMInt64TypeInContext(self.ctx)
                        let str_ptr_t = LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
                        // int_to_str returns Str — check if it uses sret (it shouldn't, Str is a ptr)
                        let its_sret = (type_map_get(&self.func_is_sret, "int_to_str") == "1")
                        if its_sret {
                            // sret path: allocate Str slot, pass as first arg
                            let sret_its = LLVMBuildAlloca(self.builder, str_ptr_t, "its_sret")
                            let its_params = self.allocator.alloc(16, 8) as **Void
                            its_params[0] = LLVMPointerType(str_ptr_t, 0)
                            its_params[1] = i64t
                            let fn_ty = LLVMFunctionType(LLVMVoidTypeInContext(self.ctx), its_params as *Void, 2, false)
                            let its_args = self.allocator.alloc(16, 8) as **Void
                            its_args[0] = sret_its
                            its_args[1] = pval
                            let _ = LLVMBuildCall2(self.builder, fn_ty, int_to_str_func, its_args as *Void, 2, "")
                            self.allocator.free(its_params as *Void)
                            self.allocator.free(its_args as *Void)
                            part_val = LLVMBuildLoad2(self.builder, str_ptr_t, sret_its, "its_val")
                        } else {
                            let i2s_params = self.allocator.alloc(8, 8) as **Void
                            i2s_params[0] = i64t
                            let fn_ty = LLVMFunctionType(str_ptr_t, i2s_params as *Void, 1, false)
                            let i2s_args = self.allocator.alloc(8, 8) as **Void
                            i2s_args[0] = pval
                            part_val = LLVMBuildCall2(self.builder, fn_ty, int_to_str_func, i2s_args as *Void, 1, "to_str")
                            self.allocator.free(i2s_params as *Void)
                            self.allocator.free(i2s_args as *Void)
                        }
                    } else {
                        part_val = LLVMBuildGlobalStringPtr(self.builder, "", "empty_part")
                    }
                }
            }
            if i == 0 {
                result = part_val
            } else {
                let concat_func = LLVMGetNamedFunction(self.module, "_kai_str_concat")
                let str_ptr_t = LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
                let cat_params = self.allocator.alloc(16, 8) as **Void
                cat_params[0] = result
                cat_params[1] = part_val
                let fn_ty = LLVMFunctionType(str_ptr_t, cat_params as *Void, 2, false)
                result = LLVMBuildCall2(self.builder, fn_ty, concat_func, cat_params as *Void, 2, "concat_res")
                self.allocator.free(cat_params as *Void)
            }
            i = i + 1
        }
        if result == 0 as *Void {
            return LLVMBuildGlobalStringPtr(self.builder, "", "empty_str")
        }
        return result
    }

    // ---- Catch (error union / optional unwrap with fallback) ----
    if expr.kind == ExprKind.ek_catch {
        let inner_val = self.gen_expr(expr.catch_expr)
        let inner_type = self.get_expr_type(expr.catch_expr)

        if length(inner_type) > 0 && inner_type[0] == Char(63) {
            // Optional catch: ?T catch fallback
            let val_type = substring(inner_type, 1, length(inner_type))
            var inner_lltype = self.map_type(val_type)
            if inner_lltype == LLVMVoidTypeInContext(self.ctx) {
                inner_lltype = LLVMInt64TypeInContext(self.ctx)
            }

            let result_addr = LLVMBuildAlloca(self.builder, inner_lltype, "catch_result")
            let has_bb  = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "catch_has")
            let miss_bb = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "catch_miss")
            let end_bb  = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "catch_end")

            var cond_i1: *Void = 0 as *Void
            if self.is_pointer_type(val_type) {
                let zero = LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
                cond_i1 = LLVMBuildICmp(self.builder, 33, inner_val, zero, "opt_cond")
            } else {
                // Store inner_val to alloca so we can GEP into it
                let opt_lltype = self.map_type(inner_type)
                let inner_addr = LLVMBuildAlloca(self.builder, opt_lltype, "opt_tmp")
                LLVMBuildStore(self.builder, inner_val, inner_addr)
                let tag_gep = LLVMBuildStructGEP2(self.builder, opt_lltype, inner_addr, 0, "has_gep")
                let has_val = LLVMBuildLoad2(self.builder, LLVMInt8TypeInContext(self.ctx), tag_gep, "has_val")
                cond_i1 = LLVMBuildICmp(self.builder, 33, has_val, LLVMConstInt(LLVMInt8TypeInContext(self.ctx), 0, false), "opt_cond")
            }
            LLVMBuildCondBr(self.builder, cond_i1, has_bb, miss_bb)

            LLVMPositionBuilderAtEnd(self.builder, has_bb)
            self.last_was_term = false
            var unwrapped_val: *Void = 0 as *Void
            if self.is_pointer_type(val_type) {
                unwrapped_val = inner_val
            } else {
                let opt_lltype2 = self.map_type(inner_type)
                let inner_addr2 = LLVMBuildAlloca(self.builder, opt_lltype2, "opt_tmp2")
                LLVMBuildStore(self.builder, inner_val, inner_addr2)
                let val_gep = LLVMBuildStructGEP2(self.builder, opt_lltype2, inner_addr2, 1, "val_gep")
                unwrapped_val = LLVMBuildLoad2(self.builder, inner_lltype, val_gep, "unwrapped")
            }
            LLVMBuildStore(self.builder, unwrapped_val, result_addr)
            LLVMBuildBr(self.builder, end_bb)

            LLVMPositionBuilderAtEnd(self.builder, miss_bb)
            self.last_was_term = false
            let fallback_val = self.gen_catch_fallback_val(expr.catch_fallback)
            LLVMBuildStore(self.builder, fallback_val, result_addr)
            LLVMBuildBr(self.builder, end_bb)

            LLVMPositionBuilderAtEnd(self.builder, end_bb)
            self.last_was_term = false
            return LLVMBuildLoad2(self.builder, inner_lltype, result_addr, "catch_val")
        }

        // Error union catch: (Val!Err) catch fallback
        if self.str_contains(inner_type, Char(33)) {
            let excl_pos = self.str_find(inner_type, Char(33))
            let val_type = substring(inner_type, 0, excl_pos)
            var inner_lltype = self.map_type(val_type)
            if inner_lltype == LLVMVoidTypeInContext(self.ctx) {
                inner_lltype = LLVMInt64TypeInContext(self.ctx)
            }

            let result_addr = LLVMBuildAlloca(self.builder, inner_lltype, "catch_result")
            let ok_bb   = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "catch_ok")
            let err_bb  = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "catch_err")
            let end_bb  = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "catch_end")

            // Store result struct to alloca so we can GEP into it
            let res_lltype = self.map_type(inner_type)
            let res_addr = LLVMBuildAlloca(self.builder, res_lltype, "res_tmp")
            LLVMBuildStore(self.builder, inner_val, res_addr)
            let tag_gep  = LLVMBuildStructGEP2(self.builder, res_lltype, res_addr, 0, "tag_gep")
            let tag_load = LLVMBuildLoad2(self.builder, LLVMInt64TypeInContext(self.ctx), tag_gep, "tag")
            let cond_i1  = LLVMBuildICmp(self.builder, 32, tag_load, LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false), "is_ok")
            LLVMBuildCondBr(self.builder, cond_i1, ok_bb, err_bb)

            LLVMPositionBuilderAtEnd(self.builder, ok_bb)
            self.last_was_term = false
            let val_gep  = LLVMBuildStructGEP2(self.builder, res_lltype, res_addr, 1, "val_gep")
            let ok_val   = LLVMBuildLoad2(self.builder, inner_lltype, val_gep, "ok_val")
            LLVMBuildStore(self.builder, ok_val, result_addr)
            LLVMBuildBr(self.builder, end_bb)

            LLVMPositionBuilderAtEnd(self.builder, err_bb)
            self.last_was_term = false
            let fallback_val = self.gen_catch_fallback_val(expr.catch_fallback)
            LLVMBuildStore(self.builder, fallback_val, result_addr)
            LLVMBuildBr(self.builder, end_bb)

            LLVMPositionBuilderAtEnd(self.builder, end_bb)
            self.last_was_term = false
            return LLVMBuildLoad2(self.builder, inner_lltype, result_addr, "catch_val")
        }

        // Fallback
        return inner_val
    }

    // ---- Try (? propagation - return error to caller) ----
    if expr.kind == ExprKind.ek_try {
        let inner_val = self.gen_expr(expr.try_expr)
        let inner_type = self.get_expr_type(expr.try_expr)
        // Just extract value (simplified - assume ok path)
        if self.str_contains(inner_type, Char(33)) {
            let excl_pos = self.str_find(inner_type, Char(33))
            let val_type = substring(inner_type, 0, excl_pos)
            let res_lltype = self.map_type(inner_type)
            var inner_lltype = self.map_type(val_type)
            if inner_lltype == LLVMVoidTypeInContext(self.ctx) {
                inner_lltype = LLVMInt64TypeInContext(self.ctx)
            }
            // Store to alloca first to get a pointer for GEP
            let res_addr = LLVMBuildAlloca(self.builder, res_lltype, "try_tmp")
            LLVMBuildStore(self.builder, inner_val, res_addr)
            let val_gep = LLVMBuildStructGEP2(self.builder, res_lltype, res_addr, 1, "val_gep")
            return LLVMBuildLoad2(self.builder, inner_lltype, val_gep, "try_val")
        }
        return inner_val
    }

    // ---- Check (?. / ! check operators) ----
    if expr.kind == ExprKind.ek_check {
        return self.gen_expr(expr.check_expr)
    }

    return 0 as *Void
}

fn gen_catch_fallback_val(self, fallback_idx: Int) -> *Void {
    // catch_fallback is always a stmt index (sk_block containing sk_expr or sk_return),
    // not an expression index. Extract the value from the block's expression.
    if fallback_idx < 0 {
        return LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
    }
    let fb_stmt = self.stmt_pool.get(fallback_idx)
    if fb_stmt.kind == StmtKind.sk_block {
        if fb_stmt.block_stmts.length() > 0 {
            let inner_idx = fb_stmt.block_stmts.get(0)
            let inner_stmt = self.stmt_pool.get(inner_idx)
            if inner_stmt.kind == StmtKind.sk_expr {
                return self.gen_expr(inner_stmt.expr_stmt)
            }
            if inner_stmt.kind == StmtKind.sk_return {
                // `catch |err| return x` — emit the return and return 0 as placeholder
                // (the return will make the block terminate anyway)
                self.gen_stmt(inner_idx)
                return LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
            }
        }
    }
    if fb_stmt.kind == StmtKind.sk_expr {
        return self.gen_expr(fb_stmt.expr_stmt)
    }
    // Fallback: emit the block as statements (side effects), return 0
    self.gen_stmt(fallback_idx)
    return LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false)
}

fn cast_to_i64(self, val: *Void, ktype: Str) -> *Void {
    let dest_ll = LLVMInt64TypeInContext(self.ctx)
    if ktype == "Char" || ktype == "Int8" {
        return LLVMBuildSExt(self.builder, val, dest_ll, "sext")
    }
    if ktype == "Bool" || ktype == "Int1" {
        return LLVMBuildZExt(self.builder, val, dest_ll, "zext")
    }
    if ktype == "Int32" {
        return LLVMBuildSExt(self.builder, val, dest_ll, "sext")
    }
    return val
}

fn gen_cast(self, src_idx: Int, target_type: Str) -> *Void {
    let val = self.gen_expr(src_idx)
    let src_ktype = self.get_expr_type(src_idx)
    let dest_ll = self.map_type(target_type)

    let src_is_ptr = length(src_ktype) > 0 && src_ktype[0] == Char(42)
    let dst_is_ptr = length(target_type) > 0 && target_type[0] == Char(42)
    let dst_is_int = target_type == "Int" || target_type == "Int8" || target_type == "Char" || target_type == "Int32" || target_type == "Bool"

    if src_is_ptr && dst_is_ptr {
        // ptr -> ptr: bitcast
        return LLVMBuildBitCast(self.builder, val, dest_ll, "ptr_cast")
    }
    if src_is_ptr && dst_is_int {
        // ptr -> int: ptrtoint
        return LLVMBuildPtrToInt(self.builder, val, dest_ll, "ptrtoint")
    }
    if !src_is_ptr && dst_is_ptr {
        // int -> ptr: inttoptr
        return LLVMBuildIntToPtr(self.builder, val, dest_ll, "inttoptr")
    }
    if src_ktype == "Float" && dst_is_int {
        return LLVMBuildFPToSI(self.builder, val, dest_ll, "fptosi")
    }
    if dst_is_int && src_ktype == target_type {
        return val
    }
    // Integer widening (e.g. Char/Int8/Int32 -> Int): use sext
    let src_is_int = self.is_integer_type(src_ktype)
    if src_is_int && dst_is_int {
        return self.cast_to_i64(val, src_ktype)
    }
    // Default: bitcast for same-category types (ptr->ptr handled above)
    return LLVMBuildBitCast(self.builder, val, dest_ll, "cast")
}

// ============================================================================
// Printing Calls & Matching
// ============================================================================

fn emit_print_call(self, ktype: Str, val: *Void) {
    let printf_func = self.get_or_declare_printf()
    
    var fmt = ""
    let args = self.allocator.alloc(16, 8) as **Void
    
    if ktype == "Float" {
        fmt = "%f\n"
        args[0] = LLVMBuildGlobalStringPtr(self.builder, fmt, "fmt_float")
        args[1] = val
    } else if ktype == "Char" {
        fmt = "%c\n"
        let int_val = LLVMBuildZExt(self.builder, val, LLVMInt32TypeInContext(self.ctx), "char_to_int")
        args[0] = LLVMBuildGlobalStringPtr(self.builder, fmt, "fmt_char")
        args[1] = int_val
    } else if ktype == "Str" {
        fmt = "%s\n"
        args[0] = LLVMBuildGlobalStringPtr(self.builder, fmt, "fmt_str")
        args[1] = val
    } else if ktype == "Bool" {
        fmt = "%s\n"
        let cond = LLVMBuildICmp(self.builder, 33, val, LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false), "bool_cond")
        let true_str = LLVMBuildGlobalStringPtr(self.builder, "true", "true_str")
        let false_str = LLVMBuildGlobalStringPtr(self.builder, "false", "false_str")
        let select_str = LLVMBuildSelect(self.builder, cond, true_str, false_str, "select_str")
        args[0] = LLVMBuildGlobalStringPtr(self.builder, fmt, "fmt_bool")
        args[1] = select_str
    } else {
        fmt = "%lld\n"
        args[0] = LLVMBuildGlobalStringPtr(self.builder, fmt, "fmt_int")
        args[1] = val
    }
    
    let printf_ty = self.get_printf_type()
    let _ = LLVMBuildCall2(self.builder, printf_ty, printf_func, args as *Void, 2, "print_call")
    self.allocator.free(args as *Void)
}

fn gen_match(self, stmt_idx: Int) {
    let stmt = self.stmt_pool.get(stmt_idx)
    let expr_type_raw = self.get_expr_type(stmt.match_expr)
    // Dereference pointer types for match — if matching on *Result or *Optional, load the value
    var expr_val = self.gen_expr(stmt.match_expr)
    var expr_type = expr_type_raw
    if length(expr_type_raw) > 0 && (expr_type_raw[0] == Char(42) || expr_type_raw[0] == Char(38)) {
        let inner_type = substring(expr_type_raw, 1, length(expr_type_raw))
        let inner_ll = self.map_type(inner_type)
        if inner_ll != LLVMVoidTypeInContext(self.ctx) && inner_ll != LLVMInt64TypeInContext(self.ctx) {
            // Dereference: load the struct value through the pointer
            expr_val = LLVMBuildLoad2(self.builder, inner_ll, expr_val, "match_deref")
            expr_type = inner_type
        }
    }
    let end_bb = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "match_end")
    
    let is_enum = (length(expr_type) > 0) && (length(type_map_get(&self.enum_decls, expr_type)) > 0)
    let has_payload = is_enum && self.enum_has_payload(expr_type)
    // Detect error-union (T!E) / Optional types that have a tag field (struct-based)
    let is_result = self.str_contains(expr_type, Char(33))
    let is_optional = (length(expr_type) > 0 && expr_type[0] == Char(63)) || (length(expr_type) >= 8 && substring(expr_type, 0, 8) == "Optional")
    // Also check if the struct type is in struct_types (has tag + value layout)
    let is_struct_with_tag = (!is_enum && !is_result && !is_optional && length(type_map_get(&self.struct_types, expr_type)) > 0)
    
    var tag_val: *Void = 0 as *Void
    var match_ptr: *Void = 0 as *Void  // pointer to the match expression's storage (for GEP in case body)
    if has_payload {
        let struct_lltype = self.map_type(expr_type)
        // Store expr_val to alloca to get a pointer for GEP
        let match_tmp = LLVMBuildAlloca(self.builder, struct_lltype, "match_tmp")
        LLVMBuildStore(self.builder, expr_val, match_tmp)
        match_ptr = match_tmp
        let tag_gep = LLVMBuildStructGEP2(self.builder, struct_lltype, match_tmp, 0, "tag_gep")
        let loaded_tag = LLVMBuildLoad2(self.builder, LLVMInt8TypeInContext(self.ctx), tag_gep, "tag_val")
        tag_val = LLVMBuildZExt(self.builder, loaded_tag, LLVMInt64TypeInContext(self.ctx), "tag_val_i64")
    } else if is_result {
        // Result type: extract tag field (field 0 = i64 tag)
        let res_lltype = self.map_type(expr_type)
        let match_tmp = LLVMBuildAlloca(self.builder, res_lltype, "match_res_tmp")
        LLVMBuildStore(self.builder, expr_val, match_tmp)
        match_ptr = match_tmp
        let tag_gep = LLVMBuildStructGEP2(self.builder, res_lltype, match_tmp, 0, "tag_gep")
        tag_val = LLVMBuildLoad2(self.builder, LLVMInt64TypeInContext(self.ctx), tag_gep, "tag_val")
    } else if is_optional {
        // Optional type: extract has_value field (field 0 = i8)
        let opt_lltype = self.map_type(expr_type)
        let match_tmp = LLVMBuildAlloca(self.builder, opt_lltype, "match_opt_tmp")
        LLVMBuildStore(self.builder, expr_val, match_tmp)
        match_ptr = match_tmp
        let tag_gep = LLVMBuildStructGEP2(self.builder, opt_lltype, match_tmp, 0, "tag_gep")
        let loaded_tag = LLVMBuildLoad2(self.builder, LLVMInt8TypeInContext(self.ctx), tag_gep, "tag_val")
        tag_val = LLVMBuildZExt(self.builder, loaded_tag, LLVMInt64TypeInContext(self.ctx), "tag_val_i64")
    } else if is_enum {
        // Enum with payload: expr_val is the loaded struct value; store to alloca for GEP in case body
        if has_payload {
            let enum_lltype = self.map_type(expr_type)
            let match_tmp = LLVMBuildAlloca(self.builder, enum_lltype, "match_enum_tmp")
            LLVMBuildStore(self.builder, expr_val, match_tmp)
            match_ptr = match_tmp
        }
        tag_val = expr_val
    } else {
        // Primitive type match (Int, etc.) - use value directly
        tag_val = expr_val
    }
    var i = 0
    while i < stmt.match_cases.length() {
        let case_node = stmt.match_cases.get(i)
        let pat_node = self.pattern_pool.get(case_node.pattern)
        
        let case_bb = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "case_body")
        let next_bb = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "case_next")
        
        var is_match: *Void = 0 as *Void
        if pat_node.kind == PatternKind.pk_else {
            is_match = LLVMConstInt(LLVMInt1TypeInContext(self.ctx), 1, false)
        } else if pat_node.kind == PatternKind.pk_literal {
            var pat_tag = 0
            match pat_node.lit_value {
                case .tv_int(v) => { pat_tag = v }
                case .tv_bool(v) => { if v { pat_tag = 1 } else { pat_tag = 0 } }
                case .tv_char(v) => { pat_tag = v as Int }
                case else => { pat_tag = 0 }
            }
            // Normalize tag_val to i64 for comparison (handle pointer match-on-null)
            var cmp_lhs = tag_val
            if self.is_pointer_type(expr_type) {
                cmp_lhs = LLVMBuildPtrToInt(self.builder, tag_val, LLVMInt64TypeInContext(self.ctx), "ptr_as_int")
            }
            let pat_const = LLVMConstInt(LLVMInt64TypeInContext(self.ctx), pat_tag, false)
            let cmp = LLVMBuildICmp(self.builder, 32, cmp_lhs, pat_const, "is_match")
            is_match = LLVMBuildZExt(self.builder, cmp, LLVMInt64TypeInContext(self.ctx), "is_match_i64")
        } else if pat_node.kind == PatternKind.pk_variant {
            let var_name = pat_node.variant_name
            let tag_key = expr_type + "_" + var_name + "_TAG"
            let tag_val_str = type_map_get(&self.enum_decls, tag_key)
            var pat_tag = 0
            if length(tag_val_str) > 0 {
                pat_tag = self.str_to_int(tag_val_str)
            }
            // Normalize tag_val to i64 for comparison
            var cmp_lhs2 = tag_val
            if self.is_pointer_type(expr_type) {
                cmp_lhs2 = LLVMBuildPtrToInt(self.builder, tag_val, LLVMInt64TypeInContext(self.ctx), "ptr_as_int")
            }
            let pat_const = LLVMConstInt(LLVMInt64TypeInContext(self.ctx), pat_tag, false)
            let cmp = LLVMBuildICmp(self.builder, 32, cmp_lhs2, pat_const, "is_match")
            is_match = LLVMBuildZExt(self.builder, cmp, LLVMInt64TypeInContext(self.ctx), "is_match_i64")
        }
        
        let cond_i1 = LLVMBuildICmp(self.builder, 33, is_match, LLVMConstInt(LLVMInt64TypeInContext(self.ctx), 0, false), "cond_i1")
        LLVMBuildCondBr(self.builder, cond_i1, case_bb, next_bb)
        
        LLVMPositionBuilderAtEnd(self.builder, case_bb)
        self.last_was_term = false
        
        if pat_node.kind == PatternKind.pk_variant && pat_node.bindings.length() > 0 {
            let bind_var = pat_node.bindings.get(0)
            let bind_ktype = self.get_variant_param_type(expr_type, pat_node.variant_name, 0)
            let bind_ll = self.map_type(bind_ktype)
            
            let struct_lltype = self.map_type(expr_type)
            // Use match_ptr (an alloca) for GEP — expr_val may be a value type, not a pointer
            var gep_base = match_ptr
            if gep_base == 0 as *Void {
                // Fallback: store expr_val to a temp alloca for GEP
                let tmp = LLVMBuildAlloca(self.builder, struct_lltype, "match_gep_tmp")
                LLVMBuildStore(self.builder, expr_val, tmp)
                gep_base = tmp
            }
            let payload_gep = LLVMBuildStructGEP2(self.builder, struct_lltype, gep_base, 1, "payload_gep")
            let raw_payload = LLVMBuildLoad2(self.builder, LLVMInt64TypeInContext(self.ctx), payload_gep, "raw_payload")
            
            var cast_payload = raw_payload
            if bind_ktype != "Int" && bind_ktype != "Bool" {
                if length(bind_ktype) > 0 && bind_ktype[0] == Char(42) {
                    cast_payload = LLVMBuildIntToPtr(self.builder, raw_payload, bind_ll, "cast_payload")
                } else if bind_ktype == "Float" {
                    cast_payload = LLVMBuildBitCast(self.builder, raw_payload, LLVMDoubleTypeInContext(self.ctx), "cast_payload")
                } else {
                    let ptr_ll = LLVMPointerType(bind_ll, 0)
                    let ptr_payload = LLVMBuildIntToPtr(self.builder, raw_payload, ptr_ll, "ptr_payload")
                    cast_payload = LLVMBuildLoad2(self.builder, bind_ll, ptr_payload, "cast_payload")
                }
            }
            
            let addr = LLVMBuildAlloca(self.builder, bind_ll, bind_var + ".addr")
            LLVMBuildStore(self.builder, cast_payload, addr)
            self.sym_store(bind_var, addr, bind_ktype)
        }
        
        self.gen_stmt(case_node.body)
        if !self.last_was_term {
            LLVMBuildBr(self.builder, end_bb)
        }
        
        LLVMPositionBuilderAtEnd(self.builder, next_bb)
        self.last_was_term = false
        
        i = i + 1
    }
    
    if !self.last_was_term {
        LLVMBuildBr(self.builder, end_bb)
    }
    
    LLVMPositionBuilderAtEnd(self.builder, end_bb)
    self.last_was_term = false
}

// ============================================================================
// Imported Module Handling
// ============================================================================

fn handle_import(self, stmt_idx: Int) {
    let stmt = self.stmt_pool.get(stmt_idx)
    let path = stmt.import_path
    var module_key = ""
    var pi = 0
    while pi < path.length() {
        if pi > 0 { module_key = module_key + "." }
        module_key = module_key + path.get(pi)
        pi = pi + 1
    }
    if module_key == "" { return }
    if self.str_list_find(module_key) >= 0 { return }
    self.loaded_modules.push(module_key)

    var has_source = false
    var source = ""
    if path.length() > 0 && path.get(0) == "std" {
        var path_str = ""
        var i = 0
        while i < path.length() {
            if i > 0 { path_str = path_str + "/" }
            path_str = path_str + path.get(i)
            i = i + 1
        }
        let rel_path = path_str + ".kai"
        
        let s1 = read_to_string(self.allocator, rel_path) catch |err| ""
        if length(s1) > 0 {
            source = s1
            has_source = true
        } else {
            unsafe {
                let buf = self.allocator.alloc(1024, 1) as *Char
                if get_exe_dir(buf, 1024) == 0 {
                    let exe_dir = buf as Str
                    let full_path = exe_dir + "/" + rel_path
                    let parent_path = exe_dir + "/../" + rel_path
                    let lib_path = exe_dir + "/../lib/kai/" + rel_path
                    self.allocator.free(buf)
                    
                    let s2 = read_to_string(self.allocator, full_path) catch |err| ""
                    if length(s2) > 0 {
                        source = s2
                        has_source = true
                    } else {
                        let s3 = read_to_string(self.allocator, parent_path) catch |err| ""
                        if length(s3) > 0 {
                            source = s3
                            has_source = true
                        } else {
                            let s4 = read_to_string(self.allocator, lib_path) catch |err| ""
                            if length(s4) > 0 {
                                source = s4
                                has_source = true
                            }
                        }
                    }
                } else {
                    self.allocator.free(buf)
                }
            }
        }
    } else if path.length() > 0 {
        let file_path = "src/" + module_key + ".kai"
        let s = read_to_string(self.allocator, file_path) catch |err| ""
        if length(s) > 0 {
            source = s
            has_source = true
        }
    }

    if has_source {
        var lexer = Lexer(self.allocator, source)
        lexer.lex()
        if lexer.has_error { return }
        var parser = Parser.init_with_pools(self.allocator, lexer.tokens, self.expr_pool, self.stmt_pool, self.pattern_pool)
        let program_idx = parser.parse_program()
        if program_idx >= 0 {
            // Only register declarations from imported module — do not generate function bodies.
            // Function bodies from imported modules will be generated in the main generate() loop
            // since they are added to the shared stmt_pool.
            self.register_all_decls()
        }
    }
}

// ============================================================================
// Code Generation Metadata Queries
// ============================================================================

fn get_expr_type(self, idx: Int) -> Str {
    if idx < 0 { return "Void" }
    let expr = self.expr_pool.get(idx)
    if length(expr.inferred_type) > 0 { return expr.inferred_type }
    
    if expr.kind == ExprKind.ek_literal {
        let vk = expr.lit_vkind
        if vk == "INT" { return "Int" }
        if vk == "FLOAT" { return "Float" }
        if vk == "BOOL" { return "Bool" }
        if vk == "CHAR" { return "Char" }
        if vk == "STRING" { return "Str" }
        return "Void"
    }
    if expr.kind == ExprKind.ek_identifier {
        let name = expr.ident_name
        let t = self.sym_type(name)
        if length(t) > 0 { return t }
        return name
    }
    if expr.kind == ExprKind.ek_binary_op {
        let op = expr.binop_op
        if op == "==" || op == "!=" || op == "<" || op == "<=" || op == ">" || op == ">=" || op == "&&" || op == "||" {
            return "Bool"
        }
        return self.get_expr_type(expr.binop_left)
    }
    if expr.kind == ExprKind.ek_unary_op {
        if expr.unop_op == "!" { return "Bool" }
        return self.get_expr_type(expr.unop_operand)
    }
    if expr.kind == ExprKind.ek_func_call {
        let fname = expr.func_name
        if fname == "cast" || fname == "as" {
            if expr.func_type_args.length() > 0 {
                return expr.func_type_args.get(0)
            }
        }
        if fname == "Char" { return "Char" }
        if fname == "Int" { return "Int" }
        if fname == "Float" { return "Float" }
        if fname == "Int8" { return "Int8" }
        if fname == "Int32" { return "Int32" }
        
        let t = type_map_get(&self.func_types, fname)
        if length(t) > 0 { return t }
        
        // If it starts with an uppercase letter, it's likely a struct constructor
        if length(fname) > 0 {
            let first_char = fname[0]
            if first_char >= Char(65) && first_char <= Char(90) {
                return "*" + fname
            }
        }
        
        return "Int"
    }
    if expr.kind == ExprKind.ek_method_call {
        let rec_type = self.get_expr_type(expr.meth_expr)
        let base = self.strip_pointers(rec_type)
        let is_enum = (length(base) > 0) && (length(type_map_get(&self.enum_types, base)) > 0)
        if is_enum {
            return base
        }
        let key = base + "_" + expr.meth_name
        let t = type_map_get(&self.func_types, key)
        if length(t) > 0 && t != "T" { return t }
        // For generic container methods (e.g. ArrayList<T>_get), infer element type
        if expr.meth_name == "get" {
            let lt_pos3 = self.str_find(base, Char(60))
            if lt_pos3 >= 0 {
                let elem_t2 = substring(base, lt_pos3 + 1, length(base) - 1)
                if length(elem_t2) > 0 { return elem_t2 }
            }
        }
        return "Int"
    }
    if expr.kind == ExprKind.ek_field_access {
        let base_node = self.expr_pool.get(expr.field_expr)
        if base_node.kind == ExprKind.ek_identifier {
            let is_enum_val = (length(type_map_get(&self.enum_types, base_node.ident_name)) > 0)
            if is_enum_val {
                return base_node.ident_name
            }
        }
        let rec_type = self.get_expr_type(expr.field_expr)
        let base = self.strip_pointers(rec_type)
        return self.get_field_type(base, expr.field_name)
    }
    if expr.kind == ExprKind.ek_index {
        let base_type = self.get_expr_type(expr.idx_expr)
        if base_type == "Str" {
            return "Char"
        }
        if length(base_type) > 0 && base_type[0] == Char(42) {
            return substring(base_type, 1, length(base_type))
        }
        if length(base_type) > 2 && substring(base_type, 0, 2) == "[]" {
            return substring(base_type, 2, length(base_type))
        }
        return "Int"
    }
    if expr.kind == ExprKind.ek_array {
        if length(expr.inferred_type) > 0 { return expr.inferred_type }
        if expr.arr_elements.length() > 0 {
            let elem_type = self.get_expr_type(expr.arr_elements.get(0))
            return "[]" + elem_type
        }
        return "[]Int"
    }
    if expr.kind == ExprKind.ek_struct_init {
        return expr.struct_name
    }
    if expr.kind == ExprKind.ek_borrow {
        return "&" + self.get_expr_type(expr.borrow_expr)
    }
    if expr.kind == ExprKind.ek_deref {
        let base_type = self.get_expr_type(expr.deref_expr)
        return self.strip_pointers(base_type)
    }
    if expr.kind == ExprKind.ek_str_interp {
        return "Str"
    }
    if expr.kind == ExprKind.ek_catch {
        let inner_type = self.get_expr_type(expr.catch_expr)
        // Optional ?T catch -> T
        if length(inner_type) > 0 && inner_type[0] == Char(63) {
            return substring(inner_type, 1, length(inner_type))
        }
        // Error union T!E catch -> T
        if self.str_contains(inner_type, Char(33)) {
            let excl_pos = self.str_find(inner_type, Char(33))
            return substring(inner_type, 0, excl_pos)
        }
        return inner_type
    }
    if expr.kind == ExprKind.ek_try {
        let inner_type = self.get_expr_type(expr.try_expr)
        // T!E try -> T
        if self.str_contains(inner_type, Char(33)) {
            let excl_pos = self.str_find(inner_type, Char(33))
            return substring(inner_type, 0, excl_pos)
        }
        return inner_type
    }
    if expr.kind == ExprKind.ek_check {
        return self.get_expr_type(expr.check_expr)
    }
    return "Int"
}

fn get_field_type(self, struct_name: Str, field_name: Str) -> Str {
    let key = struct_name + "." + field_name
    let t = type_map_get(&self.struct_field_types, key)
    if length(t) > 0 { return t }
    return "Int"
}

fn get_field_index(self, struct_name: Str, field_name: Str) -> Int {
    let key = struct_name + "." + field_name
    let idx_str = type_map_get(&self.struct_field_indices, key)
    if length(idx_str) > 0 { return self.str_to_int(idx_str) }
    return 0
}

fn enum_has_payload(self, enum_name: Str) -> Bool {
    let idx_str = type_map_get(&self.enum_decls, enum_name)
    if length(idx_str) == 0 { return false }
    let enum_stmt = self.stmt_pool.get(self.str_to_int(idx_str))
    if enum_stmt.kind != StmtKind.sk_enum_decl { return false }
    var i = 0
    while i < enum_stmt.enum_variants.length() {
        let v = enum_stmt.enum_variants.get(i)
        if v.params.length() > 0 { return true }
        i = i + 1
    }
    return false
}

fn get_variant_param_type(self, enum_name: Str, variant_name: Str, param_idx: Int) -> Str {
    let idx_str = type_map_get(&self.enum_decls, enum_name)
    if length(idx_str) == 0 { return "Int" }
    let stmt = self.stmt_pool.get(self.str_to_int(idx_str))
    if stmt.kind == StmtKind.sk_enum_decl {
        var i = 0
        while i < stmt.enum_variants.length() {
            let v = stmt.enum_variants.get(i)
            if v.vname == variant_name {
                if param_idx < v.params.length() {
                    let p = v.params.get(param_idx)
                    return p.ptype
                }
            }
            i = i + 1
        }
    }
    return "Int"
}

// ============================================================================
// Top-Level Module Emitter
// ============================================================================

fn generate(self, top_stmt_idx: Int) -> Str {
    self.module = LLVMModuleCreateWithNameInContext("kai_module", self.ctx)
    self.builder = LLVMCreateBuilderInContext(self.ctx)

    self.register_all_decls()

    self.emit_str_concat_helper()

    // Pass 0: Process all imports to ensure imported functions are registered
    var imp_idx = 0
    while imp_idx < self.stmt_pool.length() {
        let imp_stmt = self.stmt_pool.get(imp_idx)
        if imp_stmt.kind == StmtKind.sk_import {
            self.handle_import(imp_idx)
        }
        imp_idx = imp_idx + 1
    }

    // After all imports are processed, do a final registration sweep so that
    // any function whose return type was unresolved (enum/struct not yet
    // registered at first-call time) gets properly re-declared now.
    self.register_all_decls()

    // Emit monomorphized ArrayList<T> method bodies NOW — before any function
    // body generation — so call sites in generated bodies get the correctly-typed
    // function declarations rather than falling back to auto-declared i64 stubs.
    // struct_field_types is now fully populated by register_all_decls + imports.
    self.emit_monomorphized_arraylists()

    // Track initial stmt_pool length (before imports may add more)
    // Use current length for iteration to include imported declarations
    var idx = 0
    while idx < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(idx)
        if stmt.kind == StmtKind.sk_func_decl {
            // Skip trait/impl method stubs: they will be generated via impl_block
            var is_method_stub = false
            var ti = 0
            while ti < self.stmt_pool.length() {
                let ts = self.stmt_pool.get(ti)
                if ts.kind == StmtKind.sk_trait_decl {
                    var mi = 0
                    while mi < ts.trait_methods.length() {
                        if ts.trait_methods.get(mi) == idx {
                            is_method_stub = true
                        }
                        mi = mi + 1
                    }
                }
                if ts.kind == StmtKind.sk_impl_block {
                    var mi = 0
                    while mi < ts.impl_methods.length() {
                        if ts.impl_methods.get(mi) == idx {
                            is_method_stub = true
                        }
                        mi = mi + 1
                    }
                }
                ti = ti + 1
            }
            if !is_method_stub && stmt.func_body >= 0 {
                self.gen_func_body(idx, "")
            }
        }
        if stmt.kind == StmtKind.sk_impl_block {
            let struct_name = stmt.impl_struct_name
            var j = 0
            while j < stmt.impl_methods.length() {
                let m_idx = stmt.impl_methods.get(j)
                self.gen_func_body(m_idx, struct_name)
                j = j + 1
            }
        }
        // sk_trait_decl - no body to emit
        idx = idx + 1
    }

    // Generate runtime helpers in the LLVM module
    self.emit_runtime_helpers()

    // Generate runtime helpers in the LLVM module
    self.emit_runtime_helpers()

    let out_ptr = LLVMPrintModuleToString(self.module)
    let output = out_ptr as Str

    LLVMDisposeBuilder(self.builder)
    LLVMDisposeModule(self.module)
    LLVMContextDispose(self.ctx)

    return output
}

// ============================================================================
// ArrayList<T> Monomorphization
// ============================================================================

// Returns true if the function already has a body (basic blocks).
// If it exists as a declare-only (no body), keeps it for later definition — do NOT delete it.
fn func_has_body(self, fname: Str) -> Bool {
    let f = LLVMGetNamedFunction(self.module, fname)
    if f == 0 as *Void { return false }
    let first_bb = LLVMGetFirstBasicBlock(f)
    if first_bb == 0 as *Void {
        // Declaration exists but has no body yet — we'll add the body below
        return false
    }
    return true
}

// Gets (or creates) the function value to add a body to.
// If a declaration exists (no body), returns it so we can add the body directly.
// If no declaration exists, creates a new one with the given type.
fn get_or_create_func_for_body(self, fname: Str, fn_ty: *Void) -> *Void {
    let existing = LLVMGetNamedFunction(self.module, fname)
    if existing != 0 as *Void {
        return existing
    }
    return LLVMAddFunction(self.module, fname, fn_ty)
}

fn emit_arraylist_method_get(self, elem_ktype: Str, al_lltype: *Void, fname: Str) {
    if self.func_has_body(fname) { return }

    // define <elem_ll> @ArrayList<T>_get(ptr %self, i64 %index)
    let elem_ll = self.map_type(elem_ktype)
    let i64t = LLVMInt64TypeInContext(self.ctx)
    let ptrt = LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)

    var ret_ll: *Void = elem_ll
    if ret_ll == LLVMVoidTypeInContext(self.ctx) { ret_ll = i64t }

    let param_types = self.allocator.alloc(16, 8) as **Void
    param_types[0] = ptrt  // self: *ArrayList
    param_types[1] = i64t  // index: Int
    let fn_ty = LLVMFunctionType(ret_ll, param_types as *Void, 2, false)
    let func = self.get_or_create_func_for_body(fname, fn_ty)
    type_map_put(&self.func_types, fname, elem_ktype)
    self.allocator.free(param_types as *Void)

    let bb = LLVMAppendBasicBlockInContext(self.ctx, func, "entry")
    let b = LLVMCreateBuilderInContext(self.ctx)
    LLVMPositionBuilderAtEnd(b, bb)

    let self_ptr = LLVMGetParam(func, 0)
    let idx = LLVMGetParam(func, 1)

    // data is field 0 of ArrayList
    let data_gep = LLVMBuildStructGEP2(b, al_lltype, self_ptr, 0, "data_gep")
    let data_ptr = LLVMBuildLoad2(b, ptrt, data_gep, "data")

    // element ptr: GEP data[index] with elem_ll type
    let real_elem_ll = self.map_type(elem_ktype)
    var use_elem_ll: *Void = real_elem_ll
    if use_elem_ll == LLVMVoidTypeInContext(self.ctx) { use_elem_ll = i64t }
    if use_elem_ll == LLVMInt8TypeInContext(self.ctx) { use_elem_ll = LLVMInt8TypeInContext(self.ctx) }

    let idx_arr = self.allocator.alloc(8, 8) as **Void
    idx_arr[0] = idx
    let elem_gep = LLVMBuildGEP2(b, use_elem_ll, data_ptr, idx_arr as *Void, 1, "elem_gep")
    let loaded = LLVMBuildLoad2(b, use_elem_ll, elem_gep, "elem")
    LLVMBuildRet(b, loaded)
    self.allocator.free(idx_arr as *Void)

    LLVMDisposeBuilder(b)
}

fn emit_arraylist_method_length(self, fname: Str, al_lltype: *Void) {
    if self.func_has_body(fname) { return }

    let i64t = LLVMInt64TypeInContext(self.ctx)
    let ptrt = LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
    let param_types = self.allocator.alloc(8, 8) as **Void
    param_types[0] = ptrt
    let fn_ty = LLVMFunctionType(i64t, param_types as *Void, 1, false)
    let func = self.get_or_create_func_for_body(fname, fn_ty)
    type_map_put(&self.func_types, fname, "Int")
    self.allocator.free(param_types as *Void)

    let bb = LLVMAppendBasicBlockInContext(self.ctx, func, "entry")
    let b = LLVMCreateBuilderInContext(self.ctx)
    LLVMPositionBuilderAtEnd(b, bb)

    let self_ptr = LLVMGetParam(func, 0)
    // len is field 1 of ArrayList
    let len_gep = LLVMBuildStructGEP2(b, al_lltype, self_ptr, 1, "len_gep")
    let len_val = LLVMBuildLoad2(b, i64t, len_gep, "len")
    LLVMBuildRet(b, len_val)

    LLVMDisposeBuilder(b)
}

fn emit_arraylist_method_push(self, elem_ktype: Str, fname: Str, al_lltype: *Void) {
    if self.func_has_body(fname) { return }

    let i64t = LLVMInt64TypeInContext(self.ctx)
    let ptrt = LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
    let void_t = LLVMVoidTypeInContext(self.ctx)
    let elem_ll = self.map_type(elem_ktype)
    var real_elem_ll: *Void = elem_ll
    if real_elem_ll == void_t { real_elem_ll = i64t }

    let param_types = self.allocator.alloc(16, 8) as **Void
    param_types[0] = ptrt   // self
    param_types[1] = real_elem_ll  // item
    let fn_ty = LLVMFunctionType(i64t, param_types as *Void, 2, false)
    let func = self.get_or_create_func_for_body(fname, fn_ty)
    type_map_put(&self.func_types, fname, "Int")
    self.allocator.free(param_types as *Void)

    let bb = LLVMAppendBasicBlockInContext(self.ctx, func, "entry")
    let b = LLVMCreateBuilderInContext(self.ctx)
    LLVMPositionBuilderAtEnd(b, bb)

    let self_ptr = LLVMGetParam(func, 0)
    let item = LLVMGetParam(func, 1)

    // len is field 1, data is field 0
    let len_gep = LLVMBuildStructGEP2(b, al_lltype, self_ptr, 1, "len_gep")
    let len_val = LLVMBuildLoad2(b, i64t, len_gep, "len")
    let data_gep = LLVMBuildStructGEP2(b, al_lltype, self_ptr, 0, "data_gep")
    let data_ptr = LLVMBuildLoad2(b, ptrt, data_gep, "data")

    // data[len] = item
    let len_arr = self.allocator.alloc(8, 8) as **Void
    len_arr[0] = len_val
    let elem_slot = LLVMBuildGEP2(b, real_elem_ll, data_ptr, len_arr as *Void, 1, "elem_slot")
    LLVMBuildStore(b, item, elem_slot)
    self.allocator.free(len_arr as *Void)
    LLVMBuildStore(b, item, elem_slot)

    // len++
    let new_len = LLVMBuildAdd(b, len_val, LLVMConstInt(i64t, 1, false), "new_len")
    LLVMBuildStore(b, new_len, len_gep)

    LLVMBuildRet(b, LLVMConstInt(i64t, 0, false))
    LLVMDisposeBuilder(b)
}

fn emit_arraylist_method_pop(self, elem_ktype: Str, fname: Str, al_lltype: *Void) {
    if self.func_has_body(fname) { return }

    let i64t = LLVMInt64TypeInContext(self.ctx)
    let ptrt = LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
    let elem_ll = self.map_type(elem_ktype)
    var real_elem_ll: *Void = elem_ll
    if real_elem_ll == LLVMVoidTypeInContext(self.ctx) { real_elem_ll = i64t }

    let param_types = self.allocator.alloc(8, 8) as **Void
    param_types[0] = ptrt
    let fn_ty = LLVMFunctionType(real_elem_ll, param_types as *Void, 1, false)
    let func = self.get_or_create_func_for_body(fname, fn_ty)
    type_map_put(&self.func_types, fname, elem_ktype)
    self.allocator.free(param_types as *Void)

    let bb = LLVMAppendBasicBlockInContext(self.ctx, func, "entry")
    let b = LLVMCreateBuilderInContext(self.ctx)
    LLVMPositionBuilderAtEnd(b, bb)

    let self_ptr = LLVMGetParam(func, 0)
    let len_gep = LLVMBuildStructGEP2(b, al_lltype, self_ptr, 1, "len_gep")
    let len_val = LLVMBuildLoad2(b, i64t, len_gep, "len")
    let new_len = LLVMBuildSub(b, len_val, LLVMConstInt(i64t, 1, false), "new_len")
    LLVMBuildStore(b, new_len, len_gep)

    let data_gep = LLVMBuildStructGEP2(b, al_lltype, self_ptr, 0, "data_gep")
    let data_ptr = LLVMBuildLoad2(b, ptrt, data_gep, "data")
    let new_len_arr = self.allocator.alloc(8, 8) as **Void
    new_len_arr[0] = new_len
    let elem_slot = LLVMBuildGEP2(b, real_elem_ll, data_ptr, new_len_arr as *Void, 1, "elem_slot")
    let loaded = LLVMBuildLoad2(b, real_elem_ll, elem_slot, "elem")
    LLVMBuildRet(b, loaded)
    self.allocator.free(new_len_arr as *Void)

    LLVMDisposeBuilder(b)
}

fn emit_arraylist_method_init(self, elem_ktype: Str, fname: Str, al_lltype: *Void) {
    if self.func_has_body(fname) { return }

    let i64t = LLVMInt64TypeInContext(self.ctx)
    let ptrt = LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
    let void_t = LLVMVoidTypeInContext(self.ctx)

    let param_types = self.allocator.alloc(16, 8) as **Void
    param_types[0] = ptrt  // self: *ArrayList
    param_types[1] = ptrt  // allocator: *Allocator
    let fn_ty = LLVMFunctionType(ptrt, param_types as *Void, 2, false)
    let func = self.get_or_create_func_for_body(fname, fn_ty)
    type_map_put(&self.func_types, fname, "*" + "ArrayList")
    self.allocator.free(param_types as *Void)

    let bb = LLVMAppendBasicBlockInContext(self.ctx, func, "entry")
    let b = LLVMCreateBuilderInContext(self.ctx)
    LLVMPositionBuilderAtEnd(b, bb)

    let self_ptr = LLVMGetParam(func, 0)
    let allocator = LLVMGetParam(func, 1)

    // self.len = 0
    let len_gep = LLVMBuildStructGEP2(b, al_lltype, self_ptr, 1, "len_gep")
    LLVMBuildStore(b, LLVMConstInt(i64t, 0, false), len_gep)
    // self.cap = 4
    let cap_gep = LLVMBuildStructGEP2(b, al_lltype, self_ptr, 2, "cap_gep")
    LLVMBuildStore(b, LLVMConstInt(i64t, 4, false), cap_gep)
    // self.allocator = allocator
    let alloc_gep = LLVMBuildStructGEP2(b, al_lltype, self_ptr, 3, "alloc_gep")
    LLVMBuildStore(b, allocator, alloc_gep)
    // self.data = allocator.alloc(4 * 8, 1) as *T  (use 8 bytes per element as safe default)
    let alloc_fn = LLVMGetNamedFunction(self.module, "Allocator_alloc")
    if alloc_fn != 0 as *Void {
        let alloc_size = LLVMConstInt(i64t, 32, false)  // 4 * 8 = 32 bytes
        let alloc_align = LLVMConstInt(i64t, 1, false)
        let call_args = self.allocator.alloc(24, 8) as **Void
        call_args[0] = allocator
        call_args[1] = alloc_size
        call_args[2] = alloc_align
        let alloc_param_types = self.allocator.alloc(24, 8) as **Void
        alloc_param_types[0] = ptrt
        alloc_param_types[1] = i64t
        alloc_param_types[2] = i64t
        let alloc_ty = LLVMFunctionType(ptrt, alloc_param_types as *Void, 3, false)
        let data_val = LLVMBuildCall2(b, alloc_ty, alloc_fn, call_args as *Void, 3, "init_data")
        let data_gep = LLVMBuildStructGEP2(b, al_lltype, self_ptr, 0, "data_gep")
        LLVMBuildStore(b, data_val, data_gep)
        self.allocator.free(call_args as *Void)
        self.allocator.free(alloc_param_types as *Void)
    } else {
        // fallback: null data
        let data_gep = LLVMBuildStructGEP2(b, al_lltype, self_ptr, 0, "data_gep")
        LLVMBuildStore(b, LLVMConstNull(ptrt), data_gep)
    }

    LLVMBuildRet(b, self_ptr)
    LLVMDisposeBuilder(b)
}

fn emit_arraylist_method_set(self, elem_ktype: Str, fname: Str, al_lltype: *Void) {
    if self.func_has_body(fname) { return }

    let i64t = LLVMInt64TypeInContext(self.ctx)
    let ptrt = LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
    let void_t = LLVMVoidTypeInContext(self.ctx)
    let elem_ll = self.map_type(elem_ktype)
    var real_elem_ll: *Void = elem_ll
    if real_elem_ll == void_t { real_elem_ll = i64t }

    let param_types = self.allocator.alloc(24, 8) as **Void
    param_types[0] = ptrt          // self: *ArrayList
    param_types[1] = i64t          // index: Int
    param_types[2] = real_elem_ll  // item: T
    let fn_ty = LLVMFunctionType(i64t, param_types as *Void, 3, false)
    let func = self.get_or_create_func_for_body(fname, fn_ty)
    type_map_put(&self.func_types, fname, "Int")
    self.allocator.free(param_types as *Void)

    let bb = LLVMAppendBasicBlockInContext(self.ctx, func, "entry")
    let b = LLVMCreateBuilderInContext(self.ctx)
    LLVMPositionBuilderAtEnd(b, bb)

    let self_ptr = LLVMGetParam(func, 0)
    let idx = LLVMGetParam(func, 1)
    let item = LLVMGetParam(func, 2)

    // data is field 0
    let data_gep = LLVMBuildStructGEP2(b, al_lltype, self_ptr, 0, "data_gep")
    let data_ptr = LLVMBuildLoad2(b, ptrt, data_gep, "data")

    let idx_arr = self.allocator.alloc(8, 8) as **Void
    idx_arr[0] = idx
    let elem_slot = LLVMBuildGEP2(b, real_elem_ll, data_ptr, idx_arr as *Void, 1, "elem_slot")
    LLVMBuildStore(b, item, elem_slot)
    self.allocator.free(idx_arr as *Void)

    LLVMBuildRet(b, LLVMConstInt(i64t, 0, false))
    LLVMDisposeBuilder(b)
}

fn emit_monomorphized_arraylists(self) {
    // Helper: given a type string (possibly "ArrayList<T>" or "*ArrayList<T>"),
    // emit method bodies for the ArrayList<T> instantiation if recognized.
    // Scans both struct_field_types and func_param_types to find all usages.
    var i = 0
    while i < self.struct_field_types.length() {
        let entry = self.struct_field_types.get(i)
        self.maybe_emit_arraylist_for_type(entry.value)
        i = i + 1
    }
    var j = 0
    while j < self.func_param_types.length() {
        let entry2 = self.func_param_types.get(j)
        self.maybe_emit_arraylist_for_type(entry2.value)
        j = j + 1
    }
}

fn maybe_emit_arraylist_for_type(self, raw_type: Str) {
    // Strip leading pointer/reference prefix: "*ArrayList<T>" or "ArrayList<T>"
    var ftype = raw_type
    while length(ftype) > 0 && (ftype[0] == Char(42) || ftype[0] == Char(38)) {
        ftype = substring(ftype, 1, length(ftype))
    }
    // Must be "ArrayList<T>" — length > 11, starts with "ArrayList<", ends with ">"
    if length(ftype) <= 11 { return }
    if ftype[0] != Char(65)  { return }  // A
    if ftype[1] != Char(114) { return }  // r
    if ftype[2] != Char(114) { return }  // r
    if ftype[3] != Char(97)  { return }  // a
    if ftype[4] != Char(121) { return }  // y
    if ftype[5] != Char(76)  { return }  // L
    if ftype[6] != Char(105) { return }  // i
    if ftype[7] != Char(115) { return }  // s
    if ftype[8] != Char(116) { return }  // t
    if ftype[9] != Char(60)  { return }  // <
    if ftype[length(ftype) - 1] != Char(62) { return }  // >

    let al_lltype = self.map_type(ftype)
    let elem_ktype = substring(ftype, 10, length(ftype) - 1)

    var get_name: Str = ftype + "_get"
    var len_name: Str = ftype + "_length"
    var push_name: Str = ftype + "_push"
    var pop_name: Str = ftype + "_pop"
    var al_init_name: Str = ftype + "_init"
    var set_name: Str = ftype + "_set"

    self.emit_arraylist_method_length(len_name, al_lltype)
    self.emit_arraylist_method_push(elem_ktype, push_name, al_lltype)
    self.emit_arraylist_method_pop(elem_ktype, pop_name, al_lltype)
    self.emit_arraylist_method_init(elem_ktype, al_init_name, al_lltype)
    self.emit_arraylist_method_get(elem_ktype, al_lltype, get_name)
    self.emit_arraylist_method_set(elem_ktype, set_name, al_lltype)
}

fn emit_runtime_helpers(self) {
    // _kai_set_current_allocator(allocator: *Void)
    let void_ptr_t = LLVMPointerType(LLVMInt8TypeInContext(self.ctx), 0)
    let void_t = LLVMVoidTypeInContext(self.ctx)
    let i64_t = LLVMInt64TypeInContext(self.ctx)
    
    // Create global _kai_current_allocator
    let global_alloc = LLVMAddGlobal(self.module, void_ptr_t, "_kai_current_allocator")
    LLVMSetInitializer(global_alloc, LLVMConstNull(void_ptr_t))
    
    // __kai_set_current_allocator
    let set_alloc_params = self.allocator.alloc(8, 8) as **Void
    set_alloc_params[0] = void_ptr_t
    let set_alloc_ty = LLVMFunctionType(void_t, set_alloc_params as *Void, 1, false)
    var set_alloc_fn = LLVMGetNamedFunction(self.module, "_kai_set_current_allocator")
    if set_alloc_fn == 0 as *Void {
        set_alloc_fn = LLVMAddFunction(self.module, "_kai_set_current_allocator", set_alloc_ty)
    }
    let set_alloc_bb = LLVMAppendBasicBlockInContext(self.ctx, set_alloc_fn, "entry")
    LLVMPositionBuilderAtEnd(self.builder, set_alloc_bb)
    LLVMBuildStore(self.builder, LLVMGetParam(set_alloc_fn, 0), global_alloc)
    LLVMBuildRetVoid(self.builder)
    
    // Allocator_alloc(self: *Allocator, size: Int, align: Int) -> *Char
    let alloc_params = self.allocator.alloc(24, 8) as **Void
    alloc_params[0] = void_ptr_t
    alloc_params[1] = i64_t
    alloc_params[2] = i64_t
    let alloc_ty = LLVMFunctionType(void_ptr_t, alloc_params as *Void, 3, false)
    var alloc_fn = LLVMGetNamedFunction(self.module, "Allocator_alloc")
    if alloc_fn == 0 as *Void {
        alloc_fn = LLVMAddFunction(self.module, "Allocator_alloc", alloc_ty)
    }
    let alloc_bb = LLVMAppendBasicBlockInContext(self.ctx, alloc_fn, "entry")
    LLVMPositionBuilderAtEnd(self.builder, alloc_bb)
    let kai_alloc_fn = LLVMGetNamedFunction(self.module, "KaiAllocator_alloc")
    if kai_alloc_fn != 0 as *Void {
        let call_args = self.allocator.alloc(24, 8) as **Void
        call_args[0] = LLVMGetParam(alloc_fn, 0)
        call_args[1] = LLVMGetParam(alloc_fn, 1)
        call_args[2] = LLVMGetParam(alloc_fn, 2)
        let kai_alloc_ty = LLVMFunctionType(void_ptr_t, alloc_params as *Void, 3, false)
        let res = LLVMBuildCall2(self.builder, kai_alloc_ty, kai_alloc_fn, call_args as *Void, 3, "res")
        LLVMBuildRet(self.builder, res)
        self.allocator.free(call_args as *Void)
    } else {
        LLVMBuildRet(self.builder, LLVMConstNull(void_ptr_t))
    }
    
    // Allocator_free(self: *Allocator, ptr: *Char)
    let free_params = self.allocator.alloc(16, 8) as **Void
    free_params[0] = void_ptr_t
    free_params[1] = void_ptr_t
    let free_ty = LLVMFunctionType(void_t, free_params as *Void, 2, false)
    var free_fn = LLVMGetNamedFunction(self.module, "Allocator_free")
    if free_fn == 0 as *Void {
        free_fn = LLVMAddFunction(self.module, "Allocator_free", free_ty)
    }
    
    let free_bb = LLVMAppendBasicBlockInContext(self.ctx, free_fn, "entry")
    LLVMPositionBuilderAtEnd(self.builder, free_bb)
    
    let kai_free_fn = LLVMGetNamedFunction(self.module, "KaiAllocator_free")
    if kai_free_fn != 0 as *Void {
        let call_args = self.allocator.alloc(16, 8) as **Void
        call_args[0] = LLVMGetParam(free_fn, 0)
        call_args[1] = LLVMGetParam(free_fn, 1)
        let kai_free_ty = LLVMFunctionType(void_t, free_params as *Void, 2, false)
        let _ = LLVMBuildCall2(self.builder, kai_free_ty, kai_free_fn, call_args as *Void, 2, "")
        LLVMBuildRetVoid(self.builder)
        self.allocator.free(call_args as *Void)
    } else {
        LLVMBuildRetVoid(self.builder)
    }
    
    self.allocator.free(set_alloc_params as *Void)
    self.allocator.free(alloc_params as *Void)
    self.allocator.free(free_params as *Void)
}

}
