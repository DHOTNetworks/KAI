cimport "std/llvm/core.h"

import ArrayList from std.core.array
import write_string from std.io.file
import Allocator from std.core.allocator
import KaiAllocator from std.core.allocator
import length from std.core.string
import strlen from std.core.string
import Str from std.core.string
import ImportResolver from imports
import StmtNode from ast_nodes
import ExprNode from ast_nodes
import PatternNode from ast_nodes
import StmtKind from ast_nodes
import ExprKind from ast_nodes
import PatternKind from ast_nodes
import TokenValue from token_defs
import int_to_str from std.core.string
import char_to_str from std.core.string
import std.llvm.core
import StringPool from string_pool

extern fn malloc(size: Int) -> *Char
extern fn free(ptr: *Char)
extern fn kai_fflush(stream: *Void) -> Int



let LLVMObjectFile = 1
let LLVMCodeGenLevelDefault = 2
let LLVMRelocDefault = 0
let LLVMCodeModelDefault = 0
let LLVMPrintMessageAction = 1

struct LLVMStrMapEntry {
    key: Str
    value: Str
}

struct LLVMCodegen {
    allocator: *KaiAllocator
    stmt_pool: *ArrayList<StmtNode>
    expr_pool: *ArrayList<ExprNode>
    pattern_pool: *ArrayList<PatternNode>
    import_resolver: *ImportResolver
    pool: *StringPool

    ctx: *Void
    module: *Void
    builder: *Void
    cur_func: *Void
    cur_func_name: Str
    cur_block: *Void
    cur_method_is_init: Bool
    cur_self_alloca: *Void
    cur_struct_type: *Void
    last_was_term: Bool

    int1_type: *Void
    int8_type: *Void
    ptr_type: *Void
    int32_type: *Void
    int64_type: *Void
    float_type: *Void
    double_type: *Void
    void_type: *Void


    str_counter: Int

    func_type_names: ArrayList<Str>
    func_type_returns: ArrayList<Str>
    func_param_counts: ArrayList<Int>
    func_type_param_types: ArrayList<Str>

    func_cache_names: ArrayList<Str>
    func_cache_vals: ArrayList<Int>
    func_cache_types: ArrayList<Int>

    local_alloca_names: ArrayList<Str>
    local_alloca_vals: ArrayList<Int>
    local_alloca_types: ArrayList<Int>
    local_alloca_type_strs: ArrayList<Str>
    local_alloca_decls: ArrayList<Int>

    loop_cond_block: *Void
    loop_merge_block: *Void

    struct_cache_names: ArrayList<Str>
    struct_cache_types: ArrayList<Int>
    struct_cache_field_counts: ArrayList<Int>

    enum_cache_names: ArrayList<Str>
    enum_cache_types: ArrayList<Int>
    enum_has_payload: ArrayList<Bool>

    tuple_cache_names: ArrayList<Str>
    tuple_cache_types: ArrayList<Int>
    tuple_cache_field_counts: ArrayList<Int>

    current_type_map: ArrayList<LLVMStrMapEntry>
    generic_struct_decls: ArrayList<LLVMStrMapEntry>
    generic_enum_decls: ArrayList<LLVMStrMapEntry>
    monomorphized_types: ArrayList<Str>
    method_indices: ArrayList<Int>

    str_type: *Void
    // Names of all extern-declared functions (used for two-tier ABI: extern=ptr, Kai=%Str)
    extern_func_names: ArrayList<Str>
    // Names of all functions with actual Kai bodies (overrides extern declarations)
    kai_func_names: ArrayList<Str>
    global_decls: ArrayList<Int>
}

impl LLVMCodegen {

fn init(self, allocator: *KaiAllocator, stmt_pool: *ArrayList<StmtNode>, expr_pool: *ArrayList<ExprNode>, pattern_pool: *ArrayList<PatternNode>, import_resolver: *ImportResolver, pool: *StringPool) {
    self.allocator = allocator
    self.stmt_pool = stmt_pool
    self.expr_pool = expr_pool
    self.pattern_pool = pattern_pool
    self.import_resolver = import_resolver
    self.pool = pool
    self.ctx = LLVMContextCreate()
    self.module = LLVMModuleCreateWithNameInContext("kai_module", self.ctx)
    self.builder = LLVMCreateBuilderInContext(self.ctx)
    self.cur_func = (0 as *Void)
    self.cur_block = (0 as *Void)
    self.last_was_term = false
    self.int1_type = LLVMInt1TypeInContext(self.ctx)
    self.int8_type = LLVMInt8TypeInContext(self.ctx)
    self.ptr_type = LLVMPointerType(self.int8_type, 0)
    self.int32_type = LLVMInt32TypeInContext(self.ctx)
    self.int64_type = LLVMInt64TypeInContext(self.ctx)
    self.float_type = LLVMFloatTypeInContext(self.ctx)
    self.double_type = LLVMDoubleTypeInContext(self.ctx)
    self.void_type = LLVMVoidTypeInContext(self.ctx)

    self.str_counter = 0
    self.func_type_names = ArrayList<Str>(allocator)
    self.func_type_returns = ArrayList<Str>(allocator)
    self.func_param_counts = ArrayList<Int>(allocator)
    self.func_type_param_types = ArrayList<Str>(allocator)
    self.func_cache_names = ArrayList<Str>(allocator)
    self.func_cache_vals = ArrayList<Int>(allocator)
    self.func_cache_types = ArrayList<Int>(allocator)
    self.local_alloca_names = ArrayList<Str>(allocator)
    self.local_alloca_vals = ArrayList<Int>(allocator)
    self.local_alloca_types = ArrayList<Int>(allocator)
    self.local_alloca_type_strs = ArrayList<Str>(allocator)
    self.local_alloca_decls = ArrayList<Int>(allocator)
    self.loop_cond_block = (0 as *Void)
    self.loop_merge_block = (0 as *Void)

    self.struct_cache_names = ArrayList<Str>(allocator)
    self.struct_cache_types = ArrayList<Int>(allocator)
    self.struct_cache_field_counts = ArrayList<Int>(allocator)

    self.enum_cache_names = ArrayList<Str>(allocator)
    self.enum_cache_types = ArrayList<Int>(allocator)
    self.enum_has_payload = ArrayList<Bool>(allocator)

    self.tuple_cache_names = ArrayList<Str>(allocator)
    self.tuple_cache_types = ArrayList<Int>(allocator)
    self.tuple_cache_field_counts = ArrayList<Int>(allocator)

    self.current_type_map = ArrayList<LLVMStrMapEntry>(allocator)
    self.generic_struct_decls = ArrayList<LLVMStrMapEntry>(allocator)
    self.generic_enum_decls = ArrayList<LLVMStrMapEntry>(allocator)
    self.monomorphized_types = ArrayList<Str>(allocator)
    self.method_indices = ArrayList<Int>(allocator)
    self.extern_func_names = ArrayList<Str>(allocator)
    self.kai_func_names = ArrayList<Str>(allocator)
    self.global_decls = ArrayList<Int>(allocator)

    // Create fat-pointer Str type: { ptr, i64 }
    self.str_type = LLVMStructCreateNamed(self.ctx, "Str")
    var str_fields = ArrayList<Int>(allocator)
    str_fields.push((self.ptr_type as Int))   // .ptr — i8*
    str_fields.push((self.int64_type as Int)) // .len — byte count
    LLVMStructSetBody(self.str_type, str_fields.data as *Void, 2, false)
}

fn build_func_types(self) {
    self.method_indices = ArrayList<Int>(self.allocator)
    var i = 0
    while i < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(i)
        if stmt.kind == StmtKind.sk_impl_block {
            var mi = 0
            while mi < stmt.impl_methods.length() {
                self.method_indices.push(stmt.impl_methods.get(mi))
                mi = mi + 1
            }
        }
        if stmt.kind == StmtKind.sk_struct_decl {
            var mi = 0
            while mi < stmt.struct_methods.length() {
                self.method_indices.push(stmt.struct_methods.get(mi))
                mi = mi + 1
            }
        }
        if stmt.kind == StmtKind.sk_trait_decl {
            var mi = 0
            while mi < stmt.trait_methods.length() {
                self.method_indices.push(stmt.trait_methods.get(mi))
                mi = mi + 1
            }
        }
        i = i + 1
    }

    i = 0
    while i < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(i)
        if stmt.kind == StmtKind.sk_func_decl {
            var is_method = false
            var mi = 0
            while mi < self.method_indices.length() {
                if self.method_indices.get(mi) == i {
                    is_method = true
                    break
                }
                mi = mi + 1
            }
            if is_method {
                i = i + 1
                continue
            }

            self.func_type_names.push(stmt.func_name)
            self.func_type_returns.push(stmt.func_return_type)
            self.func_param_counts.push(stmt.func_params.length())
            // Build param types string
            var pts = ""
            var pi = 0
            while pi < stmt.func_params.length() {
                if pi > 0 { pts = pts + "," }
                pts = pts + stmt.func_params.get(pi).ptype
                pi = pi + 1
            }
            self.func_type_param_types.push(pts)
            // Cache Kai function name (body takes precedence over any extern decl)
            if stmt.func_body >= 0 {
                self.kai_func_names.push(stmt.func_name)
            }
        }
        if stmt.kind == StmtKind.sk_extern {
            self.func_type_names.push(stmt.extern_name)
            self.func_type_returns.push(stmt.extern_return)
            self.func_param_counts.push(stmt.extern_params.length())
            var pts = ""
            var pi = 0
            while pi < stmt.extern_params.length() {
                if pi > 0 { pts = pts + "," }
                pts = pts + stmt.extern_params.get(pi).ptype
                pi = pi + 1
            }
            self.func_type_param_types.push(pts)
            // Cache extern name for O(1) ABI lookup
            self.extern_func_names.push(stmt.extern_name)
        }
        // Handle impl block methods
        if stmt.kind == StmtKind.sk_impl_block {
            if !self.is_monomorphized_name(stmt.impl_struct_name) {
                var mi = 0
                while mi < stmt.impl_methods.length() {
                    let method_idx = stmt.impl_methods.get(mi)
                    let method_stmt = self.stmt_pool.get(method_idx)
                    if method_stmt.kind == StmtKind.sk_func_decl {
                        let mangled_name = stmt.impl_struct_name + "_" + method_stmt.func_name
                        self.func_type_names.push(mangled_name)
                        var ret = method_stmt.func_return_type
                        let is_init = (method_stmt.func_name == "init") || (method_stmt.func_return_type == stmt.impl_struct_name) || (method_stmt.func_return_type == "*" + stmt.impl_struct_name) || (method_stmt.func_return_type == "&" + stmt.impl_struct_name)
                        if is_init {
                            ret = stmt.impl_struct_name
                        }
                        self.func_type_returns.push(ret)
                        
                        var param_count = method_stmt.func_params.length()
                        if is_init {
                            param_count = param_count - 1
                        }
                        self.func_param_counts.push(param_count)
                        
                        var pts = ""
                        var pi = 0
                        while pi < method_stmt.func_params.length() {
                            let param = method_stmt.func_params.get(pi)
                            if is_init && param.name == "self" {
                                pi = pi + 1
                                continue
                            }
                            if strlen(pts) > 0 { pts = pts + "," }
                            var ptype_str = param.ptype
                            if param.name == "self" {
                                ptype_str = "*" + stmt.impl_struct_name
                            }
                            pts = pts + ptype_str
                            pi = pi + 1
                        }
                        self.func_type_param_types.push(pts)
                    }
                    mi = mi + 1
                }
            }
        }
        // Handle struct methods
        if stmt.kind == StmtKind.sk_struct_decl {
            if !self.is_monomorphized_name(stmt.struct_name) {
                var mi = 0
                while mi < stmt.struct_methods.length() {
                    let method_idx = stmt.struct_methods.get(mi)
                    let method_stmt = self.stmt_pool.get(method_idx)
                    if method_stmt.kind == StmtKind.sk_func_decl {
                        let mangled_name = stmt.struct_name + "_" + method_stmt.func_name
                        self.func_type_names.push(mangled_name)
                        self.func_type_returns.push(method_stmt.func_return_type)
                        self.func_param_counts.push(method_stmt.func_params.length())
                        var pts = ""
                        var pi = 0
                        while pi < method_stmt.func_params.length() {
                            if pi > 0 { pts = pts + "," }
                            var ptype_str = method_stmt.func_params.get(pi).ptype
                            if method_stmt.func_params.get(pi).name == "self" {
                                ptype_str = "*" + stmt.struct_name
                            }
                            pts = pts + ptype_str
                            pi = pi + 1
                        }
                        self.func_type_param_types.push(pts)
                    }
                    mi = mi + 1
                }
            }
        }
        i = i + 1
    }
}

fn build_type_caches(self) {
    // Pass 1: Pre-register all non-generic struct NAMES in LLVM's type registry.
    // This ensures map_type / LLVMGetTypeByName2 can find any struct by name even if
    // build_type_caches hasn't set its body yet (e.g. when ArrayList<SymbolTable> is
    // monomorphized while building a struct that contains ArrayList<SymbolTable> as a field).
    var i = 0
    while i < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(i)
        if stmt.kind == StmtKind.sk_struct_decl && stmt.struct_type_params.length() == 0 {
            // Create the named type placeholder (opaque, body set in pass 2)
            let sname = stmt.struct_name
            let existing_ty = LLVMGetTypeByName2(self.ctx, sname)
            if existing_ty == (0 as *Void) {
                let _ = LLVMStructCreateNamed(self.ctx, sname)
            }
        }
        i = i + 1
    }

    // Pass 2: Set struct bodies and populate all caches.
    i = 0
    while i < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(i)

        // Struct types
        if stmt.kind == StmtKind.sk_struct_decl {
            if stmt.struct_type_params.length() > 0 {
                llvm_type_map_put(&self.generic_struct_decls, stmt.struct_name, int_to_str(i))
                i = i + 1
                continue
            }
            let sname = stmt.struct_name
            let field_count = stmt.struct_fields.length()
            // Retrieve the already-created named type from pass 1
            var named_ty = LLVMGetTypeByName2(self.ctx, sname)
            if named_ty == (0 as *Void) {
                named_ty = LLVMStructCreateNamed(self.ctx, sname)
            }
            if field_count > 0 {
                var field_types = ArrayList<Int>(self.allocator)
                var fi = 0
                while fi < field_count {
                    let f = stmt.struct_fields.get(fi)
                    let fty = self.map_type(f.ftype)
                    if fty == self.void_type || fty == (0 as *Void) {
                        field_types.push((self.int64_type as Int))
                    } else {
                        field_types.push((fty as Int))
                    }
                    fi = fi + 1
                }
                LLVMStructSetBody(named_ty, field_types.data as *Void, field_count, false)
            }
            self.struct_cache_names.push(sname)
            self.struct_cache_types.push((named_ty as Int))
            self.struct_cache_field_counts.push(field_count)
        }

        // Enum types (with payload => tagged union struct)
        if stmt.kind == StmtKind.sk_enum_decl {
            if stmt.enum_type_params.length() > 0 {
                llvm_type_map_put(&self.generic_enum_decls, stmt.enum_name, int_to_str(i))
                i = i + 1
                continue
            }
            let ename = stmt.enum_name
            var has_payload = false
            var vi = 0
            while vi < stmt.enum_variants.length() {
                let v = stmt.enum_variants.get(vi)
                if v.params.length() > 0 { has_payload = true }
                vi = vi + 1
            }
            if has_payload {
                // Create struct { i8 tag, [N x i8] payload } or similar
                // For simplicity: struct { i8 tag, [8 x i64] payload } — big enough for any variant
                // Actually, create proper union: struct { i8 tag, union { struct { fields } vname; ... } }
                // LLVM doesn't support anonymous unions in structs directly via C API
                // So we use struct { i8 tag, [16 x i64] payload } as a workaround
                let named_ty = LLVMStructCreateNamed(self.ctx, ename)
                var field_types = ArrayList<Int>(self.allocator)
                field_types.push((self.int8_type as Int))  // tag
                // Use a large payload array
                let payload_ty = LLVMArrayType(self.int64_type, 16)
                field_types.push((payload_ty as Int))
                LLVMStructSetBody(named_ty, field_types.data as *Void, 2, false)
                self.enum_cache_names.push(ename)
                self.enum_cache_types.push((named_ty as Int))
                self.enum_has_payload.push(true)
            } else {
                // No-payload enum: use Int (Int64) for the enum value
                self.enum_cache_names.push(ename)
                self.enum_cache_types.push((self.int64_type as Int))
                self.enum_has_payload.push(false)
            }
        }

        i = i + 1
    }

    // Add built-in Range type to struct cache
    let range_ty = LLVMStructCreateNamed(self.ctx, "Range")
    var range_fields = ArrayList<Int>(self.allocator)
    range_fields.push((self.int64_type as Int))  // start
    range_fields.push((self.int64_type as Int))  // end
    range_fields.push((self.int1_type as Int))   // is_inclusive
    LLVMStructSetBody(range_ty, range_fields.data as *Void, 3, false)
    self.struct_cache_names.push("Range")
    self.struct_cache_types.push((range_ty as Int))
    self.struct_cache_field_counts.push(3)
}

fn get_generic_mangled_name(self, name: Str) -> Str {
    if self.str_contains(name, Char(60)) {
        let lt_pos = self.str_find(name, Char(60))
        let gt_pos = self.str_find(name, Char(62))
        if lt_pos >= 0 && gt_pos >= 0 && gt_pos > lt_pos {
            let base_name = name[0..lt_pos]
            let suffix = name[gt_pos + 1..strlen(name)]
            return base_name + suffix
        }
    }
    
    if strlen(name) > 10 && name[0..10] == "ArrayList_" {
        var last_u = strlen(name) - 1
        while last_u > 0 && name[last_u] != Char(95) {
            last_u = last_u - 1
        }
        if last_u > 9 {
            return "ArrayList_" + name[last_u + 1..strlen(name)]
        }
    }
    if strlen(name) > 8 && name[0..8] == "HashMap_" {
        var last_u = strlen(name) - 1
        while last_u > 0 && name[last_u] != Char(95) {
            last_u = last_u - 1
        }
        if last_u > 7 {
            return "HashMap_" + name[last_u + 1..strlen(name)]
        }
    }
    return name
}

fn resolve_mangled_func_name(self, name: Str) -> Str {
    var i = 0
    while i < self.func_type_names.length() {
        if llvm_str_eq(self.func_type_names.get(i), name) {
            return name
        }
        i = i + 1
    }

    var prefix = ""
    var has_func_name = false
    unsafe {
        if (self.cur_func_name as *Void) != (0 as *Void) {
            if strlen(self.cur_func_name) > 0 {
                has_func_name = true
            }
        }
    }
    if has_func_name {
        let underscore_pos = self.str_find(self.cur_func_name, Char(95))
        if underscore_pos > 0 {
            prefix = self.cur_func_name[0..underscore_pos + 1]
        }
    }
    
    if strlen(prefix) > 0 {
        i = 0
        while i < self.func_type_names.length() {
            let f_name = self.func_type_names.get(i)
            if self.decl_name_matches(f_name, name) {
                if strlen(f_name) >= strlen(prefix) && f_name[0..strlen(prefix)] == prefix {
                    return f_name
                }
            }
            i = i + 1
        }
    }
    
    i = 0
    while i < self.func_type_names.length() {
        let f_name = self.func_type_names.get(i)
        if self.decl_name_matches(f_name, name) {
            return f_name
        }
        i = i + 1
    }
    return name
}

fn get_func_return_type(self, name: Str) -> Str {
    let rname = self.resolve_mangled_func_name(name)
    var i = 0
    while i < self.func_type_names.length() {
        if llvm_str_eq(self.func_type_names.get(i), rname) {
            return self.func_type_returns.get(i) + ""
        }
        i = i + 1
    }
    let resolved = self.get_generic_mangled_name(rname)
    if resolved != rname {
        i = 0
        while i < self.func_type_names.length() {
            if llvm_str_eq(self.func_type_names.get(i), resolved) {
                return self.func_type_returns.get(i) + ""
            }
            i = i + 1
        }
    }
    return ""
}

fn get_func_param_count(self, name: Str) -> Int {
    let rname = self.resolve_mangled_func_name(name)
    var i = 0
    while i < self.func_type_names.length() {
        if llvm_str_eq(self.func_type_names.get(i), rname) {
            return self.func_param_counts.get(i)
        }
        i = i + 1
    }
    let resolved = self.get_generic_mangled_name(rname)
    if resolved != rname {
        i = 0
        while i < self.func_type_names.length() {
            if llvm_str_eq(self.func_type_names.get(i), resolved) {
                return self.func_param_counts.get(i)
            }
            i = i + 1
        }
    }
    return 0
}

fn get_func_param_types(self, name: Str) -> Str {
    let rname = self.resolve_mangled_func_name(name)
    var i = 0
    while i < self.func_type_names.length() {
        if llvm_str_eq(self.func_type_names.get(i), rname) {
            return self.func_type_param_types.get(i) + ""
        }
        i = i + 1
    }
    let resolved = self.get_generic_mangled_name(rname)
    if resolved != rname {
        i = 0
        while i < self.func_type_names.length() {
            if llvm_str_eq(self.func_type_names.get(i), resolved) {
                return self.func_type_param_types.get(i) + ""
            }
            i = i + 1
        }
    }
    return ""
}

fn get_cached_func_type(self, name: Str) -> *Void {
    let rname = self.resolve_mangled_func_name(name)
    var i = 0
    while i < self.func_cache_names.length() {
        if llvm_str_eq(self.func_cache_names.get(i), rname) {
            return (self.func_cache_types.get(i) as *Void)
        }
        i = i + 1
    }
    return (0 as *Void)
}

fn c_abi_type(self, tname: Str) -> *Void {
    if tname == "Str" || tname == "*Str" || tname == "&Str" {
        return self.ptr_type
    }
    return self.map_type(tname)
}

fn build_llvm_func_type_from_params(self, ret: *Void, param_types_str: Str, is_vararg: Bool, is_extern: Bool) -> *Void {
    let param_count = self.get_func_param_count_by_types_str(param_types_str)
    if param_count == 0 {
        return kai_func_type_0(ret)
    }
    var param_type_array = ArrayList<Int>(self.allocator)
    var start = 0
    var pi = 0
    while pi < strlen(param_types_str) {
        if param_types_str[pi] == Char(44) { // comma
            let tname = param_types_str[start..pi]
            var t: *Void = (0 as *Void)
            if is_extern {
                t = self.c_abi_type(tname)
            } else {
                t = self.map_type(tname)
            }
            if t == (0 as *Void) || t == self.void_type {
                param_type_array.push((self.int64_type as Int))
            } else {
                param_type_array.push((t as Int))
            }
            start = pi + 1
        }
        pi = pi + 1
    }
    if start < strlen(param_types_str) {
        let tname = param_types_str[start..strlen(param_types_str)]
        var t: *Void = (0 as *Void)
        if is_extern {
            t = self.c_abi_type(tname)
        } else {
            t = self.map_type(tname)
        }
        if t == (0 as *Void) || t == self.void_type {
            param_type_array.push((self.int64_type as Int))
        } else {
            param_type_array.push((t as Int))
        }
    }
    let count = param_type_array.length()
    if count == 0 {
        return kai_func_type_0(ret)
    }
    if count == 1 {
        return kai_func_type_1(ret, (param_type_array.get(0) as *Void), is_vararg)
    }
    if count == 2 {
        return kai_func_type_2(ret, (param_type_array.get(0) as *Void), (param_type_array.get(1) as *Void), is_vararg)
    }
    // For 3+ params, use the general LLVMFunctionType with array
    return LLVMFunctionType(ret, param_type_array.data as *Void, count, is_vararg)
}

fn get_func_param_count_by_types_str(self, param_types_str: Str) -> Int {
    if strlen(param_types_str) == 0 { return 0 }
    var count = 1
    var i = 0
    while i < strlen(param_types_str) {
        if param_types_str[i] == Char(44) { count = count + 1 }
        i = i + 1
    }
    return count
}

// A function is extern (C ABI) only if it has an extern declaration AND no Kai body.
// Functions imported via `import X from module` may have both an extern forward-decl
// in some files and an actual body in another — the body always takes precedence.
fn is_extern_func(self, name: Str) -> Bool {
    if name == "malloc" || name == "realloc" || name == "calloc" { return true }
    if name == "printf" || name == "fprintf" || name == "sprintf" || name == "snprintf" { return true }
    if name == "fopen" || name == "fread" || name == "fwrite" || name == "fclose" || name == "fseek" || name == "ftell" || name == "rewind" { return true }
    if name == "strlen" || name == "strcmp" { return true }
    if name == "exit" || name == "system" { return true }
    if name == "isdigit" || name == "isalpha" || name == "isalnum" || name == "isspace" { return true }
    if name == "toupper" || name == "tolower" { return true }
    if name == "atoll" { return true }
    if name == "sqrt" { return true }
    if name == "memset" || name == "memcpy" || name == "memmove" { return true }
    if name == "abort" { return true }

    // If the function has a Kai body, it is NOT extern
    var ki = 0
    while ki < self.kai_func_names.length() {
        if self.kai_func_names.get(ki) == name {
            return false
        }
        ki = ki + 1
    }
    // Otherwise, check if it's declared extern
    var i = 0
    while i < self.extern_func_names.length() {
        if llvm_str_eq(self.extern_func_names.get(i), name) {
            return true
        }
        i = i + 1
    }
    return false
}

fn lookup_or_create_func(self, name: Str) -> *Void {
    var i = 0
    while i < self.func_cache_names.length() {
        if llvm_str_eq(self.func_cache_names.get(i), name) {
            return (self.func_cache_vals.get(i) as *Void)
        }
        i = i + 1
    }
    let existing = LLVMGetNamedFunction(self.module, name)
    let is_ext = self.is_extern_func(name)
    if existing != (0 as *Void) {
        self.func_cache_names.push(name)
        self.func_cache_vals.push((existing as Int))
        let ret_type_str = self.get_func_return_type(name)
        var llvm_ret: *Void = (0 as *Void)
        if is_ext {
            llvm_ret = self.c_abi_type(ret_type_str)
        } else {
            llvm_ret = self.map_type(ret_type_str)
        }
        let is_vararg = (name == "printf")
        let param_types_str = self.get_func_param_types(name)
        var fn_type: *Void = (0 as *Void)
        if is_vararg {
            let ptype = self.map_type("*Char")
            fn_type = kai_func_type_1(llvm_ret, ptype, true)
        } else if strlen(param_types_str) > 0 {
            fn_type = self.build_llvm_func_type_from_params(llvm_ret, param_types_str, false, is_ext)
        } else {
            fn_type = kai_func_type_0(llvm_ret)
        }
        if fn_type == (0 as *Void) {
            fn_type = kai_func_type_1(llvm_ret, self.ptr_type, false)
        }
        self.func_cache_types.push((fn_type as Int))
        return existing
    }
    let ret_type_str = self.get_func_return_type(name)
    var llvm_ret: *Void = (0 as *Void)
    if is_ext {
        llvm_ret = self.c_abi_type(ret_type_str)
    } else {
        llvm_ret = self.map_type(ret_type_str)
    }
    let is_vararg = (name == "printf")
    let param_types_str = self.get_func_param_types(name)
    var fn_type: *Void = (0 as *Void)
    if is_vararg {
        let ptype = self.map_type("*Char")
        fn_type = kai_func_type_1(llvm_ret, ptype, true)
    } else if strlen(param_types_str) > 0 {
        fn_type = self.build_llvm_func_type_from_params(llvm_ret, param_types_str, false, is_ext)
    } else {
        fn_type = kai_func_type_0(llvm_ret)
    }
    if fn_type == (0 as *Void) {
        fn_type = kai_func_type_1(llvm_ret, self.ptr_type, false)
    }
    let fn_val = LLVMAddFunction(self.module, name, fn_type)
    self.func_cache_names.push(name)
    self.func_cache_vals.push((fn_val as Int))
    self.func_cache_types.push((fn_type as Int))
    return fn_val
}

fn foreach_method(self, stmt_idx: Int, decl_only: Bool) {
    let stmt = self.stmt_pool.get(stmt_idx)
    if stmt.kind == StmtKind.sk_impl_block {
        var is_generic_impl = false
        var si = 0
        while si < self.stmt_pool.length() {
            let sn = self.stmt_pool.get(si)
            if sn.kind == StmtKind.sk_struct_decl && sn.struct_name == stmt.impl_struct_name && sn.struct_type_params.length() > 0 {
                is_generic_impl = true
                break
            }
            si = si + 1
        }
        if is_generic_impl {
            return
        }

        var mi = 0
        while mi < stmt.impl_methods.length() {
            let method_idx = stmt.impl_methods.get(mi)
            let method_stmt = self.stmt_pool.get(method_idx)
            if method_stmt.kind == StmtKind.sk_func_decl {
                let mangled_name = stmt.impl_struct_name + "_" + method_stmt.func_name
                if decl_only {
                    self.emit_func_decl(method_idx, mangled_name)
                } else if method_stmt.func_body >= 0 {
                    let fn_val = self.lookup_or_create_func(mangled_name)
                    self.emit_func_body(method_idx, fn_val, stmt.impl_struct_name)
                }
            }
            mi = mi + 1
        }
    }
    if stmt.kind == StmtKind.sk_struct_decl {
        if stmt.struct_type_params.length() > 0 {
            return
        }
        var mi = 0
        while mi < stmt.struct_methods.length() {
            let method_idx = stmt.struct_methods.get(mi)
            let method_stmt = self.stmt_pool.get(method_idx)
            if method_stmt.kind == StmtKind.sk_func_decl {
                let mangled_name = stmt.struct_name + "_" + method_stmt.func_name
                if decl_only {
                    self.emit_func_decl(method_idx, mangled_name)
                } else if method_stmt.func_body >= 0 {
                    let fn_val = self.lookup_or_create_func(mangled_name)
                    self.emit_func_body(method_idx, fn_val, stmt.struct_name)
                }
            }
            mi = mi + 1
        }
    }
}

fn emit_runtime_helpers(self) {
    let old_block = self.cur_block
    let old_func = self.cur_func

    // 1. Define __kai_print_int
    let print_int_ty = kai_func_type_1(self.void_type, self.int64_type, false)
    let print_int_fn = LLVMAddFunction(self.module, "__kai_print_int", print_int_ty)
    let b1 = LLVMAppendBasicBlockInContext(self.ctx, print_int_fn, "entry")
    LLVMPositionBuilderAtEnd(self.builder, b1)
    let p_int_val = LLVMGetParam(print_int_fn, 0)
    let printf_fn = self.lookup_or_create_func("printf")
    let format_str = LLVMBuildGlobalStringPtr(self.builder, "%lld\n", "fmt_int")
    let printf_ty = self.get_cached_func_type("printf")
    let _ = kai_build_call_2(self.builder, printf_ty, printf_fn, format_str, p_int_val, "")
    LLVMBuildRetVoid(self.builder)

    // 2. Define __kai_print_float
    let print_float_ty = kai_func_type_1(self.void_type, self.double_type, false)
    let print_float_fn = LLVMAddFunction(self.module, "__kai_print_float", print_float_ty)
    let b2 = LLVMAppendBasicBlockInContext(self.ctx, print_float_fn, "entry")
    LLVMPositionBuilderAtEnd(self.builder, b2)
    let p_float_val = LLVMGetParam(print_float_fn, 0)
    let format_float = LLVMBuildGlobalStringPtr(self.builder, "%f\n", "fmt_float")
    let _ = kai_build_call_2(self.builder, printf_ty, printf_fn, format_float, p_float_val, "")
    LLVMBuildRetVoid(self.builder)

    // 3. Define _kai_munmap(addr: ptr, length: i64) -> i64  [wraps munmap]
    // Declare extern munmap
    let munmap_ty = kai_func_type_2(self.int32_type, self.ptr_type, self.int64_type, false)
    let munmap_fn = LLVMAddFunction(self.module, "munmap", munmap_ty)
    // Define _kai_munmap wrapper
    let kai_munmap_ty = kai_func_type_2(self.int64_type, self.ptr_type, self.int64_type, false)
    let kai_munmap_fn = LLVMAddFunction(self.module, "_kai_munmap", kai_munmap_ty)
    let bm = LLVMAppendBasicBlockInContext(self.ctx, kai_munmap_fn, "entry")
    LLVMPositionBuilderAtEnd(self.builder, bm)
    let munmap_addr = LLVMGetParam(kai_munmap_fn, 0)
    let munmap_len = LLVMGetParam(kai_munmap_fn, 1)
    let munmap_ret: *Void = kai_build_call_2(self.builder, munmap_ty, munmap_fn, munmap_addr, munmap_len, "")
    let munmap_ext: *Void = LLVMBuildSExt(self.builder, munmap_ret, self.int64_type, "")
    LLVMBuildRet(self.builder, munmap_ext)

    // 4. Define _kai_mmap(addr: ptr, length: i64, prot: i64, flags: i64, fd: i64, offset: i64) -> ptr [wraps mmap]
    // Declare extern mmap
    let map_anon = LLVMConstInt(self.int32_type, 4096, false)  // MAP_PRIVATE|MAP_ANONYMOUS
    // We define _kai_mmap as a wrapper that calls mmap
    // mmap signature: (ptr, size_t, int, int, int, off_t) -> ptr
    // Use a simplified 6-arg version with i64 params
    let mmap_fn = LLVMAddFunction(self.module, "mmap", kai_func_type_0(self.ptr_type))
    // Actually declare mmap with correct types later as extern; skip body for now
    // since mmap is complex (vararg). Add as declare only.

    // 5. Define get_exe_dir(buf: ptr, max_len: i64) -> i64
    // Declare extern kai_os_get_exe_dir
    let kai_os_get_exe_dir_ty = kai_func_type_2(self.int64_type, self.ptr_type, self.int64_type, false)
    let kai_os_get_exe_dir_fn = LLVMAddFunction(self.module, "kai_os_get_exe_dir", kai_os_get_exe_dir_ty)
    // Define get_exe_dir
    let get_exe_dir_ty = kai_func_type_2(self.int64_type, self.ptr_type, self.int64_type, false)
    let get_exe_dir_fn = LLVMAddFunction(self.module, "get_exe_dir", get_exe_dir_ty)
    let b_get_exe = LLVMAppendBasicBlockInContext(self.ctx, get_exe_dir_fn, "entry")
    LLVMPositionBuilderAtEnd(self.builder, b_get_exe)
    let get_exe_buf = LLVMGetParam(get_exe_dir_fn, 0)
    let get_exe_max = LLVMGetParam(get_exe_dir_fn, 1)
    let get_exe_ret = kai_build_call_2(self.builder, kai_os_get_exe_dir_ty, kai_os_get_exe_dir_fn, get_exe_buf, get_exe_max, "")
    LLVMBuildRet(self.builder, get_exe_ret)

    // Restore builder state
    self.cur_block = old_block
    self.cur_func = old_func
    if self.cur_block != (0 as *Void) {
        LLVMPositionBuilderAtEnd(self.builder, self.cur_block)
    }
}


fn generate(self, top_stmt_idx: Int, obj_path: Str) -> Bool {
    let program = self.stmt_pool.get(top_stmt_idx)
    var di = 0
    while di < program.block_stmts.length() {
        self.global_decls.push(program.block_stmts.get(di))
        di = di + 1
    }

    self.build_func_types()
    self.build_type_caches()
    self.emit_runtime_helpers()

    // Phase 1: Forward declarations
    var i = 0
    while i < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(i)
        if stmt.kind == StmtKind.sk_func_decl {
            var is_method = false
            var mi = 0
            while mi < self.method_indices.length() {
                if self.method_indices.get(mi) == i {
                    is_method = true
                    break
                }
                mi = mi + 1
            }
            if !is_method {
                self.emit_func_decl(i, "")
            }
        }
        if stmt.kind == StmtKind.sk_extern {
            self.lookup_or_create_func(stmt.extern_name)
        }
        if stmt.kind == StmtKind.sk_impl_block {
            if !self.is_monomorphized_name(stmt.impl_struct_name) {
                self.foreach_method(i, true)
            }
        }
        if stmt.kind == StmtKind.sk_struct_decl {
            if !self.is_monomorphized_name(stmt.struct_name) {
                self.foreach_method(i, true)
            }
        }
        i = i + 1
    }

    // Phase 2: Function bodies
    i = 0
    while i < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(i)
        if stmt.kind == StmtKind.sk_func_decl {
            var has_self_param = false
            var pi = 0
            while pi < stmt.func_params.length() {
                let p = stmt.func_params.get(pi)
                unsafe { if strcmp(p.name, "self") == 0 { has_self_param = true } }
                pi = pi + 1
            }
            if has_self_param {
                // skip impl methods — handled by sk_impl_block
            } else if stmt.func_type_params.length() > 0 {
                // skip generic functions
            } else if stmt.func_body < 0 {
                // skip auto-generated stubs
            } else {
                var is_method = false
                var mi = 0
                while mi < self.method_indices.length() {
                    if self.method_indices.get(mi) == i {
                        is_method = true
                        break
                    }
                    mi = mi + 1
                }
                if !is_method {
                    let fn_val = self.lookup_or_create_func(stmt.func_name)
                    self.emit_func_body(i, fn_val, "")
                }
            }
        }
        if stmt.kind == StmtKind.sk_impl_block {
            if !self.is_monomorphized_name(stmt.impl_struct_name) {
                self.foreach_method(i, false)
            }
        }
        if stmt.kind == StmtKind.sk_struct_decl {
            if !self.is_monomorphized_name(stmt.struct_name) {
                self.foreach_method(i, false)
            }
        }
        i = i + 1
    }

    return self.emit_object(obj_path)
}

fn emit_func_decl(self, stmt_idx: Int, name: Str) {
    let stmt = self.stmt_pool.get(stmt_idx)
    var decl_name = name
    if strlen(decl_name) == 0 {
        decl_name = stmt.func_name
    }
    let _ = self.lookup_or_create_func(decl_name)
}

fn emit_func_body(self, stmt_idx: Int, fn_val: *Void, struct_name: Str) {
    let stmt = self.stmt_pool.get(stmt_idx)
    if fn_val == (0 as *Void) { return }
    self.cur_func = fn_val
    if strlen(struct_name) > 0 {
        self.cur_func_name = struct_name + "_" + stmt.func_name
    } else {
        self.cur_func_name = stmt.func_name
    }
    
    self.cur_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "entry")
    LLVMPositionBuilderAtEnd(self.builder, self.cur_block)
    self.last_was_term = false
    self.local_alloca_names = ArrayList<Str>(self.allocator)
    self.local_alloca_vals = ArrayList<Int>(self.allocator)
    self.local_alloca_types = ArrayList<Int>(self.allocator)
    self.local_alloca_type_strs = ArrayList<Str>(self.allocator)
    self.local_alloca_decls = ArrayList<Int>(self.allocator)
    self.loop_cond_block = (0 as *Void)
    self.loop_merge_block = (0 as *Void)

    let is_init = ((stmt.func_name == "init") || (stmt.func_return_type == struct_name) || (stmt.func_return_type == "*" + struct_name) || (stmt.func_return_type == "&" + struct_name)) && (strlen(struct_name) > 0)
    self.cur_method_is_init = is_init
    self.cur_self_alloca = (0 as *Void)
    self.cur_struct_type = (0 as *Void)
    if is_init {
        self.cur_struct_type = self.map_type(struct_name)
    }

    var pi = 0
    while pi < stmt.func_params.length() {
        let param = stmt.func_params.get(pi)
        var param_llvm_type = self.map_type(param.ptype)
        var param_type_str = param.ptype
        
        if is_init && param.name == "self" {
            param_llvm_type = self.cur_struct_type
            param_type_str = struct_name
            let alloca_val = LLVMBuildAlloca(self.builder, param_llvm_type, "self")
            LLVMBuildStore(self.builder, LLVMConstNull(param_llvm_type), alloca_val)
            self.cur_self_alloca = alloca_val
            
            self.local_alloca_names.push("self")
            self.local_alloca_vals.push((alloca_val as Int))
            self.local_alloca_types.push((param_llvm_type as Int))
            self.local_alloca_type_strs.push(param_type_str)
            self.local_alloca_decls.push(stmt_idx)
            pi = pi + 1
            continue
        }
        
        var param_val: *Void = (0 as *Void)
        if is_init {
            param_val = LLVMGetParam(self.cur_func, pi - 1)
        } else {
            param_val = LLVMGetParam(self.cur_func, pi)
        }
        
        if param.name == "self" && strlen(struct_name) > 0 {
            param_llvm_type = self.map_type("*" + struct_name)
            param_type_str = "*" + struct_name
        }
        let alloca_val = LLVMBuildAlloca(self.builder, param_llvm_type, param.name)
        // Kai functions receive %Str by value (two-tier ABI).
        // extern functions never have bodies, so emit_func_body is only called for
        // pure Kai functions — just store the param directly, no wrapping needed.
        LLVMBuildStore(self.builder, param_val, alloca_val)
        self.local_alloca_names.push(param.name)
        self.local_alloca_vals.push((alloca_val as Int))
        self.local_alloca_types.push((param_llvm_type as Int))
        self.local_alloca_type_strs.push(param_type_str)
        self.local_alloca_decls.push(stmt_idx)
        pi = pi + 1
    }

    self.gen_stmt(stmt.func_body)
    if !self.last_was_term {
        if is_init {
            let loaded_self = LLVMBuildLoad2(self.builder, self.cur_struct_type, self.cur_self_alloca, "")
            LLVMBuildRet(self.builder, loaded_self)
        } else {
            let ret_type_str = self.get_func_return_type(self.cur_func_name)
            // Use map_type for return: Str→%Str (by value), Void→void, others as declared.
            // Never use c_abi_type here — this is a pure Kai function body, not C interop.
            let ret_type = self.map_type(ret_type_str)
            if ret_type == self.void_type || ret_type == (0 as *Void) {
                LLVMBuildRetVoid(self.builder)
            } else {
                // Return zero-initializer of the declared type (handles %Str, Bool→i1, etc.)
                LLVMBuildRet(self.builder, LLVMConstNull(ret_type))
            }
        }
        self.last_was_term = true
    }
}

// Coerce a return value to match the declared LLVM function return type.
// Handles Bool (i1) and Char (i8) truncation from i64 values,
// and the reverse: ZExt i1/i8 to i64 when function returns Int.
fn coerce_return_value(self, val: *Void, ret_type_str: Str, actual_type_str: Str) -> *Void {
    if val == (0 as *Void) { return val }
    
    // Handle optional Str (?Str) return: unwrap %Str to raw ptr
    if ret_type_str == "?Str" {
        if LLVMTypeOf(val) == self.str_type {
            return self.unwrap_str_for_c(val)
        }
    }

    // Handle general Optional (?'type) wrapping
    if strlen(ret_type_str) > 0 && ret_type_str[0] == Char(63) { // '?'
        let val_ty = LLVMTypeOf(val)
        let val_kind = LLVMGetTypeKind(val_ty)
        let declared_ty = self.map_type(ret_type_str)
        if val_ty != declared_ty {
            if val_kind == LLVMIntegerTypeKind {
                return LLVMBuildIntToPtr(self.builder, val, declared_ty, "")
            }
            if val_kind == LLVMPointerTypeKind {
                return LLVMBuildBitCast(self.builder, val, declared_ty, "")
            }
        }
    }

    // 1. Handle Error Union wrapping (T!E)
    if self.str_contains(ret_type_str, Char(33)) {
        let excl_pos = self.str_find(ret_type_str, Char(33))
        let val_payload = ret_type_str[0..excl_pos] + ""
        let err_type = ret_type_str[(excl_pos + 1)..strlen(ret_type_str)] + ""
        let mapped_type = self.map_type(ret_type_str)
        
        let val_ty = LLVMTypeOf(val)
        if val_ty == mapped_type {
            return val
        }
        
        // Check if returning the error payload
        if actual_type_str == err_type || actual_type_str == "IoError" {
            let tag_val = LLVMConstInt(self.int64_type, 1, false)
            let null_struct = LLVMConstNull(mapped_type)
            return kai_LLVMBuildInsertValue(self.builder, null_struct, tag_val, 0, ".tag")
        }
        
        // Fallback when actual_type_str is empty (Bug C: inferred_type not in shared pool):
        // If the return type is an error union and the val's LLVM type doesn't match the
        // success payload type, treat as error return. This handles Str!IoError where
        // payload is %Str (struct) but IoError variant is i64.
        if strlen(actual_type_str) == 0 {
            let payload_llvm_ty = self.map_type(val_payload)
            if payload_llvm_ty != (0 as *Void) && payload_llvm_ty != self.void_type {
                if val_ty != payload_llvm_ty {
                    let tag_val = LLVMConstInt(self.int64_type, 1, false)
                    let null_struct = LLVMConstNull(mapped_type)
                    return kai_LLVMBuildInsertValue(self.builder, null_struct, tag_val, 0, ".tag")
                }
            }
        }
        
        // Otherwise, wrap as success: tag = 0, value = val (coerced to val_payload type)
        let tag_val = LLVMConstInt(self.int64_type, 0, false)
        let null_struct = LLVMConstNull(mapped_type)
        let with_tag = kai_LLVMBuildInsertValue(self.builder, null_struct, tag_val, 0, ".tag")
        
        if val_payload != "Void" {
            let payload_copy = val_payload
            let coerced_val = self.coerce_return_value(val, payload_copy, actual_type_str)
            return kai_LLVMBuildInsertValue(self.builder, with_tag, coerced_val, 1, ".value")
        }
        return with_tag
    }

    // 2. Existing Bidirectional Integer Coercion (Bool <-> i1, Char <-> i8, etc.)
    let val_ty = LLVMTypeOf(val)
    let val_kind = LLVMGetTypeKind(val_ty)
    if val_kind != LLVMIntegerTypeKind { return val }
    let declared_ty = self.map_type(ret_type_str)
    if declared_ty == (0 as *Void) || declared_ty == self.void_type { return val }
    let declared_kind = LLVMGetTypeKind(declared_ty)
    if declared_kind != LLVMIntegerTypeKind { return val }
    if val_ty == declared_ty { return val }
    let val_width = kai_LLVMGetIntTypeWidth(val_ty)
    let declared_width = kai_LLVMGetIntTypeWidth(declared_ty)
    if val_width < declared_width {
        // Narrow value (i1/i8) going into wider declared type (i64) — ZExt
        return LLVMBuildZExt(self.builder, val, declared_ty, "")
    }
    if val_width > declared_width {
        // Wide value (i64) going into narrow declared type (i1/i8) — Trunc
        return LLVMBuildTrunc(self.builder, val, declared_ty, "")
    }
    return val
}

fn strip_module_prefix(self, name: Str) -> Str {
    var last_dot = -1
    var i = 0
    while i < length(name) {
        if name[i] == Char(46) { // '.'
            last_dot = i
        }
        i = i + 1
    }
    if last_dot >= 0 {
        return name[last_dot + 1..length(name)]
    }
    return name
}

fn map_type(self, type_name: Str) -> *Void {
    var resolved_type = self.strip_module_prefix(type_name)
    if self.current_type_map.length() > 0 {
        resolved_type = self.substitute_generic_type(resolved_type)
    }

    if strlen(resolved_type) > 0 && resolved_type[0] == Char(63) { // '?'
        return self.ptr_type
    }
    if strlen(resolved_type) > 0 && (resolved_type[0] == Char(42) || resolved_type[0] == Char(38)) {
        return self.ptr_type
    }
    if strlen(resolved_type) > 2 && resolved_type[0] == Char(91) && resolved_type[1] == Char(93) {
        return self.ptr_type
    }

    if self.str_contains(resolved_type, Char(33)) {
        let excl_pos = self.str_find(resolved_type, Char(33))
        let val_type = resolved_type[0..excl_pos] + ""
        let err_type = resolved_type[(excl_pos + 1)..strlen(resolved_type)] + ""
        let clean_val = self.clean_type_for_mangling(val_type)
        let clean_err = self.clean_type_for_mangling(err_type)
        let concrete_name = "Result_" + clean_val + "_" + clean_err

        var si = 0
        var found = false
        var cached_ty: *Void = (0 as *Void)
        while si < self.struct_cache_names.length() {
            if llvm_str_eq(self.struct_cache_names.get(si), concrete_name) {
                found = true
                cached_ty = (self.struct_cache_types.get(si) as *Void)
                break
            }
            si = si + 1
        }
        if found {
            return cached_ty
        }

        let existing_ty = LLVMGetTypeByName2(self.ctx, concrete_name)
        if existing_ty != (0 as *Void) && existing_ty != self.void_type {
            self.struct_cache_names.push(concrete_name)
            self.struct_cache_types.push((existing_ty as Int))
            self.struct_cache_field_counts.push(2)
            return existing_ty
        }

        let named_ty = LLVMStructCreateNamed(self.ctx, concrete_name)
        var field_types = ArrayList<Int>(self.allocator)
        field_types.push((self.int64_type as Int))
        var field_count = 1
        if val_type != "Void" {
            let val_llvm_ty = self.map_type(val_type)
            if val_llvm_ty != self.void_type && val_llvm_ty != (0 as *Void) {
                field_types.push((val_llvm_ty as Int))
                field_count = 2
            }
        }
        LLVMStructSetBody(named_ty, field_types.data as *Void, field_count, false)

        self.struct_cache_names.push(concrete_name)
        self.struct_cache_types.push((named_ty as Int))
        self.struct_cache_field_counts.push(field_count)
        return named_ty
    }

    if self.str_contains(resolved_type, Char(60)) {
        let lt_pos = self.str_find(resolved_type, Char(60))
        let base_name = resolved_type[0..lt_pos]
        let args_str = resolved_type[lt_pos + 1..strlen(resolved_type) - 1]
        var args = ArrayList<Str>(self.allocator)
        var start = 0
        var i = 0
        while i < strlen(args_str) {
            let c = args_str[i]
            if c == Char(44) {
                args.push(self.trim_spaces(args_str[start..i]))
                start = i + 1
            }
            i = i + 1
        }
        args.push(self.trim_spaces(args_str[start..strlen(args_str)]))
        var concrete_name = base_name
        var ai = 0
        while ai < args.length() {
            let raw_arg = args.get(ai)
            let clean_arg = self.clean_type_for_mangling(raw_arg)
            concrete_name = concrete_name + "_" + clean_arg
            ai = ai + 1
        }

        let struct_idx_str = llvm_type_map_get(&self.generic_struct_decls, base_name)
        if strlen(struct_idx_str) > 0 {
            if llvm_strlist_find(&self.monomorphized_types, concrete_name) < 0 {
                self.monomorphized_types.push(concrete_name)
                self.monomorphize_struct(self.str_to_int(struct_idx_str), concrete_name, &args)
            }
            var si = 0
            while si < self.struct_cache_names.length() {
                if llvm_str_eq(self.struct_cache_names.get(si), concrete_name) {
                    return (self.struct_cache_types.get(si) as *Void)
                }
                si = si + 1
            }
        }

        let enum_idx_str = llvm_type_map_get(&self.generic_enum_decls, base_name)
        if strlen(enum_idx_str) > 0 {
            if llvm_strlist_find(&self.monomorphized_types, concrete_name) < 0 {
                self.monomorphized_types.push(concrete_name)
                self.monomorphize_enum(self.str_to_int(enum_idx_str), concrete_name, &args)
            }
            var ei = 0
            while ei < self.enum_cache_names.length() {
                if llvm_str_eq(self.enum_cache_names.get(ei), concrete_name) {
                    return (self.enum_cache_types.get(ei) as *Void)
                }
                ei = ei + 1
            }
        }
    }

    // Check struct cache
    var si = 0
    while si < self.struct_cache_names.length() {
        if llvm_str_eq(self.struct_cache_names.get(si), resolved_type) {
            return (self.struct_cache_types.get(si) as *Void)
        }
        si = si + 1
    }
    // Check enum cache
    var ei = 0
    while ei < self.enum_cache_names.length() {
        if llvm_str_eq(self.enum_cache_names.get(ei), resolved_type) {
            return (self.enum_cache_types.get(ei) as *Void)
        }
        ei = ei + 1
    }
    if resolved_type == "Int" || resolved_type == "Int64" || resolved_type == "UInt64" || resolved_type == "UInt32" || resolved_type == "UInt16" { return self.int64_type }
    if resolved_type == "UInt8" || resolved_type == "u8" || resolved_type == "i8" { return self.int8_type }
    if resolved_type == "Int32" || resolved_type == "Int16" || resolved_type == "i32" || resolved_type == "u32" { return self.int32_type }
    if resolved_type == "Int8" { return self.int8_type }
    if resolved_type == "Bool" { return self.int1_type }
    if resolved_type == "Float" { return self.double_type }
    if resolved_type == "Str" { return self.str_type }
    if resolved_type == "*Char" { return self.ptr_type }
    if resolved_type == "Char" { return self.int8_type }
    if resolved_type == "*Void" { return self.ptr_type }
    if strlen(resolved_type) > 0 && (resolved_type[0] == Char(42) || resolved_type[0] == Char(38)) {
        // *T or &T pointer/reference types -> opaque ptr
        return self.ptr_type
    }
    if strlen(resolved_type) > 2 && resolved_type[0] == Char(91) && resolved_type[1] == Char(93) {
        // []T slice types (used as pointer in LLVM backend) -> opaque ptr
        return self.ptr_type
    }
    if resolved_type == "Void" || strlen(resolved_type) == 0 { return self.void_type }
    // Try LLVM's named type registry as fallback (handles types registered via LLVMStructCreateNamed
    // but not yet pushed to our local struct_cache — e.g. due to init-time ordering)
    let named_ty = LLVMGetTypeByName2(self.ctx, resolved_type)
    if named_ty != (0 as *Void) && named_ty != self.void_type {
        // Cache it so future lookups are O(1)
        self.struct_cache_names.push(resolved_type)
        self.struct_cache_types.push((named_ty as Int))
        self.struct_cache_field_counts.push(0)
        return named_ty
    }
    // For any unknown type that starts with uppercase (likely a struct/enum not yet cached),
    // or any other type, return int64_type as fallback
    return self.int64_type
}


fn map_tuple_type(self, tuple_type_str: Str) -> *Void {
    // Check tuple cache first
    var ti = 0
    while ti < self.tuple_cache_names.length() {
        if llvm_str_eq(self.tuple_cache_names.get(ti), tuple_type_str) {
            return (self.tuple_cache_types.get(ti) as *Void)
        }
        ti = ti + 1
    }
    // Parse (Type1, Type2, ...) format
    let len = strlen(tuple_type_str)
    if len < 2 || tuple_type_str[0] != Char(40) || tuple_type_str[len - 1] != Char(41) {
        return self.void_type
    }
    var inner = tuple_type_str[1..len - 1]
    var field_types = ArrayList<Int>(self.allocator)
    var start = 0
    var i = 0
    while i < strlen(inner) {
        if inner[i] == Char(44) {
            let ty_name = inner[start..i]
            let llvm_ty = self.map_type(ty_name)
            if llvm_ty == self.void_type || llvm_ty == (0 as *Void) {
                field_types.push((self.int64_type as Int))
            } else {
                field_types.push((llvm_ty as Int))
            }
            i = i + 2
            start = i
        } else {
            i = i + 1
        }
    }
    if start < strlen(inner) {
        let ty_name = inner[start..strlen(inner)]
        let llvm_ty = self.map_type(ty_name)
        if llvm_ty == self.void_type || llvm_ty == (0 as *Void) {
            field_types.push((self.int64_type as Int))
        } else {
            field_types.push((llvm_ty as Int))
        }
    }
    if field_types.length() == 0 { return self.void_type }
    let named_ty = LLVMStructCreateNamed(self.ctx, tuple_type_str)
    LLVMStructSetBody(named_ty, field_types.data as *Void, field_types.length(), false)
    self.tuple_cache_names.push(tuple_type_str)
    self.tuple_cache_types.push((named_ty as Int))
    self.tuple_cache_field_counts.push(field_types.length())
    return named_ty
}

fn unwrap_str_for_c(self, val: *Void) -> *Void {
    if val == (0 as *Void) { return val }
    let val_ty = LLVMTypeOf(val)
    if val_ty == self.str_type {
        return kai_LLVMBuildExtractValue(self.builder, val, 0, ".c.ptr")
    }
    return val
}

fn to_bool(self, val: *Void) -> *Void {
    if val == (0 as *Void) { return LLVMConstInt(self.int1_type, 0, false) }
    let val_type = LLVMTypeOf(val)
    if val_type == self.int1_type { return val }
    let zero = LLVMConstNull(val_type)
    let cmp = LLVMBuildICmp(self.builder, LLVMIntNE, val, zero, "")
    return cmp
}

fn ensure_reachable(self) {
    if self.last_was_term {
        self.cur_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "dead")
        LLVMPositionBuilderAtEnd(self.builder, self.cur_block)
        self.last_was_term = false
    }
}

fn gen_stmt(self, stmt_idx: Int) {
    if stmt_idx < 0 { return }
    self.ensure_reachable()
    let stmt = self.stmt_pool.get(stmt_idx)
    if stmt.kind == StmtKind.sk_block {
        var i = 0
        while i < stmt.block_stmts.length() {
            self.gen_stmt(stmt.block_stmts.get(i))
            i = i + 1
        }
        return
    }
    if stmt.kind == StmtKind.sk_return {
        if self.cur_method_is_init {
            let loaded_self = LLVMBuildLoad2(self.builder, self.cur_struct_type, self.cur_self_alloca, "")
            LLVMBuildRet(self.builder, loaded_self)
        } else if stmt.return_value >= 0 {
            let val = self.gen_expr(stmt.return_value)
            if val != (0 as *Void) {
                let ret_type_str = self.get_func_return_type(self.cur_func_name)
                var ret_val = val
                // Use map_type for native Kai ABI: Str -> %Str by value, no ptr unwrapping.
                let ret_llvm_ty = self.map_type(ret_type_str)
                if ret_llvm_ty != self.void_type && ret_llvm_ty != (0 as *Void) {
                    let val_kind = LLVMGetTypeKind(LLVMTypeOf(val))
                    let ret_kind = LLVMGetTypeKind(ret_llvm_ty)
                    if ret_kind == LLVMStructTypeKind && val_kind == LLVMPointerTypeKind {
                        // val is a pointer to the struct — load it for by-value return
                        ret_val = LLVMBuildLoad2(self.builder, ret_llvm_ty, val, "")
                    }
                }
                // Coerce return value to declared function return type
                let actual_type_str = self.get_expr_type(stmt.return_value)
                ret_val = self.coerce_return_value(ret_val, ret_type_str, actual_type_str)
                LLVMBuildRet(self.builder, ret_val)
            } else {
                let ret_type_str = self.get_func_return_type(self.cur_func_name)
                let ret_llvm_ty = self.map_type(ret_type_str)
                if ret_llvm_ty == self.void_type || ret_llvm_ty == (0 as *Void) {
                    LLVMBuildRetVoid(self.builder)
                } else {
                    LLVMBuildRet(self.builder, LLVMConstNull(ret_llvm_ty))
                }
            }
        } else {
            LLVMBuildRetVoid(self.builder)
        }
        self.last_was_term = true
        return
    }
    if stmt.kind == StmtKind.sk_expr {
        if stmt.expr_stmt >= 0 {
            let _ = self.gen_expr(stmt.expr_stmt)
        }
        return
    }
    if stmt.kind == StmtKind.sk_var_decl {
        var var_name = stmt.vardecl_name
        var var_type_str = stmt.vardecl_type

        // Void/discard pattern: let _ = expr or Void-typed variable
        if var_name == "_" || var_type_str == "Void" || var_type_str == "NoneType" {
            if stmt.vardecl_value >= 0 {
                let _ = self.gen_expr(stmt.vardecl_value)
            }
            return
        }

        // Check if initializer is an array literal — handle specially
        if stmt.vardecl_value >= 0 {
            let init_expr = self.expr_pool.get(stmt.vardecl_value)
            if init_expr.kind == ExprKind.ek_array {
                var inner_type_str = "Int"
                if strlen(init_expr.inferred_type) > 2 && init_expr.inferred_type[0] == Char(91) && init_expr.inferred_type[1] == Char(93) {
                    inner_type_str = init_expr.inferred_type[2..strlen(init_expr.inferred_type)]
                }
                let inner_llvm_type = self.map_type(inner_type_str)
                if inner_llvm_type == self.void_type || inner_llvm_type == (0 as *Void) {
                    inner_llvm_type = self.int64_type
                }
                let count = init_expr.arr_elements.length()
                var arr_type = inner_llvm_type
                if count > 0 {
                    arr_type = LLVMArrayType(inner_llvm_type, count)
                }
                let alloca_val = LLVMBuildAlloca(self.builder, arr_type, var_name)
                if count > 0 {
                    let el_ptr_ty = LLVMPointerType(inner_llvm_type, 0)
                    let casted = LLVMBuildBitCast(self.builder, alloca_val, el_ptr_ty, "")
                    var ai = 0
                    while ai < count {
                        let elem_val = self.gen_expr(init_expr.arr_elements.get(ai))
                        if elem_val != (0 as *Void) {
                            let indices = ArrayList<Int>(self.allocator)
                            indices.push((LLVMConstInt(self.int64_type, ai, false) as Int))
                            let gep = LLVMBuildGEP2(self.builder, inner_llvm_type, casted, indices.data as *Void, 1, "")
                            LLVMBuildStore(self.builder, elem_val, gep)
                        }
                        ai = ai + 1
                    }
                }
                self.local_alloca_names.push(var_name)
                self.local_alloca_vals.push((alloca_val as Int))
                self.local_alloca_types.push((arr_type as Int))
                var arr_type_str = stmt.vardecl_type
                if strlen(arr_type_str) == 0 { arr_type_str = "[]" + inner_type_str }
                self.local_alloca_type_strs.push(arr_type_str)
                self.local_alloca_decls.push(stmt_idx)
                return
            }
        }

        if strlen(var_type_str) == 0 {
            if stmt.vardecl_value >= 0 {
                var_type_str = self.get_expr_type(stmt.vardecl_value)
            }
        }
        // If still empty, check if init expr is an "as" cast and use its type arg
        if strlen(var_type_str) == 0 && stmt.vardecl_value >= 0 {
            let init_expr = self.expr_pool.get(stmt.vardecl_value)
            if (init_expr.kind == ExprKind.ek_func_call && (init_expr.func_name == "as" || init_expr.func_name == "cast")) {
                if init_expr.func_type_args.length() > 0 {
                    var_type_str = init_expr.func_type_args.get(0)
                }
            }
        }
        var generated_init: *Void = (0 as *Void)
        if strlen(var_type_str) == 0 && stmt.vardecl_value >= 0 {
            generated_init = self.gen_expr(stmt.vardecl_value)
            if generated_init != (0 as *Void) {
                let init_llvm_ty = LLVMTypeOf(generated_init)
                if init_llvm_ty == self.str_type {
                    var_type_str = "Str"
                }
            }
        }
        var var_type = self.map_type(var_type_str)
        if var_type == self.void_type {
            if generated_init != (0 as *Void) {
                var_type = LLVMTypeOf(generated_init)
            }
        }
        if var_type == self.void_type || var_type == (0 as *Void) {
            var_type = self.int64_type
        }
        let alloca_val = LLVMBuildAlloca(self.builder, var_type, var_name)
        if stmt.vardecl_value >= 0 {
            var init_val = generated_init
            if init_val == (0 as *Void) {
                init_val = self.gen_expr(stmt.vardecl_value)
            }
            if init_val != (0 as *Void) {
                if stmt.vardecl_value >= 0 {
                    let init_expr = self.expr_pool.get(stmt.vardecl_value)
                    if init_expr.kind == ExprKind.ek_literal && init_expr.lit_vkind == "NONE" {
                        // none literal: store null of the correct type
                        LLVMBuildStore(self.builder, LLVMConstNull(var_type), alloca_val)
                    } else {
                        let init_llvm_ty = LLVMTypeOf(init_val)
                        if init_llvm_ty == self.void_type {
                            // Do not store void values
                        } else {
                            let init_kind = LLVMGetTypeKind(init_llvm_ty)
                            let dest_kind = LLVMGetTypeKind(var_type)
                            if init_kind == LLVMPointerTypeKind && dest_kind == LLVMStructTypeKind {
                                let loaded = LLVMBuildLoad2(self.builder, var_type, init_val, "")
                                LLVMBuildStore(self.builder, loaded, alloca_val)
                            } else if init_kind == LLVMStructTypeKind && dest_kind == LLVMPointerTypeKind {
                                let struct_alloca = LLVMBuildAlloca(self.builder, init_llvm_ty, ".tmp_struct")
                                LLVMBuildStore(self.builder, init_val, struct_alloca)
                                LLVMBuildStore(self.builder, struct_alloca, alloca_val)
                            } else {
                                LLVMBuildStore(self.builder, init_val, alloca_val)
                            }
                        }
                    }
                }
            } else {
                if stmt.vardecl_value >= 0 {
                    let init_expr = self.expr_pool.get(stmt.vardecl_value)
                    if init_expr.kind == ExprKind.ek_literal && init_expr.lit_vkind == "NONE" {
                        // none literal: gen_expr returned NULL sentinel, store proper null
                        LLVMBuildStore(self.builder, LLVMConstNull(var_type), alloca_val)
                    }
                }
            }
        }
        self.local_alloca_names.push(var_name)
        self.local_alloca_vals.push((alloca_val as Int))
        self.local_alloca_types.push((var_type as Int))
        self.local_alloca_type_strs.push(var_type_str)
        self.local_alloca_decls.push(stmt_idx)
        return
    }
    if stmt.kind == StmtKind.sk_assignment {
        let val = self.gen_expr(stmt.assign_value)
        if val != (0 as *Void) {
            let val_ty = LLVMTypeOf(val)
            if val_ty == self.void_type {
                return // Do not assign void values
            }
            let target_expr = self.expr_pool.get(stmt.assign_target)
            if target_expr.kind == ExprKind.ek_identifier {
                let var_name = target_expr.ident_name
                let alloca = self.find_alloca(var_name)
                if alloca != (0 as *Void) {
                    let var_type = self.find_alloca_type(var_name)
                    var store_val = val
                    if var_type != (0 as *Void) && LLVMGetTypeKind(var_type) == LLVMStructTypeKind && var_type != self.str_type {
                        if LLVMGetTypeKind(LLVMTypeOf(val)) == LLVMPointerTypeKind {
                            store_val = LLVMBuildLoad2(self.builder, var_type, val, "")
                        }
                    }
                    LLVMBuildStore(self.builder, store_val, alloca)
                }
            } else if target_expr.kind == ExprKind.ek_field_access {
                // Struct field assignment: base.field = val
                // We need to get a pointer to the field (GEP) and store into it
                let base_val = self.gen_expr(target_expr.field_expr)
                if base_val != (0 as *Void) {
                    var base_type = self.get_expr_type(target_expr.field_expr)
                    // Strip pointer sigils to get struct name
                    var clean_base_type = base_type
                    while strlen(clean_base_type) > 0 && (clean_base_type[0] == Char(42) || clean_base_type[0] == Char(38)) {
                        clean_base_type = clean_base_type[1..strlen(clean_base_type)]
                    }
                    let struct_decl_idx = self.find_struct_decl(clean_base_type)
                    var field_idx = -1
                    var found_field = false
                    if struct_decl_idx >= 0 {
                        let sn = self.stmt_pool.get(struct_decl_idx)
                        var fj = 0
                        while fj < sn.struct_fields.length() {
                            if sn.struct_fields.get(fj).name == target_expr.field_name {
                                field_idx = fj
                                found_field = true
                                break
                            }
                            fj = fj + 1
                        }
                    }
                    if found_field {
                        let struct_ty = self.map_type(clean_base_type)
                        if struct_ty != (0 as *Void) && struct_ty != self.void_type {
                            var base_ptr = base_val
                            let base_llvm_ty2 = LLVMTypeOf(base_val)
                            let base_kind2 = LLVMGetTypeKind(base_llvm_ty2)
                            if base_kind2 == LLVMStructTypeKind {
                                let tmp = LLVMBuildAlloca(self.builder, struct_ty, ".tmp.assign")
                                LLVMBuildStore(self.builder, base_val, tmp)
                                base_ptr = tmp
                            }
                            let gep = LLVMBuildStructGEP2(self.builder, struct_ty, base_ptr, field_idx, target_expr.field_name)
                            let field_llvm_ty = LLVMStructGetTypeAtIndex(struct_ty, field_idx)
                            var store_val = val
                            if LLVMGetTypeKind(field_llvm_ty) == LLVMStructTypeKind && field_llvm_ty != self.str_type {
                                if LLVMGetTypeKind(LLVMTypeOf(val)) == LLVMPointerTypeKind {
                                    store_val = LLVMBuildLoad2(self.builder, field_llvm_ty, val, "")
                                }
                            }
                            LLVMBuildStore(self.builder, store_val, gep)
                        }
                    }
                }
            } else if target_expr.kind == ExprKind.ek_index {
                // Array/pointer index assignment: base[idx] = val
                let base_val = self.gen_expr(target_expr.idx_expr)
                let idx_val = self.gen_expr(target_expr.idx_index)
                if base_val != (0 as *Void) && idx_val != (0 as *Void) {
                    var store_ptr = base_val
                    let base_llvm_ty4 = LLVMTypeOf(base_val)
                    if base_llvm_ty4 == self.str_type {
                        store_ptr = self.unwrap_str_for_c(base_val)
                    }
                    
                    // Determine exact element type of target
                    let el_type_str = self.get_expr_type(stmt.assign_target)
                    var el_ty = self.map_type(el_type_str)
                    if el_ty == (0 as *Void) || el_ty == self.void_type {
                        el_ty = LLVMTypeOf(val)
                    }
                    
                    let store_val = self.gen_cast(val, el_ty)
                    
                    // Ensure idx is i64
                    var gep_idx2 = idx_val
                    let idx_ty2 = LLVMTypeOf(idx_val)
                    if idx_ty2 != self.int64_type {
                        gep_idx2 = LLVMBuildSExt(self.builder, idx_val, self.int64_type, "")
                    }
                    
                    let el_ptr_ty2 = LLVMPointerType(el_ty, 0)
                    let casted2 = LLVMBuildBitCast(self.builder, store_ptr, el_ptr_ty2, "")
                    let indices2 = ArrayList<Int>(self.allocator)
                    indices2.push((gep_idx2 as Int))
                    let gep2 = LLVMBuildGEP2(self.builder, el_ty, casted2, indices2.data as *Void, 1, "")
                    LLVMBuildStore(self.builder, store_val, gep2)
                }
            }
        }
        return
    }
    if stmt.kind == StmtKind.sk_for {
        let start_val = self.gen_expr(stmt.for_start)
        let end_val = self.gen_expr(stmt.for_end)
        if start_val == (0 as *Void) || end_val == (0 as *Void) { return }
        let var_name = stmt.for_var

        let prev_alloca_len = self.local_alloca_names.length()

        let alloca_val = LLVMBuildAlloca(self.builder, self.int64_type, var_name)
        self.local_alloca_names.push(var_name)
        self.local_alloca_vals.push((alloca_val as Int))
        self.local_alloca_types.push((self.int64_type as Int))
        self.local_alloca_decls.push(stmt_idx)
        LLVMBuildStore(self.builder, start_val, alloca_val)

        let cond_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "for_cond")
        let body_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "for_body")
        let inc_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "for_inc")
        let merge_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "for_merge")

        let prev_cond = self.loop_cond_block
        let prev_merge = self.loop_merge_block
        self.loop_cond_block = cond_block
        self.loop_merge_block = merge_block

        LLVMBuildBr(self.builder, cond_block)

        LLVMPositionBuilderAtEnd(self.builder, cond_block)
        self.last_was_term = false
        let cur_val = LLVMBuildLoad2(self.builder, self.int64_type, alloca_val, "")
        if stmt.for_inclusive {
            let cmp = LLVMBuildICmp(self.builder, LLVMIntSLE, cur_val, end_val, "")
            LLVMBuildCondBr(self.builder, cmp, body_block, merge_block)
        } else {
            let cmp = LLVMBuildICmp(self.builder, LLVMIntSLT, cur_val, end_val, "")
            LLVMBuildCondBr(self.builder, cmp, body_block, merge_block)
        }

        LLVMPositionBuilderAtEnd(self.builder, body_block)
        self.last_was_term = false
        self.gen_stmt(stmt.for_body)
        if !self.last_was_term {
            LLVMBuildBr(self.builder, inc_block)
        }

        LLVMPositionBuilderAtEnd(self.builder, inc_block)
        self.last_was_term = false
        let one = LLVMConstInt(self.int64_type, 1, false)
        let inc_val = LLVMBuildLoad2(self.builder, self.int64_type, alloca_val, "")
        let updated = LLVMBuildAdd(self.builder, inc_val, one, "")
        LLVMBuildStore(self.builder, updated, alloca_val)
        LLVMBuildBr(self.builder, cond_block)

        self.loop_cond_block = prev_cond
        self.loop_merge_block = prev_merge

        // pop the loop variable from the alloca lists
        while self.local_alloca_names.length() > prev_alloca_len {
            let _ = self.local_alloca_names.pop()
            let _ = self.local_alloca_vals.pop()
            let _ = self.local_alloca_types.pop()
        }

        LLVMPositionBuilderAtEnd(self.builder, merge_block)
        self.last_was_term = false
        return
    }
    if stmt.kind == StmtKind.sk_break {
        if self.loop_merge_block != (0 as *Void) {
            LLVMBuildBr(self.builder, self.loop_merge_block)
            self.last_was_term = true
        }
        return
    }
    if stmt.kind == StmtKind.sk_continue {
        if self.loop_cond_block != (0 as *Void) {
            LLVMBuildBr(self.builder, self.loop_cond_block)
            self.last_was_term = true
        }
        return
    }
    if stmt.kind == StmtKind.sk_if_let {
        let cond_val = self.gen_expr(stmt.iflet_expr)
        if cond_val == (0 as *Void) {
            return
        }
        let then_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "ifthen")
        let merge_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "iflet_merge")

        // Create alloca for the bound variable and store the condition value
        var iflet_var_type = self.int64_type
        var bound_type = LLVMTypeOf(cond_val)
        if bound_type != (0 as *Void) {
            iflet_var_type = bound_type
        }
        let iflet_alloca = LLVMBuildAlloca(self.builder, iflet_var_type, stmt.iflet_var)
        LLVMBuildStore(self.builder, cond_val, iflet_alloca)
        let prev_len = self.local_alloca_names.length()
        self.local_alloca_names.push(stmt.iflet_var)
        self.local_alloca_vals.push((iflet_alloca as Int))
        self.local_alloca_types.push((iflet_var_type as Int))
        self.local_alloca_decls.push(stmt_idx)

        if stmt.iflet_else >= 0 {
            let else_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "iflelse")
            let is_nonzero = self.to_bool(cond_val)
            LLVMBuildCondBr(self.builder, is_nonzero, then_block, else_block)

            LLVMPositionBuilderAtEnd(self.builder, then_block)
            self.last_was_term = false
            self.gen_stmt(stmt.iflet_then)
            if !self.last_was_term {
                LLVMBuildBr(self.builder, merge_block)
            }

            LLVMPositionBuilderAtEnd(self.builder, else_block)
            self.last_was_term = false
            self.gen_stmt(stmt.iflet_else)
            if !self.last_was_term {
                LLVMBuildBr(self.builder, merge_block)
            }
        } else {
            let is_nonzero = self.to_bool(cond_val)
            LLVMBuildCondBr(self.builder, is_nonzero, then_block, merge_block)

            LLVMPositionBuilderAtEnd(self.builder, then_block)
            self.last_was_term = false
            self.gen_stmt(stmt.iflet_then)
            if !self.last_was_term {
                LLVMBuildBr(self.builder, merge_block)
            }
        }

        // Pop the iflet variable from alloca lists (scope ended)
        while self.local_alloca_names.length() > prev_len {
            let _ = self.local_alloca_names.pop()
            let _ = self.local_alloca_vals.pop()
            let _ = self.local_alloca_types.pop()
        }

        LLVMPositionBuilderAtEnd(self.builder, merge_block)
        self.last_was_term = false
        return
    }
    if stmt.kind == StmtKind.sk_while {
        let cond_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "while_cond")
        let body_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "while_body")
        let merge_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "while_merge")

        let prev_cond = self.loop_cond_block
        let prev_merge = self.loop_merge_block
        self.loop_cond_block = cond_block
        self.loop_merge_block = merge_block

        LLVMBuildBr(self.builder, cond_block)

        LLVMPositionBuilderAtEnd(self.builder, cond_block)
        self.last_was_term = false
        let cond_val = self.to_bool(self.gen_expr(stmt.while_cond))
        LLVMBuildCondBr(self.builder, cond_val, body_block, merge_block)

        LLVMPositionBuilderAtEnd(self.builder, body_block)
        self.last_was_term = false
        self.gen_stmt(stmt.while_body)
        if !self.last_was_term {
            LLVMBuildBr(self.builder, cond_block)
        }

        self.loop_cond_block = prev_cond
        self.loop_merge_block = prev_merge

        LLVMPositionBuilderAtEnd(self.builder, merge_block)
        self.last_was_term = false
        return
    }
    if stmt.kind == StmtKind.sk_if {
        let cond_val = self.to_bool(self.gen_expr(stmt.if_cond))
        let then_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "then")
        let merge_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "if_merge")

        if stmt.if_else >= 0 {
            let else_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "else")
            LLVMBuildCondBr(self.builder, cond_val, then_block, else_block)

            LLVMPositionBuilderAtEnd(self.builder, then_block)
            self.last_was_term = false
            self.gen_stmt(stmt.if_then)
            if !self.last_was_term {
                LLVMBuildBr(self.builder, merge_block)
            }

            LLVMPositionBuilderAtEnd(self.builder, else_block)
            self.last_was_term = false
            self.gen_stmt(stmt.if_else)
            if !self.last_was_term {
                LLVMBuildBr(self.builder, merge_block)
            }
        } else {
            LLVMBuildCondBr(self.builder, cond_val, then_block, merge_block)

            LLVMPositionBuilderAtEnd(self.builder, then_block)
            self.last_was_term = false
            self.gen_stmt(stmt.if_then)
            if !self.last_was_term {
                LLVMBuildBr(self.builder, merge_block)
            }
        }

        LLVMPositionBuilderAtEnd(self.builder, merge_block)
        self.last_was_term = false
        return
    }
    if stmt.kind == StmtKind.sk_defer {
        self.gen_stmt(stmt.defer_body)
        return
    }
    if stmt.kind == StmtKind.sk_print {
        let val = self.gen_expr(stmt.print_value)
        if val == (0 as *Void) { return }
        let printf_fn = self.lookup_or_create_func("printf")
        let val_type = LLVMTypeOf(val)
        if val_type == self.int64_type {
            let fmt_str = LLVMBuildGlobalStringPtr(self.builder, "%lld\n", ".fmt_int")
            let p_char = self.map_type("*Char")
            let fn_ty = kai_func_type_2(self.int64_type, p_char, self.int64_type, true)
            let _ = kai_build_call_2(self.builder, fn_ty, printf_fn, fmt_str, val, "")
        } else if val_type == self.double_type {
            let fmt_str = LLVMBuildGlobalStringPtr(self.builder, "%f\n", ".fmt_float")
            let p_char = self.map_type("*Char")
            let fn_ty = kai_func_type_2(self.int64_type, p_char, self.double_type, true)
            let _ = kai_build_call_2(self.builder, fn_ty, printf_fn, fmt_str, val, "")
        } else if val != (0 as *Void) {
            let fmt_str = LLVMBuildGlobalStringPtr(self.builder, "%s\n", ".fmt_str")
            let p_char = self.map_type("*Char")
            let fn_ty = kai_func_type_2(self.int64_type, p_char, self.ptr_type, true)
            let _ = kai_build_call_2(self.builder, fn_ty, printf_fn, fmt_str, val, "")
        }
        return
    }
    if stmt.kind == StmtKind.sk_errdefer {
        self.gen_stmt(stmt.errdefer_body)
        return
    }
    if stmt.kind == StmtKind.sk_unsafe {
        self.gen_stmt(stmt.unsafe_body)
        return
    }
    if stmt.kind == StmtKind.sk_func_decl {
        return
    }
    if stmt.kind == StmtKind.sk_extern {
        return
    }
    if stmt.kind == StmtKind.sk_struct_decl {
        return
    }
    if stmt.kind == StmtKind.sk_enum_decl {
        return
    }
    if stmt.kind == StmtKind.sk_trait_decl {
        return
    }
    if stmt.kind == StmtKind.sk_import {
        return
    }
    if stmt.kind == StmtKind.sk_cimport {
        return
    }
    if stmt.kind == StmtKind.sk_error_decl {
        return
    }
    if stmt.kind == StmtKind.sk_none {
        return
    }
    if stmt.kind == StmtKind.sk_impl_block {
        // Emit method bodies inside impl blocks
        var mi = 0
        while mi < stmt.impl_methods.length() {
            let method_idx = stmt.impl_methods.get(mi)
            let method_stmt = self.stmt_pool.get(method_idx)
            if method_stmt.kind == StmtKind.sk_func_decl {
                let fn_val = self.lookup_or_create_func(method_stmt.func_name)
                self.emit_func_body(method_idx, fn_val, stmt.impl_struct_name)
            }
            mi = mi + 1
        }
        return
    }
    if stmt.kind == StmtKind.sk_match {
        let match_expr_val = self.gen_expr(stmt.match_expr)
        if match_expr_val == (0 as *Void) {
            return
        }
        let match_expr_node = self.expr_pool.get(stmt.match_expr)
        let match_expr_type = self.get_expr_type(stmt.match_expr)
        var clean_type = match_expr_type
        if strlen(clean_type) == 0 {
            let rec_ty = LLVMTypeOf(match_expr_val)
            let ty_str = LLVMPrintTypeToString(rec_ty) as Str
            var start_idx = 0
            if strlen(ty_str) > 8 && ty_str[0..8] == "%struct." {
                start_idx = 8
            } else if strlen(ty_str) > 1 && ty_str[0] == Char(37) {
                start_idx = 1
            }
            var end_idx = strlen(ty_str)
            while end_idx > start_idx && (ty_str[end_idx - 1] == Char(42) || ty_str[end_idx - 1] == Char(38) || ty_str[end_idx - 1] == Char(32)) {
                end_idx = end_idx - 1
            }
            if end_idx > start_idx {
                clean_type = ty_str[start_idx..end_idx]
            }
        }
        while strlen(clean_type) > 0 && (clean_type[0] == Char(42) || clean_type[0] == Char(38)) {
            clean_type = clean_type[1..strlen(clean_type)]
        }
        if strlen(clean_type) >= 4 && clean_type[0..4] == "mut " {
            clean_type = clean_type[4..strlen(clean_type)]
        }
        let mapped_type = self.map_type(clean_type)
        var llvm_match_type = mapped_type
        if llvm_match_type == (0 as *Void) { llvm_match_type = self.int64_type }
        var is_ptr = false
        if strlen(match_expr_type) > 0 && (match_expr_type[0] == Char(42) || match_expr_type[0] == Char(38)) {
            is_ptr = true
        }
        // Simple match as if-else chain.
        // match_end is the block all arm bodies jump to when done.
        // merge_block (match_next) is where execution goes when a condition FAILS.
        let match_end_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "match_end")
        var case_idx = 0
        while case_idx < stmt.match_cases.length() {
            let case_node = stmt.match_cases.get(case_idx)
            let pat_node = self.pattern_pool.get(case_node.pattern)
            let then_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "match_then")
            var merge_block: *Void = (0 as *Void)

            if case_idx < stmt.match_cases.length() - 1 {
                merge_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "match_next")
            } else {
                // Last arm: if condition fails (shouldn't for else), also go to match_end
                merge_block = match_end_block
            }

            if pat_node.kind == PatternKind.pk_literal {
                var lit_val: *Void = (0 as *Void)
                match pat_node.lit_value {
                    case .tv_int(v) => { lit_val = LLVMConstInt(self.int64_type, v, false) }
                    case .tv_bool(v) => {
                        if v { lit_val = LLVMConstInt(self.int1_type, 1, false) }
                        else { lit_val = LLVMConstInt(self.int1_type, 0, false) }
                    }
                    case else => { lit_val = LLVMConstInt(self.int64_type, 0, false) }
                }
                let cmp = LLVMBuildICmp(self.builder, LLVMIntEQ, match_expr_val, lit_val, "")
                LLVMBuildCondBr(self.builder, cmp, then_block, merge_block)
            } else if pat_node.kind == PatternKind.pk_variant {
                // Error union match (.ok / .err)
                var is_error_union = self.str_contains(clean_type, Char(33))
                if is_error_union {
                    let excl_pos = self.str_find(clean_type, Char(33))
                    let val_type = clean_type[0..excl_pos] + ""
                    let err_type = clean_type[(excl_pos + 1)..strlen(clean_type)] + ""
                    // Load tag from struct field 0
                    var loaded_struct: *Void = match_expr_val
                    let type_kind = LLVMGetTypeKind(LLVMTypeOf(match_expr_val))
                    if type_kind == LLVMPointerTypeKind {
                        loaded_struct = LLVMBuildLoad2(self.builder, llvm_match_type, match_expr_val, ".match_val")
                    }
                    let tag_val = kai_LLVMBuildExtractValue(self.builder, loaded_struct, 0, ".tag")
                    var target_tag: Int = 0
                    var payload_type: Str = ""
                    if pat_node.variant_name == "ok" {
                        target_tag = 0
                        payload_type = val_type
                    } else if pat_node.variant_name == "err" {
                        target_tag = 1
                        payload_type = err_type
                    }
                    let expected_tag = LLVMConstInt(self.int64_type, target_tag, false)
                    let cmp = LLVMBuildICmp(self.builder, LLVMIntEQ, tag_val, expected_tag, "")
                    LLVMBuildCondBr(self.builder, cmp, then_block, merge_block)
                    LLVMPositionBuilderAtEnd(self.builder, then_block)
                    self.last_was_term = false

                    // Bind the payload value (field 1) if the variant has a binding
                    if pat_node.bindings.length() > 0 {
                        let payload_llvm_ty = self.map_type(payload_type)
                        let ext_val = kai_LLVMBuildExtractValue(self.builder, loaded_struct, 1, ".val")
                        let coerced_val = self.gen_cast(ext_val, payload_llvm_ty)
                        let bind_name = pat_node.bindings.get(0)
                        if bind_name != "_" && payload_llvm_ty != (0 as *Void) && payload_llvm_ty != self.void_type {
                            let bind_alloca = LLVMBuildAlloca(self.builder, payload_llvm_ty, bind_name)
                            LLVMBuildStore(self.builder, coerced_val, bind_alloca)
                            self.local_alloca_names.push(bind_name)
                            self.local_alloca_vals.push((bind_alloca as Int))
                            self.local_alloca_types.push((payload_llvm_ty as Int))
                            self.local_alloca_type_strs.push(payload_type)
                            self.local_alloca_decls.push(stmt_idx)
                        }
                    }
                } else {
                // Find actual variant index in the enum decl
                var target_tag_idx = 0
                var enum_stmt_idx = 0
                while enum_stmt_idx < self.stmt_pool.length() {
                    let s = self.stmt_pool.get(enum_stmt_idx)
                    if s.kind == StmtKind.sk_enum_decl && s.enum_name == clean_type {
                        var vi = 0
                        while vi < s.enum_variants.length() {
                            if s.enum_variants.get(vi).vname == pat_node.variant_name {
                                target_tag_idx = vi
                                break
                            }
                            vi = vi + 1
                        }
                    }
                    enum_stmt_idx = enum_stmt_idx + 1
                }

                // Variant pattern: check tag
                // For enums with payload, load tag from struct field 0
                var has_payload_enum = false
                let stripped_clean_type = self.strip_module_prefix(clean_type)
                var ei = 0
                while ei < self.enum_cache_names.length() {
                    if llvm_str_eq(self.enum_cache_names.get(ei), stripped_clean_type) && self.enum_has_payload.get(ei) {
                        has_payload_enum = true
                    }
                    ei = ei + 1
                }
                if has_payload_enum {
                    let gep = LLVMBuildStructGEP2(self.builder, llvm_match_type, match_expr_val, 0, ".tag")
                    let actual_tag = LLVMBuildLoad2(self.builder, self.int8_type, gep, "")
                    let tag_val = LLVMConstInt(self.int8_type, target_tag_idx, false)
                    let cmp = LLVMBuildICmp(self.builder, LLVMIntEQ, actual_tag, tag_val, "")
                    LLVMBuildCondBr(self.builder, cmp, then_block, merge_block)
                    LLVMPositionBuilderAtEnd(self.builder, then_block)
                    self.last_was_term = false

                    // Handle bindings (extract payload fields)
                    // 1. Find enum definition in AST to get field names and types of this variant
                    var enum_stmt_idx2 = 0
                    var found_enum = false
                    var matched_var = Variant(vname: "", params: empty_param_array())
                    while enum_stmt_idx2 < self.stmt_pool.length() {
                        let stmt = self.stmt_pool.get(enum_stmt_idx2)
                        if stmt.kind == StmtKind.sk_enum_decl && stmt.enum_name == clean_type {
                            var vi = 0
                            while vi < stmt.enum_variants.length() {
                                let v = stmt.enum_variants.get(vi)
                                if v.vname == pat_node.variant_name {
                                    matched_var = v
                                    found_enum = true
                                }
                                vi = vi + 1
                            }
                        }
                        enum_stmt_idx2 = enum_stmt_idx2 + 1
                    }

                    if found_enum {
                        // Build the variant's struct type for layout extraction
                        var variant_field_types = ArrayList<Int>(self.allocator)
                        var p_idx = 0
                        while p_idx < matched_var.params.length() {
                            let p = matched_var.params.get(p_idx)
                            let p_llvm_ty = self.map_type(p.ptype)
                            variant_field_types.push((p_llvm_ty as Int))
                            p_idx = p_idx + 1
                        }
                        let variant_struct_ty = LLVMStructTypeInContext(self.ctx, variant_field_types.data as *Void, variant_field_types.length(), false)
                        
                        let payload_gep = LLVMBuildStructGEP2(self.builder, llvm_match_type, match_expr_val, 1, ".payload")
                        let casted_payload_ptr = LLVMBuildBitCast(self.builder, payload_gep, LLVMPointerType(variant_struct_ty, 0), "")

                        var bi = 0
                        while bi < pat_node.bindings.length() {
                            let bind_name = pat_node.bindings.get(bi)
                            if bind_name != "_" && bi < matched_var.params.length() {
                                let param = matched_var.params.get(bi)
                                let p_llvm_ty = self.map_type(param.ptype)
                                
                                let dest_gep = LLVMBuildStructGEP2(self.builder, variant_struct_ty, casted_payload_ptr, bi, "")
                                let loaded_val = LLVMBuildLoad2(self.builder, p_llvm_ty, dest_gep, "")
                                
                                let bind_alloca = LLVMBuildAlloca(self.builder, p_llvm_ty, bind_name)
                                LLVMBuildStore(self.builder, loaded_val, bind_alloca)
                                
                                self.local_alloca_names.push(bind_name)
                                self.local_alloca_vals.push((bind_alloca as Int))
                                self.local_alloca_types.push((p_llvm_ty as Int))
                                self.local_alloca_type_strs.push(param.ptype)
                                self.local_alloca_decls.push(stmt_idx)
                            }
                            bi = bi + 1
                        }
                    }
                } else {
                    // No-payload enum: compare directly with int constant
                    let tag_val = LLVMConstInt(self.int64_type, target_tag_idx, false)
                    let cmp = LLVMBuildICmp(self.builder, LLVMIntEQ, match_expr_val, tag_val, "")
                    LLVMBuildCondBr(self.builder, cmp, then_block, merge_block)
                }
                }
            } else if pat_node.kind == PatternKind.pk_else {
                LLVMBuildBr(self.builder, then_block)
            }

            LLVMPositionBuilderAtEnd(self.builder, then_block)
            self.last_was_term = false
            self.gen_stmt(case_node.body)
            if !self.last_was_term {
                // After executing an arm body, always jump to match_end (not merge_block)
                LLVMBuildBr(self.builder, match_end_block)
            }

            // Position at merge_block for the next arm's condition check
            LLVMPositionBuilderAtEnd(self.builder, merge_block)
            self.last_was_term = false
            case_idx = case_idx + 1
        }
        // After all arms, we're positioned at match_end_block already
        return
    }
}

fn find_alloca_by_idx(self, decl_idx: Int, name: Str) -> *Void {
    var i = self.local_alloca_decls.length() - 1
    while i >= 0 {
        if self.local_alloca_decls.get(i) == decl_idx && llvm_str_eq(self.local_alloca_names.get(i), name) {
            return (self.local_alloca_vals.get(i) as *Void)
        }
        i = i - 1
    }
    return (0 as *Void)
}

fn find_alloca_type_by_idx(self, decl_idx: Int, name: Str) -> *Void {
    var i = self.local_alloca_decls.length() - 1
    while i >= 0 {
        if self.local_alloca_decls.get(i) == decl_idx && llvm_str_eq(self.local_alloca_names.get(i), name) {
            return (self.local_alloca_types.get(i) as *Void)
        }
        i = i - 1
    }
    return (0 as *Void)
}

fn find_alloca(self, name: Str) -> *Void {
    // Iterate backwards so inner-scope variables shadow outer-scope ones
    var i = self.local_alloca_names.length() - 1
    while i >= 0 {
        if llvm_str_eq(self.local_alloca_names.get(i), name) {
            return (self.local_alloca_vals.get(i) as *Void)
        }
        i = i - 1
    }
    return (0 as *Void)
}

fn find_alloca_type(self, name: Str) -> *Void {
    // Iterate backwards so inner-scope variables shadow outer-scope ones
    var i = self.local_alloca_names.length() - 1
    while i >= 0 {
        if llvm_str_eq(self.local_alloca_names.get(i), name) {
            return (self.local_alloca_types.get(i) as *Void)
        }
        i = i - 1
    }
    return (0 as *Void)
}

fn get_expr_type(self, expr_idx: Int) -> Str {
    if expr_idx < 0 { return "" }
    let expr = self.expr_pool.get(expr_idx)
    if strlen(expr.inferred_type) > 0 {
        return expr.inferred_type
    }
    if expr.kind == ExprKind.ek_literal {
        if expr.lit_vkind == "INT" { return "Int" }
        if expr.lit_vkind == "STRING" { return "Str" }
        if expr.lit_vkind == "FLOAT" { return "Float" }
        if expr.lit_vkind == "BOOL" { return "Bool" }
        if expr.lit_vkind == "CHAR" { return "Char" }
    }
    if expr.kind == ExprKind.ek_str_interp {
        return "Str"
    }
    if expr.kind == ExprKind.ek_range {
        return "Range"
    }
    if expr.kind == ExprKind.ek_struct_init {
        let is_enum = (strlen(expr.struct_name) > 0) && (self.str_contains(expr.struct_name, Char(46)))
        if is_enum {
            let dot_pos = self.str_find(expr.struct_name, Char(46))
            return expr.struct_name[0..dot_pos]
        }
        return expr.struct_name
    }
    if expr.kind == ExprKind.ek_array {
        if expr.func_args.length() > 0 {
            return "[]" + self.get_expr_type(expr.func_args.get(0))
        }
        return "[]Void"
    }
    if expr.kind == ExprKind.ek_tuple {
        var t_str = "("
        var ti = 0
        while ti < expr.func_args.length() {
            if ti > 0 { t_str = t_str + ", " }
            t_str = t_str + self.get_expr_type(expr.func_args.get(ti))
            ti = ti + 1
        }
        t_str = t_str + ")"
        return t_str
    }
    if expr.kind == ExprKind.ek_identifier {
        var vi = self.local_alloca_names.length() - 1
        while vi >= 0 {
            if llvm_str_eq(self.local_alloca_names.get(vi), expr.ident_name) {
                // Force a heap-allocated copy to ensure null-termination (slices are not null-terminated)
                let ty_str = self.local_alloca_type_strs.get(vi) + ""
                return ty_str
            }
            vi = vi - 1
        }
        if self.is_struct_type(expr.ident_name) || self.is_enum_type(expr.ident_name) || self.is_error_type(expr.ident_name) {
            return expr.ident_name
        }
    }
    // For function and constructor calls
    if expr.kind == ExprKind.ek_func_call {
        var lookup_name = expr.func_name
        if self.is_struct_type(lookup_name) {
            var struct_type_name = lookup_name
            if expr.func_type_args.length() > 0 {
                var tai = 0
                while tai < expr.func_type_args.length() {
                    let clean_arg = self.clean_type_for_mangling(expr.func_type_args.get(tai))
                    struct_type_name = struct_type_name + "_" + clean_arg
                    tai = tai + 1
                }
            }
            return struct_type_name
        }
        if lookup_name == "as" || lookup_name == "cast" {
            if expr.func_type_args.length() > 0 {
                return expr.func_type_args.get(0)
            }
        }
        var i = 0
        while i < self.func_type_names.length() {
            if llvm_str_eq(self.func_type_names.get(i), lookup_name) {
                return self.func_type_returns.get(i)
            }
            i = i + 1
        }
    }
    if expr.kind == ExprKind.ek_method_call {
        let receiver_type = self.get_expr_type(expr.meth_expr)
        var clean_type = receiver_type
        if strlen(clean_type) == 0 {
            return ""
        }
        while strlen(clean_type) > 0 && (clean_type[0] == Char(42) || clean_type[0] == Char(38)) {
            clean_type = clean_type[1..strlen(clean_type)]
        }
        if strlen(clean_type) >= 4 && clean_type[0..4] == "mut " {
            clean_type = clean_type[4..strlen(clean_type)]
        }
        let mangled_type = self.clean_type_for_mangling(clean_type)
        let func_name = mangled_type + "_" + expr.meth_name
        return self.get_func_return_type(func_name)
    }
    if expr.kind == ExprKind.ek_field_access {
        let base_type = self.get_expr_type(expr.field_expr)
        var clean_type = base_type
        while strlen(clean_type) > 0 && (clean_type[0] == Char(42) || clean_type[0] == Char(38)) {
            clean_type = clean_type[1..strlen(clean_type)]
        }
        if strlen(clean_type) >= 4 && clean_type[0..4] == "mut " {
            clean_type = clean_type[4..strlen(clean_type)]
        }
        if self.is_enum_type(clean_type) || self.is_error_type(clean_type) {
            return clean_type
        }
        
        var is_error_union = false
        var excl_idx = -1
        if self.str_contains(clean_type, Char(33)) { // '!'
            is_error_union = true
            excl_idx = self.str_find(clean_type, Char(33))
        } else if strlen(clean_type) > 7 && clean_type[0..7] == "Result_" {
            is_error_union = true
        }
        
        if is_error_union {
            if expr.field_name == "tag" {
                return "Int"
            }
            if expr.field_name == "value" {
                if excl_idx >= 0 {
                    return clean_type[0..excl_idx]
                }
                var last_under = -1
                var ui = strlen(clean_type) - 1
                while ui >= 0 {
                    if clean_type[ui] == Char(95) {
                        last_under = ui
                        break
                    }
                    ui = ui - 1
                }
                if last_under > 7 {
                    return clean_type[7..last_under]
                }
            }
        }
        
        let struct_decl_idx = self.find_struct_decl(clean_type)
        if struct_decl_idx >= 0 {
            let stmt = self.stmt_pool.get(struct_decl_idx)
            var f_idx = 0
            while f_idx < stmt.struct_fields.length() {
                let f = stmt.struct_fields.get(f_idx)
                if f.name == expr.field_name {
                    var ftype = f.ftype
                    // If it is a generic struct (either ArrayList<T> or monomorphized ArrayList_PatternNode)
                    if stmt.struct_type_params.length() > 0 {
                        let old_map = self.current_type_map
                        self.current_type_map = self.setup_type_map_from_mangled_name(stmt.struct_name, clean_type, &stmt.struct_type_params)
                        let resolved_ftype = self.substitute_generic_type(ftype)
                        ftype = resolved_ftype
                        self.current_type_map = old_map
                    }
                    return ftype
                }
                f_idx = f_idx + 1
            }
        }
        return "Void"
    }
    if expr.kind == ExprKind.ek_index {
        let base_type = self.get_expr_type(expr.idx_expr)
        if strlen(base_type) > 2 && base_type[0] == Char(91) && base_type[1] == Char(93) {
            return base_type[2..strlen(base_type)]
        }
        if strlen(base_type) > 0 && base_type[0] == Char(42) {
            return base_type[1..strlen(base_type)]
        }
        return "Void"
    }
    if expr.kind == ExprKind.ek_borrow {
        let opty = self.get_expr_type(expr.borrow_expr)
        return "*" + opty
    }
    if expr.kind == ExprKind.ek_deref {
        let opty = self.get_expr_type(expr.deref_expr)
        if strlen(opty) > 0 && (opty[0] == Char(42) || opty[0] == Char(38)) {
            return opty[1..strlen(opty)]
        }
        return "Void"
    }
    return ""
}

fn gen_expr(self, expr_idx: Int) -> *Void {
    if expr_idx < 0 { return (0 as *Void) }
    self.ensure_reachable()
    let expr = self.expr_pool.get(expr_idx)
    if expr.kind == ExprKind.ek_literal {
        if expr.lit_vkind == "INT" {
            var val: Int = 0
            match expr.lit_value {
                case .tv_int(v) => { val = v }
                case .tv_str(v) => { val = self.str_to_int(self.pool.get(v)) }
                case else => {}
            }
            return LLVMConstInt(self.int64_type, val, false)
        }
        if expr.lit_vkind == "FLOAT" {
            var val: Float = 0.0
            match expr.lit_value {
                case .tv_float(v) => { val = v }
                case .tv_str(v) => { val = self.str_to_float(self.pool.get(v)) }
                case else => {}
            }
            return LLVMConstReal(self.double_type, val)
        }
        if expr.lit_vkind == "BOOL" {
            var bval: Bool = false
            match expr.lit_value {
                case .tv_bool(v) => { bval = v }
                case else => {}
            }
            if bval {
                return LLVMConstInt(self.int1_type, 1, false)
            }
            return LLVMConstInt(self.int1_type, 0, false)
        }
        if expr.lit_vkind == "STRING" {
            var sval: Str = ""
            match expr.lit_value {
                case .tv_str(v) => { sval = self.pool.get(v) }
                case else => {}
            }
            let gname = ".str" + int_to_str(self.str_counter)
            self.str_counter = self.str_counter + 1
            let ptr_val = LLVMBuildGlobalStringPtr(self.builder, sval, gname)
            // Build %Str{ ptr, len } fat-pointer struct value
            let null_str = LLVMConstNull(self.str_type)
            let with_ptr = kai_LLVMBuildInsertValue(self.builder, null_str, ptr_val, 0, ".str.ptr")
            let len_val = LLVMConstInt(self.int64_type, strlen(sval), false)
            return kai_LLVMBuildInsertValue(self.builder, with_ptr, len_val, 1, ".str")
        }
        if expr.lit_vkind == "CHAR" {
            var val: Int = 0
            match expr.lit_value {
                case .tv_char(v) => { val = (v as Int) }
                case .tv_int(v) => { val = v }
                case else => {}
            }
            return LLVMConstInt(self.int8_type, val, false)
        }
        if expr.lit_vkind == "NONE" {
            return (0 as *Void)
        }
        return (0 as *Void)
    }
    if expr.kind == ExprKind.ek_identifier {
        var alloca = (0 as *Void)
        var elem_ty = (0 as *Void)
        if expr.resolved_symbol_idx >= 0 {
            alloca = self.find_alloca_by_idx(expr.resolved_symbol_idx, expr.ident_name)
            elem_ty = self.find_alloca_type_by_idx(expr.resolved_symbol_idx, expr.ident_name)
        }
        if alloca == (0 as *Void) {
            alloca = self.find_alloca(expr.ident_name)
            elem_ty = self.find_alloca_type(expr.ident_name)
        }
        if alloca != (0 as *Void) {
            if elem_ty == (0 as *Void) {
                elem_ty = self.int64_type
            }
            // For array/struct types, return the pointer directly (no load)
            // Exception: Str is a fat-pointer struct loaded by value
            var is_aggregate = false
            if elem_ty != self.str_type {
                let ty_kind = LLVMGetTypeKind(elem_ty)
                if ty_kind == LLVMArrayTypeKind || ty_kind == LLVMStructTypeKind {
                    is_aggregate = true
                }
            }
            if is_aggregate {
                return alloca
            }
            return LLVMBuildLoad2(self.builder, elem_ty, alloca, expr.ident_name)
        }
        var si = 0
        while si < self.stmt_pool.length() {
            let stmt = self.stmt_pool.get(si)
            if stmt.kind == StmtKind.sk_var_decl {
                if self.decl_name_matches(stmt.vardecl_name, expr.ident_name) {
                    return self.gen_expr(stmt.vardecl_value)
                }
            }
            si = si + 1
        }
        return (0 as *Void)
    }
    if expr.kind == ExprKind.ek_func_call {
        let name = expr.func_name
        // Type constructor calls: Char(x), Int(x), Float(x), Bool(x) — treat as casts
        if name == "Char" || name == "Int" || name == "Float" || name == "Bool" {
            if expr.func_args.length() > 0 {
                let val = self.gen_expr(expr.func_args.get(0))
                if val == (0 as *Void) { return (0 as *Void) }
                let dest_type = self.map_type(name)
                return self.gen_cast(val, dest_type)
            }
            return (0 as *Void)
        }
        if name == "as" || name == "cast" {
            let val = self.gen_expr(expr.func_args.get(0))
            let dest_type_str = expr.func_type_args.get(0)
            let dest_type = self.map_type(dest_type_str)
            return self.gen_cast(val, dest_type)
        }
        if name == "size_of" {
            let dest_type_str = expr.func_type_args.get(0)
            let dest_type = self.map_type(dest_type_str)
            return LLVMSizeOf(dest_type)
        }
        // strlen builtin: extract .len from %Str struct instead of calling C strlen.
        // This is safe for zero-initialized strings (LLVMConstNull) where .ptr is NULL.
        if name == "strlen" {
            if expr.func_args.length() > 0 {
                let s_val = self.gen_expr(expr.func_args.get(0))
                if s_val == (0 as *Void) { return LLVMConstInt(self.int64_type, 0, false) }
                if LLVMTypeOf(s_val) == self.str_type {
                    return kai_LLVMBuildExtractValue(self.builder, s_val, 1, ".len")
                }
                // Fallback: for *Char, call strlen via lookup (handled below)
            }
        }
        var target_fn_name = expr.func_name
        if self.is_struct_type(expr.func_name) {
            if expr.func_type_args.length() > 0 {
                var tai = 0
                while tai < expr.func_type_args.length() {
                    let clean = self.clean_type_for_mangling(expr.func_type_args.get(tai))
                    target_fn_name = target_fn_name + "_" + clean
                    tai = tai + 1
                }
                target_fn_name = target_fn_name + "_init"
            } else {
                target_fn_name = expr.func_name + "_init"
            }
        }
        let fn_val = self.lookup_or_create_func(target_fn_name)
        if fn_val == (0 as *Void) { return (0 as *Void) }
        let fn_ty = self.get_cached_func_type(target_fn_name)
        if fn_ty == (0 as *Void) { return (0 as *Void) }
        let fn_ret_ty = LLVMGetReturnType(fn_ty)
        let param_types_str = self.get_func_param_types(target_fn_name)
        let arg_count = expr.func_args.length()
        let callee_is_extern = self.is_extern_func(target_fn_name)
        var args_val_array = ArrayList<Int>(self.allocator)
        var ai = 0
        while ai < arg_count {
            let expr_arg = expr.func_args.get(ai)
            let raw_arg = self.gen_expr(expr_arg)
            let param_ty_str = self.get_param_type_at_index(param_types_str, ai)
            let prepared = self.prepare_arg(raw_arg, param_ty_str, callee_is_extern)
            if prepared == (0 as *Void) {
                // If any argument compilation fails, return null
                return (0 as *Void)
            }
            args_val_array.push((prepared as Int))
            ai = ai + 1
        }
        return LLVMBuildCall2(self.builder, fn_ty, fn_val, args_val_array.data as *Void, arg_count, "")
    }
    if expr.kind == ExprKind.ek_unary_op {
        let operand = self.gen_expr(expr.unop_operand)
        if operand == (0 as *Void) { return (0 as *Void) }
        if expr.unop_op == "!" {
            let op_type = LLVMTypeOf(operand)
            if op_type == self.int1_type {
                let zero = LLVMConstInt(self.int1_type, 0, false)
                let is_zero = LLVMBuildICmp(self.builder, LLVMIntEQ, operand, zero, "")
                return LLVMBuildZExt(self.builder, is_zero, self.int64_type, "")
            } else {
                let zero = LLVMConstInt(self.int64_type, 0, false)
                let is_zero = LLVMBuildICmp(self.builder, LLVMIntEQ, operand, zero, "")
                return LLVMBuildZExt(self.builder, is_zero, self.int64_type, "")
            }
        }
        if expr.unop_op == "-" {
            let op_ty = LLVMTypeOf(operand)
            if op_ty == self.double_type {
                return LLVMBuildFNeg(self.builder, operand, "")
            }
            return LLVMBuildNeg(self.builder, operand, "")
        }
        if expr.unop_op == "~" {
            return LLVMBuildNot(self.builder, operand, "")
        }
        return (0 as *Void)
    }
    if expr.kind == ExprKind.ek_binary_op {
        let op = expr.binop_op
        
        // Logical AND and OR (non-short-circuit for now — safety relies on coerce_return_value
        // zeroing the error union value field, and imports.kai using nested-if patterns).
        if op == "&&" || op == "||" {
            let lhs = self.gen_expr(expr.binop_left)
            let rhs = self.gen_expr(expr.binop_right)
            let zero = LLVMConstInt(self.int64_type, 0, false)
            var lhs_i64 = lhs
            var rhs_i64 = rhs
            if lhs == (0 as *Void) { lhs_i64 = zero }
            else if LLVMTypeOf(lhs) != self.int64_type { lhs_i64 = LLVMBuildSExt(self.builder, lhs, self.int64_type, "") }
            if rhs == (0 as *Void) { rhs_i64 = zero }
            else if LLVMTypeOf(rhs) != self.int64_type { rhs_i64 = LLVMBuildSExt(self.builder, rhs, self.int64_type, "") }
            let lhs_ne = LLVMBuildICmp(self.builder, LLVMIntNE, lhs_i64, zero, "")
            let rhs_ne = LLVMBuildICmp(self.builder, LLVMIntNE, rhs_i64, zero, "")
            if op == "&&" {
                let and_val = LLVMBuildAnd(self.builder, lhs_ne, rhs_ne, "")
                return LLVMBuildZExt(self.builder, and_val, self.int64_type, "")
            }
            let or_val = LLVMBuildOr(self.builder, lhs_ne, rhs_ne, "")
            return LLVMBuildZExt(self.builder, or_val, self.int64_type, "")
        }
        
        let lhs = self.gen_expr(expr.binop_left)
        let rhs = self.gen_expr(expr.binop_right)
        if op != "==" && op != "!=" {
            if lhs == (0 as *Void) || rhs == (0 as *Void) { return (0 as *Void) }
        }
        // Handle 'none' (null sentinel) comparisons for == and !=.
        // ek_none returns (0 as *Void); we must compare the non-null side against null
        // before any LLVMTypeOf call, which would crash on a NULL value.
        if lhs == (0 as *Void) || rhs == (0 as *Void) {
            if lhs == (0 as *Void) && rhs == (0 as *Void) {
                if op == "==" { return LLVMConstInt(self.int64_type, 1, false) }
                return LLVMConstInt(self.int64_type, 0, false)
            }
            var ptr_val = lhs
            if lhs == (0 as *Void) { ptr_val = rhs }
            let ptr_int = LLVMBuildPtrToInt(self.builder, ptr_val, self.int64_type, "")
            let zero = LLVMConstInt(self.int64_type, 0, false)
            if op == "==" {
                let cmp = LLVMBuildICmp(self.builder, LLVMIntEQ, ptr_int, zero, "")
                return LLVMBuildZExt(self.builder, cmp, self.int64_type, "")
            }
            let cmp = LLVMBuildICmp(self.builder, LLVMIntNE, ptr_int, zero, "")
            return LLVMBuildZExt(self.builder, cmp, self.int64_type, "")
        }
        let lhs_ty = LLVMTypeOf(lhs)
        let left_type = self.get_expr_type(expr.binop_left)
        let right_type = self.get_expr_type(expr.binop_right)
        let expr_type_str = self.get_expr_type(expr_idx)
        
        let is_left_str = lhs_ty == self.str_type || left_type == "Str" || left_type == "*Char"
        let is_right_str = LLVMTypeOf(rhs) == self.str_type || right_type == "Str" || right_type == "*Char"
        // Only do Str concatenation when BOTH sides are actually string/ptr types (not integers)
        let rhs_kind_for_str = LLVMGetTypeKind(LLVMTypeOf(rhs))
        let lhs_kind_for_str = LLVMGetTypeKind(lhs_ty)
        let both_are_str_compat = (rhs_kind_for_str == LLVMPointerTypeKind || LLVMTypeOf(rhs) == self.str_type) && (lhs_kind_for_str == LLVMPointerTypeKind || lhs_ty == self.str_type)
        
        // Str + Str string concatenation (only when both operands are pointer/str typed)
        if (is_left_str || is_right_str) && op == "+" && both_are_str_compat {
            let lhs_str = self.gen_cast(lhs, self.str_type)
            let rhs_str = self.gen_cast(rhs, self.str_type)
            let concat_fn = self.lookup_or_create_func("concatAlloc")
            if concat_fn != (0 as *Void) {
                let concat_ty = self.get_cached_func_type("concatAlloc")
                if concat_ty != (0 as *Void) {
                    var args_array = ArrayList<Int>(self.allocator)
                    args_array.push((lhs_str as Int))
                    args_array.push((rhs_str as Int))
                    let raw_result = LLVMBuildCall2(self.builder, concat_ty, concat_fn, args_array.data as *Void, 2, "")
                    if expr_type_str == "*Char" {
                        return self.unwrap_str_for_c(raw_result)
                    }
                    return raw_result
                }
            }
            return (0 as *Void)
        }
        // Str == Str / Str != Str string comparison
        if (left_type == "Str" || right_type == "Str" || lhs_ty == self.str_type || LLVMTypeOf(rhs) == self.str_type) && (op == "==" || op == "!=") {
            let lhs_ptr = self.unwrap_str_for_c(lhs)
            let rhs_ptr = self.unwrap_str_for_c(rhs)
            let strcmp_fn = self.lookup_or_create_func("strcmp")
            if strcmp_fn != (0 as *Void) {
                let strcmp_ty = self.get_cached_func_type("strcmp")
                if strcmp_ty != (0 as *Void) {
                    let cmp_result: *Void = kai_build_call_2(self.builder, strcmp_ty, strcmp_fn, lhs_ptr, rhs_ptr, "")
                    let zero = LLVMConstInt(self.int64_type, 0, false)
                    if op == "==" {
                        let eq = LLVMBuildICmp(self.builder, LLVMIntEQ, cmp_result, zero, "")
                        return LLVMBuildZExt(self.builder, eq, self.int64_type, "")
                    } else {
                        let ne = LLVMBuildICmp(self.builder, LLVMIntNE, cmp_result, zero, "")
                        return LLVMBuildZExt(self.builder, ne, self.int64_type, "")
                    }
                }
            }
            return (0 as *Void)
        }
        let is_float = lhs_ty == self.double_type
        if is_float {
            if op == "+" { return LLVMBuildFAdd(self.builder, lhs, rhs, "") }
            if op == "-" { return LLVMBuildFSub(self.builder, lhs, rhs, "") }
            if op == "*" { return LLVMBuildFMul(self.builder, lhs, rhs, "") }
            if op == "/" { return LLVMBuildFDiv(self.builder, lhs, rhs, "") }
            if op == "==" {
                let cmp = LLVMBuildFCmp(self.builder, LLVMRealOEQ, lhs, rhs, "")
                return LLVMBuildZExt(self.builder, cmp, self.int64_type, "")
            }
            if op == "!=" {
                let cmp = LLVMBuildFCmp(self.builder, LLVMRealONE, lhs, rhs, "")
                return LLVMBuildZExt(self.builder, cmp, self.int64_type, "")
            }
            if op == "<" {
                let cmp = LLVMBuildFCmp(self.builder, LLVMRealOLT, lhs, rhs, "")
                return LLVMBuildZExt(self.builder, cmp, self.int64_type, "")
            }
            if op == ">" {
                let cmp = LLVMBuildFCmp(self.builder, LLVMRealOGT, lhs, rhs, "")
                return LLVMBuildZExt(self.builder, cmp, self.int64_type, "")
            }
            if op == "<=" {
                let cmp = LLVMBuildFCmp(self.builder, LLVMRealOLE, lhs, rhs, "")
                return LLVMBuildZExt(self.builder, cmp, self.int64_type, "")
            }
            if op == ">=" {
                let cmp = LLVMBuildFCmp(self.builder, LLVMRealOGE, lhs, rhs, "")
                return LLVMBuildZExt(self.builder, cmp, self.int64_type, "")
            }
            return (0 as *Void)
        }
        if op == "+" { return LLVMBuildAdd(self.builder, lhs, rhs, "") }
        if op == "-" { return LLVMBuildSub(self.builder, lhs, rhs, "") }
        if op == "*" { return LLVMBuildMul(self.builder, lhs, rhs, "") }
        if op == "/" { return LLVMBuildSDiv(self.builder, lhs, rhs, "") }
        if op == "%" { return LLVMBuildSRem(self.builder, lhs, rhs, "") }
        if op == "&" { return LLVMBuildAnd(self.builder, lhs, rhs, "") }
        if op == "|" { return LLVMBuildOr(self.builder, lhs, rhs, "") }
        if op == "^" { return LLVMBuildXor(self.builder, lhs, rhs, "") }
        if op == "<<" { return LLVMBuildShl(self.builder, lhs, rhs, "") }
        if op == ">>" { return LLVMBuildAShr(self.builder, lhs, rhs, "") }
        // Normalize operand types for comparisons: widen narrow ints to i64
        var cmp_lhs = lhs
        var cmp_rhs = rhs
        let rhs_ty = LLVMTypeOf(rhs)
        let lhs_kind = LLVMGetTypeKind(lhs_ty)
        let rhs_kind = LLVMGetTypeKind(rhs_ty)
        if lhs_kind == LLVMIntegerTypeKind && rhs_kind == LLVMIntegerTypeKind {
            let lhs_w = kai_LLVMGetIntTypeWidth(lhs_ty)
            let rhs_w = kai_LLVMGetIntTypeWidth(rhs_ty)
            if lhs_w < rhs_w {
                cmp_lhs = LLVMBuildSExt(self.builder, lhs, rhs_ty, "")
            } else if rhs_w < lhs_w {
                cmp_rhs = LLVMBuildSExt(self.builder, rhs, lhs_ty, "")
            }
        }
        if op == "==" {
            // If one side is pointer and other is integer (null check), align types
            let cl_kind = LLVMGetTypeKind(LLVMTypeOf(cmp_lhs))
            let cr_kind = LLVMGetTypeKind(LLVMTypeOf(cmp_rhs))
            if cl_kind == LLVMPointerTypeKind && cr_kind == LLVMIntegerTypeKind {
                cmp_rhs = LLVMConstNull(LLVMTypeOf(cmp_lhs))
            } else if cl_kind == LLVMIntegerTypeKind && cr_kind == LLVMPointerTypeKind {
                cmp_lhs = LLVMBuildPtrToInt(self.builder, cmp_lhs, self.int64_type, "")
                cmp_rhs = LLVMConstInt(self.int64_type, 0, false)
            }
            let cmp = LLVMBuildICmp(self.builder, LLVMIntEQ, cmp_lhs, cmp_rhs, "")
            return LLVMBuildZExt(self.builder, cmp, self.int64_type, "")
        }
        if op == "!=" {
            let cl_kind2 = LLVMGetTypeKind(LLVMTypeOf(cmp_lhs))
            let cr_kind2 = LLVMGetTypeKind(LLVMTypeOf(cmp_rhs))
            if cl_kind2 == LLVMPointerTypeKind && cr_kind2 == LLVMIntegerTypeKind {
                cmp_rhs = LLVMConstNull(LLVMTypeOf(cmp_lhs))
            } else if cl_kind2 == LLVMIntegerTypeKind && cr_kind2 == LLVMPointerTypeKind {
                cmp_lhs = LLVMBuildPtrToInt(self.builder, cmp_lhs, self.int64_type, "")
                cmp_rhs = LLVMConstInt(self.int64_type, 0, false)
            }
            let cmp = LLVMBuildICmp(self.builder, LLVMIntNE, cmp_lhs, cmp_rhs, "")
            return LLVMBuildZExt(self.builder, cmp, self.int64_type, "")
        }
        if op == "<" {
            let cmp = LLVMBuildICmp(self.builder, LLVMIntSLT, cmp_lhs, cmp_rhs, "")
            return LLVMBuildZExt(self.builder, cmp, self.int64_type, "")
        }
        if op == ">" {
            let cmp = LLVMBuildICmp(self.builder, LLVMIntSGT, cmp_lhs, cmp_rhs, "")
            return LLVMBuildZExt(self.builder, cmp, self.int64_type, "")
        }
        if op == "<=" {
            let cmp = LLVMBuildICmp(self.builder, LLVMIntSLE, cmp_lhs, cmp_rhs, "")
            return LLVMBuildZExt(self.builder, cmp, self.int64_type, "")
        }
        if op == ">=" {
            let cmp = LLVMBuildICmp(self.builder, LLVMIntSGE, cmp_lhs, cmp_rhs, "")
            return LLVMBuildZExt(self.builder, cmp, self.int64_type, "")
        }
        return (0 as *Void)
    }
    if expr.kind == ExprKind.ek_check {
        return self.gen_expr(expr.check_expr)
    }
    if expr.kind == ExprKind.ek_borrow {
        return self.gen_expr_address(expr.borrow_expr)
    }
    if expr.kind == ExprKind.ek_deref {
        return self.gen_expr(expr.deref_expr)
    }
    if expr.kind == ExprKind.ek_try {
        return self.gen_expr(expr.try_expr)
    }
    if expr.kind == ExprKind.ek_catch {
        let inner = self.gen_expr(expr.catch_expr)
        if expr.catch_fallback >= 0 {
            let fallback = self.gen_expr(expr.catch_fallback)
            if inner == (0 as *Void) { return fallback }
            if fallback == (0 as *Void) { return inner }
            let is_ok = self.to_bool(inner)
            if is_ok == (0 as *Void) { return fallback }
            
            var cond_val = is_ok
            if LLVMTypeOf(cond_val) != self.int1_type {
                let zero = LLVMConstNull(LLVMTypeOf(cond_val))
                cond_val = LLVMBuildICmp(self.builder, LLVMIntNE, cond_val, zero, "")
            }
            
            var cast_fallback = fallback
            if LLVMTypeOf(inner) != LLVMTypeOf(fallback) {
                cast_fallback = self.gen_cast(fallback, LLVMTypeOf(inner))
            }
            return LLVMBuildSelect(self.builder, cond_val, inner, cast_fallback, "")
        }
        return inner
    }
    if expr.kind == ExprKind.ek_array {
        var inner_type_str = "Int"
        if strlen(expr.inferred_type) > 2 && expr.inferred_type[0] == Char(91) && expr.inferred_type[1] == Char(93) {
            inner_type_str = expr.inferred_type[2..strlen(expr.inferred_type)]
        }
        let inner_llvm_type = self.map_type(inner_type_str)
        if inner_llvm_type == self.void_type || inner_llvm_type == (0 as *Void) {
            inner_llvm_type = self.int64_type
        }
        let count = expr.arr_elements.length()
        if count == 0 {
            return LLVMBuildAlloca(self.builder, inner_llvm_type, ".arr_empty")
        }
        let arr_type = LLVMArrayType(inner_llvm_type, count)
        let arr_ptr = LLVMBuildAlloca(self.builder, arr_type, ".arr")
        // Bitcast to element pointer for easier GEP
        let el_ptr_ty = LLVMPointerType(inner_llvm_type, 0)
        let casted = LLVMBuildBitCast(self.builder, arr_ptr, el_ptr_ty, "")
        var ai = 0
        while ai < count {
            let elem_val = self.gen_expr(expr.arr_elements.get(ai))
            if elem_val != (0 as *Void) {
                let indices = ArrayList<Int>(self.allocator)
                let idx_val = LLVMConstInt(self.int64_type, ai, false)
                indices.push((idx_val as Int))
                let gep = LLVMBuildGEP2(self.builder, inner_llvm_type, casted, indices.data as *Void, 1, "")
                LLVMBuildStore(self.builder, elem_val, gep)
            }
            ai = ai + 1
        }
        return arr_ptr
    }
    if expr.kind == ExprKind.ek_index {
        let base_val = self.gen_expr(expr.idx_expr)
        if base_val == (0 as *Void) { return (0 as *Void) }
        let idx_val = self.gen_expr(expr.idx_index)
        if idx_val == (0 as *Void) { return (0 as *Void) }
        // Determine element type
        var inner_type_str = "Int"
        let base_expr2 = self.expr_pool.get(expr.idx_expr)
        var base_type_for_index = self.get_expr_type(expr.idx_expr)
        if strlen(base_type_for_index) == 0 { base_type_for_index = base_expr2.inferred_type }
        if base_type_for_index == "Str" {
            inner_type_str = "Char"
        } else if strlen(base_type_for_index) > 2 && base_type_for_index[0] == Char(91) && base_type_for_index[1] == Char(93) {
            inner_type_str = base_type_for_index[2..strlen(base_type_for_index)]
        } else if strlen(base_type_for_index) > 0 && base_type_for_index[0] == Char(42) {
            inner_type_str = base_type_for_index[1..strlen(base_type_for_index)]
        } else if strlen(base_expr2.inferred_type) > 2 && base_expr2.inferred_type[0] == Char(91) && base_expr2.inferred_type[1] == Char(93) {
            inner_type_str = base_expr2.inferred_type[2..strlen(base_expr2.inferred_type)]
        } else if strlen(base_expr2.inferred_type) > 0 && base_expr2.inferred_type[0] == Char(42) {
            inner_type_str = base_expr2.inferred_type[1..strlen(base_expr2.inferred_type)]
        }
        var inner_llvm_type = self.map_type(inner_type_str)
        if inner_llvm_type == self.void_type || inner_llvm_type == (0 as *Void) {
            inner_llvm_type = self.int64_type
        }
        // If base is a %Str fat pointer, extract the raw .ptr field first
        var base_ptr2 = base_val
        let base_llvm_ty3 = LLVMTypeOf(base_val)
        if base_llvm_ty3 == self.str_type {
            base_ptr2 = self.unwrap_str_for_c(base_val)
            inner_llvm_type = self.int8_type
        } else if LLVMGetTypeKind(base_llvm_ty3) == LLVMStructTypeKind {
            // Some other struct — skip indexing
            return (0 as *Void)
        }
        // Ensure idx_val is i64 for GEP
        var gep_idx = idx_val
        let idx_ty = LLVMTypeOf(idx_val)
        if idx_ty != self.int64_type {
            gep_idx = LLVMBuildSExt(self.builder, idx_val, self.int64_type, "")
        }
        let el_ptr_ty = LLVMPointerType(inner_llvm_type, 0)
        let casted = LLVMBuildBitCast(self.builder, base_ptr2, el_ptr_ty, "")
        let indices = ArrayList<Int>(self.allocator)
        indices.push((gep_idx as Int))
        let gep = LLVMBuildGEP2(self.builder, inner_llvm_type, casted, indices.data as *Void, 1, "")
        let loaded = LLVMBuildLoad2(self.builder, inner_llvm_type, gep, "")
        // Widen to i64 for Char/i8 results so comparisons stay consistent
        if inner_llvm_type == self.int8_type {
            return LLVMBuildSExt(self.builder, loaded, self.int64_type, "")
        }
        return loaded
    }
    if expr.kind == ExprKind.ek_range {
        let range_ty = self.map_type("Range")
        if range_ty == self.void_type || range_ty == (0 as *Void) { return (0 as *Void) }
        let start_val = self.gen_expr(expr.range_start)
        let end_val = self.gen_expr(expr.range_end)
        if start_val == (0 as *Void) || end_val == (0 as *Void) { return (0 as *Void) }
        var incl_int: Int = 0
        if expr.range_inclusive { incl_int = 1 }
        let incl_val = LLVMConstInt(self.int1_type, incl_int, false)
        let alloca_val = LLVMBuildAlloca(self.builder, range_ty, ".range")
        let start_gep = LLVMBuildStructGEP2(self.builder, range_ty, alloca_val, 0, ".start")
        LLVMBuildStore(self.builder, start_val, start_gep)
        let end_gep = LLVMBuildStructGEP2(self.builder, range_ty, alloca_val, 1, ".end")
        LLVMBuildStore(self.builder, end_val, end_gep)
        let incl_gep = LLVMBuildStructGEP2(self.builder, range_ty, alloca_val, 2, ".incl")
        LLVMBuildStore(self.builder, incl_val, incl_gep)
        return alloca_val
    }
    if expr.kind == ExprKind.ek_slice {
        let base_val = self.gen_expr(expr.slice_expr)
        if base_val == (0 as *Void) { return (0 as *Void) }
        let base_llvm_ty = LLVMTypeOf(base_val)
        if base_llvm_ty == self.str_type {
            // Fat-pointer Str slice
            let str_alloca = LLVMBuildAlloca(self.builder, self.str_type, ".parent.str")
            LLVMBuildStore(self.builder, base_val, str_alloca)
            let ptr_gep = LLVMBuildStructGEP2(self.builder, self.str_type, str_alloca, 0, ".parent.ptr.gep")
            let parent_ptr = LLVMBuildLoad2(self.builder, self.ptr_type, ptr_gep, ".parent.ptr")
            let len_gep = LLVMBuildStructGEP2(self.builder, self.str_type, str_alloca, 1, ".parent.len.gep")
            let parent_len = LLVMBuildLoad2(self.builder, self.int64_type, len_gep, ".parent.len")
            var lower_val = LLVMConstInt(self.int64_type, 0, false)
            if expr.slice_lower >= 0 {
                lower_val = self.gen_expr(expr.slice_lower)
                if lower_val == (0 as *Void) { return (0 as *Void) }
            }
            var upper_val = parent_len
            if expr.slice_upper >= 0 {
                upper_val = self.gen_expr(expr.slice_upper)
                if upper_val == (0 as *Void) { return (0 as *Void) }
                let cmp = LLVMBuildICmp(self.builder, LLVMIntSGT, upper_val, parent_len, "")
                upper_val = LLVMBuildSelect(self.builder, cmp, parent_len, upper_val, ".upper.clamped")
            }
            let lower_gt_upper = LLVMBuildICmp(self.builder, LLVMIntSGT, lower_val, upper_val, "")
            upper_val = LLVMBuildSelect(self.builder, lower_gt_upper, lower_val, upper_val, ".upper.fixed")
            let gep_indices = ArrayList<Int>(self.allocator)
            gep_indices.push((lower_val as Int))
            let new_ptr = LLVMBuildGEP2(self.builder, self.int8_type, parent_ptr, gep_indices.data as *Void, 1, ".slice.ptr")
            let new_len = LLVMBuildSub(self.builder, upper_val, lower_val, ".slice.len")
            let result_alloca = LLVMBuildAlloca(self.builder, self.str_type, ".slice.str")
            let res_ptr_gep = LLVMBuildStructGEP2(self.builder, self.str_type, result_alloca, 0, ".slice.ptr.gep")
            LLVMBuildStore(self.builder, new_ptr, res_ptr_gep)
            let res_len_gep = LLVMBuildStructGEP2(self.builder, self.str_type, result_alloca, 1, ".slice.len.gep")
            LLVMBuildStore(self.builder, new_len, res_len_gep)
            return LLVMBuildLoad2(self.builder, self.str_type, result_alloca, ".slice.str")
        }
        // Raw pointer / array slice
        var lower_val: *Void = LLVMConstInt(self.int64_type, 0, false)
        if expr.slice_lower >= 0 {
            lower_val = self.gen_expr(expr.slice_lower)
            if lower_val == (0 as *Void) { return (0 as *Void) }
        }
        let indices = ArrayList<Int>(self.allocator)
        indices.push((lower_val as Int))
        return LLVMBuildGEP2(self.builder, self.int8_type, base_val, indices.data as *Void, 1, ".slice")
    }
    if expr.kind == ExprKind.ek_tuple {
        if strlen(expr.inferred_type) > 0 {
            let tuple_ty = self.map_tuple_type(expr.inferred_type)
            if tuple_ty == self.void_type || tuple_ty == (0 as *Void) { return (0 as *Void) }
            let alloca_val = LLVMBuildAlloca(self.builder, tuple_ty, ".tuple")
            var ei = 0
            while ei < expr.tup_elements.length() {
                let elem_val = self.gen_expr(expr.tup_elements.get(ei))
                if elem_val != (0 as *Void) {
                    let gep = LLVMBuildStructGEP2(self.builder, tuple_ty, alloca_val, ei, ".elem")
                    LLVMBuildStore(self.builder, elem_val, gep)
                }
                ei = ei + 1
            }
            return alloca_val
        }
        return (0 as *Void)
    }
    if expr.kind == ExprKind.ek_struct_init {
        let struct_name = expr.struct_name
        // Check if this is an enum variant constructor (struct_name contains ".")
        var is_enum_variant = false
        var dot_pos = -1
        var ei = 0
        while ei < strlen(struct_name) {
            if struct_name[ei] == Char(46) { dot_pos = ei }
            ei = ei + 1
        }
        if dot_pos >= 0 {
            is_enum_variant = true
        }
        if is_enum_variant {
            let enum_part = struct_name[0..dot_pos]
            let variant_name = struct_name[(dot_pos + 1)..strlen(struct_name)]
            
            // Find variant index to use as tag
            var tag_idx = 0
            var found_tag = false
            var enum_stmt_idx = 0
            while enum_stmt_idx < self.stmt_pool.length() {
                let stmt = self.stmt_pool.get(enum_stmt_idx)
                if stmt.kind == StmtKind.sk_enum_decl && stmt.enum_name == enum_part {
                    var vi = 0
                    while vi < stmt.enum_variants.length() {
                        if stmt.enum_variants.get(vi).vname == variant_name {
                            tag_idx = vi
                            found_tag = true
                        }
                        vi = vi + 1
                    }
                }
                enum_stmt_idx = enum_stmt_idx + 1
            }

            // Check if this enum has payload
            var has_payload = false
            let stripped_enum_part = self.strip_module_prefix(enum_part)
            var ei_chk = 0
            while ei_chk < self.enum_cache_names.length() {
                if llvm_str_eq(self.enum_cache_names.get(ei_chk), stripped_enum_part) {
                    has_payload = self.enum_has_payload.get(ei_chk)
                }
                ei_chk = ei_chk + 1
            }


            if !has_payload {
                // No payload -> just return the tag index directly as a scalar int64
                return LLVMConstInt(self.int64_type, tag_idx, false)
            }

            // Has payload -> build the enum struct { i8 tag, [16 x i64] payload }
            let enum_ty = self.map_type(enum_part)
            if enum_ty == self.void_type || enum_ty == (0 as *Void) {
                return (0 as *Void)
            }
            let alloca_val = LLVMBuildAlloca(self.builder, enum_ty, ".enum_var")
            
            // 1. Store tag in field 0 (.tag)
            let tag_gep = LLVMBuildStructGEP2(self.builder, enum_ty, alloca_val, 0, ".tag")
            LLVMBuildStore(self.builder, LLVMConstInt(self.int8_type, tag_idx, false), tag_gep)

            // 2. Store constructor arguments in payload
            if expr.struct_fields.length() > 0 {
                // Determine field values and types
                var variant_field_types = ArrayList<Int>(self.allocator)
                var field_vals = ArrayList<Int>(self.allocator)
                var fi = 0
                while fi < expr.struct_fields.length() {
                    let f = expr.struct_fields.get(fi)
                    let field_val = self.gen_expr(f.value)
                    if field_val != (0 as *Void) {
                        variant_field_types.push((LLVMTypeOf(field_val) as Int))
                        field_vals.push((field_val as Int))
                    }
                    fi = fi + 1
                }
                
                // Create anonymous struct matching the variant's payload layout
                let variant_struct_ty = LLVMStructTypeInContext(self.ctx, variant_field_types.data as *Void, variant_field_types.length(), false)
                
                // Get pointer to payload (field 1 in the enum struct), and bitcast to variant payload pointer
                let payload_gep = LLVMBuildStructGEP2(self.builder, enum_ty, alloca_val, 1, ".payload")
                let casted_payload_ptr = LLVMBuildBitCast(self.builder, payload_gep, LLVMPointerType(variant_struct_ty, 0), "")
                
                // Store variant fields
                var sfi = 0
                while sfi < field_vals.length() {
                    let f_val = field_vals.get(sfi) as *Void
                    let dest_gep = LLVMBuildStructGEP2(self.builder, variant_struct_ty, casted_payload_ptr, sfi, "")
                    LLVMBuildStore(self.builder, f_val, dest_gep)
                    sfi = sfi + 1
                }
            }

            return alloca_val
        }
        // Plain struct literal
        let struct_ty = self.map_type(struct_name)
        if struct_ty == self.void_type || struct_ty == (0 as *Void) {
            return (0 as *Void)
        }
        let alloca_val = LLVMBuildAlloca(self.builder, struct_ty, ".struct")
        var fi = 0
        while fi < expr.struct_fields.length() {
            let f = expr.struct_fields.get(fi)
            var field_val = self.gen_expr(f.value)
            if field_val != (0 as *Void) {
                let gep = LLVMBuildStructGEP2(self.builder, struct_ty, alloca_val, fi, f.name)
                let fv_kind = LLVMGetTypeKind(LLVMTypeOf(field_val))
                let field_llvm_ty = LLVMStructGetTypeAtIndex(struct_ty, fi)
                let field_kind = LLVMGetTypeKind(field_llvm_ty)
                // If gen_expr returned a pointer-to-struct but the field expects a struct value,
                // we need to load (dereference) the pointer first.
                if fv_kind == LLVMPointerTypeKind && field_kind == LLVMStructTypeKind {
                    field_val = LLVMBuildLoad2(self.builder, field_llvm_ty, field_val, "")
                }
                LLVMBuildStore(self.builder, field_val, gep)
            }
            fi = fi + 1
        }
        return alloca_val
    }
    if expr.kind == ExprKind.ek_field_access {
        // Check if compile-time enum variant reference
        var is_enum_member_ref = false
        let base_expr = self.expr_pool.get(expr.field_expr)
        if base_expr.kind == ExprKind.ek_identifier {
            if self.is_enum_type(base_expr.ident_name) {
                is_enum_member_ref = true
            }
            if self.is_error_type(base_expr.ident_name) {
                is_enum_member_ref = true
            }
        }
        
        if is_enum_member_ref {
            let enum_name = base_expr.ident_name
            let variant_name = expr.field_name
            
            // Find variant index to use as tag
            var tag_idx = 0
            var found_tag = false
            var enum_stmt_idx = 0
            while enum_stmt_idx < self.stmt_pool.length() {
                let stmt = self.stmt_pool.get(enum_stmt_idx)
                if stmt.kind == StmtKind.sk_enum_decl && stmt.enum_name == enum_name {
                    var vi = 0
                    while vi < stmt.enum_variants.length() {
                        if stmt.enum_variants.get(vi).vname == variant_name {
                            tag_idx = vi
                            found_tag = true
                        }
                        vi = vi + 1
                    }
                }
                if stmt.kind == StmtKind.sk_error_decl && stmt.error_name == enum_name {
                    var vi = 0
                    while vi < stmt.error_variants.length() {
                        if stmt.error_variants.get(vi) == variant_name {
                            tag_idx = vi
                            found_tag = true
                        }
                        vi = vi + 1
                    }
                }
                enum_stmt_idx = enum_stmt_idx + 1
            }
            
            // Check if this enum has payload
            var has_payload = false
            let stripped_enum_name = self.strip_module_prefix(enum_name)
            var ei_chk = 0
            while ei_chk < self.enum_cache_names.length() {
                if llvm_str_eq(self.enum_cache_names.get(ei_chk), stripped_enum_name) {
                    has_payload = self.enum_has_payload.get(ei_chk)
                }
                ei_chk = ei_chk + 1
            }
            
            if !has_payload {
                return LLVMConstInt(self.int64_type, tag_idx, false)
            } else {
                let enum_ty = self.map_type(enum_name)
                if enum_ty == self.void_type || enum_ty == (0 as *Void) {
                    return (0 as *Void)
                }
                let alloca_val = LLVMBuildAlloca(self.builder, enum_ty, ".enum_var")
                let tag_gep = LLVMBuildStructGEP2(self.builder, enum_ty, alloca_val, 0, ".tag")
                LLVMBuildStore(self.builder, LLVMConstInt(self.int8_type, tag_idx, false), tag_gep)
                return LLVMBuildLoad2(self.builder, enum_ty, alloca_val, "")
            }
        }

        let base_val = self.gen_expr(expr.field_expr)
        if base_val == (0 as *Void) { return (0 as *Void) }
        var base_type = self.get_expr_type(expr.field_expr)
        if strlen(base_type) == 0 {
            let base_llvm_ty = LLVMTypeOf(base_val)
            let ty_str = LLVMPrintTypeToString(base_llvm_ty) as Str
            var start_idx = 0
            if strlen(ty_str) > 8 && ty_str[0..8] == "%struct." {
                start_idx = 8
            } else if strlen(ty_str) > 1 && ty_str[0] == Char(37) {
                start_idx = 1
            }
            var end_idx = strlen(ty_str)
            while end_idx > start_idx && (ty_str[end_idx - 1] == Char(42) || ty_str[end_idx - 1] == Char(38) || ty_str[end_idx - 1] == Char(32)) {
                end_idx = end_idx - 1
            }
            if end_idx > start_idx {
                base_type = ty_str[start_idx..end_idx]
            }
        }
        // Strip leading pointer/ref sigils for struct name lookup
        var clean_base_type = base_type
        while strlen(clean_base_type) > 0 && (clean_base_type[0] == Char(42) || clean_base_type[0] == Char(38)) {
            clean_base_type = clean_base_type[1..strlen(clean_base_type)]
        }
        // Find field index in struct definition
        var field_idx = -1
        var found_field = false
        var struct_decl_idx = -1
        var is_error_union = false
        if self.str_contains(clean_base_type, Char(33)) { // '!'
            is_error_union = true
        } else if strlen(clean_base_type) > 7 && clean_base_type[0..7] == "Result_" {
            is_error_union = true
        }
        if is_error_union {
            if expr.field_name == "tag" {
                field_idx = 0
                found_field = true
            } else if expr.field_name == "value" {
                field_idx = 1
                found_field = true
            }
        } else {
            struct_decl_idx = self.find_struct_decl(clean_base_type)
            if struct_decl_idx >= 0 {
                let s = self.stmt_pool.get(struct_decl_idx)
                var fii = 0
                while fii < s.struct_fields.length() {
                    if s.struct_fields.get(fii).name == expr.field_name {
                        field_idx = fii
                        found_field = true
                        break
                    }
                    fii = fii + 1
                }
            }
        }
        if !found_field {
            return (0 as *Void)
        }
        let struct_ty = self.map_type(clean_base_type)
        if struct_ty == (0 as *Void) || struct_ty == self.void_type {
            return (0 as *Void)
        }
        // If base_type was a pointer, base_val is already a ptr — use it directly.
        // Otherwise base_val is a struct value; we need to alloca to get a pointer.
        var base_ptr = base_val
        let base_llvm_ty = LLVMTypeOf(base_val)
        let base_kind = LLVMGetTypeKind(base_llvm_ty)
        if base_kind == LLVMStructTypeKind {
            // Value struct — alloca temporarily
            let tmp = LLVMBuildAlloca(self.builder, struct_ty, ".tmp.field")
            LLVMBuildStore(self.builder, base_val, tmp)
            base_ptr = tmp
        }
        let gep = LLVMBuildStructGEP2(self.builder, struct_ty, base_ptr, field_idx, expr.field_name)
        // Determine field type for load
        var field_type_str = "Int"
        if found_field && struct_decl_idx >= 0 {
            let s2 = self.stmt_pool.get(struct_decl_idx)
            if field_idx >= 0 && field_idx < s2.struct_fields.length() {
                field_type_str = s2.struct_fields.get(field_idx).ftype
                
                // If the struct is generic, reconstruct type map dynamically to substitute field type
                if s2.struct_type_params.length() > 0 {
                    let old_map = self.current_type_map
                    self.current_type_map = self.setup_type_map_from_mangled_name(s2.struct_name, clean_base_type, &s2.struct_type_params)
                    let resolved_field_ty = self.substitute_generic_type(field_type_str)
                    field_type_str = resolved_field_ty
                    self.current_type_map = old_map
                }
            }
        }
        let field_llvm_type = LLVMStructGetTypeAtIndex(struct_ty, field_idx)
        var is_aggregate = false
        if field_llvm_type != (0 as *Void) && field_llvm_type != self.void_type && field_llvm_type != self.str_type {
            let ty_kind = LLVMGetTypeKind(field_llvm_type)
            if ty_kind == LLVMStructTypeKind || ty_kind == LLVMArrayTypeKind {
                is_aggregate = true
            }
        }
        if is_aggregate {
            return gep
        }
        if field_llvm_type == (0 as *Void) || field_llvm_type == self.void_type {
            return LLVMBuildLoad2(self.builder, self.int64_type, gep, "")
        }
        return LLVMBuildLoad2(self.builder, field_llvm_type, gep, expr.field_name)
    }
    if expr.kind == ExprKind.ek_method_call {
        var receiver_val = self.gen_expr(expr.meth_expr)
        var is_static = false
        var clean_type = ""
        let receiver_node = self.expr_pool.get(expr.meth_expr)
        if receiver_node.kind == ExprKind.ek_identifier {
            let name = receiver_node.ident_name
            if self.find_alloca(name) == (0 as *Void) && self.find_alloca_by_idx(-1, name) == (0 as *Void) {
                is_static = true
                clean_type = name
            }
        }
        if !is_static && receiver_val == (0 as *Void) {
            return (0 as *Void)
        }

        if !is_static {
            let receiver_type = self.get_expr_type(expr.meth_expr)
            clean_type = receiver_type
            if strlen(clean_type) == 0 {
                let rec_ty = LLVMTypeOf(receiver_val)
                let ty_str = LLVMPrintTypeToString(rec_ty) as Str
                var start_idx = 0
                if strlen(ty_str) > 8 && ty_str[0..8] == "%struct." {
                    start_idx = 8
                } else if strlen(ty_str) > 1 && ty_str[0] == Char(37) {
                    start_idx = 1
                }
                var end_idx = strlen(ty_str)
                while end_idx > start_idx && (ty_str[end_idx - 1] == Char(42) || ty_str[end_idx - 1] == Char(38) || ty_str[end_idx - 1] == Char(32)) {
                    end_idx = end_idx - 1
                }
                if end_idx > start_idx {
                    clean_type = ty_str[start_idx..end_idx]
                }
            }
        }
        while strlen(clean_type) > 0 && (clean_type[0] == Char(42) || clean_type[0] == Char(38)) {
            clean_type = clean_type[1..strlen(clean_type)]
        }
        if strlen(clean_type) >= 4 && clean_type[0..4] == "mut " {
            clean_type = clean_type[4..strlen(clean_type)]
        }
        let mangled_type = self.clean_type_for_mangling(clean_type)
        let func_name = mangled_type + "_" + expr.meth_name
        let fn_val = self.lookup_or_create_func(func_name)
        if fn_val == (0 as *Void) { return (0 as *Void) }
        let fn_ty = self.get_cached_func_type(func_name)
        if fn_ty == (0 as *Void) { return (0 as *Void) }
        let ret_ty = self.get_func_return_type(func_name)
        let is_init = (expr.meth_name == "init") || (ret_ty == clean_type) || (ret_ty == "*" + clean_type) || (ret_ty == "&" + clean_type)
        // Build args list: receiver + all method args (except for init/static which doesn't pass receiver)
        var arg_vals = ArrayList<Int>(self.allocator)
        if !is_init && !is_static {
            // Pass receiver as first arg (pointer to self)
            var receiver_ptr = receiver_val
            let rec_llvm_ty = LLVMTypeOf(receiver_val)
            let rec_kind = LLVMGetTypeKind(rec_llvm_ty)
            if rec_kind == LLVMStructTypeKind {
                let tmp = LLVMBuildAlloca(self.builder, rec_llvm_ty, ".tmp.receiver")
                LLVMBuildStore(self.builder, receiver_val, tmp)
                receiver_ptr = tmp
            }
            arg_vals.push((receiver_ptr as Int))
        }
        let param_types_str = self.get_func_param_types(func_name)
        // Methods are never extern in Kai — always use native %Str ABI
        var ai = 0
        while ai < expr.meth_args.length() {
            let raw_arg = self.gen_expr(expr.meth_args.get(ai))
            var param_idx = ai + 1
            if is_init {
                param_idx = ai
            }
            let param_ty_str = self.get_param_type_at_index(param_types_str, param_idx)
            let av = self.prepare_arg(raw_arg, param_ty_str, false)
            if av != (0 as *Void) {
                arg_vals.push((av as Int))
            } else {
                arg_vals.push((LLVMConstInt(self.int64_type, 0, false) as Int))
            }
            ai = ai + 1
        }
        let call_res = LLVMBuildCall2(self.builder, fn_ty, fn_val, arg_vals.data as *Void, arg_vals.length(), "")
        
        if is_init {
            if is_static {
                return call_res
            }
            if call_res != (0 as *Void) {
                LLVMBuildStore(self.builder, call_res, receiver_val)
            }
            return receiver_val
        }
        return call_res
    }
    if expr.kind == ExprKind.ek_asm {
        // Build constraints string: outputs + inputs + clobbers
        var constraints_str = ""
        var oi = 0
        while oi < expr.asm_outputs.length() {
            let out = expr.asm_outputs.get(oi)
            if strlen(constraints_str) > 0 { constraints_str = constraints_str + "," }
            constraints_str = constraints_str + "=" + out.constraint
            oi = oi + 1
        }
        var ii = 0
        while ii < expr.asm_inputs.length() {
            let inp = expr.asm_inputs.get(ii)
            if strlen(constraints_str) > 0 { constraints_str = constraints_str + "," }
            constraints_str = constraints_str + inp.constraint
            ii = ii + 1
        }
        var ci = 0
        while ci < expr.asm_clobbers.length() {
            if strlen(constraints_str) > 0 { constraints_str = constraints_str + "," }
            constraints_str = constraints_str + "~{" + expr.asm_clobbers.get(ci) + "}"
            ci = ci + 1
        }
        // Generate input values first (and collect types)
        let total_inputs = expr.asm_inputs.length()
        var inp_vals = ArrayList<Int>(self.allocator)
        var param_types = ArrayList<Int>(self.allocator)
        var inp_idx = 0
        while inp_idx < total_inputs {
            let inp = expr.asm_inputs.get(inp_idx)
            let iv = self.gen_expr(inp.expr_idx)
            if iv == (0 as *Void) {
                inp_vals.push((LLVMConstInt(self.int64_type, 0, false) as Int))
                param_types.push((self.int64_type as Int))
            } else {
                inp_vals.push((iv as Int))
                param_types.push((LLVMTypeOf(iv) as Int))
            }
            inp_idx = inp_idx + 1
        }
        // Determine return type from inferred_type or outputs
        var ret_ty = self.void_type
        if strlen(expr.inferred_type) > 0 {
            let mt = self.map_type(expr.inferred_type)
            if mt != self.void_type && mt != (0 as *Void) { ret_ty = mt }
        } else if expr.asm_outputs.length() > 0 && strlen(expr.asm_outputs.get(0).type_name) > 0 {
            let mt = self.map_type(expr.asm_outputs.get(0).type_name)
            if mt != self.void_type && mt != (0 as *Void) { ret_ty = mt }
        }
        let fn_ty = LLVMFunctionType(ret_ty, param_types.data as *Void, total_inputs, false)
        let asm_str = expr.asm_code
        let asm_val = kai_LLVMGetInlineAsm(
            fn_ty,
            asm_str as *Char,
            strlen(asm_str),
            constraints_str as *Char,
            strlen(constraints_str),
            expr.asm_is_volatile,
            false,
            0,
            false
        )
        if asm_val == (0 as *Void) { return (0 as *Void) }
        // Call the asm with input values
        return LLVMBuildCall2(self.builder, fn_ty, asm_val, inp_vals.data as *Void, total_inputs, "")
    }
    if expr.kind == ExprKind.ek_str_interp {
        if expr.interp_parts.length() == 0 {
            return LLVMBuildGlobalStringPtr(self.builder, "", ".str_empty")
        }
        // Simple concatenation: for now, just concatenate string literal parts
        var result_str = ""
        var i = 0
        while i < expr.interp_parts.length() {
            let part = expr.interp_parts.get(i)
            if part.kind == 0 {
                result_str = result_str + part.str_val
            } else {
                // For expression parts, just emit the expression (simplified)
                let expr_val = self.gen_expr(part.expr_idx)
                let _ = expr_val
            }
            i = i + 1
        }
        let gname = ".str" + int_to_str(self.str_counter)
        self.str_counter = self.str_counter + 1
        let ptr_val = LLVMBuildGlobalStringPtr(self.builder, result_str, gname)
        let null_str = LLVMConstNull(self.str_type)
        let with_ptr = kai_LLVMBuildInsertValue(self.builder, null_str, ptr_val, 0, ".str.ptr")
        let len_val = LLVMConstInt(self.int64_type, strlen(result_str), false)
        return kai_LLVMBuildInsertValue(self.builder, with_ptr, len_val, 1, ".str")
    }
    if expr.kind == ExprKind.ek_none {
        return (0 as *Void)
    }
    return (0 as *Void)
}

fn str_to_int(self, s: Str) -> Int {
    var result: Int = 0
    var i: Int = 0
    var neg = false
    if strlen(s) > 0 && s[0] == Char(45) {
        neg = true
        i = 1
    }
    while i < strlen(s) {
        let c = s[i]
        if c >= Char(48) && c <= Char(57) {
            result = (result * 10) + ((c as Int) - 48)
        }
        i = i + 1
    }
    if neg { result = -result }
    return result
}

fn str_to_float(self, s: Str) -> Float {
    var result: Float = 0.0
    var i: Int = 0
    var neg = false
    if strlen(s) > 0 && s[0] == Char(45) {
        neg = true
        i = 1
    }
    while i < strlen(s) && s[i] >= Char(48) && s[i] <= Char(57) {
        result = (result * 10.0) + ((s[i] as Int - 48) as Float)
        i = i + 1
    }
    if i < strlen(s) && s[i] == Char(46) {
        i = i + 1
        var divisor: Float = 10.0
        while i < strlen(s) && s[i] >= Char(48) && s[i] <= Char(57) {
            result = result + ((s[i] as Int - 48) as Float) / divisor
            divisor = divisor * 10.0
            i = i + 1
        }
    }
    if neg { result = -result }
    return result
}

fn get_param_type_at_index(self, param_types_str: Str, idx: Int) -> Str {
    if strlen(param_types_str) == 0 { return "" }
    var start = 0
    var curr_idx = 0
    var pi = 0
    while pi < strlen(param_types_str) {
        if param_types_str[pi] == Char(44) { // comma
            if curr_idx == idx {
                return param_types_str[start..pi]
            }
            start = pi + 1
            curr_idx = curr_idx + 1
        }
        pi = pi + 1
    }
    if curr_idx == idx {
        return param_types_str[start..strlen(param_types_str)]
    }
    return ""
}

// Prepare a call argument for passing to a function.
// callee_is_extern: true => C ABI: Str is passed as raw ptr (i8*).
//                  false => Kai ABI: Str is passed as %Str fat-pointer by value.
fn prepare_arg(self, arg_val: *Void, param_type_str: Str, callee_is_extern: Bool) -> *Void {
    if callee_is_extern {
        if arg_val != (0 as *Void) {
            if LLVMTypeOf(arg_val) == self.str_type {
                return self.unwrap_str_for_c(arg_val)
            }
        }
    }
    let is_str = (param_type_str == "Str" || param_type_str == "*Str" || param_type_str == "&Str")

    // Handle Str two-tier ABI first
    if is_str {
        if callee_is_extern {
            // Extern C function expects raw i8* pointer
            return self.unwrap_str_for_c(arg_val)
        } else {
            // Pure Kai function expects %Str by value
            if arg_val == (0 as *Void) {
                return LLVMConstNull(self.str_type)
            }
            return self.gen_cast(arg_val, self.str_type)
        }
    }

    let param_llvm_ty = self.map_type(param_type_str)
    var effective_ty: *Void = param_llvm_ty
    if param_llvm_ty == self.void_type || param_llvm_ty == (0 as *Void) {
        effective_ty = self.ptr_type
    }

    if arg_val == (0 as *Void) {
        return LLVMConstNull(effective_ty)
    }
    if strlen(param_type_str) == 0 {
        // Unknown param type: pass raw (no conversion)
        return arg_val
    }

    let ty_kind = LLVMGetTypeKind(effective_ty)
    if ty_kind == LLVMStructTypeKind {
        let arg_ty = LLVMTypeOf(arg_val)
        // If arg already has the exact struct type (returned by value from a call), use it directly
        if arg_ty == effective_ty {
            return arg_val
        }
        let arg_kind = LLVMGetTypeKind(arg_ty)
        if arg_kind == LLVMPointerTypeKind {
            // arg is a pointer to the struct — load it
            return LLVMBuildLoad2(self.builder, effective_ty, arg_val, "")
        }
        // arg is an integer or other non-pointer non-struct: zero-initialize the struct
        return LLVMConstNull(effective_ty)
    }

    return self.gen_cast(arg_val, effective_ty)
}



fn gen_cast(self, val: *Void, dest_type: *Void) -> *Void {
    if val == (0 as *Void) || dest_type == (0 as *Void) { return val }
    let src_type = LLVMTypeOf(val)
    if src_type == dest_type { return val }
    let src_kind = LLVMGetTypeKind(src_type)
    let dest_kind = LLVMGetTypeKind(dest_type)


    // pointer to struct -> load struct value
    if dest_kind == LLVMStructTypeKind && src_kind == LLVMPointerTypeKind && dest_type != self.str_type {
        return LLVMBuildLoad2(self.builder, dest_type, val, "")
    }

    // ptr → Str: wrap raw pointer into a %Str fat pointer
    if src_kind == LLVMPointerTypeKind && dest_type == self.str_type {
        let undef_s: *Void = LLVMGetUndef(self.str_type)
        let with_p: *Void = LLVMBuildInsertValue(self.builder, undef_s, val, 0, "")
        var fn_val = LLVMGetNamedFunction(self.module, "strlen")
        let strlen_ty = kai_func_type_1(self.int64_type, self.ptr_type, false)
        if fn_val == (0 as *Void) {
            fn_val = LLVMAddFunction(self.module, "strlen", strlen_ty)
        }
        let len_val = kai_build_call_1(self.builder, strlen_ty, fn_val, val, "")
        let with_l: *Void = LLVMBuildInsertValue(self.builder, with_p, len_val, 1, "")
        return with_l
    }
    // Str → ptr: extract the raw .ptr field from %Str
    if src_type == self.str_type && dest_kind == LLVMPointerTypeKind {
        return LLVMBuildExtractValue(self.builder, val, 0, "")
    }
    // Str → int: extract ptr, then ptrtoint
    if src_type == self.str_type && dest_kind == LLVMIntegerTypeKind {
        let raw_ptr: *Void = LLVMBuildExtractValue(self.builder, val, 0, "")
        return LLVMBuildPtrToInt(self.builder, raw_ptr, dest_type, "")
    }

    if src_kind == LLVMPointerTypeKind && dest_kind == LLVMPointerTypeKind {
        return LLVMBuildBitCast(self.builder, val, dest_type, "")
    }
    if src_kind == LLVMPointerTypeKind && dest_kind == LLVMIntegerTypeKind {
        return LLVMBuildPtrToInt(self.builder, val, dest_type, "")
    }
    if src_kind == LLVMIntegerTypeKind && dest_kind == LLVMPointerTypeKind {
        return LLVMBuildIntToPtr(self.builder, val, dest_type, "")
    }
    if src_kind == LLVMIntegerTypeKind && dest_kind == LLVMIntegerTypeKind {
        let src_width = kai_LLVMGetIntTypeWidth(src_type)
        let dest_width = kai_LLVMGetIntTypeWidth(dest_type)
        if src_width < dest_width {
            return LLVMBuildZExt(self.builder, val, dest_type, "")
        } else if src_width > dest_width {
            return LLVMBuildTrunc(self.builder, val, dest_type, "")
        }
        return val
    }
    if src_kind == LLVMFloatTypeKind || src_kind == LLVMDoubleTypeKind {
        if dest_kind == LLVMIntegerTypeKind {
            return LLVMBuildFPToSI(self.builder, val, dest_type, "")
        }
    }
    if dest_kind == LLVMFloatTypeKind || dest_kind == LLVMDoubleTypeKind {
        if src_kind == LLVMIntegerTypeKind {
            return LLVMBuildSIToFP(self.builder, val, dest_type, "")
        }
    }
    return LLVMBuildBitCast(self.builder, val, dest_type, "")
}

fn is_struct_type(self, name: Str) -> Bool {
    if name == "ArrayList" || name == "HashMap" || name == "StringBuilder" {
        return true
    }
    return self.find_struct_decl(name) >= 0
}

fn is_enum_type(self, name: Str) -> Bool {
    return self.find_enum_decl(name) >= 0
}

fn is_error_type(self, name: Str) -> Bool {
    return self.find_error_decl(name) >= 0
}

fn clean_type_for_mangling(self, s: Str) -> Str {
    if self.str_contains(s, Char(60)) {
        let lt_pos = self.str_find(s, Char(60))
        let base_name = s[0..lt_pos]
        let args_str = s[lt_pos + 1..strlen(s) - 1]
        var args = ArrayList<Str>(self.allocator)
        var start = 0
        var i = 0
        while i < strlen(args_str) {
            let c = args_str[i]
            if c == Char(44) {
                args.push(self.trim_spaces(args_str[start..i]))
                start = i + 1
            }
            i = i + 1
        }
        args.push(self.trim_spaces(args_str[start..strlen(args_str)]))
        var concrete_name = base_name
        var ai = 0
        while ai < args.length() {
            let raw_arg = args.get(ai)
            let clean_arg = self.clean_type_for_mangling(raw_arg)
            concrete_name = concrete_name + "_" + clean_arg
            ai = ai + 1
        }
        return concrete_name
    }

    var result = ""
    var i = 0
    while i < strlen(s) {
        let c = s[i]
        if c == Char(42) { result = result + "ptr" }
        else if c == Char(38) { result = result + "ref" }
        else if c == Char(32) { result = result + "_" }
        else if c == Char(60) || c == Char(62) || c == Char(44) || c == Char(33) || c == Char(63) || c == Char(40) || c == Char(41) {
            result = result + "_"
        }
        else {
            result = result + char_to_str(c)
        }
        i = i + 1
    }
    return result
}

fn str_find(self, s: Str, c: Char) -> Int {
    var i = 0
    while i < strlen(s) {
        if s[i] == c { return i }
        i = i + 1
    }
    return -1
}

fn str_contains(self, s: Str, c: Char) -> Bool {
    return self.str_find(s, c) >= 0
}

fn substitute_generic_type_in_ftype(self, ftype: Str, clean_type: Str, stmt: StmtNode) -> Str {
    let lt_pos = self.str_find(clean_type, Char(60))
    let gt_pos = self.str_find(clean_type, Char(62))
    if lt_pos < 0 || gt_pos < 0 || gt_pos <= lt_pos { return ftype }
    let arg_str = clean_type[lt_pos + 1..gt_pos]
    
    if stmt.struct_type_params.length() > 0 {
        let param_name = stmt.struct_type_params.get(0)
        if ftype == param_name { return arg_str }
        if ftype == "*" + param_name { return "*" + arg_str }
        if ftype == "[]" + param_name { return "[]" + arg_str }
    }
    return ftype
}




fn emit_object(self, obj_path: Str) -> Bool {
    LLVMDumpModule(self.module)
    var verify_err: *Char = (0 as *Char)
    let verify_res = LLVMVerifyModule(self.module, 2, &verify_err as *Void)
    if verify_res != 0 {
        if verify_err != (0 as *Char) {
            printf("LLVM Module Verification failed: %s\n", verify_err)
            kai_fflush(stdout)
        }
    }
    LLVMSetTarget(self.module, LLVMGetDefaultTargetTriple() as Str)
    let ir_str = LLVMPrintModuleToString(self.module)
    printf("emit_object: writing to path='%s'\n", obj_path)
    kai_fflush(stdout)
    let write_res = write_string(obj_path, ir_str as Str)
    printf("emit_object: write_res.tag=%lld\n", write_res.tag)
    kai_fflush(stdout)
    return (write_res.tag == 0)
}

fn trim_spaces(self, s: Str) -> Str {
    var start = 0
    while start < strlen(s) && (s[start] == Char(32) || s[start] == Char(9) || s[start] == Char(10) || s[start] == Char(13)) {
        start = start + 1
    }
    var end = strlen(s)
    while end > start && (s[end - 1] == Char(32) || s[end - 1] == Char(9) || s[end - 1] == Char(10) || s[end - 1] == Char(13)) {
        end = end - 1
    }
    return s[start..end]
}

fn substitute_generic_type(self, name: Str) -> Str {
    var i = 0
    while i < self.current_type_map.length() {
        let entry = self.current_type_map.get(i)
        if entry.key == name {
            return entry.value
        }
        i = i + 1
    }
    return name
}

fn find_struct_decl(self, clean_name: Str) -> Int {
    let stripped_clean = self.strip_module_prefix(clean_name)
    var si = 0
    while si < self.stmt_pool.length() {
        let s = self.stmt_pool.get(si)
        if s.kind == StmtKind.sk_struct_decl {
            let decl_name = self.strip_module_prefix(s.struct_name)
            if decl_name == stripped_clean {
                return si
            }
            if s.struct_type_params.length() > 0 {
                let prefix = decl_name + "_"
                if strlen(stripped_clean) > strlen(prefix) && stripped_clean[0..strlen(prefix)] == prefix {
                    return si
                }
            }
        }
        si = si + 1
    }
    return -1
}

fn find_enum_decl(self, clean_name: Str) -> Int {
    let stripped_clean = self.strip_module_prefix(clean_name)
    var si = 0
    while si < self.stmt_pool.length() {
        let s = self.stmt_pool.get(si)
        if s.kind == StmtKind.sk_enum_decl {
            let decl_name = self.strip_module_prefix(s.enum_name)
            if decl_name == stripped_clean {
                return si
            }
            if s.enum_type_params.length() > 0 {
                let prefix = decl_name + "_"
                if strlen(stripped_clean) > strlen(prefix) && stripped_clean[0..strlen(prefix)] == prefix {
                    return si
                }
            }
        }
        si = si + 1
    }
    return -1
}

fn find_error_decl(self, clean_name: Str) -> Int {
    let stripped_clean = self.strip_module_prefix(clean_name)
    var si = 0
    while si < self.stmt_pool.length() {
        let s = self.stmt_pool.get(si)
        if s.kind == StmtKind.sk_error_decl {
            let decl_name = self.strip_module_prefix(s.error_name)
            if decl_name == stripped_clean {
                return si
            }
        }
        si = si + 1
    }
    return -1
}

fn setup_type_map_from_mangled_name(self, base_name: Str, mangled_name: Str, param_names: *ArrayList<Str>) -> ArrayList<LLVMStrMapEntry> {
    var map = ArrayList<LLVMStrMapEntry>(self.allocator)
    let prefix = base_name + "_"
    if strlen(mangled_name) <= strlen(prefix) {
        return map
    }
    let suffix = mangled_name[strlen(prefix)..strlen(mangled_name)]
    var start = 0
    var i = 0
    var arg_idx = 0
    while i < strlen(suffix) && arg_idx < param_names.length() {
        if suffix[i] == Char(95) { // '_'
            let arg = suffix[start..i]
            map.push(LLVMStrMapEntry(key: param_names.get(arg_idx), value: arg))
            arg_idx = arg_idx + 1
            start = i + 1
        }
        i = i + 1
    }
    if start < strlen(suffix) && arg_idx < param_names.length() {
        let arg = suffix[start..strlen(suffix)]
        map.push(LLVMStrMapEntry(key: param_names.get(arg_idx), value: arg))
    }
    return map
}

fn setup_current_type_map(self, param_names: *ArrayList<Str>, type_args: *ArrayList<Str>) {
    var i = 0
    while i < param_names.length() && i < type_args.length() {
        self.current_type_map.push(LLVMStrMapEntry(key: param_names.get(i), value: type_args.get(i)))
        i = i + 1
    }
}

fn monomorphize_struct(self, stmt_idx: Int, concrete_name: Str, type_args: *ArrayList<Str>) {
    let stmt = self.stmt_pool.get(stmt_idx)
    let old_type_map = self.current_type_map
    self.current_type_map = ArrayList<LLVMStrMapEntry>(self.allocator)
    self.setup_current_type_map(&stmt.struct_type_params, type_args)

    let field_count = stmt.struct_fields.length()
    let named_ty = LLVMStructCreateNamed(self.ctx, concrete_name)
    if field_count > 0 {
        var field_types = ArrayList<Int>(self.allocator)
        var fi = 0
        while fi < field_count {
            let f = stmt.struct_fields.get(fi)
            let fty = self.map_type(f.ftype)
            if fty == self.void_type || fty == (0 as *Void) {
                field_types.push((self.int64_type as Int))
            } else {
                field_types.push((fty as Int))
            }
            fi = fi + 1
        }
        LLVMStructSetBody(named_ty, field_types.data as *Void, field_count, false)
    }

    self.struct_cache_names.push(concrete_name)
    self.struct_cache_types.push((named_ty as Int))
    self.struct_cache_field_counts.push(field_count)

    self.current_type_map = old_type_map

    self.monomorphize_methods_for_struct(stmt.struct_name, concrete_name, &stmt.struct_type_params, type_args)
}

fn monomorphize_enum(self, stmt_idx: Int, concrete_name: Str, type_args: *ArrayList<Str>) {
    let stmt = self.stmt_pool.get(stmt_idx)
    let old_type_map = self.current_type_map
    self.current_type_map = ArrayList<LLVMStrMapEntry>(self.allocator)
    self.setup_current_type_map(&stmt.enum_type_params, type_args)

    var has_payload = false
    var vi = 0
    while vi < stmt.enum_variants.length() {
        let v = stmt.enum_variants.get(vi)
        if v.params.length() > 0 { has_payload = true }
        vi = vi + 1
    }

    if has_payload {
        let named_ty = LLVMStructCreateNamed(self.ctx, concrete_name)
        var field_types = ArrayList<Int>(self.allocator)
        field_types.push((self.int8_type as Int))  // tag
        let payload_ty = LLVMArrayType(self.int64_type, 16)
        field_types.push((payload_ty as Int))
        LLVMStructSetBody(named_ty, field_types.data as *Void, 2, false)

        self.enum_cache_names.push(concrete_name)
        self.enum_cache_types.push((named_ty as Int))
        self.enum_has_payload.push(true)
    } else {
        self.enum_cache_names.push(concrete_name)
        self.enum_cache_types.push((self.int64_type as Int))
        self.enum_has_payload.push(false)
    }

    self.current_type_map = old_type_map

    self.monomorphize_methods_for_struct(stmt.enum_name, concrete_name, &stmt.enum_type_params, type_args)
}

fn substitute_type_params(self, type_name: Str, param_names: *ArrayList<Str>, arg_types: *ArrayList<Str>) -> Str {
    if param_names.length() == 0 { return type_name }
    var result = type_name
    var i = 0
    while i < param_names.length() {
        let pn = param_names.get(i)
        let arg = arg_types.get(i)
        if self.str_contains(result, pn[0]) {
            var ri = 0
            var new_res = ""
            var pn_len = strlen(pn)
            while ri < strlen(result) {
                var matches = true
                var mi = 0
                while mi < pn_len {
                    if (ri + mi) >= strlen(result) { matches = false; break }
                    if result[ri + mi] != pn[mi] { matches = false; break }
                    mi = mi + 1
                }
                if matches {
                    new_res = new_res + arg
                    ri = ri + pn_len
                } else {
                    new_res = new_res + char_to_str(result[ri])
                    ri = ri + 1
                }
            }
            result = new_res
        }
        i = i + 1
    }
    return result
}

fn is_monomorphized_name(self, name: Str) -> Bool {
    let len = strlen(name)
    if len > 10 && name[0..10] == "ArrayList_" { return true }
    if len > 8 && name[0..8] == "HashMap_" { return true }
    if len > 14 && name[0..14] == "StringBuilder_" { return true }
    if len > 7 && name[0..7] == "Result_" { return true }
    if len > 9 && name[0..9] == "optional_" { return true }
    return false
}

fn monomorphize_methods_for_struct(self, base_struct_name: Str, concrete_name: Str, param_names: *ArrayList<Str>, type_args: *ArrayList<Str>) {
    var si = 0
    while si < self.stmt_pool.length() {
        let s = self.stmt_pool.get(si)
        if s.kind == StmtKind.sk_impl_block && s.impl_struct_name == base_struct_name {
            var j = 0
            while j < s.impl_methods.length() {
                let m_idx = s.impl_methods.get(j)
                let m_node = self.stmt_pool.get(m_idx)
                let method_name = m_node.func_name
                let is_init = (method_name == "init") || (m_node.func_return_type == base_struct_name) || (m_node.func_return_type == "*" + base_struct_name) || (m_node.func_return_type == "&" + base_struct_name)
                let mangled_fn = concrete_name + "_" + method_name

                var ret = m_node.func_return_type
                if param_names.length() > 0 {
                    ret = self.substitute_type_params(ret, param_names, type_args)
                }
                if is_init { ret = concrete_name }
                
                // Register method type info
                self.func_type_names.push(mangled_fn)
                self.func_type_returns.push(ret)
                
                var param_count = m_node.func_params.length()
                if is_init {
                    param_count = param_count - 1
                }
                self.func_param_counts.push(param_count)
                
                var pts = ""
                var pi = 0
                while pi < m_node.func_params.length() {
                    let p = m_node.func_params.get(pi)
                    if is_init && p.name == "self" {
                        pi = pi + 1
                        continue
                    }
                    if strlen(pts) > 0 { pts = pts + "," }
                    var ptype_str = p.ptype
                    if p.name == "self" {
                        ptype_str = "*" + concrete_name
                    } else if param_names.length() > 0 {
                        ptype_str = self.substitute_type_params(ptype_str, param_names, type_args)
                    }
                    pts = pts + ptype_str
                    pi = pi + 1
                }
                self.func_type_param_types.push(pts)
                
                // Define LLVM function — clear type_map so non-generic struct types
                // (e.g. SymbolTable) are resolved from struct_cache, not substituted
                let saved_outer_type_map = self.current_type_map
                self.current_type_map = ArrayList<LLVMStrMapEntry>(self.allocator)
                let fn_val = self.lookup_or_create_func(mangled_fn)
                self.current_type_map = saved_outer_type_map
                if fn_val != (0 as *Void) {
                    // Save builder insertion point and context variables
                    let saved_func = self.cur_func
                    let saved_func_name = self.cur_func_name
                    let saved_block = self.cur_block
                    let saved_method_is_init = self.cur_method_is_init
                    let saved_self_alloca = self.cur_self_alloca
                    let saved_struct_type = self.cur_struct_type
                    let saved_last_was_term = self.last_was_term
                    let saved_local_alloca_names = self.local_alloca_names
                    let saved_local_alloca_vals = self.local_alloca_vals
                    let saved_local_alloca_types = self.local_alloca_types
                    let saved_local_alloca_type_strs = self.local_alloca_type_strs
                    let saved_local_alloca_decls = self.local_alloca_decls
                    let saved_loop_cond = self.loop_cond_block
                    let saved_loop_merge = self.loop_merge_block
                    let saved_ip = LLVMGetInsertBlock(self.builder)
                    
                    self.emit_func_body_mono(m_idx, fn_val, concrete_name, param_names, type_args)
                    
                    // Restore context
                    self.cur_func = saved_func
                    self.cur_func_name = saved_func_name
                    self.cur_block = saved_block
                    self.cur_method_is_init = saved_method_is_init
                    self.cur_self_alloca = saved_self_alloca
                    self.cur_struct_type = saved_struct_type
                    self.last_was_term = saved_last_was_term
                    self.local_alloca_names = saved_local_alloca_names
                    self.local_alloca_vals = saved_local_alloca_vals
                    self.local_alloca_types = saved_local_alloca_types
                    self.local_alloca_type_strs = saved_local_alloca_type_strs
                    self.local_alloca_decls = saved_local_alloca_decls
                    self.loop_cond_block = saved_loop_cond
                    self.loop_merge_block = saved_loop_merge
                    if saved_ip != (0 as *Void) {
                        LLVMPositionBuilderAtEnd(self.builder, saved_ip)
                    }
                }
                
                j = j + 1
            }
        }
        si = si + 1
    }
}

fn emit_func_body_mono(self, stmt_idx: Int, fn_val: *Void, struct_name: Str, param_names: *ArrayList<Str>, type_args: *ArrayList<Str>) {
    let stmt = self.stmt_pool.get(stmt_idx)
    if fn_val == (0 as *Void) { return }
    self.cur_func = fn_val
    self.cur_func_name = struct_name + "_" + stmt.func_name
    self.cur_block = LLVMAppendBasicBlockInContext(self.ctx, self.cur_func, "mono_entry")
    LLVMPositionBuilderAtEnd(self.builder, self.cur_block)
    self.last_was_term = false
    self.local_alloca_names = ArrayList<Str>(self.allocator)
    self.local_alloca_vals = ArrayList<Int>(self.allocator)
    self.local_alloca_types = ArrayList<Int>(self.allocator)
    self.local_alloca_type_strs = ArrayList<Str>(self.allocator)
    self.local_alloca_decls = ArrayList<Int>(self.allocator)
    self.loop_cond_block = (0 as *Void)
    self.loop_merge_block = (0 as *Void)

    let is_init = (stmt.func_name == "init") || (stmt.func_return_type == struct_name) || (stmt.func_return_type == "*" + struct_name) || (stmt.func_return_type == "&" + struct_name)
    self.cur_method_is_init = is_init
    self.cur_self_alloca = (0 as *Void)
    self.cur_struct_type = (0 as *Void)
    if is_init {
        self.cur_struct_type = self.map_type(struct_name)
    }

    // Set up type map for generic substitution
    let old_type_map = self.current_type_map
    self.current_type_map = ArrayList<LLVMStrMapEntry>(self.allocator)
    self.setup_current_type_map(param_names, type_args)

    var pi = 0
    while pi < stmt.func_params.length() {
        let param = stmt.func_params.get(pi)
        var ptype_str = param.ptype
        if ptype_str != "self" && param.name != "self" {
            ptype_str = self.substitute_type_params(ptype_str, param_names, type_args)
        }
        var param_llvm_type = self.map_type(ptype_str)
        var param_type_str = ptype_str
        
        if is_init && param.name == "self" {
            param_llvm_type = self.cur_struct_type
            param_type_str = struct_name
            let alloca_val = LLVMBuildAlloca(self.builder, param_llvm_type, "self")
            LLVMBuildStore(self.builder, LLVMConstNull(param_llvm_type), alloca_val)
            self.cur_self_alloca = alloca_val
            
            self.local_alloca_names.push("self")
            self.local_alloca_vals.push((alloca_val as Int))
            self.local_alloca_types.push((param_llvm_type as Int))
            self.local_alloca_type_strs.push(param_type_str)
            self.local_alloca_decls.push(stmt_idx)
            pi = pi + 1
            continue
        }
        
        var param_val: *Void = (0 as *Void)
        if is_init {
            param_val = LLVMGetParam(self.cur_func, pi - 1)
        } else {
            param_val = LLVMGetParam(self.cur_func, pi)
        }
        
        if param.name == "self" {
            param_llvm_type = self.map_type("*" + struct_name)
            param_type_str = "*" + struct_name
        }
        let alloca_val = LLVMBuildAlloca(self.builder, param_llvm_type, param.name)
        // Store directly for Kai functions (two-tier ABI pass-by-value)
        LLVMBuildStore(self.builder, param_val, alloca_val)
        self.local_alloca_names.push(param.name)
        self.local_alloca_vals.push((alloca_val as Int))
        self.local_alloca_types.push((param_llvm_type as Int))
        self.local_alloca_type_strs.push(param_type_str)
        self.local_alloca_decls.push(stmt_idx)
        pi = pi + 1
    }

    self.gen_stmt(stmt.func_body)
    if !self.last_was_term {
        if is_init {
            let loaded_self = LLVMBuildLoad2(self.builder, self.cur_struct_type, self.cur_self_alloca, "")
            LLVMBuildRet(self.builder, loaded_self)
        } else {
            let ret_type_str = self.get_func_return_type(self.cur_func_name)
            let ret_type = self.map_type(ret_type_str)
            if ret_type == self.void_type || ret_type == (0 as *Void) {
                LLVMBuildRetVoid(self.builder)
            } else {
                LLVMBuildRet(self.builder, LLVMConstNull(ret_type))
            }
        }
    }

    // Restore type map
    self.current_type_map = old_type_map
}

fn gen_expr_address(self, expr_idx: Int) -> *Void {
    let expr = self.expr_pool.get(expr_idx)
    if expr.kind == ExprKind.ek_identifier {
        let name = expr.ident_name
        var alloca = self.find_alloca(name)
        if alloca == (0 as *Void) {
            alloca = self.find_alloca_by_idx(-1, name)
        }
        return alloca
    }
    if expr.kind == ExprKind.ek_field_access {
        let base_val = self.gen_expr(expr.field_expr)
        if base_val == (0 as *Void) { return (0 as *Void) }
        var base_type = self.get_expr_type(expr.field_expr)
        var clean_base_type = base_type
        while strlen(clean_base_type) > 0 && (clean_base_type[0] == Char(42) || clean_base_type[0] == Char(38)) {
            clean_base_type = clean_base_type[1..strlen(clean_base_type)]
        }
        if strlen(clean_base_type) >= 4 && clean_base_type[0..4] == "mut " {
            clean_base_type = clean_base_type[4..strlen(clean_base_type)]
        }
        let struct_ty = self.map_type(clean_base_type)
        if struct_ty == (0 as *Void) || struct_ty == self.void_type {
            return (0 as *Void)
        }
        var base_ptr = base_val
        let base_llvm_ty = LLVMTypeOf(base_val)
        let base_kind = LLVMGetTypeKind(base_llvm_ty)
        if base_kind == LLVMStructTypeKind {
            let tmp = LLVMBuildAlloca(self.builder, struct_ty, ".tmp.field")
            LLVMBuildStore(self.builder, base_val, tmp)
            base_ptr = tmp
        }
        var field_idx = -1
        var found_field = false
        var struct_decl_idx = self.find_struct_decl(clean_base_type)
        if struct_decl_idx >= 0 {
            let s = self.stmt_pool.get(struct_decl_idx)
            var fii = 0
            while fii < s.struct_fields.length() {
                if s.struct_fields.get(fii).name == expr.field_name {
                    field_idx = fii
                    found_field = true
                    break
                }
                fii = fii + 1
            }
        }
        if !found_field { return (0 as *Void) }
        return LLVMBuildStructGEP2(self.builder, struct_ty, base_ptr, field_idx, expr.field_name)
    }
    if expr.kind == ExprKind.ek_index {
        let base_val = self.gen_expr(expr.idx_expr)
        let idx_val = self.gen_expr(expr.idx_index)
        if base_val == (0 as *Void) || idx_val == (0 as *Void) { return (0 as *Void) }
        let base_ty = LLVMTypeOf(base_val)
        let base_kind = LLVMGetTypeKind(base_ty)
        if base_kind == LLVMPointerTypeKind {
            let el_type_str = self.get_expr_type(expr.idx_expr)
            var el_ty = self.map_type(el_type_str)
            while strlen(el_type_str) > 0 && (el_type_str[0] == Char(42) || el_type_str[0] == Char(38)) {
                el_ty = self.map_type(el_type_str[1..strlen(el_type_str)])
            }
            return LLVMBuildGEP2(self.builder, el_ty, base_val, &idx_val as *Void, 1, "")
        }
    }
    return self.gen_expr(expr_idx)
}

fn decl_name_matches(self, decl_name: Str, ident_name: Str) -> Bool {
    let dl = strlen(decl_name)
    let il = strlen(ident_name)
    if dl < il { return false }
    if dl == il {
        unsafe { return strcmp(decl_name, ident_name) == 0 }
    }
    let suffix = decl_name[(dl - il)..dl]
    unsafe {
        if strcmp(suffix, ident_name) != 0 { return false }
    }
    let prev_char = decl_name[dl - il - 1]
    return prev_char == Char(95) || prev_char == Char(46)
}


} // End of impl LLVMCodegen

fn llvm_str_eq(a: Str, b: Str) -> Bool {
    let al = strlen(a)
    let bl = strlen(b)
    if al != bl { return false }
    var i = 0
    while i < al {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}


fn llvm_type_map_find(arr: *ArrayList<LLVMStrMapEntry>, key: Str) -> Int {
    var i = arr.length() - 1
    while i >= 0 {
        if llvm_str_eq(arr.get(i).key, key) { return i }
        i = i - 1
    }
    return -1
}

fn llvm_type_map_get(arr: *ArrayList<LLVMStrMapEntry>, key: Str) -> Str {
    let idx = llvm_type_map_find(arr, key)
    if idx < 0 { return "" }
    return arr.get(idx).value
}

fn llvm_type_map_put(arr: *ArrayList<LLVMStrMapEntry>, key: Str, value: Str) {
    arr.push(LLVMStrMapEntry(key: key, value: value))
}

fn llvm_strlist_find(arr: *ArrayList<Str>, key: Str) -> Int {
    var i = 0
    while i < arr.length() {
        if llvm_str_eq(arr.get(i), key) { return i }
        i = i + 1
    }
    return -1
}
