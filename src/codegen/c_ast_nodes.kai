//== 10. CDeclNode Constructors

fn cdecl_new_func(name: Str, ret_type: Str, params: ArrayList<Str>, is_extern: Bool, is_vararg: Bool) -> CDeclNode {
    var empty_stmts = ArrayList<Int>(data: 0 as *Int, len: 0, cap: 0, allocator: 0 as *KaiAllocator)
    var empty_strs = ArrayList<Str>(data: 0 as *Str, len: 0, cap: 0, allocator: 0 as *KaiAllocator)
    return CDeclNode(
        is_function: true, func_ret: ctype_new(ret_type, 0, false, false), func_name: name,
        func_params: params, func_vararg: is_vararg, func_body: empty_stmts,
        is_extern: is_extern, var_type: ctype_void(), var_name: "", var_init: -1,
        is_struct: false, struct_name: "", struct_fields: empty_strs,
        is_enum: false, enum_name: "", enum_variants: empty_strs,
        is_tagged_enum: false, tagged_name: "", tagged_variants: empty_strs,
        is_tagged_union_struct: false,
        is_typedef: false, typedef_alias: "", typedef_def: ctype_void()
    )
}

