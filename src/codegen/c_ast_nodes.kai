        kind: CExprKind.ck_float_lit, int_val: "", float_val: val, str_val: "", char_val: "", bool_val: false,
        ident_name: "", binop_left: -1, binop_right: -1, binop_op: "", unop_operand: -1, unop_op: "", is_prefix: false,
        call_func: -1, call_args: args, callee_name: "", field_expr: -1, field_name: "", idx_expr: -1, idx_index: -1,
        cast_type: ctype_void(), cast_expr: -1, compound_type: ctype_void(), compound_fields: fields,
        tern_cond: -1, tern_then: -1, tern_else: -1, sizeof_type: ctype_void(), sizeof_expr: -1,
