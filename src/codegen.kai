//== External C Runtime Functions

extern fn strcmp(s1: Str, s2: Str) -> Int
extern fn exit(code: Int)
extern fn get_exe_dir(buf: *Char, max_len: Int) -> Int
extern fn strstr(haystack: Str, needle: Str) -> *Char
extern fn malloc(size: Int) -> *Char


extern fn concatAlloc(left: Str, right: Str) -> Str

//== Type Map Entry (simple key-value pair for type/function lookups)

struct StrMapEntry {
    key: Str
    value: Str
}

struct Codegen {
    allocator: *KaiAllocator
    stmt_pool: *ArrayList<StmtNode>
    expr_pool: *ArrayList<ExprNode>
    pattern_pool: *ArrayList<PatternNode>
    import_resolver: *ImportResolver
    pool: *StringPool

    //== Legacy string-based accumulators
    output: StringBuilder
    struct_decls: StringBuilder
    func_decls: StringBuilder

    cur_func_name: Str
    cur_return_type: Str
    cur_method_is_init: Bool

    func_types: ArrayList<StrMapEntry>
    var_types: ArrayList<StrMapEntry>
    block_stack: ArrayList<Int>

    generic_struct_decls: ArrayList<StrMapEntry>
    generic_enum_decls: ArrayList<StrMapEntry>
    generic_func_decls: ArrayList<StrMapEntry>
    generic_impl_blocks: ArrayList<StrMapEntry>
    monomorphized_types: ArrayList<Str>
    current_type_map: ArrayList<StrMapEntry>
    enum_decls: ArrayList<StrMapEntry>
    result_definitions: ArrayList<Str>
    defer_stack: ArrayList<Int>
    defer_depths: ArrayList<Int>
    func_param_types: ArrayList<StrMapEntry>
}

//== Type Map Helpers

fn type_map_find(arr: *ArrayList<StrMapEntry>, key: Str) -> Int {
    var i = arr.length() - 1
    while i >= 0 {
        if arr.get(i).key == key {
            return i
        }
        i = i - 1
    }
    return -1
}

fn type_map_get(arr: *ArrayList<StrMapEntry>, key: Str) -> Str {
    let idx = type_map_find(arr, key)
    if idx < 0 { return "" }
    return arr.get(idx).value
}

fn type_map_put(arr: *ArrayList<StrMapEntry>, key: Str, value: Str) {
    arr.push(StrMapEntry(key: key, value: value))
}

fn strlist_find(arr: *ArrayList<Str>, key: Str) -> Int {
    var i = 0
    while i < arr.length() {
        if arr.get(i) == key {
            return i
        }
        i = i + 1
    }
    return -1
}

//== Codegen Implementation

impl Codegen {

//== Init Return Helper

fn add_init_return(self, body_str: Str, struct_name: Str) -> Str {
    let self_decl = "    " + struct_name + " self = (" + struct_name + "){0};\n"
    let body_len = length(body_str)
    var stripped_body = body_str[2..body_len - 1]
    
    // Check if the stripped body already ends with return self;
    var ends_with_return = false
    unsafe {
        let ret_ptr = strstr(stripped_body, "return self;")
        if ret_ptr != (0 as *Char) {
            let offset = (ret_ptr as Int) - (stripped_body as Int)
            if offset >= length(stripped_body) - 20 {
                ends_with_return = true
            }
        }
    }
    
    if ends_with_return {
        return "{\n" + self_decl + stripped_body + "}"
    }
    let self_ret = "    return self;\n}"
    return "{\n" + self_decl + stripped_body + self_ret
}

fn init(self, allocator: *KaiAllocator, stmt_pool: *ArrayList<StmtNode>, expr_pool: *ArrayList<ExprNode>, pattern_pool: *ArrayList<PatternNode>, import_resolver: *ImportResolver, pool: *StringPool) {
    self.allocator = allocator
    self.stmt_pool = stmt_pool
    self.expr_pool = expr_pool
    self.pattern_pool = pattern_pool
    self.import_resolver = import_resolver
    self.pool = pool
    self.output = StringBuilder(allocator)
    self.struct_decls = StringBuilder(allocator)
    self.func_decls = StringBuilder(allocator)
    self.cur_func_name = ""
    self.cur_return_type = ""
    self.cur_method_is_init = false
    self.func_types = ArrayList<StrMapEntry>(allocator)
    self.var_types = ArrayList<StrMapEntry>(allocator)
    self.block_stack = ArrayList<Int>(allocator)
    self.generic_struct_decls = ArrayList<StrMapEntry>(allocator)
    self.generic_enum_decls = ArrayList<StrMapEntry>(allocator)
    self.generic_func_decls = ArrayList<StrMapEntry>(allocator)
    self.generic_impl_blocks = ArrayList<StrMapEntry>(allocator)
    self.monomorphized_types = ArrayList<Str>(allocator)
    self.current_type_map = ArrayList<StrMapEntry>(allocator)
    self.enum_decls = ArrayList<StrMapEntry>(allocator)
    self.result_definitions = ArrayList<Str>(allocator)
    self.defer_stack = ArrayList<Int>(allocator)
    self.defer_depths = ArrayList<Int>(allocator)
    self.func_param_types = ArrayList<StrMapEntry>(allocator)
}

//== Type Query Helpers

fn is_pointer_type(self, t: Str) -> Bool {
    if length(t) == 0 { return false }
    if t[0] == Char(42) || t[0] == Char(38) { return true }
    if t == "Str" { return true }
    if length(t) >= 2 && t[0..2] == "[]" { return true }
    return false
}

//== Type Mapping (Kai -> C)

fn strip_module_prefix(self, name: Str) -> Str {
    var last_dot = -1
    var i = 0
    while i < length(name) {
        if name[i] == Char(46) { // '.'
            last_dot = i
        }
        i = i + 1
    }
    if last_dot >= 0 {
        return name[last_dot + 1..length(name)]
    }
    return name
}

fn map_type(self, type_name: Str) -> Str {
    if length(type_name) == 0 {
        return "void"
    }

    var resolved_type = self.strip_module_prefix(type_name)
    if self.current_type_map.length() > 0 {
        resolved_type = self.substitute_generic_type(type_name)
    }

    if length(resolved_type) > 0 && resolved_type[0] == Char(40) { // starts with '(' indicating a tuple type (T1, T2, ...)
        let clean_name = "Tuple_" + self.clean_type_for_mangling(resolved_type)
        if strlist_find(&self.result_definitions, clean_name) < 0 {
            self.result_definitions.push(clean_name)
            // Parse the comma-separated types inside
            let inner_types = resolved_type[1..length(resolved_type) - 1]
            var types_list = ArrayList<Str>(self.allocator)
            var start = 0
            var i = 0
            while i < length(inner_types) {
                if inner_types[i] == Char(44) {
                    types_list.push(self.trim_spaces(inner_types[start..i]))
                    start = i + 1
                }
                i = i + 1
            }
            types_list.push(self.trim_spaces(inner_types[start..length(inner_types)]))

            var struct_str = "typedef struct " + clean_name + " " + clean_name + ";\n"
            struct_str = struct_str + "struct " + clean_name + " {\n"
            var ti = 0
            while ti < types_list.length() {
                struct_str = struct_str + "    " + self.map_type(types_list.get(ti)) + " f" + int_to_str(ti) + ";\n"
                ti = ti + 1
            }
            struct_str = struct_str + "};\n"
            let _ = self.struct_decls.append(struct_str)
        }
        return clean_name
    }

    if length(resolved_type) > 0 && resolved_type[0] == Char(63) {
        let val_type = resolved_type[1..length(resolved_type)]
        if self.is_pointer_type(val_type) {
            return self.map_type(val_type)
        }
        let clean_val = self.clean_type_for_mangling(val_type)
        let concrete_name = "Optional_" + clean_val
        if strlist_find(&self.result_definitions, concrete_name) < 0 {
            self.result_definitions.push(concrete_name)
            var struct_str = "typedef struct " + concrete_name + " " + concrete_name + ";\n"
            struct_str = struct_str + "struct " + concrete_name + " {\n"
            struct_str = struct_str + "    bool has_value;\n"
            struct_str = struct_str + "    " + self.map_type(val_type) + " value;\n"
            struct_str = struct_str + "};\n"
            let _ = self.struct_decls.append(struct_str)
        }
        return concrete_name
    }

    if self.str_contains(resolved_type, Char(33)) {
        let excl_pos = self.str_find(resolved_type, Char(33))
        let val_type = resolved_type[0..excl_pos]
        let err_type = resolved_type[excl_pos + 1..length(resolved_type)]
        let clean_val = self.clean_type_for_mangling(val_type)
        let clean_err = self.clean_type_for_mangling(err_type)
        let concrete_name = "Result_" + clean_val + "_" + clean_err
        if strlist_find(&self.result_definitions, concrete_name) < 0 {
            self.result_definitions.push(concrete_name)
            var struct_str = "typedef struct " + concrete_name + " " + concrete_name + ";\n"
            struct_str = struct_str + "struct " + concrete_name + " {\n"
            struct_str = struct_str + "    int64_t tag;\n"
            if val_type != "Void" {
                struct_str = struct_str + "    " + self.map_type(val_type) + " value;\n"
            }
            struct_str = struct_str + "};\n"
            let _ = self.struct_decls.append(struct_str)
        }
        return concrete_name
    }

    if resolved_type == "Int" || resolved_type == "i64" { return "int64_t" }
    if resolved_type == "isize" { return "intptr_t" }
    if resolved_type == "i8" { return "int8_t" }
    if resolved_type == "i32" { return "int32_t" }
    if resolved_type == "i16" { return "int16_t" }
    if resolved_type == "u8" { return "uint8_t" }
    if resolved_type == "u16" { return "uint16_t" }
    if resolved_type == "u32" { return "uint32_t" }
    if resolved_type == "u64" { return "uint64_t" }
    if resolved_type == "usize" { return "size_t" }
    if resolved_type == "Bool" { return "bool" }
    if resolved_type == "Char" { return "char" }
    if resolved_type == "Float" { return "double" }
    if resolved_type == "Void" { return "void" }
    if resolved_type == "Str" { return "const char*" }
    
    if resolved_type[0..2] == "[]" {
        let inner = resolved_type[2..length(resolved_type)]
        return self.map_type(inner) + "*"
    }

    if resolved_type[0] == Char(42) {
        if length(resolved_type) > 5 && resolved_type[0..5] == "*mut " {
            let inner = resolved_type[5..length(resolved_type)]
            if inner == "Void" { return "void*" }
            return self.map_type(inner) + "*"
        } else {
            let inner = resolved_type[1..length(resolved_type)]
            if inner == "Void" { return "void*" }
            return self.map_type(inner) + "*"
        }
    }

    if resolved_type[0] == Char(38) {
        if length(resolved_type) > 5 && resolved_type[0..5] == "&mut " {
            let inner = resolved_type[5..length(resolved_type)]
            return self.map_type(inner) + "*"
        } else {
            let inner = resolved_type[1..length(resolved_type)]
            return self.map_type(inner) + "*"
        }
    }

    if self.str_contains(resolved_type, Char(60)) {
        let lt_pos = self.str_find(resolved_type, Char(60))
        let base_name = resolved_type[0..lt_pos]
        let args_str = resolved_type[lt_pos + 1..length(resolved_type) - 1]
        var args = ArrayList<Str>(self.allocator)
        var start = 0
        var i = 0
        while i < length(args_str) {
            let c = args_str[i]
            if c == Char(44) {
                args.push(self.trim_spaces(args_str[start..i]))
                start = i + 1
            }
            i = i + 1
        }
        args.push(self.trim_spaces(args_str[start..length(args_str)]))
        var concrete_name = base_name
        var ai = 0
        while ai < args.length() {
            let raw_arg = args.get(ai)
            let clean_arg = self.clean_type_for_mangling(raw_arg)
            concrete_name = concrete_name + "_" + clean_arg
            ai = ai + 1
        }

        let struct_idx_str = type_map_get(&self.generic_struct_decls, base_name)
        if length(struct_idx_str) > 0 {
            if strlist_find(&self.monomorphized_types, concrete_name) < 0 {
                self.monomorphized_types.push(concrete_name)
                self.monomorphize_struct(self.str_to_int(struct_idx_str), concrete_name, &args)
            }
            return concrete_name
        }

        let enum_idx_str = type_map_get(&self.generic_enum_decls, base_name)
        if length(enum_idx_str) > 0 {
            if strlist_find(&self.monomorphized_types, concrete_name) < 0 {
                self.monomorphized_types.push(concrete_name)
                self.monomorphize_enum(self.str_to_int(enum_idx_str), concrete_name, &args)
            }
            return concrete_name
        }
        
        return concrete_name
    }

    return resolved_type
}

//== Generic Type Substitution

fn substitute_generic_type(self, type_name: Str) -> Str {
    let mapped = type_map_get(&self.current_type_map, type_name)
    if length(mapped) > 0 {
        return mapped
    }
    
    if type_name[0] == Char(42) {
        return "*" + self.substitute_generic_type(type_name[1..length(type_name)])
    }
    if type_name[0] == Char(38) {
        if type_name[0..5] == "&mut " {
            return "&mut " + self.substitute_generic_type(type_name[5..length(type_name)])
        }
        return "&" + self.substitute_generic_type(type_name[1..length(type_name)])
    }
    
    if self.str_contains(type_name, Char(60)) {
        let lt_pos = self.str_find(type_name, Char(60))
        let base = type_name[0..lt_pos]
        let inner = type_name[lt_pos + 1..length(type_name) - 1]
        var res = base + "<"
        var start = 0
        var i = 0
        var arg_count = 0
        while i < length(inner) {
            let c = inner[i]
            if c == Char(44) {
                let arg = self.trim_spaces(inner[start..i])
                if arg_count > 0 { res = res + ", " }
                res = res + self.substitute_generic_type(arg)
                start = i + 1
                arg_count = arg_count + 1
            }
            i = i + 1
        }
        let arg = self.trim_spaces(inner[start..length(inner)])
        if arg_count > 0 { res = res + ", " }
        res = res + self.substitute_generic_type(arg)
        res = res + ">"
        return res
    }
    
    return type_name
}

//== String Utilities

fn trim_spaces(self, s: Str) -> Str {
    var start = 0
    while start < length(s) && s[start] == Char(32) {
        start = start + 1
    }
    var end = length(s)
    while end > start && s[end - 1] == Char(32) {
        end = end - 1
    }
    return s[start..end]
}

fn clean_type_for_mangling(self, s: Str) -> Str {
    var res = ""
    var i = 0
    while i < length(s) {
        let c = s[i]
        if c == Char(42) {
            res = res + "ptr"
        } else if c == Char(38) {
            res = res + "ref"
        } else if c == Char(32) {
            res = res + "_"
        } else if c == Char(63) {
            res = res + "opt_"
        } else if c == Char(60) || c == Char(62) || c == Char(44) || c == Char(33) || c == Char(40) || c == Char(41) {
            res = res + "_"
        } else {
            res = res + char_to_str(c)
        }
        i = i + 1
    }
    return res
}

fn str_to_int(self, s: Str) -> Int {
    var res = 0
    var i = 0
    while i < length(s) {
        let c = s[i]
        if c >= Char(48) && c <= Char(57) {
            res = res * 10 + (Int(c) - 48)
        }
        i = i + 1
    }
    return res
}

//== Generic Type Inference & Monomorphization

fn infer_type_args(self, func_stmt_idx: Int, expr_idx: Int) -> ArrayList<Str> {
    let stmt = self.stmt_pool.get(func_stmt_idx)
    let expr = self.expr_pool.get(expr_idx)
    var type_args = ArrayList<Str>(self.allocator)
    
    var p_idx = 0
    while p_idx < stmt.func_type_params.length() {
        type_args.push("")
        p_idx = p_idx + 1
    }
    
    var arg_i = 0
    while arg_i < expr.func_args.length() && arg_i < stmt.func_params.length() {
        let arg = expr.func_args.get(arg_i)
        let param = stmt.func_params.get(arg_i)
        let arg_type = self.get_expr_type(arg)
        
        var ptype = param.ptype
        var atype = arg_type
        
        var done = false
        while !done {
            if length(ptype) > 0 && (ptype[0] == Char(42) || ptype[0] == Char(38)) {
                ptype = ptype[1..length(ptype)]
            } else {
                done = true
            }
        }
        done = false
        while !done {
            if length(atype) > 0 && (atype[0] == Char(42) || atype[0] == Char(38)) {
                atype = atype[1..length(atype)]
            } else {
                done = true
            }
        }
        if length(ptype) >= 4 && ptype[0..4] == "mut " {
            ptype = ptype[4..length(ptype)]
        }
        if length(atype) >= 4 && atype[0..4] == "mut " {
            atype = atype[4..length(atype)]
        }
        
        var is_param = false
        if length(ptype) == 1 && ptype[0] >= Char(65) && ptype[0] <= Char(90) {
            is_param = true
        }
        
        if is_param {
            var tp_i = 0
            while tp_i < stmt.func_type_params.length() {
                var tp_name = stmt.func_type_params.get(tp_i)
                if self.str_contains(tp_name, Char(58)) {
                    let colon_pos = self.str_find(tp_name, Char(58))
                    tp_name = tp_name[0..colon_pos]
                }
                if tp_name == ptype {
                    type_args.set(tp_i, atype)
                }
                tp_i = tp_i + 1
            }
        }
        arg_i = arg_i + 1
    }
    
    var i = 0
    while i < type_args.length() {
        if length(type_args.get(i)) == 0 {
            type_args.set(i, "Int")
        }
        i = i + 1
    }
    return type_args
}

//== Type Map Setup for Generics

fn setup_current_type_map(self, type_params: *ArrayList<Str>, type_args: *ArrayList<Str>) -> Void {
    var i = 0
    while i < type_params.length() {
        var param_name = self.trim_spaces(type_params.get(i))
        let arg_name = self.trim_spaces(type_args.get(i))
        if self.str_contains(param_name, Char(58)) { // ':' is 58
            let colon_pos = self.str_find(param_name, Char(58))
            param_name = param_name[0..colon_pos]
        }
        type_map_put(&self.current_type_map, param_name, arg_name)
        i = i + 1
    }
}

//== Struct Monomorphization

fn monomorphize_struct(self, stmt_idx: Int, concrete_name: Str, type_args: *ArrayList<Str>) -> Void {
    let stmt = self.stmt_pool.get(stmt_idx)
    let old_type_map = self.current_type_map
    self.current_type_map = ArrayList<StrMapEntry>(self.allocator)
    self.setup_current_type_map(&stmt.struct_type_params, type_args)
    let typedef_str = "typedef struct " + concrete_name + " " + concrete_name + ";\n"
    let _ = self.struct_decls.append(typedef_str)
    var body = "struct " + concrete_name + " {\n"
    var i = 0
    while i < stmt.struct_fields.length() {
        let f = stmt.struct_fields.get(i)
        let f_type = self.map_type(f.ftype)
        body = body + "    " + f_type + " " + f.name + ";\n"
        i = i + 1
    }
    body = body + "};\n"
    let _ = self.struct_decls.append(body)
    self.monomorphize_methods(stmt.struct_name, concrete_name)
    self.current_type_map = old_type_map
}

//== Enum Monomorphization

fn monomorphize_enum(self, stmt_idx: Int, concrete_name: Str, type_args: *ArrayList<Str>) -> Void {
    let stmt = self.stmt_pool.get(stmt_idx)
    let old_type_map = self.current_type_map
    self.current_type_map = ArrayList<StrMapEntry>(self.allocator)
    self.setup_current_type_map(&stmt.enum_type_params, type_args)
    let typedef_str = "typedef struct " + concrete_name + " " + concrete_name + ";\n"
    let _ = self.struct_decls.append(typedef_str)
    let tags_name = concrete_name + "_tags"
    var tags_str = "typedef enum {\n"
    var i = 0
    while i < stmt.enum_variants.length() {
        let v = stmt.enum_variants.get(i)
        tags_str = tags_str + "    " + concrete_name + "_" + v.vname + "_TAG,\n"
        i = i + 1
    }
    tags_str = tags_str + "} " + tags_name + ";\n"
    let _ = self.struct_decls.append(tags_str)
    var body = "struct " + concrete_name + " {\n"
    body = body + "    uint8_t tag;\n"
    body = body + "    union {\n"
    i = 0
    while i < stmt.enum_variants.length() {
        let v = stmt.enum_variants.get(i)
        if v.params.length() > 0 {
            body = body + "        struct {\n"
            var p_idx = 0
            while p_idx < v.params.length() {
                let p = v.params.get(p_idx)
                body = body + "            " + self.map_type(p.ptype) + " " + p.name + ";\n"
                p_idx = p_idx + 1
            }
            body = body + "        } " + v.vname + ";\n"
        }
        i = i + 1
    }
    body = body + "    } payload;\n"
    body = body + "};\n"
    let _ = self.struct_decls.append(body)
    self.monomorphize_methods(stmt.enum_name, concrete_name)
    self.current_type_map = old_type_map
}

//== Method Monomorphization

fn monomorphize_methods(self, base_struct_name: Str, concrete_struct_name: Str) -> Void {
    var idx = 0
    while idx < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(idx)
        if stmt.kind == StmtKind.sk_impl_block && stmt.impl_struct_name == base_struct_name {
            var j = 0
            while j < stmt.impl_methods.length() {
                let m_idx = stmt.impl_methods.get(j)
                let m_node = self.stmt_pool.get(m_idx)
                let method_name = m_node.func_name
                let is_init = (method_name == "init") || (m_node.func_return_type == base_struct_name) || (m_node.func_return_type == "*" + base_struct_name) || (m_node.func_return_type == "&" + base_struct_name)
                var ret_type = ""
                if is_init {
                    ret_type = concrete_struct_name
                } else {
                    ret_type = self.map_type(m_node.func_return_type)
                }
                var params_str = ""
                if !is_init {
                    params_str = concrete_struct_name + "* self"
                }
                var p_idx = 0
                while p_idx < m_node.func_params.length() {
                    let p = m_node.func_params.get(p_idx)
                    if p.name != "self" {
                        if length(params_str) > 0 {
                            params_str = params_str + ", "
                        }
                        params_str = params_str + self.map_type(p.ptype) + " " + p.name
                    }
                    p_idx = p_idx + 1
                }
                if length(params_str) == 0 {
                    params_str = "void"
                }
                let mangled_fn_name = concrete_struct_name + "_" + method_name
                var concrete_ret = m_node.func_return_type
                if self.current_type_map.length() > 0 {
                    concrete_ret = self.substitute_generic_type(concrete_ret)
                }
                type_map_put(&self.func_types, mangled_fn_name, concrete_ret)
                let old_fn = self.cur_func_name
                let old_ret = self.cur_return_type
                let old_init = self.cur_method_is_init
                self.cur_func_name = mangled_fn_name
                if is_init {
                    self.cur_return_type = base_struct_name
                } else {
                    self.cur_return_type = m_node.func_return_type
                }
                self.cur_method_is_init = is_init
                
                let old_var_len = self.var_types.length()
                if is_init {
                    type_map_put(&self.var_types, "self", concrete_struct_name)
                } else {
                    type_map_put(&self.var_types, "self", "*" + concrete_struct_name)
                }
                var p_idx2 = 0
                while p_idx2 < m_node.func_params.length() {
                    let p = m_node.func_params.get(p_idx2)
                    if p.name != "self" {
                        type_map_put(&self.var_types, p.name, p.ptype)
                    }
                    p_idx2 = p_idx2 + 1
                }
                
                var body_str = self.gen_stmt(m_node.func_body)
                
                while self.var_types.length() > old_var_len {
                    let _ = self.var_types.pop()
                }
                
                if is_init {
                    body_str = self.add_init_return(body_str, concrete_struct_name)
                }
                let proto = ret_type + " " + mangled_fn_name + "(" + params_str + ");\n"
                let impl_str = ret_type + " " + mangled_fn_name + "(" + params_str + ") " + body_str + "\n"
                let _ = self.func_decls.append(proto)
                let _ = self.output.append(impl_str)
                self.cur_func_name = old_fn
                self.cur_return_type = old_ret
                self.cur_method_is_init = old_init
                j = j + 1
            }
        }
        idx = idx + 1
    }
}

//== Function Monomorphization

fn monomorphize_func(self, func_stmt_idx: Int, mangled_name: Str, type_args: *ArrayList<Str>) -> Void {
    if strlist_find(&self.monomorphized_types, mangled_name) >= 0 {
        return
    }
    self.monomorphized_types.push(mangled_name)
    let stmt = self.stmt_pool.get(func_stmt_idx)
    let old_type_map = self.current_type_map
    self.current_type_map = ArrayList<StrMapEntry>(self.allocator)
    self.setup_current_type_map(&stmt.func_type_params, type_args)
    
    let concrete_ret_type = self.substitute_generic_type(stmt.func_return_type)
    let mapped_ret = self.map_type(concrete_ret_type)
    
    var params_str = ""
    var p_idx = 0
    while p_idx < stmt.func_params.length() {
        let p = stmt.func_params.get(p_idx)
        if p_idx > 0 {
            params_str = params_str + ", "
        }
        let concrete_ptype = self.substitute_generic_type(p.ptype)
        params_str = params_str + self.map_type(concrete_ptype) + " " + p.name
        p_idx = p_idx + 1
    }
    if length(params_str) == 0 {
        params_str = "void"
    }
    
    type_map_put(&self.func_types, mangled_name, concrete_ret_type)
    
    let old_fn = self.cur_func_name
    let old_ret = self.cur_return_type
    let old_init = self.cur_method_is_init
    self.cur_func_name = mangled_name
    self.cur_return_type = concrete_ret_type
    self.cur_method_is_init = false
    
    let old_var_len = self.var_types.length()
    var p_reg = 0
    while p_reg < stmt.func_params.length() {
        let p = stmt.func_params.get(p_reg)
        let concrete_ptype = self.substitute_generic_type(p.ptype)
        type_map_put(&self.var_types, p.name, concrete_ptype)
        p_reg = p_reg + 1
    }
    let old_block_stack = self.block_stack
    let old_defer_stack = self.defer_stack
    let old_defer_depths = self.defer_depths
    self.block_stack = ArrayList<Int>(self.allocator)
    self.defer_stack = ArrayList<Int>(self.allocator)
    self.defer_depths = ArrayList<Int>(self.allocator)
    
    let body_str = self.gen_stmt(stmt.func_body)
    
    self.block_stack = old_block_stack
    self.defer_stack = old_defer_stack
    self.defer_depths = old_defer_depths
    
    while self.var_types.length() > old_var_len {
        let _ = self.var_types.pop()
    }
    
    let proto = mapped_ret + " " + mangled_name + "(" + params_str + ");\n"
    let impl_str = mapped_ret + " " + mangled_name + "(" + params_str + ") " + body_str + "\n"
    let _ = self.func_decls.append(proto)
    let _ = self.output.append(impl_str)
    
    self.cur_func_name = old_fn
    self.cur_return_type = old_ret
    self.cur_method_is_init = old_init
    self.current_type_map = old_type_map
}

fn extract_first_type_arg(self, type_name: Str) -> Str {
    var start = -1
    var end = -1
    var i = 0
    while i < length(type_name) {
        let c = type_name[i]
        if c == Char(60) { // '<' is 60
            start = i + 1
        } else if c == Char(44) { // ',' is 44
            end = i
            break
        } else if c == Char(62) { // '>' is 62
            end = i
            break
        }
        i = i + 1
    }
    if start >= 0 && end >= 0 {
        return type_name[start..end]
    }
    return "Int"
}

//== Function Type Registry

fn build_func_types(self) -> Void {
    var i = 0
    while i < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(i)
        if stmt.kind == StmtKind.sk_func_decl {
            type_map_put(&self.func_types, stmt.func_name, stmt.func_return_type)
            var p_i = 0
            while p_i < stmt.func_params.length() {
                let p = stmt.func_params.get(p_i)
                let p_key = stmt.func_name + "_param_" + int_to_str(p_i)
                type_map_put(&self.func_param_types, p_key, p.ptype)
                p_i = p_i + 1
            }
        }
        if stmt.kind == StmtKind.sk_extern {
            type_map_put(&self.func_types, stmt.extern_name, stmt.extern_return)
            var p_i = 0
            while p_i < stmt.extern_params.length() {
                let p = stmt.extern_params.get(p_i)
                let p_key = stmt.extern_name + "_param_" + int_to_str(p_i)
                type_map_put(&self.func_param_types, p_key, p.ptype)
                p_i = p_i + 1
            }
        }
        if stmt.kind == StmtKind.sk_impl_block {
            let struct_name = stmt.impl_struct_name
            var j = 0
            while j < stmt.impl_methods.length() {
                let m_idx = stmt.impl_methods.get(j)
                let m_node = self.stmt_pool.get(m_idx)
                let key = struct_name + "_" + m_node.func_name
                var ret = m_node.func_return_type
                if m_node.func_name == "init" {
                    ret = struct_name
                }
                type_map_put(&self.func_types, key, ret)
                var p_i = 0
                while p_i < m_node.func_params.length() {
                    let p = m_node.func_params.get(p_i)
                    let p_key = key + "_param_" + int_to_str(p_i)
                    type_map_put(&self.func_param_types, p_key, p.ptype)
                    p_i = p_i + 1
                }
                j = j + 1
            }
        }
        if stmt.kind == StmtKind.sk_struct_decl {
            let struct_name = stmt.struct_name
            var ti = 0
            while ti < stmt.struct_trait_impls.length() {
                let impl_idx = stmt.struct_trait_impls.get(ti)
                let impl_node = self.stmt_pool.get(impl_idx)
                var j = 0
                while j < impl_node.impl_methods.length() {
                    let m_idx = impl_node.impl_methods.get(j)
                    let m_node = self.stmt_pool.get(m_idx)
                    let key = struct_name + "_" + m_node.func_name
                    var ret = m_node.func_return_type
                    if m_node.func_name == "init" {
                        ret = struct_name
                    }
                    type_map_put(&self.func_types, key, ret)
                    var p_i = 0
                    while p_i < m_node.func_params.length() {
                        let p = m_node.func_params.get(p_i)
                        let p_key = key + "_param_" + int_to_str(p_i)
                        type_map_put(&self.func_param_types, p_key, p.ptype)
                        p_i = p_i + 1
                    }
                    j = j + 1
                }
                ti = ti + 1
            }
        }
        i = i + 1
    }
}

//== Expression Type Resolution

fn get_expr_type(self, expr_idx: Int) -> Str {
    if expr_idx < 0 { return "Void" }
    let expr = self.expr_pool.get(expr_idx)
    
    if expr.kind == ExprKind.ek_literal {
        let vkind = expr.lit_vkind
        if vkind == "INT" { return "Int" }
        if vkind == "FLOAT" { return "Float" }
        if vkind == "STRING" { return "Str" }
        if vkind == "BOOL" { return "Bool" }
        if vkind == "CHAR" { return "Char" }
        return "Void"
    }
    
    if expr.kind == ExprKind.ek_identifier {
        let name = expr.ident_name
        let var_t = type_map_get(&self.var_types, name)
        if length(var_t) > 0 { return var_t }
        
        let fn_t = type_map_get(&self.func_types, name)
        if length(fn_t) > 0 { return fn_t }
        
        let first_char = name[0]
        if first_char >= Char(65) && first_char <= Char(90) {
            if expr.ident_type_args.length() > 0 {
                var full_name = name + "<"
                var tai = 0
                while tai < expr.ident_type_args.length() {
                    if tai > 0 {
                        full_name = full_name + ", "
                    }
                    full_name = full_name + expr.ident_type_args.get(tai)
                    tai = tai + 1
                }
                full_name = full_name + ">"
                return full_name
            }
            return name
        }
        
        return "Void"
    }
    
    if expr.kind == ExprKind.ek_binary_op {
        let op = expr.binop_op
        if op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" || op == "&&" || op == "||" {
            return "Bool"
        }
        return self.get_expr_type(expr.binop_left)
    }
    
    if expr.kind == ExprKind.ek_unary_op {
        let op = expr.unop_op
        if op == "!" {
            return "Bool"
        }
        return self.get_expr_type(expr.unop_operand)
    }
    
    if expr.kind == ExprKind.ek_func_call {
        let name = expr.func_name
        if name == "cast" || name == "as" {
            return expr.func_type_args.get(0)
        }
        if name == "size_of" {
            return "Int"
        }
        if name == "Char" || name == "Int" || name == "Float" || name == "Bool" {
            return name
        }
        var is_struct = false
        var s_idx = 0
        while s_idx < self.stmt_pool.length() {
            let stmt = self.stmt_pool.get(s_idx)
            if stmt.kind == StmtKind.sk_struct_decl && stmt.struct_name == name {
                is_struct = true
            }
            s_idx = s_idx + 1
        }
        if name == "ArrayList" || name == "HashMap" || name == "StringBuilder" {
            is_struct = true
        }
        if is_struct {
            if expr.func_type_args.length() > 0 {
                return name + "<" + str_array_join(expr.func_type_args, ", ") + ">"
            }
            return name
        }
        let gf_idx_str = type_map_get(&self.generic_func_decls, name)
        if length(gf_idx_str) > 0 {
            let gf_idx = self.str_to_int(gf_idx_str)
            var type_args = ArrayList<Str>(self.allocator)
            if expr.func_type_args.length() > 0 {
                var j = 0
                while j < expr.func_type_args.length() {
                    type_args.push(expr.func_type_args.get(j))
                    j = j + 1
                }
            } else {
                type_args = self.infer_type_args(gf_idx, expr_idx)
            }
            let stmt = self.stmt_pool.get(gf_idx)
            let old_type_map = self.current_type_map
            self.current_type_map = ArrayList<StrMapEntry>(self.allocator)
            self.setup_current_type_map(&stmt.func_type_params, &type_args)
            let ret_t = self.substitute_generic_type(stmt.func_return_type)
            self.current_type_map = old_type_map
            return ret_t
        }
        let fn_t = type_map_get(&self.func_types, name)
        if length(fn_t) > 0 { return fn_t }
        var si = 0
        while si < self.stmt_pool.length() {
            let s = self.stmt_pool.get(si)
            if s.kind == StmtKind.sk_extern && s.extern_name == name { return s.extern_return }
            if s.kind == StmtKind.sk_func_decl && s.func_name == name { return s.func_return_type }
            si = si + 1
        }
        return "Void"
    }
    
    if expr.kind == ExprKind.ek_field_access {
        let base_node = self.expr_pool.get(expr.field_expr)
        if base_node.kind == ExprKind.ek_identifier {
            var is_static = false
            var s_idx = 0
            while s_idx < self.stmt_pool.length() {
                let stmt = self.stmt_pool.get(s_idx)
                if (stmt.kind == StmtKind.sk_enum_decl && stmt.enum_name == base_node.ident_name) || (stmt.kind == StmtKind.sk_error_decl && stmt.error_name == base_node.ident_name) {
                    is_static = true
                }
                s_idx = s_idx + 1
            }
            if is_static {
                return base_node.ident_name
            }
        }
        let base_type = self.get_expr_type(expr.field_expr)
        var clean_type = ""
        var i = 0
        while i < length(base_type) {
            let c = base_type[i]
            if c != Char(42) && c != Char(38) {
                clean_type = clean_type + char_to_str(c)
            }
            i = i + 1
        }
        if clean_type[0..4] == "mut " {
            clean_type = clean_type[4..length(clean_type)]
        }
        var s_idx = 0
        while s_idx < self.stmt_pool.length() {
            let stmt = self.stmt_pool.get(s_idx)
            if stmt.kind == StmtKind.sk_struct_decl {
                var is_match = false
                if stmt.struct_name == clean_type {
                    is_match = true
                } else if self.str_contains(clean_type, Char(95)) { // '_' is 95
                    // Only match via underscore fallback if the struct has generic type params
                    // This prevents false matches with unrelated structs sharing a prefix
                    if stmt.struct_type_params.length() > 0 {
                        let underscore_pos = self.str_find(clean_type, Char(95))
                        let base_name = clean_type[0..underscore_pos]
                        if stmt.struct_name == base_name {
                            is_match = true
                        }
                    }
                }
                
                if is_match {
                    var f_idx = 0
                    while f_idx < stmt.struct_fields.length() {
                        let f = stmt.struct_fields.get(f_idx)
                        if f.name == expr.field_name {
                            var ftype = f.ftype
                            if self.current_type_map.length() > 0 {
                                ftype = self.substitute_generic_type(ftype)
                            }
                            return ftype
                        }
                        f_idx = f_idx + 1
                    }
                }
            }
            s_idx = s_idx + 1
        }
        return "Void"
    }
    
    if expr.kind == ExprKind.ek_index {
        let base_type = self.get_expr_type(expr.idx_expr)
        if base_type == "Str" {
            return "Char"
        }
        if length(base_type) >= 2 && base_type[0..2] == "[]" {
            return base_type[2..length(base_type)]
        }
        if length(base_type) > 0 && base_type[0] == Char(42) {
            return base_type[1..length(base_type)]
        }
        return "Void"
    }
    
    if expr.kind == ExprKind.ek_borrow {
        return "&" + self.get_expr_type(expr.borrow_expr)
    }
    
    if expr.kind == ExprKind.ek_deref {
        let base_type = self.get_expr_type(expr.deref_expr)
        if length(base_type) > 5 && base_type[0..5] == "*mut " {
            return base_type[5..length(base_type)]
        }
        if length(base_type) > 5 && base_type[0..5] == "&mut " {
            return base_type[5..length(base_type)]
        }
        if base_type[0] == Char(42) || base_type[0] == Char(38) {
            return base_type[1..length(base_type)]
        }
        return "Void"
    }
    
    if expr.kind == ExprKind.ek_struct_init {
        let sname = expr.struct_name
        let dot_pos = self.str_find(sname, Char(46))
        if dot_pos >= 0 {
            return sname[0..dot_pos]
        }
        return sname
    }
    
    if expr.kind == ExprKind.ek_method_call {
        let receiver_node = self.expr_pool.get(expr.meth_expr)
        let method_name = expr.meth_name
        
        var rec_type = self.get_expr_type(expr.meth_expr)
        var clean_type = ""
        var i = 0
        while i < length(rec_type) {
            let c = rec_type[i]
            if c != Char(42) && c != Char(38) {
                clean_type = clean_type + char_to_str(c)
            }
            i = i + 1
        }
        if clean_type[0..4] == "mut " {
            clean_type = clean_type[4..length(clean_type)]
        }
        
        var is_constructor = false
        if receiver_node.kind == ExprKind.ek_identifier {
            let r_name = receiver_node.ident_name
            let first_char = r_name[0]
            if first_char >= Char(65) && first_char <= Char(90) {
                is_constructor = true
            }
        }
        
        if method_name == "init" {
            return clean_type
        }
        
        let key = clean_type + "_" + method_name
        let ret = type_map_get(&self.func_types, key)
        if length(ret) > 0 { return ret }
        
        var clean_rec = rec_type
        var done = false
        while !done {
            if length(clean_rec) > 0 && (clean_rec[0] == Char(42) || clean_rec[0] == Char(38)) {
                clean_rec = clean_rec[1..length(clean_rec)]
            } else {
                done = true
            }
        }
        if clean_rec[0..4] == "mut " {
            clean_rec = clean_rec[4..length(clean_rec)]
        }
        
        if self.str_contains(clean_rec, Char(60)) { // '<'
            let lt_pos = self.str_find(clean_rec, Char(60))
            let base_struct = clean_rec[0..lt_pos]
            let args_str = clean_rec[lt_pos + 1..length(clean_rec) - 1]
            var args = ArrayList<Str>(self.allocator)
            var start = 0
            var ai = 0
            while ai < length(args_str) {
                let c = args_str[ai]
                if c == Char(44) {
                    args.push(self.trim_spaces(args_str[start..ai]))
                    start = ai + 1
                }
                ai = ai + 1
            }
        args.push(self.trim_spaces(args_str[start..length(args_str)]))
            
            var struct_idx = -1
            var si = 0
            while si < self.stmt_pool.length() {
                let s = self.stmt_pool.get(si)
                if s.kind == StmtKind.sk_struct_decl && s.struct_name == base_struct {
                    struct_idx = si
                }
                si = si + 1
            }
            
            if struct_idx >= 0 {
                let s_decl = self.stmt_pool.get(struct_idx)
                var temp_map = ArrayList<StrMapEntry>(self.allocator)
                var pi = 0
                while pi < s_decl.struct_type_params.length() {
                    var p_name = self.trim_spaces(s_decl.struct_type_params.get(pi))
                    if self.str_contains(p_name, Char(58)) {
                        let cp = self.str_find(p_name, Char(58))
                        p_name = p_name[0..cp]
                    }
                    let a_name = args.get(pi)
                    type_map_put(&temp_map, p_name, a_name)
                    pi = pi + 1
                }
                
                var impl_idx = 0
                while impl_idx < self.stmt_pool.length() {
                    let s_impl = self.stmt_pool.get(impl_idx)
                    if s_impl.kind == StmtKind.sk_impl_block && s_impl.impl_struct_name == base_struct {
                        var mi = 0
                        while mi < s_impl.impl_methods.length() {
                            let m_node = self.stmt_pool.get(s_impl.impl_methods.get(mi))
                            if m_node.func_name == method_name {
                                var ret_t = m_node.func_return_type
                                let old_type_map = self.current_type_map
                                self.current_type_map = temp_map
                                ret_t = self.substitute_generic_type(ret_t)
                                self.current_type_map = old_type_map
                                return ret_t
                            }
                            mi = mi + 1
                        }
                    }
                    impl_idx = impl_idx + 1
                }
            }
        }
        return "Void"
    }
    if expr.kind == ExprKind.ek_range {
        return "Range"
    }
    if expr.kind == ExprKind.ek_slice {
        if length(expr.inferred_type) > 0 {
            return expr.inferred_type
        }
        return self.get_expr_type(expr.slice_expr)
    }
    if expr.kind == ExprKind.ek_array {
        return expr.inferred_type
    }
    if expr.kind == ExprKind.ek_tuple {
        return expr.inferred_type
    }
    if expr.kind == ExprKind.ek_asm {
        return expr.inferred_type
    }
    if expr.kind == ExprKind.ek_try {
        let inner_ty = self.get_expr_type(expr.try_expr)
        let excl_pos = self.str_find(inner_ty, Char(33))
        if excl_pos >= 0 {
            return inner_ty[0..excl_pos]
        }
        return inner_ty
    }
    if expr.kind == ExprKind.ek_catch {
        let inner_ty = self.get_expr_type(expr.catch_expr)
        if length(inner_ty) > 0 && inner_ty[0] == Char(63) {
            return inner_ty[1..length(inner_ty)]
        }
        let excl_pos = self.str_find(inner_ty, Char(33))
        if excl_pos >= 0 {
            return inner_ty[0..excl_pos]
        }
        return inner_ty
    }
    return "Void"
}

//== Expression Code Generation

fn gen_expr_with_expected_type(self, expr_idx: Int, expected_type: Str) -> Str {
    if expr_idx < 0 { return "" }
    let expr = self.expr_pool.get(expr_idx)
    let actual_type = self.get_expr_type(expr_idx)
    if expr.kind == ExprKind.ek_literal && expr.lit_vkind == "NONE" {
        if length(expected_type) > 0 && expected_type[0] == Char(63) {
            let val_type = expected_type[1..length(expected_type)]
            if self.is_pointer_type(val_type) {
                return "NULL"
            }
            return "(" + self.map_type(expected_type) + "){0}"
        }
        return "NULL"
    }
    let gen_val = self.gen_expr(expr_idx)
    if length(expected_type) > 0 && expected_type[0] == Char(63) {
        let val_type = expected_type[1..length(expected_type)]
        if !self.is_pointer_type(val_type) && actual_type == val_type {
            return "(" + self.map_type(expected_type) + "){ .has_value = true, .value = " + gen_val + " }"
        }
    }
    return gen_val
}

//== Main Expression Generator

fn gen_expr(self, expr_idx: Int) -> Str {
    if expr_idx < 0 { return "" }
    let expr = self.expr_pool.get(expr_idx)
    
    if expr.kind == ExprKind.ek_try {
        let inner_ty = self.get_expr_type(expr.try_expr)
        let excl_pos = self.str_find(inner_ty, Char(33))
        let inner = self.gen_expr(expr.try_expr)
        if excl_pos < 0 {
            return inner
        }
        let val_type = inner_ty[0..excl_pos]
        let result_ctype = self.map_type(inner_ty)
        let ret_ctype = self.map_type(self.cur_return_type)
        var try_code = "({ " + result_ctype + " _kai_res = (" + inner + "); "
        try_code = try_code + "if (_kai_res.tag != 0) { "
        try_code = try_code + ret_ctype + " _kai_err_ret; _kai_err_ret.tag = _kai_res.tag; return _kai_err_ret; } "
        if val_type == "Void" {
            try_code = try_code + "0; })"
        } else {
            try_code = try_code + "_kai_res.value; })"
        }
        return try_code
    }
    
    if expr.kind == ExprKind.ek_literal {
        let vkind = expr.lit_vkind
        if vkind == "INT" {
            match expr.lit_value {
                case .tv_str(v) => {
                    let s: Str = self.pool.get(v)
                    return s + "LL"
                }
                case .tv_int(v) => { return int_to_str(v) + "LL" }
                case else => { return "0LL" }
            }
        }
        if vkind == "FLOAT" {
            match expr.lit_value {
                case .tv_str(v) => { return self.pool.get(v) }
                case else => { return "0.0" }
            }
        }
        if vkind == "STRING" {
            match expr.lit_value {
                case .tv_str(v) => {
                    return "\"" + self.escape_string(self.pool.get(v)) + "\""
                }
                case else => { return "\"\"" }
            }
        }
        if vkind == "BOOL" {
            match expr.lit_value {
                case .tv_bool(v) => {
                    if v { return "true" }
                    else { return "false" }
                }
                case .tv_str(v) => {
                    var is_true = false
                    unsafe {
                        if strcmp(self.pool.get(v), "true") == 0 {
                            is_true = true
                        }
                    }
                    if is_true { return "true" }
                    return "false"
                }
                case else => { return "false" }
            }
        }
        if vkind == "CHAR" {
            match expr.lit_value {
                case .tv_char(v) => {
                    if v == Char(10) { return "'\\n'" }
                    if v == Char(13) { return "'\\r'" }
                    if v == Char(9) { return "'\\t'" }
                    if v == Char(92) { return "'\\\\'" }
                    if v == Char(39) { return "'\\''" }
                    return "'" + char_to_str(v) + "'"
                }
                case else => { return "'\\0'" }
            }
        }
        if vkind == "NONE" {
            return "NULL"
        }
        return "0"
    }
    
    if expr.kind == ExprKind.ek_str_interp {
        // String interpolation: concatenate literal parts and formatted expression parts
        if expr.interp_parts.length() == 0 {
            return "\"\""
        }
        var result = ""
        var i = 0
        while i < expr.interp_parts.length() {
            let part = expr.interp_parts.get(i)
            var part_str = ""
            if part.kind == 0 {
                // Literal string part
                part_str = "\"" + self.escape_string(part.str_val) + "\""
            } else {
                // Expression part - generate and format based on type
                let expr_val = self.gen_expr(part.expr_idx)
                let expr_type = self.get_expr_type(part.expr_idx)
                if expr_type == "Int" {
                    part_str = "int_to_str(" + expr_val + ")"
                } else if expr_type == "Char" {
                    part_str = "char_to_str(" + expr_val + ")"
                } else if expr_type == "Bool" {
                    part_str = "((" + expr_val + ") ? \"true\" : \"false\")"
                } else if expr_type == "Str" {
                    part_str = expr_val
                } else {
                    // Default: treat as string
                    part_str = expr_val
                }
            }
            if i == 0 {
                result = part_str
            } else {
                result = "concatAlloc(" + result + ", " + part_str + ")"
            }
            i = i + 1
        }
        return result
    }
    
    if expr.kind == ExprKind.ek_identifier {
        return expr.ident_name
    }
    
    if expr.kind == ExprKind.ek_binary_op {
        let lhs = self.gen_expr(expr.binop_left)
        let rhs = self.gen_expr(expr.binop_right)
        let op = expr.binop_op
        let lhs_type = self.get_expr_type(expr.binop_left)
        let rhs_type = self.get_expr_type(expr.binop_right)
        if op == "==" || op == "!=" {
            if length(lhs_type) > 0 && lhs_type[0] == Char(63) && rhs == "NULL" {
                let val_type = lhs_type[1..length(lhs_type)]
                if self.is_pointer_type(val_type) {
                    return "(" + lhs + " " + op + " NULL)"
                }
                if op == "==" {
                    return "(!" + lhs + ".has_value)"
                }
                return "(" + lhs + ".has_value)"
            }
            if length(rhs_type) > 0 && rhs_type[0] == Char(63) && lhs == "NULL" {
                let val_type = rhs_type[1..length(rhs_type)]
                if self.is_pointer_type(val_type) {
                    return "(NULL " + op + " " + rhs + ")"
                }
                if op == "==" {
                    return "(!" + rhs + ".has_value)"
                }
                return "(" + rhs + ".has_value)"
            }
        }
        
        let lhs_node = self.expr_pool.get(expr.binop_left)
        if lhs_type == "Str" {
            if op == "+" {
                return "concatAlloc(" + lhs + ", " + rhs + ")"
            }
            if op == "==" {
                return "(strcmp(" + lhs + ", " + rhs + ") == 0)"
            }
            if op == "!=" {
                return "(strcmp(" + lhs + ", " + rhs + ") != 0)"
            }
        }
        
        if (op == "==" || op == "!=") && self.is_enum_type(lhs_type) {
            if self.enum_has_payload(lhs_type) {
                var is_ptr = false
                if lhs_type[0] == Char(42) || lhs_type[0] == Char(38) {
                    is_ptr = true
                }
                var tag_op = "."
                if is_ptr {
                    tag_op = "->"
                }
                let rhs_type = self.get_expr_type(expr.binop_right)
                var rhs_is_ptr = false
                if rhs_type[0] == Char(42) || rhs_type[0] == Char(38) {
                    rhs_is_ptr = true
                }
                var rhs_tag_op = "."
                if rhs_is_ptr {
                    rhs_tag_op = "->"
                }
                return "((" + lhs + ")" + tag_op + "tag " + op + " (" + rhs + ")" + rhs_tag_op + "tag)"
            }
        }
        
        return "(" + lhs + " " + op + " " + rhs + ")"
    }
    
    if expr.kind == ExprKind.ek_unary_op {
        let operand = self.gen_expr(expr.unop_operand)
        let op = expr.unop_op
        if op == "own" {
            return operand
        }
        return "(" + op + operand + ")"
    }
    
    if expr.kind == ExprKind.ek_func_call {
        let name = expr.func_name
        if name == "cast" || name == "as" {
            let target_type = expr.func_type_args.get(0)
            let operand_type = self.get_expr_type(expr.func_args.get(0))
            let is_target_ptr = (length(target_type) > 0 && (target_type[0] == Char(42) || target_type[0] == Char(38))) || strcmp(target_type, "Str") == 0
            let is_operand_int = strcmp(operand_type, "Int") == 0 || strcmp(operand_type, "Char") == 0 || strcmp(operand_type, "Bool") == 0
            if is_target_ptr && is_operand_int {
                return "(" + self.map_type(target_type) + ")(unsigned long long)(" + self.gen_expr(expr.func_args.get(0)) + ")"
            }
            return "(" + self.map_type(target_type) + ")(" + self.gen_expr(expr.func_args.get(0)) + ")"
        }
        if name == "size_of" {
            return "sizeof(" + self.map_type(expr.func_type_args.get(0)) + ")"
        }
        if name == "Char" || name == "Int" || name == "Float" || name == "Bool" {
            let ctype = self.map_type(name)
            let arg_val = self.gen_expr(expr.func_args.get(0))
            return "((" + ctype + ")(" + arg_val + "))"
        }
        if name == "length" {
            let arg_val = self.gen_expr(expr.func_args.get(0))
            return "strlen(" + arg_val + ")"
        }
        var is_struct = false
        var s_idx = 0
        while s_idx < self.stmt_pool.length() {
            let stmt = self.stmt_pool.get(s_idx)
            if stmt.kind == StmtKind.sk_struct_decl && stmt.struct_name == name {
                is_struct = true
            }
            s_idx = s_idx + 1
        }
        if name == "ArrayList" || name == "HashMap" || name == "StringBuilder" {
            is_struct = true
        }
        
        var fn_name = name
        var type_args = ArrayList<Str>(self.allocator)
        let gf_idx_str = type_map_get(&self.generic_func_decls, name)
        if length(gf_idx_str) > 0 {
            let gf_idx = self.str_to_int(gf_idx_str)
            if expr.func_type_args.length() > 0 {
                var j = 0
                while j < expr.func_type_args.length() {
                    type_args.push(expr.func_type_args.get(j))
                    j = j + 1
                }
            } else {
                type_args = self.infer_type_args(gf_idx, expr_idx)
            }
            var j = 0
            while j < type_args.length() {
                fn_name = fn_name + "_" + self.clean_type_for_mangling(type_args.get(j))
                j = j + 1
            }
            self.monomorphize_func(gf_idx, fn_name, &type_args)
        } else {
            if expr.func_type_args.length() > 0 {
                var j = 0
                while j < expr.func_type_args.length() {
                    fn_name = fn_name + "_" + self.clean_type_for_mangling(expr.func_type_args.get(j))
                    j = j + 1
                }
            }
        }
        if is_struct {
            fn_name = fn_name + "_init"
        }
        
        var args_str = ""
        var i = 0
        while i < expr.func_args.length() {
            if i > 0 {
                args_str = args_str + ", "
            }
            var p_idx = i
            if is_struct {
                p_idx = i + 1
            }
            let p_key = fn_name + "_param_" + int_to_str(p_idx)
            let expected_type = type_map_get(&self.func_param_types, p_key)
            args_str = args_str + self.gen_expr_with_expected_type(expr.func_args.get(i), expected_type)
            i = i + 1
        }
        return fn_name + "(" + args_str + ")"
    }
    
    if expr.kind == ExprKind.ek_field_access {
        let base_node = self.expr_pool.get(expr.field_expr)
        if base_node.kind == ExprKind.ek_identifier && self.is_enum_type(base_node.ident_name) {
            let enum_name = self.map_type(self.get_expr_type(expr.field_expr))
            let var_name = expr.field_name
            if self.enum_has_payload(base_node.ident_name) {
                return "(" + enum_name + "){ .tag = " + enum_name + "_" + var_name + "_TAG }"
            } else {
                return enum_name + "_" + var_name
            }
        }
        
        let base_val = self.gen_expr(expr.field_expr)
        let base_type = self.get_expr_type(expr.field_expr)
        var is_ptr = false
        let is_self_ptr = (base_node.kind == ExprKind.ek_identifier && base_node.ident_name == "self" && !self.cur_method_is_init)
        if base_type[0] == Char(42) || base_type[0] == Char(38) || is_self_ptr {
            is_ptr = true
        }
        var op = "."
        if is_ptr {
            op = "->"
        }
        let is_complex = (base_node.kind == ExprKind.ek_func_call || base_node.kind == ExprKind.ek_index || base_node.kind == ExprKind.ek_deref)
        if is_ptr && is_complex {
            return "(" + base_val + ")" + op + expr.field_name
        }
        return base_val + op + expr.field_name
    }
    
    if expr.kind == ExprKind.ek_index {
        let base_val = self.gen_expr(expr.idx_expr)
        let idx_val = self.gen_expr(expr.idx_index)
        return "(" + base_val + ")[" + idx_val + "]"
    }
    
    if expr.kind == ExprKind.ek_borrow {
        return "&(" + self.gen_expr(expr.borrow_expr) + ")"
    }
    
    if expr.kind == ExprKind.ek_deref {
        return "*(" + self.gen_expr(expr.deref_expr) + ")"
    }
    
    if expr.kind == ExprKind.ek_check {
        return self.gen_expr(expr.check_expr)
    }
    
    if expr.kind == ExprKind.ek_try {
        return self.gen_expr(expr.try_expr)
    }

    if expr.kind == ExprKind.ek_range {
        let start = self.gen_expr(expr.range_start)
        let end = self.gen_expr(expr.range_end)
        var incl = "false"
        if expr.range_inclusive {
            incl = "true"
        }
        return "(Range){ .start = " + start + ", .end = " + end + ", .is_inclusive = " + incl + " }"
    }

    if expr.kind == ExprKind.ek_slice {
        let base = self.gen_expr(expr.slice_expr)
        let base_type = self.get_expr_type(expr.slice_expr)
        var lower = "0"
        var upper = "strlen(" + base + ")"
        if expr.slice_lower >= 0 {
            lower = self.gen_expr(expr.slice_lower)
        }
        if expr.slice_upper >= 0 {
            upper = self.gen_expr(expr.slice_upper)
        }
        if base_type == "Str" || base_type == "*Char" {
            return "__kai_str_sub(" + base + ", " + lower + ", " + upper + ")"
        }
        if length(base_type) >= 2 && base_type[0..2] == "[]" {
            let inner_type = base_type[2..length(base_type)]
            let mapped_inner = self.map_type(inner_type)
            return "__kai_arr_sub(" + base + ", " + lower + ", " + upper + ", sizeof(" + mapped_inner + "))"
        }
        return base
    }

    if expr.kind == ExprKind.ek_array {
        var elems = ArrayList<Str>(self.allocator)
        var i = 0
        while i < expr.arr_elements.length() {
            elems.push(self.gen_expr(expr.arr_elements.get(i)))
            i = i + 1
        }
        var elems_str = str_array_join(elems, ", ")
        if length(elems_str) == 0 {
            elems_str = "0"
        }
        var inner_ty = "Int"
        if length(expr.inferred_type) > 2 && expr.inferred_type[0..2] == "[]" {
            inner_ty = expr.inferred_type[2..length(expr.inferred_type)]
        }
        let mapped_inner = self.map_type(inner_ty)
        return "(" + mapped_inner + "[]){ " + elems_str + " }"
    }

    if expr.kind == ExprKind.ek_tuple {
        if length(expr.inferred_type) > 0 {
            let mapped_ty = self.map_type(expr.inferred_type)
            var elems = ArrayList<Str>(self.allocator)
            var i = 0
            while i < expr.tup_elements.length() {
                elems.push(self.gen_expr(expr.tup_elements.get(i)))
                i = i + 1
            }
            return "(" + mapped_ty + "){ " + str_array_join(elems, ", ") + " }"
        }
        return "NULL"
    }

    if expr.kind == ExprKind.ek_asm {
        var decls = ArrayList<Str>(self.allocator)
        var out_ops = ArrayList<Str>(self.allocator)
        var i = 0
        while i < expr.asm_outputs.length() {
            let out = expr.asm_outputs.get(i)
            if length(out.type_name) > 0 {
                let mapped_type = self.map_type(out.type_name)
                let var_name = "asm_ret_" + int_to_str(i)
                decls.push(mapped_type + " " + var_name + ";")
                out_ops.push("[" + out.name + "] \"" + out.constraint + "\" (" + var_name + ")")
            } else if out.expr_idx >= 0 {
                let val_str = self.gen_expr(out.expr_idx)
                out_ops.push("[" + out.name + "] \"" + out.constraint + "\" (" + val_str + ")")
            }
            i = i + 1
        }

        var in_ops = ArrayList<Str>(self.allocator)
        var j = 0
        while j < expr.asm_inputs.length() {
            let inp = expr.asm_inputs.get(j)
            let val_str = self.gen_expr(inp.expr_idx)
            in_ops.push("[" + inp.name + "] \"" + inp.constraint + "\" (" + val_str + ")")
            j = j + 1
        }

        var clobs = ArrayList<Str>(self.allocator)
        var k = 0
        while k < expr.asm_clobbers.length() {
            clobs.push("\"" + expr.asm_clobbers.get(k) + "\"")
            k = k + 1
        }

        var volatile_prefix = ""
        if expr.asm_is_volatile {
            volatile_prefix = "volatile"
        }

        var escaped_asm = ""
        var c_idx = 0
        while c_idx < length(expr.asm_code) {
            let c = expr.asm_code[c_idx]
            if c == Char(10) {
                escaped_asm = escaped_asm + "\\n\\t"
            } else if c == Char(34) {
                escaped_asm = escaped_asm + "\\\""
            } else {
                escaped_asm = escaped_asm + char_to_str(c)
            }
            c_idx = c_idx + 1
        }

        var asm_stmt = "__asm__ " + volatile_prefix + " (\"" + escaped_asm + "\""
        if out_ops.length() > 0 || in_ops.length() > 0 || clobs.length() > 0 {
            asm_stmt = asm_stmt + " : " + str_array_join(out_ops, ", ")
        }
        if in_ops.length() > 0 || clobs.length() > 0 {
            asm_stmt = asm_stmt + " : " + str_array_join(in_ops, ", ")
        }
        if clobs.length() > 0 {
            asm_stmt = asm_stmt + " : " + str_array_join(clobs, ", ")
        }
        asm_stmt = asm_stmt + ");"

        var res = "({\n"
        var d_idx = 0
        while d_idx < decls.length() {
            res = res + "    " + decls.get(d_idx) + "\n"
            d_idx = d_idx + 1
        }
        res = res + "    " + asm_stmt + "\n"

        if expr.asm_outputs.length() == 1 {
            let out0 = expr.asm_outputs.get(0)
            if length(out0.type_name) > 0 {
                res = res + "    asm_ret_0;\n"
            }
        } else if expr.asm_outputs.length() > 1 {
            var types = ArrayList<Str>(self.allocator)
            var ti = 0
            var all_typed = true
            while ti < expr.asm_outputs.length() {
                let out = expr.asm_outputs.get(ti)
                if length(out.type_name) == 0 {
                    all_typed = false
                }
                types.push(out.type_name)
                ti = ti + 1
            }
            if all_typed {
                let tuple_type = "(" + str_array_join(types, ", ") + ")"
                let mapped_tuple = self.map_type(tuple_type)
                var vals = ArrayList<Str>(self.allocator)
                var vi = 0
                while vi < expr.asm_outputs.length() {
                    vals.push("asm_ret_" + int_to_str(vi))
                    vi = vi + 1
                }
                res = res + "    (" + mapped_tuple + "){ " + str_array_join(vals, ", ") + " };\n"
            }
        }
        res = res + "})"
        return res
    }
    
    if expr.kind == ExprKind.ek_struct_init {
        let is_enum = (length(expr.struct_name) > 0) && (self.str_contains(expr.struct_name, Char(46))) // '.' is 46
        if is_enum {
            let dot_pos = self.str_find(expr.struct_name, Char(46))
            let enum_part = expr.struct_name[0..dot_pos]
            let variant_name = expr.struct_name[dot_pos + 1..length(expr.struct_name)]
            let enum_name = self.map_type(enum_part)
            
            var fields_str = ""
            var i = 0
            while i < expr.struct_fields.length() {
                let f = expr.struct_fields.get(i)
                if i > 0 {
                    fields_str = fields_str + ", "
                }
                fields_str = fields_str + "." + f.name + " = " + self.gen_expr(f.value)
                i = i + 1
            }
            
            var payload_str = ""
            if length(fields_str) > 0 {
                payload_str = ", .payload = { ." + variant_name + " = { " + fields_str + " } }"
            }
            return "(" + enum_name + "){ .tag = " + enum_name + "_" + variant_name + "_TAG" + payload_str + " }"
        } else {
            let struct_name = self.map_type(expr.struct_name)
            var fields_str = ""
            var i = 0
            while i < expr.struct_fields.length() {
                let f = expr.struct_fields.get(i)
                if i > 0 {
                    fields_str = fields_str + ", "
                }
                // Look up the expected field type from the struct declaration
                var field_type = ""
                var si = 0
                while si < self.stmt_pool.length() {
                    let s = self.stmt_pool.get(si)
                    if s.kind == StmtKind.sk_struct_decl && s.struct_name == expr.struct_name {
                        var fi = 0
                        while fi < s.struct_fields.length() {
                            let sf = s.struct_fields.get(fi)
                            if sf.name == f.name {
                                field_type = sf.ftype
                            }
                            fi = fi + 1
                        }
                    }
                    si = si + 1
                }
                fields_str = fields_str + "." + f.name + " = " + self.gen_expr_with_expected_type(f.value, field_type)
                i = i + 1
            }
            return "(" + struct_name + "){ " + fields_str + " }"
        }
    }
    
    if expr.kind == ExprKind.ek_method_call {
        let receiver_idx = expr.meth_expr
        let receiver_node = self.expr_pool.get(receiver_idx)
        let method_name = expr.meth_name
        
        var rec_type = self.get_expr_type(expr.meth_expr)
        var clean_type = ""
        var i = 0
        while i < length(rec_type) {
            let c = rec_type[i]
            if c != Char(42) && c != Char(38) { // not '*' and not '&'
                clean_type = clean_type + char_to_str(c)
            }
            i = i + 1
        }
        if clean_type[0..4] == "mut " {
            clean_type = clean_type[4..length(clean_type)]
        }
        clean_type = self.map_type(clean_type)
        
        var is_constructor = false
        if receiver_node.kind == ExprKind.ek_identifier {
            let r_name = receiver_node.ident_name
            let first_char = r_name[0]
            if first_char >= Char(65) && first_char <= Char(90) { // Uppercase A-Z
                is_constructor = true
                clean_type = self.map_type(rec_type)
            }
        }
        
        let func_name = clean_type + "_" + method_name
        if type_map_find(&self.func_types, func_name) < 0 {
            printf("error[E0023]: type '%s' has no method '%s' (looked up: '%s')\n", rec_type, method_name, func_name)
            var d_i = 0
            while d_i < self.func_types.length() {
                printf("  registered: %s\n", self.func_types.get(d_i).key)
                d_i = d_i + 1
            }
            unsafe {
                exit(1)
            }
        }
        
        var args_str = ""
        if !is_constructor && method_name != "init" {
            let rec_val = self.gen_expr(receiver_idx)
            let rec_inferred = self.get_expr_type(receiver_idx)
            let is_self_ptr = (receiver_node.kind == ExprKind.ek_identifier && receiver_node.ident_name == "self" && !self.cur_method_is_init)
            if rec_inferred[0] == Char(42) || rec_inferred[0] == Char(38) || is_self_ptr {
                args_str = rec_val
            } else {
                // Check if receiver is a complex expression (temporary) that can't have address taken
                let is_complex = (receiver_node.kind == ExprKind.ek_func_call || receiver_node.kind == ExprKind.ek_method_call)
                if is_complex {
                    // Use GCC statement-expression to create a temporary and take its address
                    let tmp_type = self.map_type(rec_inferred)
                    args_str = "({ " + tmp_type + " __tmp_recv = " + rec_val + "; &__tmp_recv; })"
                } else {
                    args_str = "&(" + rec_val + ")"
                }
            }
        }
        
        var ai = 0
        while ai < expr.meth_args.length() {
            if length(args_str) > 0 {
                args_str = args_str + ", "
            }
            let p_key = func_name + "_param_" + int_to_str(ai + 1)
            let expected_type = type_map_get(&self.func_param_types, p_key)
            args_str = args_str + self.gen_expr_with_expected_type(expr.meth_args.get(ai), expected_type)
            ai = ai + 1
        }
        
        if method_name == "init" && !is_constructor {
            let rec_val = self.gen_expr(receiver_idx)
            let rec_inferred = self.get_expr_type(receiver_idx)
            if rec_inferred[0] == Char(42) || rec_inferred[0] == Char(38) {
                return "*(" + rec_val + ") = " + func_name + "(" + args_str + ")"
            }
            return rec_val + " = " + func_name + "(" + args_str + ")"
        }
        
        return func_name + "(" + args_str + ")"
    }
    
    if expr.kind == ExprKind.ek_catch {
        let inner = self.gen_expr(expr.catch_expr)
        let inner_ty = self.get_expr_type(expr.catch_expr)
        if length(inner_ty) > 0 && inner_ty[0] == Char(63) {
            let val_type = inner_ty[1..length(inner_ty)]
            let val_ctype = self.map_type(val_type)
            let cond_ctype = self.map_type(inner_ty)
            // Generate fallback: if it's an expr statement, use the expression directly
            var fallback_code = ""
            var fallback_is_stmt2 = false
            if expr.catch_fallback >= 0 {
                let fb_node = self.stmt_pool.get(expr.catch_fallback)
                if fb_node.kind == StmtKind.sk_expr {
                    fallback_code = self.gen_expr(fb_node.expr_stmt)
                } else if fb_node.kind == StmtKind.sk_block {
                    var is_single_expr = false
                    var expr_idx = -1
                    if fb_node.block_stmts.length() == 1 {
                        let single_stmt = self.stmt_pool.get(fb_node.block_stmts.get(0))
                        if single_stmt.kind == StmtKind.sk_expr {
                            is_single_expr = true
                            expr_idx = single_stmt.expr_stmt
                        }
                    }
                    if is_single_expr {
                        fallback_code = self.gen_expr(expr_idx)
                    } else {
                        fallback_code = self.gen_stmt(expr.catch_fallback)
                        fallback_is_stmt2 = true
                    }
                } else {
                    fallback_code = self.gen_stmt(expr.catch_fallback)
                    fallback_is_stmt2 = true
                }
            } else {
                fallback_code = "0"
            }
            var catch_code = "({ "
            if self.is_pointer_type(val_type) {
                catch_code = catch_code + val_ctype + " _kai_opt = (" + inner + "); "
                catch_code = catch_code + val_ctype + " _kai_cv; "
                catch_code = catch_code + "if (_kai_opt != NULL) { _kai_cv = _kai_opt; } "
                if fallback_is_stmt2 {
                    catch_code = catch_code + "else { " + fallback_code + " __builtin_unreachable(); } _kai_cv; })"
                } else {
                    catch_code = catch_code + "else { _kai_cv = (" + fallback_code + "); } _kai_cv; })"
                }
            } else {
                catch_code = catch_code + cond_ctype + " _kai_opt = (" + inner + "); "
                catch_code = catch_code + val_ctype + " _kai_cv; "
                catch_code = catch_code + "if (_kai_opt.has_value) { _kai_cv = _kai_opt.value; } "
                if fallback_is_stmt2 {
                    catch_code = catch_code + "else { " + fallback_code + " __builtin_unreachable(); } _kai_cv; })"
                } else {
                    catch_code = catch_code + "else { _kai_cv = (" + fallback_code + "); } _kai_cv; })"
                }
            }
            return catch_code
        }
        let excl_pos = self.str_find(inner_ty, Char(33))
        if excl_pos < 0 {
            return inner
        }
        let val_type = inner_ty[0..excl_pos]
        let result_ctype = self.map_type(inner_ty)
        let val_ctype = self.map_type(val_type)
        // Generate fallback: if it's an expr statement, use the expression directly
        var fallback_code = ""
        var fallback_is_stmt = false
        if expr.catch_fallback >= 0 {
            let fb_node = self.stmt_pool.get(expr.catch_fallback)
            if fb_node.kind == StmtKind.sk_expr {
                fallback_code = self.gen_expr(fb_node.expr_stmt)
            } else if fb_node.kind == StmtKind.sk_block {
                var is_single_expr = false
                var expr_idx = -1
                if fb_node.block_stmts.length() == 1 {
                    let single_stmt = self.stmt_pool.get(fb_node.block_stmts.get(0))
                    if single_stmt.kind == StmtKind.sk_expr {
                        is_single_expr = true
                        expr_idx = single_stmt.expr_stmt
                    }
                }
                if is_single_expr {
                    fallback_code = self.gen_expr(expr_idx)
                } else {
                    fallback_code = self.gen_stmt(expr.catch_fallback)
                    fallback_is_stmt = true
                }
            } else {
                fallback_code = self.gen_stmt(expr.catch_fallback)
                fallback_is_stmt = true
            }
        } else {
            fallback_code = "0"
        }
        var catch_code = "({ " + result_ctype + " _kai_cr = (" + inner + "); "
        if val_type == "Void" {
            catch_code = catch_code + "if (_kai_cr.tag != 0) { "
            if length(expr.catch_var) > 0 {
                catch_code = catch_code + "int64_t " + expr.catch_var + " = _kai_cr.tag; "
            }
            catch_code = catch_code + fallback_code + " } 0; })"
        } else {
            catch_code = catch_code + val_ctype + " _kai_cv; "
            catch_code = catch_code + "if (_kai_cr.tag != 0) { "
            if length(expr.catch_var) > 0 {
                catch_code = catch_code + "int64_t " + expr.catch_var + " = _kai_cr.tag; "
            }
            if fallback_is_stmt {
                catch_code = catch_code + fallback_code + " __builtin_unreachable(); "
            } else {
                catch_code = catch_code + "_kai_cv = (" + fallback_code + "); "
            }
            catch_code = catch_code + "} else { _kai_cv = _kai_cr.value; } _kai_cv; })"
        }
        return catch_code
    }
    
    return "0"
}

fn str_contains(self, s: Str, target: Char) -> Bool {
    var i = 0
    while i < length(s) {
        if s[i] == target {
            return true
        }
        i = i + 1
    }
    return false
}

fn str_find(self, s: Str, target: Char) -> Int {
    var i = 0
    while i < length(s) {
        if s[i] == target {
            return i
        }
        i = i + 1
    }
    return -1
}

//== Standard C Detection

fn is_standard_c_func(self, name: Str) -> Bool {
    let l = length(name)
    if l >= 4 {
        let sub4 = name[0..4]
        var is_llvm = false
        unsafe {
            if strcmp(sub4, "LLVM") == 0 { is_llvm = true }
        }
        if is_llvm { return true }
    }
    if l >= 8 {
        let sub8 = name[0..8]
        var is_kai_llvm = false
        unsafe {
            if strcmp(sub8, "kai_LLVM") == 0 { is_kai_llvm = true }
        }
        if is_kai_llvm { return true }
    }
    if l >= 13 {
        let sub13 = name[0..13]
        var is_kai_func = false
        unsafe {
            if strcmp(sub13, "kai_func_type") == 0 { is_kai_func = true }
        }
        if is_kai_func { return true }
    }
    if l >= 14 {
        let sub14 = name[0..14]
        var is_kai_build = false
        unsafe {
            if strcmp(sub14, "kai_build_call") == 0 { is_kai_build = true }
        }
        if is_kai_build { return true }
    }

    if name == "atoll" { return true }
    if name == "malloc" { return true }
    if name == "free" { return true }
    if name == "realloc" { return true }
    if name == "calloc" { return true }
    if name == "isdigit" { return true }
    if name == "isalpha" { return true }
    if name == "isalnum" { return true }
    if name == "isspace" { return true }
    if name == "toupper" { return true }
    if name == "tolower" { return true }
    if name == "strlen" { return true }
    if name == "exit" { return true }
    if name == "system" { return true }
    if name == "fopen" { return true }
    if name == "fread" { return true }
    if name == "fwrite" { return true }
    if name == "fclose" { return true }
    if name == "fseek" { return true }
    if name == "ftell" { return true }
    if name == "rewind" { return true }
    //if name == "print_int" { return true }
    if name == "strcmp" { return true }
    if name == "printf" { return true }
    if name == "fprintf" { return true }
    if name == "sprintf" { return true }
    if name == "snprintf" { return true }
    if name == "sqrt" { return true }
    return false
}

//== Statement Code Generation

fn gen_stmt(self, stmt_idx: Int) -> Str {
    if stmt_idx < 0 { return "" }

    let stmt = self.stmt_pool.get(stmt_idx)
    
    if stmt.kind == StmtKind.sk_block {
        self.block_stack.push(stmt_idx)
        self.defer_depths.push(self.defer_stack.length())
        var block_str = "{\n"
        var i = 0
        while i < stmt.block_stmts.length() {
            let s = self.gen_stmt(stmt.block_stmts.get(i))
            if length(s) > 0 {
                block_str = block_str + "    " + s + "\n"
            }
            i = i + 1
        }
        let start_idx = self.defer_depths.pop()
        while self.defer_stack.length() > start_idx {
            let def_idx = self.defer_stack.pop()
            let def_node = self.stmt_pool.get(def_idx)
            let s = self.gen_stmt(def_node.defer_body)
            if length(s) > 0 {
                block_str = block_str + "    " + s + "\n"
            }
        }
        var di = 0
        while di < stmt.block_drop_vars.length() {
            let entry = stmt.block_drop_vars.get(di)
            block_str = block_str + "    " + entry.base_type + "_drop(&" + entry.name + ");\n"
            di = di + 1
        }
        block_str = block_str + "}"
        let _ = self.block_stack.pop()
        return block_str
    }
    
    if stmt.kind == StmtKind.sk_defer {
        self.defer_stack.push(stmt_idx)
        return ""
    }
    
    if stmt.kind == StmtKind.sk_var_decl {
        let name = stmt.vardecl_name
        var var_type_name = stmt.vardecl_type
        if length(var_type_name) == 0 {
            var_type_name = self.get_expr_type(stmt.vardecl_value)
        }
        let init_val = self.gen_expr_with_expected_type(stmt.vardecl_value, var_type_name)
        if name == "_" {
            return "(void)(" + init_val + ");"
        }
        let var_type = self.map_type(var_type_name)
        
        type_map_put(&self.var_types, name, var_type_name)
        
        return var_type + " " + name + " = " + init_val + ";"
    }
    
    if stmt.kind == StmtKind.sk_assignment {
        let lhs = self.gen_expr(stmt.assign_target)
        let lhs_type = self.get_expr_type(stmt.assign_target)
        let rhs = self.gen_expr_with_expected_type(stmt.assign_value, lhs_type)
        var op = "="
        if length(stmt.assign_op) > 0 {
            op = stmt.assign_op
        }
        return lhs + " " + op + " " + rhs + ";"
    }
    
    if stmt.kind == StmtKind.sk_func_decl {
        if stmt.func_type_params.length() > 0 {
            type_map_put(&self.generic_func_decls, stmt.func_name, int_to_str(stmt_idx))
            return ""
        }
        let name = stmt.func_name
        let ret_type = self.map_type(stmt.func_return_type)
        
        var params_str = ""
        var i = 0
        while i < stmt.func_params.length() {
            let p = stmt.func_params.get(i)
            if i > 0 {
                params_str = params_str + ", "
            }
            params_str = params_str + self.map_type(p.ptype) + " " + p.name
            i = i + 1
        }
        if length(params_str) == 0 {
            params_str = "void"
        }
        
        let old_fn = self.cur_func_name
        let old_ret = self.cur_return_type
        let old_init = self.cur_method_is_init
        
        self.cur_func_name = name
        self.cur_return_type = stmt.func_return_type
        self.cur_method_is_init = false
        
        let old_var_len2 = self.var_types.length()
        var p_reg2 = 0
        while p_reg2 < stmt.func_params.length() {
            let p = stmt.func_params.get(p_reg2)
            type_map_put(&self.var_types, p.name, p.ptype)
            p_reg2 = p_reg2 + 1
        }
        
        if stmt.func_body < 0 {
            self.cur_func_name = old_fn
            self.cur_return_type = old_ret
            self.cur_method_is_init = old_init
            return ""
        }
        var body_str = self.gen_stmt(stmt.func_body)
        
        while self.var_types.length() > old_var_len2 {
            let _ = self.var_types.pop()
        }
        
        var proto = ""
        var impl_str = ""
        if name == "main" {
            impl_str = "int main(int argc, char** argv) " + body_str
        } else {
            proto = ret_type + " " + name + "(" + params_str + ");\n"
            impl_str = ret_type + " " + name + "(" + params_str + ") " + body_str + "\n"
        }
        
        if length(proto) > 0 {
            let _ = self.func_decls.append(proto)
        }
        let _ = self.output.append(impl_str)
        
        self.cur_func_name = old_fn
        self.cur_return_type = old_ret
        self.cur_method_is_init = old_init
        return ""
    }
    
    if stmt.kind == StmtKind.sk_struct_decl {
        if stmt.struct_type_params.length() > 0 {
            type_map_put(&self.generic_struct_decls, stmt.struct_name, int_to_str(stmt_idx))
        }
        return ""
    }
    if stmt.kind == StmtKind.sk_trait_decl {
        var method_names = ""
        var mi = 0
        while mi < stmt.trait_methods.length() {
            let m_node = self.stmt_pool.get(stmt.trait_methods.get(mi))
            if mi > 0 { method_names = method_names + ", " }
            method_names = method_names + m_node.func_name
            mi = mi + 1
        }
        let comment = "/* trait " + stmt.trait_name + ": " + method_names + " */\n"
        let _ = self.struct_decls.append(comment)
        return ""
    }
    
    if stmt.kind == StmtKind.sk_error_decl {
        type_map_put(&self.enum_decls, stmt.error_name, int_to_str(stmt_idx))
        let name = self.map_type(stmt.error_name)
        var enum_str = "typedef enum {\n"
        var j = 0
        while j < stmt.error_variants.length() {
            let vname = stmt.error_variants.get(j)
            enum_str = enum_str + "    " + name + "_" + vname + " = " + int_to_str(j + 1) + ",\n"
            j = j + 1
        }
        enum_str = enum_str + "} " + name + ";\n"
        let _ = self.struct_decls.append(enum_str)
        return ""
    }
    
    if stmt.kind == StmtKind.sk_enum_decl {
        type_map_put(&self.enum_decls, stmt.enum_name, int_to_str(stmt_idx))
        if stmt.enum_type_params.length() > 0 {
            type_map_put(&self.generic_enum_decls, stmt.enum_name, int_to_str(stmt_idx))
            return ""
        }
        let name = self.map_type(stmt.enum_name)
        var has_payload = false
        var i = 0
        while i < stmt.enum_variants.length() {
            let v = stmt.enum_variants.get(i)
            if v.params.length() > 0 {
                has_payload = true
            }
            i = i + 1
        }
        
        var enum_str = ""
        if !has_payload {
            enum_str = "typedef enum {\n"
            var j = 0
            while j < stmt.enum_variants.length() {
                let v = stmt.enum_variants.get(j)
                enum_str = enum_str + "    " + name + "_" + v.vname + ",\n"
                j = j + 1
            }
            enum_str = enum_str + "} " + name + ";\n"
        } else {
            let tags_name = name + "_tags"
            enum_str = "typedef enum {\n"
            var j = 0
            while j < stmt.enum_variants.length() {
                let v = stmt.enum_variants.get(j)
                enum_str = enum_str + "    " + name + "_" + v.vname + "_TAG,\n"
                j = j + 1
            }
            enum_str = enum_str + "} " + tags_name + ";\n"
            
            enum_str = enum_str + "typedef struct " + name + " " + name + ";\n"
            enum_str = enum_str + "struct " + name + " {\n"
            enum_str = enum_str + "    uint8_t tag;\n"
            enum_str = enum_str + "    union {\n"
            var k = 0
            while k < stmt.enum_variants.length() {
                let v = stmt.enum_variants.get(k)
                if v.params.length() > 0 {
                    enum_str = enum_str + "        struct {\n"
                    var p_idx = 0
                    while p_idx < v.params.length() {
                        let p = v.params.get(p_idx)
                        enum_str = enum_str + "            " + self.map_type(p.ptype) + " " + p.name + ";\n"
                        p_idx = p_idx + 1
                    }
                    enum_str = enum_str + "        } " + v.vname + ";\n"
                }
                k = k + 1
            }
            enum_str = enum_str + "    } payload;\n"
            enum_str = enum_str + "};\n"
        }
        let _ = self.struct_decls.append(enum_str)
        return ""
    }
    
    if stmt.kind == StmtKind.sk_impl_block {
        let struct_name = stmt.impl_struct_name
        let has_generic_struct = (length(type_map_get(&self.generic_struct_decls, struct_name)) > 0) || (length(type_map_get(&self.generic_enum_decls, struct_name)) > 0)
        if has_generic_struct || self.str_contains(struct_name, Char(60)) {
            type_map_put(&self.generic_impl_blocks, struct_name, int_to_str(stmt_idx))
            return ""
        }
        let mapped_struct_name = self.map_type(struct_name)
        
        var idx = 0
        while idx < stmt.impl_methods.length() {
            let method_stmt_idx = stmt.impl_methods.get(idx)
            let method_node = self.stmt_pool.get(method_stmt_idx)
            let method_name = method_node.func_name
            
            let is_init = (method_name == "init") || (method_node.func_return_type == struct_name) || (method_node.func_return_type == "*" + struct_name) || (method_node.func_return_type == "&" + struct_name)
            
            var ret_type = ""
            if is_init {
                ret_type = mapped_struct_name
            } else {
                ret_type = self.map_type(method_node.func_return_type)
            }
            
            var params_str = ""
            if !is_init {
                params_str = mapped_struct_name + "* self"
            }
            
            var p_idx = 0
            while p_idx < method_node.func_params.length() {
                let p = method_node.func_params.get(p_idx)
                if p.name != "self" {
                    if length(params_str) > 0 {
                        params_str = params_str + ", "
                    }
                    params_str = params_str + self.map_type(p.ptype) + " " + p.name
                }
                p_idx = p_idx + 1
            }
            if length(params_str) == 0 {
                params_str = "void"
            }
            
            let mangled_fn_name = mapped_struct_name + "_" + method_name
            
            let old_fn = self.cur_func_name
            let old_ret = self.cur_return_type
            let old_init = self.cur_method_is_init
            
            self.cur_func_name = mangled_fn_name
            
            if is_init {
                self.cur_return_type = struct_name
            } else {
                self.cur_return_type = method_node.func_return_type
            }
            self.cur_method_is_init = is_init
            
            let old_var_len = self.var_types.length()
            if is_init {
                type_map_put(&self.var_types, "self", struct_name)
            } else {
                type_map_put(&self.var_types, "self", "*" + struct_name)
            }
            var p_reg = 0
            while p_reg < method_node.func_params.length() {
                let p = method_node.func_params.get(p_reg)
                if p.name != "self" {
                    type_map_put(&self.var_types, p.name, p.ptype)
                }
                p_reg = p_reg + 1
            }
            
            var body_str = self.gen_stmt(method_node.func_body)
            
            while self.var_types.length() > old_var_len {
                let _ = self.var_types.pop()
            }
            
            if is_init {
                body_str = self.add_init_return(body_str, mapped_struct_name)
            }
            
            let proto = ret_type + " " + mangled_fn_name + "(" + params_str + ");\n"
            let impl_str = ret_type + " " + mangled_fn_name + "(" + params_str + ") " + body_str + "\n"
            
            let _ = self.func_decls.append(proto)
            let _ = self.output.append(impl_str)
            
            self.cur_func_name = old_fn
            self.cur_return_type = old_ret
            self.cur_method_is_init = old_init
            idx = idx + 1
        }
        return ""
    }
    
    if stmt.kind == StmtKind.sk_if {
        let cond_val = self.gen_expr(stmt.if_cond)
        var cond_str = ""
        if length(cond_val) > 1 && cond_val[0] == Char(40) && cond_val[length(cond_val) - 1] == Char(41) {
            cond_str = cond_val
        } else {
            cond_str = "(" + cond_val + ")"
        }
        var if_str = "if " + cond_str + " " + self.gen_stmt(stmt.if_then)
        if stmt.if_else >= 0 {
            let else_node = self.stmt_pool.get(stmt.if_else)
            if else_node.kind == StmtKind.sk_block && else_node.block_stmts.length() == 1 {
                let single_stmt_idx = else_node.block_stmts.get(0)
                let single_stmt = self.stmt_pool.get(single_stmt_idx)
                if single_stmt.kind == StmtKind.sk_if {
                    if_str = if_str + " else " + self.gen_stmt(single_stmt_idx)
                } else {
                    if_str = if_str + " else " + self.gen_stmt(stmt.if_else)
                }
            } else {
                if_str = if_str + " else " + self.gen_stmt(stmt.if_else)
            }
        }
        return if_str
    }
    
    if stmt.kind == StmtKind.sk_if_let {
        let cond_val = self.gen_expr(stmt.iflet_expr)
        let cond_type = self.get_expr_type(stmt.iflet_expr)
        let unwrapped_type = cond_type[1..length(cond_type)]
        let unwrapped_ctype = self.map_type(unwrapped_type)
        let cond_ctype = self.map_type(cond_type)
        
        let old_var_len = self.var_types.length()
        type_map_put(&self.var_types, stmt.iflet_var, unwrapped_type)
        
        var then_str = self.gen_stmt(stmt.iflet_then)
        var else_str = ""
        if stmt.iflet_else >= 0 {
            let else_node = self.stmt_pool.get(stmt.iflet_else)
            if else_node.kind == StmtKind.sk_block && else_node.block_stmts.length() == 1 {
                let single_stmt_idx = else_node.block_stmts.get(0)
                let single_stmt = self.stmt_pool.get(single_stmt_idx)
                if single_stmt.kind == StmtKind.sk_if_let {
                    else_str = " else " + self.gen_stmt(single_stmt_idx)
                } else {
                    else_str = " else " + self.gen_stmt(stmt.iflet_else)
                }
            } else {
                else_str = " else " + self.gen_stmt(stmt.iflet_else)
            }
        }
        
        while self.var_types.length() > old_var_len {
            let _ = self.var_types.pop()
        }
        
        var if_code = ""
        if self.is_pointer_type(unwrapped_type) {
            if_code = "if ((" + cond_val + ") != NULL) {\n"
            if_code = if_code + "    " + unwrapped_ctype + " " + stmt.iflet_var + " = " + cond_val + ";\n"
            if_code = if_code + "    " + then_str + "\n"
            if_code = if_code + "}" + else_str
        } else {
            if_code = "{\n"
            if_code = if_code + "    " + cond_ctype + " _kai_opt = " + cond_val + ";\n"
            if_code = if_code + "    if (_kai_opt.has_value) {\n"
            if_code = if_code + "        " + unwrapped_ctype + " " + stmt.iflet_var + " = _kai_opt.value;\n"
            if_code = if_code + "        " + then_str + "\n"
            if_code = if_code + "    }" + else_str + "\n"
            if_code = if_code + "}"
        }
        return if_code
    }
    
    if stmt.kind == StmtKind.sk_while {
        let cond_val = self.gen_expr(stmt.while_cond)
        var cond_str = ""
        if length(cond_val) > 1 && cond_val[0] == Char(40) && cond_val[length(cond_val) - 1] == Char(41) {
            cond_str = cond_val
        } else {
            cond_str = "(" + cond_val + ")"
        }
        if stmt.while_body >= 0 {
            var body_stmt = self.stmt_pool.get(stmt.while_body)
            body_stmt.block_is_loop_body = true
            self.stmt_pool.set(stmt.while_body, body_stmt)
        }
        return "while " + cond_str + " " + self.gen_stmt(stmt.while_body)
    }
    
    if stmt.kind == StmtKind.sk_for {
        let iter_var = stmt.for_var
        let start = self.gen_expr(stmt.for_start)
        let end = self.gen_expr(stmt.for_end)
        if stmt.for_body >= 0 {
            var body_stmt = self.stmt_pool.get(stmt.for_body)
            body_stmt.block_is_loop_body = true
            self.stmt_pool.set(stmt.for_body, body_stmt)
        }
        let body = self.gen_stmt(stmt.for_body)
        // Generate a for loop that handles both ascending and descending ranges at runtime
        var cmp_asc = "<"
        var cmp_desc = ">"
        if stmt.for_inclusive {
            cmp_asc = "<="
            cmp_desc = ">="
        }
        var for_str = "for (int64_t " + iter_var + " = " + start + "; "
        for_str = for_str + "(" + start + " <= " + end + ") ? (" + iter_var + " " + cmp_asc + " " + end + ") : (" + iter_var + " " + cmp_desc + " " + end + "); "
        for_str = for_str + "(" + start + " <= " + end + ") ? ++" + iter_var + " : --" + iter_var + ") " + body
        return for_str
    }
    
    if stmt.kind == StmtKind.sk_return {
        var drop_calls = ArrayList<Str>(self.allocator)
        var bi = self.block_stack.length() - 1
        while bi >= 0 {
            let b_idx = self.block_stack.get(bi)
            let b_node = self.stmt_pool.get(b_idx)
            
            let start_idx = self.defer_depths.get(bi)
            var next_start_idx = self.defer_stack.length()
            if bi < self.block_stack.length() - 1 {
                next_start_idx = self.defer_depths.get(bi + 1)
            }
            var def_i = next_start_idx - 1
            while def_i >= start_idx {
                let def_idx = self.defer_stack.get(def_i)
                let def_node = self.stmt_pool.get(def_idx)
                let s = self.gen_stmt(def_node.defer_body)
                if length(s) > 0 {
                    drop_calls.push(s)
                }
                def_i = def_i - 1
            }
            
            var di = 0
            while di < b_node.block_drop_vars.length() {
                let entry = b_node.block_drop_vars.get(di)
                drop_calls.push(entry.base_type + "_drop(&" + entry.name + ");")
                di = di + 1
            }
            bi = bi - 1
        }
        
        if drop_calls.length() == 0 {
            if stmt.return_value >= 0 {
                let ret_excl_pos = self.str_find(self.cur_return_type, Char(33))
                if ret_excl_pos >= 0 {
                    let result_ctype = self.map_type(self.cur_return_type)
                    let val_payload_type = self.cur_return_type[0..ret_excl_pos]
                    let err_type = self.cur_return_type[ret_excl_pos + 1..length(self.cur_return_type)]
                    let ret_node = self.expr_pool.get(stmt.return_value)
                    var is_error_variant = false
                    if ret_node.kind == ExprKind.ek_field_access {
                        let base_node = self.expr_pool.get(ret_node.field_expr)
                        if base_node.kind == ExprKind.ek_identifier {
                            if self.is_enum_type(base_node.ident_name) {
                                is_error_variant = true
                            }
                        }
                    }
                    let val_str = self.gen_expr(stmt.return_value)
                    let expr_ty = self.get_expr_type(stmt.return_value)
                    let expr_excl_pos = self.str_find(expr_ty, Char(33))
                    if expr_excl_pos >= 0 {
                        return "return " + val_str + ";"
                    }
                    if is_error_variant {
                        return "return (" + result_ctype + "){ .tag = " + val_str + " };"
                    }
                    if val_payload_type == "Void" {
                        return "return (" + result_ctype + "){ .tag = 0 };"
                    }
                    return "return (" + result_ctype + "){ .tag = 0, .value = " + val_str + " };"
                }
                return "return " + self.gen_expr_with_expected_type(stmt.return_value, self.cur_return_type) + ";"
            }
            return "return;"
        }
        
        if stmt.return_value >= 0 {
            let val_str = self.gen_expr_with_expected_type(stmt.return_value, self.cur_return_type)
            let val_type = self.get_expr_type(stmt.return_value)
            
            if val_type == "Void" || val_type == "NoneType" {
                var res = val_str + "; "
                var ci = 0
                while ci < drop_calls.length() {
                    res = res + drop_calls.get(ci) + " "
                    ci = ci + 1
                }
                return res + "return;"
            }
            
            let ret_excl_pos = self.str_find(self.cur_return_type, Char(33))
            let mapped_type = self.map_type(self.cur_return_type)
            
            if ret_excl_pos >= 0 {
                // Result type with drops - need to wrap in Result struct
                let val_payload_type = self.cur_return_type[0..ret_excl_pos]
                let ret_node = self.expr_pool.get(stmt.return_value)
                var is_error_variant = false
                if ret_node.kind == ExprKind.ek_field_access {
                    let base_node = self.expr_pool.get(ret_node.field_expr)
                    if base_node.kind == ExprKind.ek_identifier {
                        if self.is_enum_type(base_node.ident_name) {
                            is_error_variant = true
                        }
                    }
                }
                let raw_val = self.gen_expr(stmt.return_value)
                let expr_ty = self.get_expr_type(stmt.return_value)
                let expr_excl_pos = self.str_find(expr_ty, Char(33))
                
                var ret_expr = ""
                if expr_excl_pos >= 0 {
                    ret_expr = raw_val
                } else if is_error_variant {
                    ret_expr = "(" + mapped_type + "){ .tag = " + raw_val + " }"
                } else if val_payload_type == "Void" {
                    ret_expr = "(" + mapped_type + "){ .tag = 0 }"
                } else {
                    ret_expr = "(" + mapped_type + "){ .tag = 0, .value = " + raw_val + " }"
                }
                
                var res_str = "{\n"
                res_str = res_str + "    " + mapped_type + " __ret_val = " + ret_expr + ";\n"
                var ci = 0
                while ci < drop_calls.length() {
                    res_str = res_str + "    " + drop_calls.get(ci) + "\n"
                    ci = ci + 1
                }
                res_str = res_str + "    return __ret_val;\n"
                res_str = res_str + "}"
                return res_str
            }
            
            var res_str = "{\n"
            res_str = res_str + "    " + mapped_type + " __ret_val = " + val_str + ";\n"
            var ci = 0
            while ci < drop_calls.length() {
                res_str = res_str + "    " + drop_calls.get(ci) + "\n"
                ci = ci + 1
            }
            res_str = res_str + "    return __ret_val;\n"
            res_str = res_str + "}"
            return res_str
        } else {
            var res_str = "{\n"
            var ci = 0
            while ci < drop_calls.length() {
                res_str = res_str + "    " + drop_calls.get(ci) + "\n"
                ci = ci + 1
            }
            res_str = res_str + "    return;\n"
            res_str = res_str + "}"
            return res_str
        }
    }
    
    if stmt.kind == StmtKind.sk_expr {
        return self.gen_expr(stmt.expr_stmt) + ";"
    }
    
    if stmt.kind == StmtKind.sk_print {
        let arg = stmt.print_value
        let val = self.gen_expr(arg)
        let arg_type = self.get_expr_type(arg)
        if arg_type == "Int" {
            return "__kai_print_int(" + val + ");"
        }
        if arg_type == "Float" {
            return "__kai_print_float(" + val + ");"
        }
        if arg_type == "Char" {
            return "printf(\"%c\\n\", (char)(" + val + "));"
        }
        if arg_type == "Bool" {
            return "printf(\"%s\\n\", (" + val + ") ? \"true\" : \"false\");"
        }
        return "printf(\"%s\\n\", " + val + ");"
    }
    
    if stmt.kind == StmtKind.sk_unsafe {
        return self.gen_stmt(stmt.unsafe_body)
    }
    
    if stmt.kind == StmtKind.sk_extern {
        let name = stmt.extern_name
        if self.is_standard_c_func(name) {
            return ""
        }
        let ret_type = self.map_type(stmt.extern_return)
        
        var params_str = ""
        var i = 0
        while i < stmt.extern_params.length() {
            let p = stmt.extern_params.get(i)
            if i > 0 {
                params_str = params_str + ", "
            }
            params_str = params_str + self.map_type(p.ptype) + " " + p.name
            i = i + 1
        }
        if length(params_str) == 0 {
            params_str = "void"
        }
        
        let proto = "extern " + ret_type + " " + name + "(" + params_str + ");\n"
        let _ = self.func_decls.append(proto)
        return ""
    }
    
    if stmt.kind == StmtKind.sk_cimport {
        self.import_resolver.record_cimport(stmt.cimport_header)
        return ""
    }

    if stmt.kind == StmtKind.sk_import { return "" }
    
    if stmt.kind == StmtKind.sk_break {
        let drop_calls = self._collect_loop_drops()
        if drop_calls.length() == 0 {
            return "break;"
        }
        var res_str = "{\n"
        var ci = 0
        while ci < drop_calls.length() {
            res_str = res_str + "    " + drop_calls.get(ci) + "\n"
            ci = ci + 1
        }
        res_str = res_str + "    break;\n"
        res_str = res_str + "}"
        return res_str
    }
    
    if stmt.kind == StmtKind.sk_continue {
        let drop_calls = self._collect_loop_drops()
        if drop_calls.length() == 0 {
            return "continue;"
        }
        var res_str = "{\n"
        var ci = 0
        while ci < drop_calls.length() {
            res_str = res_str + "    " + drop_calls.get(ci) + "\n"
            ci = ci + 1
        }
        res_str = res_str + "    continue;\n"
        res_str = res_str + "}"
        return res_str
    }
    
    if stmt.kind == StmtKind.sk_match {
        let expr_idx = stmt.match_expr
        let expr_val = self.gen_expr(expr_idx)
        let expr_node = self.expr_pool.get(expr_idx)
        let expr_type = self.get_expr_type(expr_idx)
        let mapped_expr_type = self.map_type(expr_type)
        
        let is_self_ptr = (expr_node.kind == ExprKind.ek_identifier && expr_node.ident_name == "self" && !self.cur_method_is_init)
        var is_ptr = false
        if expr_type[0] == Char(42) || expr_type[0] == Char(38) || is_self_ptr {
            is_ptr = true
        }
        var op = "."
        if is_ptr {
            op = "->"
        }
        
        var match_str = ""
        var case_idx = 0
        while case_idx < stmt.match_cases.length() {
            let case_node = stmt.match_cases.get(case_idx)
            let pat_node = self.pattern_pool.get(case_node.pattern)
            let block_str = self.gen_stmt(case_node.body)
            
            var cond = ""
            var bindings_str = ""
            
            if pat_node.kind == PatternKind.pk_literal {
                var lit_str = ""
                match pat_node.lit_value {
                    case .tv_int(v) => { lit_str = int_to_str(v) }
                    case .tv_str(v) => { lit_str = "\"" + self.escape_string(self.pool.get(v)) + "\"" }
                    case .tv_bool(v) => {
                        if v { lit_str = "true" }
                        else { lit_str = "false" }
                    }
                    case .tv_char(v) => {
                        if v == Char(10) { lit_str = "'\\n'" }
                        else if v == Char(13) { lit_str = "'\\r'" }
                        else if v == Char(9) { lit_str = "'\\t'" }
                        else if v == Char(92) { lit_str = "'\\\\'" }
                        else if v == Char(39) { lit_str = "'\\''" }
                        else { lit_str = "'" + char_to_str(v) + "'" }
                    }
                    case else => { lit_str = "0" }
                }
                cond = expr_val + " == " + lit_str
            } else if pat_node.kind == PatternKind.pk_variant {
                let var_name = pat_node.variant_name
                var base_type = mapped_expr_type
                if length(base_type) > 0 && (base_type[length(base_type) - 1] == Char(42) || base_type[length(base_type) - 1] == Char(38)) {
                    base_type = base_type[0..length(base_type) - 1]
                }
                if length(base_type) > 0 && base_type[0] == Char(42) {
                    base_type = base_type[1..length(base_type)]
                }
                if self.enum_has_payload(expr_type) {
                    cond = expr_val + op + "tag == " + base_type + "_" + var_name + "_TAG"
                } else {
                    cond = expr_val + " == " + base_type + "_" + var_name
                }
                
                var clean_enum_name = expr_type
                var done_clean = false
                while !done_clean {
                    if length(clean_enum_name) > 0 && (clean_enum_name[0] == Char(42) || clean_enum_name[0] == Char(38)) {
                        clean_enum_name = clean_enum_name[1..length(clean_enum_name)]
                    } else {
                        done_clean = true
                    }
                }
                let underscore_pos = self.str_find(clean_enum_name, Char(95))
                if underscore_pos >= 0 {
                    clean_enum_name = clean_enum_name[0..underscore_pos]
                }
                let lt_pos = self.str_find(clean_enum_name, Char(60))
                if lt_pos >= 0 {
                    clean_enum_name = clean_enum_name[0..lt_pos]
                }
                let enum_idx_str = type_map_get(&self.enum_decls, clean_enum_name)
                var found_var = false
                var matched_var = Variant(vname: "", params: empty_param_array())
                if length(enum_idx_str) > 0 {
                    let enum_stmt = self.stmt_pool.get(self.str_to_int(enum_idx_str))
                    var vi = 0
                    while vi < enum_stmt.enum_variants.length() {
                        let v = enum_stmt.enum_variants.get(vi)
                        if v.vname == var_name {
                            found_var = true
                            matched_var = v
                            break
                        }
                        vi = vi + 1
                    }
                }
                
                if pat_node.bindings.length() > 0 {
                    var bi = 0
                    while bi < pat_node.bindings.length() {
                        let bind_name = pat_node.bindings.get(bi)
                        if bind_name != "_" {
                            var bind_type = "Void"
                            var field_name = ""
                            if found_var && bi < matched_var.params.length() {
                                let param = matched_var.params.get(bi)
                                bind_type = param.ptype
                                field_name = param.name
                            }
                            if bind_type == "T" {
                                var t_type = type_map_get(&self.current_type_map, "T")
                                if length(t_type) == 0 {
                                    t_type = self.extract_first_type_arg(expr_type)
                                }
                                bind_type = t_type
                            } else if bind_type == "E" {
                                var e_type = type_map_get(&self.current_type_map, "E")
                                if length(e_type) == 0 {
                                    e_type = "Int"
                                }
                                bind_type = e_type
                            }
                            let mapped_bind_type = self.map_type(bind_type)
                            let single_binding = "    " + mapped_bind_type + " " + bind_name + " = " + expr_val + op + "payload." + var_name + "." + field_name + ";\n"
                            bindings_str = bindings_str + single_binding
                        }
                        bi = bi + 1
                    }
                }
            } else if pat_node.kind == PatternKind.pk_else {
                cond = "true"
            }
            
            var prefix = ""
            if case_idx == 0 {
                prefix = "if (" + cond + ")"
            } else if cond == "true" {
                prefix = "else"
            } else {
                prefix = "else if (" + cond + ")"
            }
            
            var full_block = block_str
            if length(bindings_str) > 0 {
                let body_len = length(block_str)
                full_block = "{\n" + bindings_str + block_str[1..body_len]
            }
            
            match_str = match_str + prefix + " " + full_block + " "
            case_idx = case_idx + 1
        }
        return match_str
    }
    
    return ""
}

    fn clean_enum_name(self, type_name: Str) -> Str {
    var base_name = type_name
    if self.str_contains(type_name, Char(60)) { // '<'
        let lt_pos = self.str_find(type_name, Char(60))
        base_name = type_name[0..lt_pos]
    }
    
    if base_name[0..4] == "mut " {
        base_name = base_name[4..length(base_name)]
    }
    
    var done = false
    while !done {
        if length(base_name) > 0 && (base_name[0] == Char(42) || base_name[0] == Char(38)) {
            base_name = base_name[1..length(base_name)]
        } else {
            done = true
        }
    }
    
    done = false
    while !done {
        let l = length(base_name)
        if l > 0 && (base_name[l - 1] == Char(42) || base_name[l - 1] == Char(38)) {
            base_name = base_name[0..l - 1]
        } else {
            done = true
        }
    }
    
    if length(type_map_get(&self.enum_decls, base_name)) == 0 {
        if self.str_contains(base_name, Char(95)) { // '_' is 95
            let underscore_pos = self.str_find(base_name, Char(95))
            let fallback_name = base_name[0..underscore_pos]
            if length(type_map_get(&self.enum_decls, fallback_name)) > 0 {
                return fallback_name
            }
        }
    }
    
    return base_name
}

fn is_enum_type(self, type_name: Str) -> Bool {
    let clean_name = self.clean_enum_name(type_name)
    return length(type_map_get(&self.enum_decls, clean_name)) > 0
}

fn enum_has_payload(self, enum_name: Str) -> Bool {
    let clean_name = self.clean_enum_name(enum_name)
    let idx_str = type_map_get(&self.enum_decls, clean_name)
    if length(idx_str) == 0 {
        return false
    }
    let enum_stmt = self.stmt_pool.get(self.str_to_int(idx_str))
    if enum_stmt.kind == StmtKind.sk_error_decl {
        return false
    }
    var has_payload = false
    var vi = 0
    while vi < enum_stmt.enum_variants.length() {
        let v = enum_stmt.enum_variants.get(vi)
        if v.params.length() > 0 {
            has_payload = true
        }
        vi = vi + 1
    }
    return has_payload
}

fn escape_string(self, s: Str) -> Str {
    var res = ""
    var i = 0
    while i < length(s) {
        let c = s[i]
        if c == Char(10) { res = res + "\\n" }
        else if c == Char(13) { res = res + "\\r" }
        else if c == Char(9) { res = res + "\\t" }
        else if c == Char(92) { res = res + "\\\\" }
        else if c == Char(34) { res = res + "\\\"" }
        else { res = res + char_to_str(c) }
        i = i + 1
    }
    return res
}

fn _collect_loop_drops(self) -> ArrayList<Str> {
    var drop_calls = ArrayList<Str>(self.allocator)
    var bi = self.block_stack.length() - 1
    var done = false
    while bi >= 0 && !done {
        let b_idx = self.block_stack.get(bi)
        let b_node = self.stmt_pool.get(b_idx)
        
        let start_idx = self.defer_depths.get(bi)
        var next_start_idx = self.defer_stack.length()
        if bi < self.block_stack.length() - 1 {
            next_start_idx = self.defer_depths.get(bi + 1)
        }
        var def_i = next_start_idx - 1
        while def_i >= start_idx {
            let def_idx = self.defer_stack.get(def_i)
            let def_node = self.stmt_pool.get(def_idx)
            let s = self.gen_stmt(def_node.defer_body)
            if length(s) > 0 {
                drop_calls.push(s)
            }
            def_i = def_i - 1
        }
        
        var di = 0
        while di < b_node.block_drop_vars.length() {
            let entry = b_node.block_drop_vars.get(di)
            drop_calls.push(entry.base_type + "_drop(&" + entry.name + ");")
            di = di + 1
        }
        if b_node.block_is_loop_body {
            done = true
        }
        bi = bi - 1
    }
    return drop_calls
}

fn emit_struct_body_with_deps(self, stmt_idx: Int, emitted: *ArrayList<Str>) -> Void {
    let stmt = self.stmt_pool.get(stmt_idx)
    if stmt.kind != StmtKind.sk_struct_decl { return }
    if stmt.struct_type_params.length() > 0 { return }
    let name = self.map_type(stmt.struct_name)
    if strlist_find(emitted, name) >= 0 { return }
    emitted.push(name)

    // Ensure value-type dependencies are emitted first
    var fi = 0
    while fi < stmt.struct_fields.length() {
        let f = stmt.struct_fields.get(fi)
        let ftype = f.ftype
        // Check if this is a value-type struct dependency
        unsafe {
            if length(ftype) > 0 && ftype[0] != Char(42) && ftype[0] != Char(38) {
                var si = 0
                while si < self.stmt_pool.length() {
                    let s2 = self.stmt_pool.get(si)
                    if s2.kind == StmtKind.sk_struct_decl && s2.struct_type_params.length() == 0 {
                        if s2.struct_name == ftype {
                            self.emit_struct_body_with_deps(si, emitted)
                        }
                    }
                    si = si + 1
                }
            }
        }
        fi = fi + 1
    }

    // Now emit struct definition
    var struct_str = "struct " + name + " {\n"
    var i = 0
    while i < stmt.struct_fields.length() {
        let f = stmt.struct_fields.get(i)
        struct_str = struct_str + "    " + self.map_type(f.ftype) + " " + f.name + ";\n"
        i = i + 1
    }
    struct_str = struct_str + "};\n"
    let _ = self.struct_decls.append(struct_str)

    // Process trait impls
    var ti = 0
    while ti < stmt.struct_trait_impls.length() {
        let impl_idx = stmt.struct_trait_impls.get(ti)
        let _ = self.gen_stmt(impl_idx)
        ti = ti + 1
    }
}

fn generate(self, top_stmt_idx: Int) -> Str {
    // Phase 1: Register all generic types first
    var g_i = 0
    while g_i < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(g_i)
        if stmt.kind == StmtKind.sk_struct_decl {
            if stmt.struct_type_params.length() > 0 {
                type_map_put(&self.generic_struct_decls, stmt.struct_name, int_to_str(g_i))
            }
        }
        if stmt.kind == StmtKind.sk_enum_decl {
            if stmt.enum_type_params.length() > 0 {
                type_map_put(&self.generic_enum_decls, stmt.enum_name, int_to_str(g_i))
            }
        }
        g_i = g_i + 1
    }

    // Pass 1a: Forward declare all non-generic structs
    var fd_i = 0
    while fd_i < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(fd_i)
        if stmt.kind == StmtKind.sk_struct_decl && stmt.struct_type_params.length() == 0 {
            let name = self.map_type(stmt.struct_name)
            let _ = self.struct_decls.append("typedef struct " + name + " " + name + ";\n")
        }
        fd_i = fd_i + 1
    }

    self.build_func_types()

    // Pass 1: Emit all non-generic structs, enums, errors
    var emitted_structs = ArrayList<Str>(self.allocator)
    var s_i = 0
    while s_i < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(s_i)
        if stmt.kind == StmtKind.sk_struct_decl {
            self.emit_struct_body_with_deps(s_i, &emitted_structs)
        }
        if stmt.kind == StmtKind.sk_enum_decl {
            let _ = self.gen_stmt(s_i)
        }
        if stmt.kind == StmtKind.sk_error_decl {
            let _ = self.gen_stmt(s_i)
        }
        s_i = s_i + 1
    }

    // Pass 2: Emit all non-generic functions, externs, impls
    var f_i = 0
    while f_i < self.stmt_pool.length() {
        let stmt = self.stmt_pool.get(f_i)
        if stmt.kind == StmtKind.sk_func_decl {
            var has_self = false
            var pi = 0
            while pi < stmt.func_params.length() {
                unsafe {
                    if strcmp(stmt.func_params.get(pi).name, "self") == 0 { has_self = true }
                }
                pi = pi + 1
            }
            if !has_self && stmt.func_type_params.length() == 0 {
                let _ = self.gen_stmt(f_i)
            }
        }
        if stmt.kind == StmtKind.sk_extern {
            let _ = self.gen_stmt(f_i)
        }
        if stmt.kind == StmtKind.sk_impl_block {
            let _ = self.gen_stmt(f_i)
        }
        f_i = f_i + 1
    }

    //== Assemble final C output
    var result = StringBuilder(self.allocator)

    //== Phase 1: Baseline C headers
    result.append("#include <stdint.h>\n")
    result.append("#include <stdbool.h>\n")
    result.append("#include <stdio.h>\n")
    result.append("#include <stdlib.h>\n")
    result.append("#include <string.h>\n")

    // Compat: imported concatAlloc maps to __kai_std_str_concat_alloc
    result.append("#ifndef __kai_std_str_concat_alloc\n")
    result.append("#define __kai_std_str_concat_alloc concatAlloc\n")
    result.append("#endif\n")

    //== Phase 2: get_exe_dir (delegates to std/os/os.h)
    result.append("#ifndef NO_GET_EXE_DIR\n")
    result.append("#include \"std/os/os.h\"\n")
    result.append("int64_t get_exe_dir(char* out_buf, int64_t max_len) {\n")
    result.append("    return kai_os_get_exe_dir(out_buf, max_len);\n")
    result.append("}\n")
    result.append("#endif\n")
    result.append("\n")

    //== Phase 3: Runtime helper functions (str_sub, arr_sub)
    result.append("static char* __kai_str_sub(const char* s, int64_t start, int64_t end) {\n")
    result.append("    int64_t len = strlen(s);\n")
    result.append("    if (end > len) end = len;\n")
    result.append("    if (start < 0) start = 0;\n")
    result.append("    if (start >= end) {\n")
    result.append("        char* empty = malloc(1);\n")
    result.append("        if (empty) empty[0] = '\\0';\n")
    result.append("        return empty;\n")
    result.append("    }\n")
    result.append("    int64_t sub_len = end - start;\n")
    result.append("    char* buf = malloc(sub_len + 1);\n")
    result.append("    if (buf) {\n")
    result.append("        memcpy(buf, s + start, sub_len);\n")
    result.append("        buf[sub_len] = '\\0';\n")
    result.append("    }\n")
    result.append("    return buf;\n")
    result.append("}\n")
    result.append("\n")
    result.append("static void* __kai_arr_sub(const void* arr, int64_t start, int64_t end, int64_t elem_size) {\n")
    result.append("    int64_t count = end - start;\n")
    result.append("    if (count <= 0) return NULL;\n")
    result.append("    size_t total = (size_t)count * (size_t)elem_size;\n")
    result.append("    void* buf = malloc(total);\n")
    result.append("    if (buf) memcpy(buf, (const char*)arr + start * elem_size, total);\n")
    result.append("    return buf;\n")
    result.append("}\n")
    result.append("\n")


    //== Phase 4: User C FFI imports (non-baseline headers)
    var ci = 0
    var has_cimports = false
    while ci < self.import_resolver.cimport_headers.length() {
        let hdr = self.import_resolver.cimport_headers.get(ci)
        var is_baseline = false
        if hdr == "stdint.h" { is_baseline = true }
        else if hdr == "stdbool.h" { is_baseline = true }
        else if hdr == "stdio.h" { is_baseline = true }
        else if hdr == "stdlib.h" { is_baseline = true }
        else if hdr == "string.h" { is_baseline = true }
        else if hdr == "sys/mman.h" { is_baseline = true }
        else if hdr == "ctype.h" { is_baseline = true }

        if !is_baseline {
            if !has_cimports {
                result.append("/* C FFI Imports */\n")
                has_cimports = true
            }
            var has_slash = false
            var dot_start = false
            if length(hdr) > 0 {
                var hi = 0
                while hi < length(hdr) {
                    if hdr[hi] == Char(47) { has_slash = true }
                    hi = hi + 1
                }
                if hdr[0] == Char(46) { dot_start = true }
            }
            if !has_slash && !dot_start {
                result.append("#include <" + hdr + ">\n")
            } else {
                result.append("#include \"" + hdr + "\"\n")
            }
        }
        ci = ci + 1
    }

    //== Phase 5: Allocator + runtime glue
    result.append("#ifndef MAP_FAILED\n")
    result.append("#define MAP_FAILED ((void*)-1)\n")
    result.append("#endif\n")
    result.append("#ifndef MAP_PRIVATE\n")
    result.append("#define MAP_PRIVATE 2\n")
    result.append("#endif\n")
    result.append("#ifndef MAP_ANONYMOUS\n")
    result.append("#ifdef __APPLE__\n")
    result.append("#define MAP_ANONYMOUS 0x1000\n")
    result.append("#else\n")
    result.append("#define MAP_ANONYMOUS 0x20\n")
    result.append("#endif\n")
    result.append("#endif\n")
    result.append("extern void* mmap(void* addr, unsigned long long length, int prot, int flags, int fd, long long offset);\n")
    result.append("extern int munmap(void* addr, unsigned long long length);\n")
    result.append("\n")
    result.append("void __kai_print_int(int64_t v) {\n")
    result.append("    printf(\"%lld\\n\", (long long)(v));\n")
    result.append("}\n")
    result.append("\n")
    result.append("void __kai_print_float(double v) {\n")
    result.append("    printf(\"%f\\n\", (double)(v));\n")
    result.append("}\n")
    result.append("\n")
    result.append("static inline uint8_t* _kai_mmap(uint8_t* addr, int64_t length, int64_t prot, int64_t flags, int64_t fd, int64_t offset) {\n")
    result.append("    return (uint8_t*)mmap(addr, length, prot, MAP_PRIVATE | MAP_ANONYMOUS, fd, offset);\n")
    result.append("}\n")
    result.append("\n")
    result.append("static inline int64_t _kai_munmap(uint8_t* addr, int64_t length) {\n")
    result.append("    return munmap(addr, length);\n")
    result.append("}\n")
    result.append("\n")
    result.append("extern void __kai_panic(const char* msg);\n")
    result.append("#ifndef __KAI_NO_PANIC\n")
    result.append("void __kai_panic(const char* msg) {\n")
    result.append("    fprintf(stderr, \"KAI PANIC: %s\\n\", msg);\n")
    result.append("    fflush(stderr);\n")
    result.append("    abort();\n")
    result.append("}\n")
    result.append("#endif\n")
    result.append("\n")

    //== Phase 6: User struct declarations
    result.append(self.struct_decls.to_str())
    result.append("\n")

    //== Phase 7: User function declarations
    result.append(self.func_decls.to_str())
    result.append("\n")

    //== Phase 8: User function implementations
    result.append(self.output.to_str())

    return result.to_str()
}

}
