import KaiAllocator from std.core.allocator
import int_to_str from std.core.string
import std.io.print

extern fn _kai_set_current_allocator(allocator: *Void)

error FileError
{
    case not_found
    case permission_denied
}

trait Describable
{
    fn describe(self) -> Str {
    }
}

struct Point
{
    x: Int
    y: Int
}

impl Point
{
    fn describe(self) -> Str {
        return "Point(" + int_to_str(self.x) + ", " + int_to_str(self.y) + ")"
    }
}

fn identity<T>(val: T) -> T {
    return val
}

fn divide_or_error(flag: Bool) -> Int!FileError {
    if flag {
        return 42
    }
    return FileError.not_found
}

fn get_optional_value(flag: Bool) -> ?Int {
    if flag {
        return 42
    }
    return none
}

fn main() -> Int {
    var allocator = KaiAllocator(heads: 0 as *u8, used: 0)
    allocator.init()
    _kai_set_current_allocator(&allocator as *Void)
    
    defer {
        printf("Final defer run: Success\n")
    }

    let a = 10
    var b = 20
    b = b + a
    printf("Arithmetic check: ")
    printi(b)
    printf("\n")

    let p = Point(x: 3, y: 4)
    printf("Trait check: ")
    prints(p.describe())
    printf("\n")

    let id_int = identity<Int>(100)
    printf("Generics check: ")
    printi(id_int)
    printf("\n")

    let res_ok = divide_or_error(true) catch |err| 99
    let res_err = divide_or_error(false) catch |err| 100
    printf("Error Union OK: ")
    printi(res_ok)
    printf("\n")
    printf("Error Union Catch: ")
    printi(res_err)
    printf("\n")

    let opt_some = get_optional_value(true)
    let opt_none = get_optional_value(false)
    
    if let val = opt_some {
        printf("Optional if-let: ")
        printi(val)
        printf("\n")
    }
    
    let fallback = opt_none catch 99
    printf("Optional catch: ")
    printi(fallback)
    printf("\n")

    var sum = 0
    var i = 0
    while i < 5 {
        sum = sum + i
        i = i + 1
    }
    printf("While loop sum: ")
    printi(sum)
    printf("\n")

    unsafe {
        let ptr: *Int = &b
        printf("Unsafe ptr read: ")
        printi(*ptr)
        printf("\n")
    }

    return 0
}
